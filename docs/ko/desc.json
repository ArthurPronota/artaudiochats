["\ud504\ub85c\uadf8\ub7a8 \"\uc624\ub514\uc624 \ucc44\ud305\"\uc5d0 \ub300\ud55c \uc124\uba85.", "\ub0b4\uc6a9\ubb3c", "1. \uc2dc\uc791\ud558\uae30 \uc804\uc5d0.", "2. \uac04\ub2e8\ud55c \uc124\uba85.", "3. \ucee4\ubba4\ub2c8\ucf00\uc774\uc158\uc744\uc704\ud55c \uc0ac\uc6a9 \uac00\ub2a5\ud55c \uc5b8\uc5b4 \ubaa9\ub85d.", "4. \ud504\ub85c\uadf8\ub7a8\uc774 \uc791\ub3d9\ud558\ub294 \ub370 \ud544\uc694\ud55c \uac83.", "5. \ud504\ub85c\uadf8\ub7a8 \uc791\uc5c5.", "5.1 \uad6c\uc131.", "5.2 \uc0c8\ub85c\uc6b4 \ub300\ub3d9\ub9e5\uc758 \ud504\ub85c\ud30c\uc77c.", "5.3 \ub3c4\uc6c0 \uc139\uc158.", "5.4 \uc885\ub8cc \ubc84\ud2bc.", "5.5 \ub300\ub2f4 \uc790 \ubaa9\ub85d.", "5.6 \ub300\ub2f4 \uc790\uc758 \ucc44\ud305 \uae30\ub85d.", "5.7 \ub300\ub2f4 \uc790\uc758 \uc5ed\uc0ac\ub97c \uc9c0\uc6b0\uae30.", "5.8 \ub300\ub2f4 \uc790 \uc0ad\uc81c.", "5.9 \ub300\ub2f4 \uc790\uc758 \ud504\ub85c\ud544\ubcf4\uae30.", "5.10 \uc67c\ucabd\uacfc \uc624\ub978\ucabd \ubd80\ubd84 \uc0ac\uc774\uc758 \uc218\uc9c1 \ubd84\ub9ac\uae30.", "6. \uc791\uc5c5\uc744 \ub9c8\uce5c \ud6c4.", "\ud654\uba74\uc758 \uc624\ub978\ucabd \ud558\ub2e8\uc5d0\uc788\ub294 \uc2a4\ud53c\ucee4 \uc774\ubbf8\uc9c0 \uc704\ub85c \ub9c8\uc6b0\uc2a4 \ucee4\uc11c\ub97c \ub9c8\uc6b0\uc2a4 \uc624\ub978\ucabd \ubc84\ud2bc\uc73c\ub85c \ud074\ub9ad\ud558\uc2ed\uc2dc\uc624.", "\uadf8\ub9bc 1. \uc5f4\ub9b0 \uc0ac\uc6b4\ub4dc \uc124\uc815.", "\ud604\uc7ac \uc0ac\uc6b4\ub4dc \uc124\uc815\uc774\uc788\ub294 \ud654\uba74\uc774 \ub098\ud0c0\ub0a9\ub2c8\ub2e4. \uc785\ub825 \ubc0f \ucd9c\ub825 \uc624\ub514\uc624 \uc7a5\uce58\ub97c \uc704\ud574 \uc124\uc815\ub41c \ub0b4\uc6a9\uc744 \uae30\uc5b5\ud558\uc2ed\uc2dc\uc624. \uc791\uc5c5\uc744 \ub9c8\uce5c \ud6c4\uc5d0\ub294\uc774 \uc815\ubcf4\uac00 \ud544\uc694\ud569\ub2c8\ub2e4. \uadf8\ub9bc 2\uc5d0\uc11c \ube68\uac04\uc0c9 \ud654\uc0b4\ud45c\ub294 \uae30\uc5b5\ud574\uc57c \ud560 \uac83\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \uadc0\ud558\uc758 \uacbd\uc6b0 \uc774\ub984\uc740 \ub2e4\ub985\ub2c8\ub2e4.", "\uadf8\ub9bc 2. \ucd08\uae30 \uc0ac\uc6b4\ub4dc \uc124\uc815", "\uc0ac\uc6b4\ub4dc \ucd9c\ub825 \uc7a5\uce58\ub97c \uc124\uc815\ud558\uc2ed\uc2dc\uc624", "\uc0ac\uc6b4\ub4dc \uc785\ub825 \uc7a5\uce58\ub97c \uc124\uc815\ud558\uc2ed\uc2dc\uc624", "\uadf8\ub9bc 3\uc5d0\uc11c \ube68\uac04\uc0c9 \ud654\uc0b4\ud45c\ub294 \ubb34\uc5c7\uc744 \uc124\uc815\ud574\uc57c\ud588\ub294\uc9c0 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4.", "\uadf8\ub9bc 3. \uc791\ub3d9 \uc0ac\uc6b4\ub4dc \uc124\uc815", "\uc2dc\uc2a4\ud15c \uc124\uc815\uc774 \uc644\ub8cc\ub418\uba74 \ud504\ub85c\uadf8\ub7a8\uc744 \uc2e4\ud589\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4", "\ub2f9\uc2e0\uc740 \ub2f9\uc2e0\uc774 \uc544\ub294 \uc5b8\uc5b4\ub97c \ub9d0\ud558\uace0, \ub2f9\uc2e0\uc758 \ub300\ub2f4\uc790\uac00 \uc774\ud574\ud558\ub294 \uc5b8\uc5b4\ub85c \ub4e4\ub9bd\ub2c8\ub2e4. \ubaa9\ub3d9\uc758 \ud1b5\ub098\ubb34\uac00 \uc720\uc9c0\ub418\uba70, \ub2f9\uc2e0\uc740 \ub2f9\uc2e0\uc774 \ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ubaa8\ub4e0 \uc791\uc5c5\uc740 Windows 10 \ub610\ub294 Windows 11\uc744 \uc2e4\ud589\ud558\ub294 \ucef4\ud4e8\ud130\uc5d0\uc11c \ub85c\uceec\ub85c \uc218\ud589\ub429\ub2c8\ub2e4. \uadf8\ub798\ud53d \ud504\ub85c\uc138\uc11c\uac00 \ubc14\ub78c\uc9c1\ud558\uc9c0\ub9cc \ud504\ub85c\uadf8\ub7a8\uc774 \uc791\ub3d9\ud558\ub824\uba74 \uc694\uad6c \uc0ac\ud56d\uc774 \ud544\uc694\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \ubcc0\ud658\uc758 \ud488\uc9c8\uc740 \uadf8\ub798\ud53d \ud504\ub85c\uc138\uc11c\ub85c \ud5a5\uc0c1\ub429\ub2c8\ub2e4.", "\uc774 \ubaa9\ub85d\uc758 \uc5b8\uc5b4 \uc911 \ud558\ub098\ub97c \uc774\ud574\ud558\uba74\uc774 \ubaa9\ub85d\uc758 \ubaa8\ub4e0 \uc5b8\uc5b4\uc5d0 \ub300\ud55c \uc6d0\uc5b4\ubbfc\uc758 \ub9d0\ud558\uae30\uc640 \uc758\uc0ac \uc18c\ud1b5 \ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ucee4\ubba4\ub2c8\ucf00\uc774\uc158\uc740 Telegram, WhatsApp, Google Meet, Vkmessenger, YandexMessenger \ub610\ub294 \uae30\ud0c0 \uba54\uc2e0\uc800\uc5d0\uc11c \uc774\ub8e8\uc5b4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. Mentio \uc5b8\uc5b4\ub85c \ub274\uc2a4, \uad50\uc721 \uacfc\uc815 \ubc0f \uae30\ud0c0 \ud31f \uce90\uc2a4\ud2b8\ub97c \ub4e3\uace0 \uc774\ud574\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc81c \uc678\uad6d \uae30\uc5c5\uacfc \ud6e8\uc52c \ub354 \ub9ce\uc740 \uc778\ud130\ubdf0\ub97c \ud1b5\uacfc \ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc678\uad6d\uc5b4\ub85c \uc624\ub514\uc624 / \ube44\ub514\uc624 \ud30c\uc77c\uc744 \uc7ac\uc0dd\ud558\uc5ec \uc5b8\uc5b4\ub85c\ub4e4\uc744 \uc218\ub3c4 \uc788\uc2b5\ub2c8\ub2e4. \uce21\uba74 \uc751\uc6a9 \ud504\ub85c\uadf8\ub7a8 \uc911 \ud558\ub098\ub294 \ub3d9\uc77c\ud55c \uc5b8\uc5b4\ub85c \ub300\ub2f4 \uc790\uc640\uc758 \ub300\ud654\uc774\uc9c0\ub9cc, \ub300\ub2f4\uc790\uac00 \uc0dd\uc131 \ub41c \uac83\uc744\ub4e4\uc744 \uac83\uc785\ub2c8\ub2e4. \uc790\uc2e0\uc758 \ubaa9\uc18c\ub9ac\uac00 \uc544\ub2d9\ub2c8\ub2e4. TOIS \uc774\uac83\uc740 \ud544\uc694\ud569\ub2c8\ub2e4. \uac00\ub2a5\ud55c \ub9ce\uc740 \uc751\uc6a9 \ud504\ub85c\uadf8\ub7a8\uc774 \uc788\uc2b5\ub2c8\ub2e4.", "\uc6b4\uc601 \uccb4\uc81c Windows 10 \ub610\ub294 Windows 11.", "\uc0ac\uc6a9 \uac00\ub2a5\ud55c \ud558\ub4dc \ub4dc\ub77c\uc774\ube0c \uacf5\uac04 8GB.", "10GB\uc5d0\uc11c RAM.", "6GB \uc774\uc0c1\uc758 GPU (\uadf8\ub798\ud53d \ucc98\ub9ac \uc7a5\uce58)\uac00 \ubc14\ub78c\uc9c1\ud558\uc9c0\ub9cc \ud544\uc694\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.", "\ub9c8\uc774\ud06c\uac00\uc788\ub294 \ud5e4\ub4dc\ud3f0.", "\ud504\ub85c\uadf8\ub7a8 \uc791\uc5c5\uc758 \uc804\uccb4 \uc778\ud130\ud398\uc774\uc2a4\ub294 \ube0c\ub77c\uc6b0\uc800\uc5d0\uc11c \uc218\ud589\ub429\ub2c8\ub2e4.", "\"\uad6c\uc131\"\ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uba74 \uae30\ubcf8 \uc791\ub3d9 \ub9e4\uac1c \ubcc0\uc218\uc640 \ud568\uaed8 \uc591\uc2dd\uc774 \uc0c1\ub2e8 \uba54\ub274\uc5d0 \ud45c\uc2dc\ub429\ub2c8\ub2e4. \uadf8\ub9bc 4\ub97c \ucc38\uc870\ud558\uc2ed\uc2dc\uc624.", "\uadf8\ub9bc 4. \uad6c\uc131.", "\uad6c\uc131 \uc139\uc158\uc5d0\ub294 \uc8fc\uc694 \uc791\ub3d9 \ub9e4\uac1c \ubcc0\uc218\uac00 \ud3ec\ud568\ub429\ub2c8\ub2e4.", "\uc5b8\uc5b4 - \ub2f9\uc2e0\uc774 \ub9d0\ud558\ub294 \uc5b8\uc5b4 \uc124\uc815.", "\uc0ac\uc6b4\ub4dc - \uc0ac\uc6b4\ub4dc emitting \uc7a5\uce58\uc758 \ub4dc\ub77c\uc774\ubc84 \uc774\ub984.", "\ub9c8\uc774\ud06c - \ub9c8\uc774\ud06c\uc758 \ub4dc\ub77c\uc774\ubc84 \uc774\ub984.", "\uc6f9 \ube0c\ub77c\uc6b0\uc800 - \uc791\ub3d9 \ud560 \ube0c\ub77c\uc6b0\uc800\uc758 \uc774\ub984\uc785\ub2c8\ub2e4.", "\uc5b8\uc5b4\ub97c \ubcc0\uacbd\ud558\uace0 \uad6c\uc131 \uc124\uc815\uc744 \uc800\uc7a5\ud558\uba74 \ubaa8\ub4e0 \ud14d\uc2a4\ud2b8, \ud45c\ud604\uc2dd, \ubc84\ud2bc \uc774\ub984 \ubc0f \uae30\ud0c0 \ud14d\uc2a4\ud2b8\uac00 \uc0c8 \uc5b8\uc5b4\ub85c \ud45c\uc2dc\ub429\ub2c8\ub2e4. \uc0c8\ub85c\uc6b4 \ucc44\ud305\uc740 \uc120\ud0dd\ud55c \uc5b8\uc5b4\ub85c \ubc88\uc5ed \ub418\uba70\uc774 \uc0c8\ub85c\uc6b4 \uc5b8\uc5b4\ub85c \uc5f0\uc124\uc744\ub4e4\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc6f9 \ube0c\ub77c\uc6b0\uc800 \ub9e4\uac1c \ubcc0\uc218\uc5d0 \ub300\ud55c \uc911\uc694\ud55c \ucc38\uace0 \uc0ac\ud56d. \uae30\ubcf8\uc801\uc73c\ub85c \uc6f9 \ube0c\ub77c\uc6b0\uc800 \ub9e4\uac1c \ubcc0\uc218\ub294 \ud56d\uc0c1 Windows\uc5d0 \uc124\uce58\ub418\uc5b4 \uc788\uc73c\ubbc0\ub85c Microsoft Edge\ub85c \uc124\uc815\ub429\ub2c8\ub2e4. \uc774 \ub9e4\uac1c \ubcc0\uc218\uc758 \uacbd\uc6b0 \uc6b4\uc601 \uccb4\uc81c\uc5d0 \uc124\uce58 \ubc0f \uc2e4\ud589\uc911\uc778 \ube0c\ub77c\uc6b0\uc800 \ub9cc \uc120\ud0dd\ud558\uc2ed\uc2dc\uc624.", "\uc0c8 \ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uba74 AWW \ub300\uae30\uc11c\ub97c \uc791\uc131\ud558\uae30\uc704\ud55c \uc591\uc2dd\uc774 \ud45c\uc2dc\ub429\ub2c8\ub2e4. \uadf8\ub9bc 5\ub97c \ucc38\uc870\ud558\uc2ed\uc2dc\uc624.", "\uadf8\ub9bc 5. \uc0c8\ub85c\uc6b4 \ub300\ub2f4\uc790 \ud504\ub85c\ud30c\uc77c", "\"\uc0c8\ub85c\uc6b4 \ub300\ub2f4 \uc790 \ud504\ub85c\ud30c\uc77c\"\uc139\uc158\uc5d0\ub294 \uc8fc\uc694 \uc791\ub3d9 \ub9e4\uac1c \ubcc0\uc218\uac00 \ud3ec\ud568\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.", "\ub2c9\ub124\uc784 - \ub300\ub2f4\uc790\uc5d0 \ub300\ud574 \uc120\ud0dd\ud55c \uc774\ub984.", "\uc5b8\uc5b4 - \ub300\ub2f4\uc790\uac00 \ub9d0\ud558\ub294 \uc5b8\uc5b4.", "\uc124\uba85 - \ub300\ub2f4 \uc790\uc758 \uc124\uba85.", "\ub9c8\uc774\ud06c \uc0ac\uc6a9 - \ub9c8\uc774\ud06c \uc0ac\uc6a9 \ud50c\ub798\uadf8\ub97c \uc124\uc815\ud558\uc2ed\uc2dc\uc624.", "\uc774\ubbf8\uc9c0 - \ub300\ub2f4\uae30\uc758 \uc544\uc774\ucf58\uc744 \uc124\uc815\ud558\uc2ed\uc2dc\uc624.", "\ub300\ub2f4 \uc790\uc758 \uc774\ubbf8\uc9c0\ub97c \uc120\ud0dd\ud558\uc9c0 \uc54a\uc740 \uacbd\uc6b0 \uae30\ubcf8 \uc774\ubbf8\uc9c0\uac00 \uadf8\uc5d0\uac8c \uc0ac\uc6a9\ub429\ub2c8\ub2e4.", "\"\ub9c8\uc774\ud06c \uc0ac\uc6a9\"\ub9e4\uac1c \ubcc0\uc218\ub294 \uccad\ucde8 \ud560 \ub54c (\ub274\uc2a4, \uc624\ub514\uc624 \ub808\uc2a8 \ub4f1) \uc0ac\ub840\uc5d0 \ub9de\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.", "\"\ub3c4\uc6c0\ub9d0\"\ubcf4\uc548\uc740 \uadc0\ud558\uc758 \uc5b8\uc5b4\ub85c \ud504\ub85c\uadf8\ub7a8\uc744 \uc0ac\uc6a9\ud558\ub294 \ubc29\ubc95\uc744 \uc124\uba85\ud569\ub2c8\ub2e4. \uadf8\ub9bc 6\uc744 \ucc38\uc870\ud558\uc2ed\uc2dc\uc624.", "\uadf8\ub9bc 6. \ub3c4\uc6c0\ub9d0 \uc139\uc158.", "\"\uc885\ub8cc\"\ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uba74 \ud504\ub85c\uadf8\ub7a8\uc774 \uc885\ub8cc\ub429\ub2c8\ub2e4. \uadf8\ub9bc 7\uc744 \ucc38\uc870\ud558\uc2ed\uc2dc\uc624.", "\uadf8\ub9bc 7. \uc885\ub8cc \ubc84\ud2bc.", "\ube0c\ub77c\uc6b0\uc800 \ucc3d\uc744 \ub2eb\uac70\ub098 \ube0c\ub77c\uc6b0\uc800\ub97c \ub2eb\ub294 \uacbd\uc6b0 \ud504\ub85c\uadf8\ub7a8\uc774 \uc885\ub8cc\ub429\ub2c8\ub2e4.", "\ud398\uc774\uc9c0\ub97c \uc0c8\ub85c \uace0\uce68\ud558\uba74 \ud504\ub85c\uadf8\ub7a8\uc774 \uc885\ub8cc\ub429\ub2c8\ub2e4.", "\ube0c\ub77c\uc6b0\uc800\uc758 \uc67c\ucabd\uc5d0\ub294 \ub300\ub2f4 \uc790 \ubaa9\ub85d\uc774 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub9bc 8\uc744 \ucc38\uc870\ud558\uc2ed\uc2dc\uc624.", "\uadf8\ub9bc 8. \ub300\ub2f4 \uc790 \ubaa9\ub85d.", "\uac01 \ub300\ub2f4 \uc790\uc5d0 \ub300\ud574 \uc544\uc774\ucf58, \ub9c8\uc9c0\ub9c9 \uba54\uc2dc\uc9c0 \ub0a0\uc9dc \ubc0f \uc5b8\uc5b4\uc758 \ub9c8\uc9c0\ub9c9 \uba54\uc2dc\uc9c0\uc758 \ud14d\uc2a4\ud2b8\uc5d0 \ud45c\uc2dc\ub429\ub2c8\ub2e4. \uc791\uc5c5\uc744 \ud1b5\ud574 \ub0a0\uc9dc \ud615\uc2dd\uc740 \uc5b8\uc5b4\uc5d0 \ud574\ub2f9\ud569\ub2c8\ub2e4. \ub300\ub2f4\uc790\ub97c \ud074\ub9ad\ud558\uba74 \ucc44\ud305 \uae30\ub85d\uc774 \ud45c\uc2dc\ub429\ub2c8\ub2e4.", "\ub300\ub2f4 \uc790\uc758 \ucc44\ud305 \uae30\ub85d\uc740 \ube0c\ub77c\uc6b0\uc800\uc758 \uc624\ub978\ucabd\uc5d0 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub9bc 9\ub97c \ucc38\uc870\ud558\uc2ed\uc2dc\uc624.", "\uadf8\ub9bc 9. \ub300\ub2f4\uc758 \ucc44\ud305 \uae30\ub85d.", "\ub300\ub2f4 \uc790\uc758 \ucc44\ud305 \uae30\ub85d\uc740 \uc67c\ucabd \ubd80\ubd84\uc758 \ub300\ub2f4\uc790\ub97c \ud074\ub9ad \ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "\uc0c1\ub2e8 \uba54\ub274\uc5d0\ub294 \ub2e4\uc74c\uc774 \ud3ec\ud568\ub429\ub2c8\ub2e4.", "\ub300\ub2f4 \uc790\uc758 \uc544\uc774\ucf58", "\ub300\ub2f4 \uc790\uc758 \ubcc4\uba85", "\"\ub300\ud654 \uc2dc\uc791\"\ubc84\ud2bc", "\"Clear History\"\ubc84\ud2bc", "\"\ub300\ub2f4 \uc790 \uc0ad\uc81c\"\ubc84\ud2bc", "\"\ub300\ub2f4 \uc790\uc758 \ud504\ub85c\ud544\"\ubc84\ud2bc", "\uc120\ud0dd\ud55c \ub300\ub2f4 \uc790\uc640\uc758 \ucc44\ud305 \uae30\ub85d\uc774 \uc624\ub978\ucabd \ubd80\ubd84\uc5d0 \ub098\ud0c0\ub0a9\ub2c8\ub2e4.", "\ucc44\ud305 \uc81c\ubaa9\uc740 \"\ub300\ub2f4\uc758 \uc5b8\uc5b4\"/\"\ub2f9\uc2e0\uc758 \uc5b8\uc5b4\"\ub77c\ub294 \ud55c \uc30d\uc758 Yaks\ub85c \ubc88\ud638\uac00 \ub9e4\uaca8\uc9d1\ub2c8\ub2e4.", "\ucc44\ud305 \uc81c\ubaa9\uc5d0\ub294 \"\uc774 \ucc44\ud305 \uc0ad\uc81c\"\ubc84\ud2bc\uc774 \ud3ec\ud568\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.", "\"\uc774 \ucc44\ud305 \uc0ad\uc81c \uc0ad\uc81c\"\ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uba74\uc774 \ucc44\ud305\uc774 \ub300\ub2f4\uc758 \ucc44\ud305 \uae30\ub85d\uc5d0\uc11c \uc0ad\uc81c\ub429\ub2c8\ub2e4.", "\ubaa8\ub4e0 \uba54\uc2dc\uc9c0\ub294 \ub450 \uadf8\ub8f9\uc73c\ub85c \ub098\ub269\ub2c8\ub2e4.", "\ub300\ub2f4 \uc790\uc758 \uba54\uc2dc\uc9c0.", "\ub2f9\uc2e0\uc758 \uba54\uc2dc\uc9c0.", "\ub300\ub2f4 \uc790\uc758 \uba54\uc2dc\uc9c0\uac00 \uc67c\ucabd\uc73c\ub85c \uc774\ub3d9\ub429\ub2c8\ub2e4. \uba54\uc2dc\uc9c0\uac00 \uc624\ub978\ucabd\uc73c\ub85c \uc774\ub3d9\ub429\ub2c8\ub2e4.", "\uac01 \uba54\uc2dc\uc9c0 \uadf8\ub8f9\uc740 \ub450 \ubd80\ubd84\uc73c\ub85c \uad6c\uc131\ub429\ub2c8\ub2e4.", "\uba54\uc2dc\uc9c0 \ud14d\uc2a4\ud2b8 \ub300\ub2f4 \uc790\uc758 \uc5b8\uc5b4 \ub85c\uc774 \uba54\uc2dc\uc9c0\uc758 \uc0c9\uc0c1\uc740 \uac80\uc740 \uc0c9\uc785\ub2c8\ub2e4.", "\uba54\uc2dc\uc9c0 \ud14d\uc2a4\ud2b8 \ub2f9\uc2e0\uc758 \uc5b8\uc5b4\ub85c,\uc774 \uba54\uc2dc\uc9c0\uc758 \uc0c9\uc0c1\uc740 \ub179\uc0c9\uc785\ub2c8\ub2e4.", "\uba54\uc2dc\uc9c0 \ub0a0\uc9dc\ub294 \uc5b8\uc5b4\uc5d0 \ud574\ub2f9\ud569\ub2c8\ub2e4.", "\ucd5c\uc2e0 \uba54\uc2dc\uc9c0 (\ub0a0\uc9dc \ubcc4)\ub294 \uad6c\ud615 Oones\ubcf4\ub2e4 \ub0ae\uc2b5\ub2c8\ub2e4.", "\ub300\ub2f4 \uc790\uc758 \ucc44\ud305\uc758 \ubc14\ub2e5\uc5d0\ub294 \"\ub300\ud654 \uc2dc\uc791\"\ubc84\ud2bc\uc774 \uc788\uc2b5\ub2c8\ub2e4. \ud074\ub9ad\ud558\uba74 \ud504\ub85c\uadf8\ub7a8\uc774 \ub9c8\uc774\ud06c\uc640 \uc0ac\uc6b4\ub4dc \uc7a5\uce58\ub97c \ubcf4\uc815\ud558\uc5ec \uc2e0\ud638/\ub178\uc774\uc988 \ub808\ubca8\uc744 \uacb0\uc815\ud558\uace0 \ud574\ub2f9 \uba54\uc2dc\uc9c0\ub97c \ud45c\uc2dc\ud558\uae30 \uc2dc\uc791\ud569\ub2c8\ub2e4.", "\uc0ac\uc6b4\ub4dc \uc7a5\uce58\ub97c \uad50\uc815 \ud55c \ud6c4 \ubc84\ud2bc\uc758 \uc774\ub984\uc774 \ubcc0\uacbd\ub429\ub2c8\ub2e4. \"\ub300\ud654 \uc2dc\uc791\" -> \"\ub300\ud654 \uc911\uc9c0\".", "\uc774 \uc2dc\uc810\ubd80\ud130 \ub300\ud654\ub97c \uc2dc\uc791\ud558\uac70\ub098 \uc624\ub514\uc624/\ube44\ub514\uc624 \ud30c\uc77c\uc744 \uc2dc\uc791\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "\uc218\uc2e0 \uba54\uc2dc\uc9c0 (\uc0c1\ub300\ubc29\uc758 \ubaa8\ub4e0 \uc0ac\ub78c)\uac00 \uc67c\ucabd\uc5d0 \ub098\ud0c0\ub0a9\ub2c8\ub2e4.", "\ubaa8\ub4e0 \uc678\ucd9c \uba54\uc2dc\uc9c0 (\ub2f9\uc2e0\uc5d0\uac8c\uc11c)\ub294 \uc624\ub978\ucabd\uc5d0 \ub098\ud0c0\ub0a9\ub2c8\ub2e4.", "\ub2f9\uc2e0\uc740 \ub2f9\uc2e0\uc758 \uc5b8\uc5b4\ub85c \uba54\uc2dc\uc9c0\ub97c \ub4e3\uace0 \ub2f9\uc2e0\uc758 \ub2e4\ub978 \uc0ac\ub78c\uc740 \uadf8\ub4e4\uc758 \uc5b8\uc5b4\ub85c \uba54\uc2dc\uc9c0\ub97c\ub4e4\uc744 \uac83\uc785\ub2c8\ub2e4.", "\ub300\ud654\uac00 \ub05d\ub098\uba74 \ube44\ub514\uc624\ub97c \ub4e3\uace0 \"\ub300\ud654 \uc911\uc9c0\"\ubc84\ud2bc \uc911 \ud558\ub098\ub97c \ud074\ub9ad\ud574\uc57c\ud569\ub2c8\ub2e4.", "\ub300\ud654\ub294 \ub610\ud55c \ub2e4\uc74c\uacfc \uac19\uc774 \ub05d\ub0a9\ub2c8\ub2e4.", "\ub300\ub2f4 \uc790 \ubaa9\ub85d\uc5d0\uc11c \ube0c\ub77c\uc6b0\uc800\uc758 \uc67c\ucabd \ubd80\ubd84\uc5d0\uc788\ub294 \uc0c1\ub300\ubc29\uc744 \ud074\ub9ad\ud569\ub2c8\ub2e4.", "\ub300\ub2f4 \uc790 \ubaa9\ub85d\uc758 \uc0c1\ub2e8\uc5d0\uc11c \"\uc0c8\"\ubc84\ud2bc\uc744 \ud074\ub9ad\ud569\ub2c8\ub2e4.", "\uc0c1\ub2e8 \uba54\ub274\uc5d0\uc11c \"\ub3c4\uc6c0\ub9d0\"\ubc84\ud2bc\uc744 \ud074\ub9ad\ud569\ub2c8\ub2e4.", "\uc0c1\ub2e8 \uba54\ub274\uc5d0\uc11c \"Clear History\"\ubc84\ud2bc\uc744 \ud074\ub9ad\ud569\ub2c8\ub2e4.", "\uc0c1\ub2e8 \uba54\ub274\uc5d0\uc11c \"\ub300\ub2f4 \uc790 \uc0ad\uc81c\"\ub97c \ud074\ub9ad\ud569\ub2c8\ub2e4.", "\uc0c1\ub2e8 \uba54\ub274\uc5d0\uc11c \"\uc778\ud130 \ub85c\ubcf4\ud130\uc758 \ud504\ub85c\ud544\"\ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uc5ec", "\uc0c1\ub2e8 \uba54\ub274\uc5d0\uc11c \"\uc885\ub8cc\"\ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uc5ec", "\ucc44\ud305 \uae30\ub85d\uc758 \uba54\uc2dc\uc9c0 \ud45c\uc2dc\ub294 \uba54\ub274\uc758 \uc67c\ucabd \uc0c1\ub2e8 (\ub179\uc0c9 \ud654\uc0b4\ud45c)\uc5d0\uc11c \uba54\uc2dc\uc9c0 \ub514\uc2a4\ud50c\ub808\uc774 \uc635\uc158\uc744 \uc120\ud0dd\ud558\uc5ec \uc815\ub9bd\ub429\ub2c8\ub2e4.", "\"\ubaa8\ub4e0 \uc5b8\uc5b4\"\ub97c \uc120\ud0dd\ud560 \ub54c - \ub300\ub2f4 \uc790\uc758 \uba54\uc2dc\uc9c0\uc640 \uba54\uc2dc\uc9c0\ub294 \ubaa8\ub4e0 \uc5b8\uc5b4\ub85c \ud45c\uc2dc\ub429\ub2c8\ub2e4.", "\"\ub0b4 \uc5b8\uc5b4\"\ub97c \uc120\ud0dd\ud560 \ub54c - \ub300\ub2f4 \uc790\uc758 \uba54\uc2dc\uc9c0\uc640 \uba54\uc2dc\uc9c0\ub294 \uc5b8\uc5b4\uc5d0\ub9cc \ud45c\uc2dc\ub429\ub2c8\ub2e4.", "\"\ub300\ub2f4 \uc790\uc758 \uc5b8\uc5b4\"\ub97c \uc120\ud0dd\ud560 \ub54c - \ub300\ub2f4 \uc790\uc758 \uba54\uc2dc\uc9c0\uc640 \uba54\uc2dc\uc9c0\ub294 \ub300\ub2f4 \uc790\uc758 \uc5b8\uc5b4\uc5d0\ub9cc \ud45c\uc2dc\ub429\ub2c8\ub2e4.", "\uae30\ubcf8 \uba54\uc2dc\uc9c0 \ud45c\uc2dc \ubaa8\ub4dc\ub294 \"\ubaa8\ub4e0 \uc5b8\uc5b4\"\uc785\ub2c8\ub2e4.", "\"Clear History\"\ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uba74 \uc778\ud130 \ub85c\ucf54\uc5c5\uc790\uc640\uc758 \ubaa8\ub4e0 \ucc44\ud305\uc774 \uc0ad\uc81c\ub418\uc9c0\ub9cc \ub300\uad50\uac70\ub294 \ub0a8\uc544 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub9bc 10\uc744 \ucc38\uc870\ud558\uc2ed\uc2dc\uc624.", "\uadf8\ub9bc 10. \ub300\ub2f4\uc758 \uc774\ub825 \uc81c\uac70.", "\ub300\ub2f4 \uc790\uc640\uc758 \ucc44\ud305\uc774 \ud604\uc7ac \uc9c4\ud589\uc911\uc778 \uacbd\uc6b0 \uc911\uc9c0\ub429\ub2c8\ub2e4.", "\"\uc778\ud130 \ub85c\ubc84\ud2b8 \uc0ad\uc81c\"\ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uba74 \ubaa8\ub4e0 \ucc44\ud305\uc774 \ub300\ub2f4 \uc790 \ubc0f \ub300\ub2f4 \uc790\uccb4\uc640 \ud568\uaed8 \uc0ad\uc81c\ub429\ub2c8\ub2e4. \uadf8\ub9bc 11\uc744 \ucc38\uc870\ud558\uc2ed\uc2dc\uc624.", "\uadf8\ub9bc 11. \ub300\ub2f4\uae30 \uc0ad\uc81c.", "\ub300\ub2f4 \uc790\uc640\uc758 \ucc44\ud305\uc774 \ud604\uc7ac \uc9c4\ud589\uc911\uc778 \uacbd\uc6b0 \uc911\uc9c0\ub429\ub2c8\ub2e4.", "\"\uc778\ud130 \ub85c\ucee4\uc758 \ud504\ub85c\ud544\"\ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uba74 \ub300\ub2f4 \uc790\uc758 \ub370\uc774\ud130\ub85c \ucc44\uc6cc\uc9c4 \uc591\uc2dd\uc774 \ud45c\uc2dc\ub429\ub2c8\ub2e4. \uadf8\ub9bc 12\ub97c \ucc38\uc870\ud558\uc2ed\uc2dc\uc624.", "\uadf8\ub9bc 12. \ub300\ub2f4 \uc790\uc758 \ud504\ub85c\ud544\ubcf4\uae30.", "\uc774 \ud56d\ubaa9\uc740 \ud56d\ubaa9\uacfc \uc720\uc0ac\ud569\ub2c8\ub2e4", "\uc218\uc9c1 \ubd84\ub9ac\uae30\ub97c \uc0ac\uc6a9\ud558\uba74 \uc791\uc5c5 \uacf5\uac04\uc758 \uc67c\ucabd \ubc0f \uc624\ub978\ucabd \uc601\uc5ed\uc758 \ub108\ube44\ub97c \ubcc0\uacbd\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub9bc 13\uc744 \ucc38\uc870\ud558\uc2ed\uc2dc\uc624.", "\uadf8\ub9bc 13. \uc67c\ucabd \ubc0f \uc624\ub978\ucabd \ubd80\ubd84\uc758 \uc218\uc9c1 \ubd84\ub9ac\uae30.", "\uc218\uc9c1 \ubd84\ub9ac\uae30\ub97c \uc6c0\uc9c1\uc77c \ub54c \uc704\uce58\uac00 \uc800\uc7a5\ub429\ub2c8\ub2e4. \ud504\ub85c\uadf8\ub7a8\uc744 \ub2e4\uc2dc \uc2dc\uc791\ud558\uba74 \uc124\uc815 \ud55c \ub9c8\uc9c0\ub9c9 \uc704\uce58\uac00 \ubcf5\uc6d0\ub429\ub2c8\ub2e4.", "\ud654\uba74\uc758 \uc624\ub978\ucabd \ud558\ub2e8\uc5d0\uc788\ub294 \uc2a4\ud53c\ucee4 \uc774\ubbf8\uc9c0 \uc704\ub85c \ub9c8\uc6b0\uc2a4 \ucee4\uc11c\ub97c \uc774\ub3d9\ud558\uace0 \uc624\ub978\ucabd \ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uba74 \uadf8\ub9bc 14\uc640 \uac19\uc774 \"\uc0ac\uc6b4\ub4dc \uc124\uc815 \uc5f4\uae30\"\uba54\ub274 \ud56d\ubaa9\uc744 \uc120\ud0dd\ud558\uc2ed\uc2dc\uc624.", "\uadf8\ub9bc 14. \uc5f4\uae30 \uc0ac\uc6b4\ub4dc \uc124\uc815.", "\ud604\uc7ac \uc0ac\uc6b4\ub4dc \uc124\uc815\uc774\uc788\ub294 \ud654\uba74\uc774 \ub098\ud0c0\ub0a9\ub2c8\ub2e4.", "\uadf8\ub9bc 15. \ud604\uc7ac \uc0ac\uc6b4\ub4dc \uc124\uc815.", "\uc791\uc5c5\uc744 \uc2dc\uc791\ud558\uae30 \uc804\uc758 \ucd08\uae30 \uac12\uc744 \ubcf5\uc6d0\ud558\uc2ed\uc2dc\uc624. \uadc0\ud558\uc758 \uacbd\uc6b0 \uc774\ub984\uc740 \ub2e4\ub985\ub2c8\ub2e4.", "\uadf8\ub9bc 16. \ucd08\uae30 \uc0ac\uc6b4\ub4dc \uc124\uc815.", "\uc2dc\uc2a4\ud15c \uc124\uc815\uc774 \ubcf5\uc6d0\ub418\uc5c8\uc73c\uba70 Windows\uc5d0\uc11c \uc791\uc5c5 \ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4."]