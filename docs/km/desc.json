["\u1780\u17b6\u179a\u1796\u17b7\u1796\u178e\u17cc\u1793\u17b6\u17a2\u17c6\u1796\u17b8\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8 \"\u1780\u17b6\u179a\u1787\u1787\u17c2\u1780\u1780\u17c6\u179f\u17b6\u1793\u17d2\u178f\u17a2\u17bc\u178c\u17b8\u1799\u17c9\u17bc\" \u17d4", "\u1798\u17b6\u178f\u17b7\u1780\u17b6", "1 \u17d4 \u1798\u17bb\u1793\u1796\u17c1\u179b\u17a2\u17d2\u1793\u1780\u1785\u17b6\u1794\u17cb\u1795\u17d2\u178f\u17be\u1798\u17d4", "2 \u17d4 \u1780\u17b6\u179a\u1796\u17b7\u1796\u178e\u17cc\u1793\u17b6\u179f\u1784\u17d2\u1781\u17c1\u1794\u17d4", "3 \u17d4 \u1794\u1789\u17d2\u1787\u17b8\u1797\u17b6\u179f\u17b6\u178a\u17c2\u179b\u1798\u17b6\u1793\u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb\u1780\u17b6\u179a\u1794\u17d2\u179a\u17b6\u179f\u17d2\u179a\u17d0\u1799\u1791\u17b6\u1780\u17cb\u1791\u1784\u17d4", "4 \u17d4 \u17a2\u17d2\u179c\u17b8\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bc\u179c\u1780\u17b6\u179a\u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u1792\u17d2\u179c\u17be\u1780\u17b6\u179a\u17d4", "5 \u17d4 \u1792\u17d2\u179c\u17be\u1780\u17b6\u179a\u1787\u17b6\u1798\u17bd\u1799\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u17d4", "5.1 \u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179a\u1785\u1793\u17b6\u179f\u1798\u17d2\u1796\u17d0\u1793\u17d2\u1792\u17d4", "5.2 \u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u179a\u17bc\u1794\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u1790\u17d2\u1798\u17b8\u17d4", "5.3 \u1795\u17d2\u1793\u17c2\u1780\u1787\u17c6\u1793\u17bd\u1799\u17d4", "5.4 \u1794\u17ca\u17bc\u178f\u17bb\u1784\u1785\u17c1\u1789\u17d4", "5.5 \u1794\u1789\u17d2\u1787\u17b8\u1788\u17d2\u1798\u17c4\u17c7\u17a2\u1793\u17d2\u178f\u179a\u1780\u1798\u17d2\u1798\u17d4", "5.6 \u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u1787\u1787\u17c2\u1780\u179a\u1794\u179f\u17cb\u17a2\u1793\u17d2\u178f\u179a\u1780\u17d2\u179a\u17bb\u1798\u17d4", "5.7 \u1780\u17b6\u179a\u1794\u17c4\u179f\u179f\u17c6\u17a2\u17b6\u178f\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u179f\u17b6\u179f\u17d2\u179a\u17d2\u178f\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bd\u178f\u1796\u17b7\u1793\u17b7\u178f\u17d2\u1799\u17d4", "5.8 \u179b\u17bb\u1794\u17a2\u17d2\u1793\u1780\u1794\u17d2\u179a\u1799\u17bb\u1791\u17d2\u1792\u17d4", "5.9 \u1780\u17b6\u179a\u1798\u17be\u179b\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u179a\u17bc\u1794\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1791\u17c6\u1793\u17b6\u1780\u17cb\u1791\u17c6\u1793\u1784\u17d4", "5.10 \u179f\u1789\u17d2\u1789\u17b6\u1794\u17c6\u1794\u17c2\u1780\u1794\u1789\u17d2\u1788\u179a\u179a\u179c\u17b6\u1784\u1795\u17d2\u1793\u17c2\u1780\u1781\u17b6\u1784\u1786\u17d2\u179c\u17c1\u1784\u1793\u17b7\u1784\u1781\u17b6\u1784\u179f\u17d2\u178f\u17b6\u17c6\u17d4", "6 \u17d4 \u1794\u1793\u17d2\u1791\u17b6\u1794\u17cb\u1796\u17b8\u17a2\u17d2\u1793\u1780\u1794\u1789\u17d2\u1785\u1794\u17cb\u1780\u17b6\u179a\u1784\u17b6\u179a\u17d4", "\u178a\u17b6\u1780\u17cb\u1791\u179f\u17d2\u179f\u1793\u17cd\u1791\u17d2\u179a\u1793\u17b7\u1785\u1780\u178e\u17d2\u178f\u17bb\u179a\u179b\u17be\u179a\u17bc\u1794\u1797\u17b6\u1796\u17a2\u17bc\u1794\u17c9\u17b6\u179b\u17d0\u179a\u1793\u17c5\u1787\u17d2\u179a\u17bb\u1784\u1781\u17b6\u1784\u179f\u17d2\u178f\u17b6\u17c6\u1781\u17b6\u1784\u1780\u17d2\u179a\u17c4\u1798\u1793\u17c3\u17a2\u17c1\u1780\u17d2\u179a\u1784\u17cb\u17a0\u17be\u1799\u1785\u17bb\u1785\u1781\u17b6\u1784\u179f\u17d2\u178f\u17b6\u17c6\u1780\u17b6\u179a\u1794\u17be\u1780\u179f\u17c6\u179b\u17c1\u1784 \"\u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 1 \u17d4 \u1794\u17be\u1780\u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179f\u17c6\u17a1\u17c1\u1784\u17d4", "\u17a2\u17c1\u1780\u17d2\u179a\u1784\u17cb\u178a\u17c2\u179b\u1798\u17b6\u1793\u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179f\u17c6\u17a1\u17c1\u1784\u1794\u1785\u17d2\u1785\u17bb\u1794\u17d2\u1794\u1793\u17d2\u1793\u1793\u17b9\u1784\u179b\u17c1\u1785\u17a1\u17be\u1784\u17d4 \u1785\u1784\u1785\u17b6\u17c6\u17a2\u17d2\u179c\u17b8\u178a\u17c2\u179b\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1780\u17c6\u178e\u178f\u17cb\u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb\u17a7\u1794\u1780\u179a\u178e\u17cd\u1794\u1789\u17d2\u1785\u17bc\u179b\u1793\u17b7\u1784\u1794\u1789\u17d2\u1785\u17c1\u1789\u179f\u17c6\u17a1\u17c1\u1784\u17d4 \u17a2\u17d2\u1793\u1780\u1793\u17b9\u1784\u178f\u17d2\u179a\u17bc\u179c\u1780\u17b6\u179a\u1796\u17d0\u178f\u17cc\u1798\u17b6\u1793\u1793\u17c1\u17c7\u1794\u1793\u17d2\u1791\u17b6\u1794\u17cb\u1796\u17b8\u17a2\u17d2\u1793\u1780\u1794\u1789\u17d2\u1785\u1794\u17cb\u1780\u17b6\u179a\u1784\u17b6\u179a\u17d4 \u1780\u17d2\u1793\u17bb\u1784\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 2 \u1796\u17d2\u179a\u17bd\u1789\u1796\u178e\u17cc\u1780\u17d2\u179a\u17a0\u1798\u1794\u1784\u17d2\u17a0\u17b6\u1789\u1796\u17b8\u17a2\u17d2\u179c\u17b8\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bc\u179c\u1780\u17b6\u179a\u1785\u1784\u1785\u17b6\u17c6\u17d4 \u1780\u17d2\u1793\u17bb\u1784\u1780\u179a\u178e\u17b8\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1788\u17d2\u1798\u17c4\u17c7\u1793\u17b9\u1784\u1781\u17bb\u179f\u1782\u17d2\u1793\u17b6\u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 2 \u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179f\u17c6\u17a1\u17c1\u1784\u178a\u17c6\u1794\u17bc\u1784", "\u1780\u17c6\u178e\u178f\u17cb\u17a7\u1794\u1780\u179a\u178e\u17cd\u179b\u1791\u17d2\u1792\u1795\u179b\u179f\u17c6\u17a1\u17c1\u1784\u1791\u17c5", "\u1780\u17c6\u178e\u178f\u17cb\u17a7\u1794\u1780\u179a\u178e\u17cd\u1794\u1789\u17d2\u1785\u17bc\u179b\u179f\u17c6\u17a1\u17c1\u1784\u1791\u17c5", "\u1780\u17d2\u1793\u17bb\u1784\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 3 \u1796\u17d2\u179a\u17bd\u1789\u1796\u178e\u17cc\u1780\u17d2\u179a\u17a0\u1798\u1794\u1784\u17d2\u17a0\u17b6\u1789\u1796\u17b8\u17a2\u17d2\u179c\u17b8\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bc\u179c\u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 3 \u17d4 \u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179f\u17c6\u17a1\u17c1\u1784\u1792\u17d2\u179c\u17be\u1780\u17b6\u179a", "\u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u1794\u17d2\u179a\u1796\u17d0\u1793\u17d2\u1792\u1794\u17b6\u1793\u1794\u1789\u17d2\u1785\u1794\u17cb\u17a2\u17d2\u1793\u1780\u17a2\u17b6\u1785\u178a\u17c6\u178e\u17be\u179a\u1780\u17b6\u179a\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u1794\u17b6\u1793", "\u17a2\u17d2\u1793\u1780\u1793\u17b7\u1799\u17b6\u1799\u1797\u17b6\u179f\u17b6\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u178a\u17b9\u1784\u17a2\u17d2\u1793\u1780\u1793\u17b9\u1784\u1794\u17b6\u1793 heard \u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u1797\u17b6\u179f\u17b6\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u1794\u17d2\u179a\u1780\u17b6\u1793\u17cb\u1781\u17d2\u1787\u17b6\u1794\u17cb\u1793\u17bc\u179c\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17d4 \u1780\u17c6\u178e\u178f\u17cb\u17a0\u17c1\u178f\u17bb\u1793\u17c3\u1780\u17b6\u179a\u1794\u17d2\u179a\u17b6\u179f\u17d2\u179a\u17d0\u1799\u1791\u17b6\u1780\u17cb\u1791\u1784\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u179a\u1780\u17d2\u179f\u17b6\u1791\u17bb\u1780\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u17a2\u17b6\u1785\u1792\u17d2\u179c\u17be\u1794\u17b6\u1793\u17d4 \u1794\u17d2\u179a\u178f\u17b7\u1794\u178f\u17d2\u178a\u17b7\u1780\u17b6\u179a\u1791\u17b6\u17c6\u1784\u17a2\u179f\u17cb\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u17a2\u1793\u17bb\u179c\u178f\u17d2\u178f\u1787\u17b6\u1798\u17bc\u179b\u178a\u17d2\u178b\u17b6\u1793\u1793\u17c5\u179b\u17be\u1780\u17bb\u17c6\u1796\u17d2\u1799\u17bc\u1791\u17d0\u179a\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u178a\u17c2\u179b\u1780\u17c6\u1796\u17bb\u1784\u178a\u17c6\u178e\u17be\u179a\u1780\u17b6\u179a\u179c\u17b8\u1793\u178a\u17bc 10 \u17ac\u179c\u17b8\u1793\u178a\u17bc 11 \u17d4 \u1781\u17bd\u179a\u1780\u17d2\u1794\u17b6\u179b\u1780\u17d2\u179a\u17b6\u17a0\u17d2\u179c\u17b7\u1780\u1782\u17ba\u1782\u17bd\u179a\u17b1\u17d2\u1799\u1785\u1784\u17cb\u1794\u17b6\u1793\u1794\u17c9\u17bb\u1793\u17d2\u178f\u17c2\u1798\u17b7\u1793\u1798\u17b6\u1793\u178f\u1798\u17d2\u179a\u17bc\u179c\u1780\u17b6\u179a\u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u178a\u17c6\u178e\u17be\u179a\u1780\u17b6\u179a\u1791\u17c1\u17d4 \u1782\u17bb\u178e\u1797\u17b6\u1796\u1793\u17c3\u1780\u17b6\u179a\u1794\u1780\u1794\u17d2\u179a\u17c2\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1792\u17d2\u179c\u17be\u17b1\u17d2\u1799\u1794\u17d2\u179a\u179f\u17be\u179a\u17a1\u17be\u1784\u1787\u17b6\u1798\u17bd\u1799\u1793\u17b9\u1784\u1794\u17d2\u179a\u1796\u17d0\u1793\u17d2\u1792\u178a\u17c6\u178e\u17be\u179a\u1780\u17b6\u179a\u1780\u17d2\u179a\u17b6\u17a0\u17d2\u179c\u17b7\u1780\u17d4", "\u1794\u17d2\u179a\u179f\u17b7\u1793\u1794\u17be\u17a2\u17d2\u1793\u1780\u1799\u179b\u17cb\u1796\u17b8\u1797\u17b6\u179f\u17b6\u1798\u17bd\u1799\u1796\u17b8\u1794\u1789\u17d2\u1787\u17b8\u1793\u17c1\u17c7\u17a2\u17d2\u1793\u1780\u1793\u17b9\u1784\u17a2\u17b6\u1785\u1794\u17d2\u179a\u17b6\u179f\u17d2\u179a\u17d0\u1799\u1791\u17b6\u1780\u17cb\u1791\u1784\u1787\u17b6\u1798\u17bd\u1799\u17a2\u17d2\u1793\u1780\u1793\u17b7\u1799\u17b6\u1799\u1797\u17b6\u179f\u17b6\u1794\u17c2\u1794\u17a2\u1785\u179b\u1793\u1791\u17d2\u179a\u1796\u17d2\u1799\u1793\u17c3\u1797\u17b6\u179f\u17b6\u178e\u17b6\u1798\u17bd\u1799\u1796\u17b8\u1794\u1789\u17d2\u1787\u17b8\u1793\u17c1\u17c7\u17d4 \u1780\u17b6\u179a\u1794\u17d2\u179a\u17b6\u179f\u17d2\u179a\u17d0\u1799\u1791\u17b6\u1780\u17cb\u1791\u1784\u17a2\u17b6\u1785\u1798\u17b6\u1793\u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u178f\u17c1\u17a1\u17c1\u1780\u17d2\u179a\u17b6\u1798 WhatsApp, Google \u1787\u17bd\u1794, Vkmessenger, yandexmessengen \u17ac\u17a2\u17d2\u1793\u1780\u1793\u17b6\u17c6\u179f\u17b6\u179a\u1795\u17d2\u179f\u17c1\u1784\u1791\u17c0\u178f\u17d4 \u17a2\u17d2\u1793\u1780\u17a2\u17b6\u1785\u179f\u17d2\u178f\u17b6\u1794\u17cb\u1796\u17d0\u178f\u17cc\u1798\u17b6\u1793\u179c\u1782\u17d2\u1782\u1794\u178e\u17d2\u178f\u17bb\u17c7\u1794\u178e\u17d2\u178f\u17b6\u179b\u1793\u17b7\u1784\u1795\u178f\u1783\u17c2\u179f\u17d2\u1790\u1795\u17d2\u179f\u17c1\u1784\u1791\u17c0\u178f\u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u1797\u17b6\u179f\u17b6\u178e\u17b6\u1798\u17bd\u1799\u1793\u17c3 Mentio \u1793\u17b7\u1784\u1799\u179b\u17cb\u1796\u17b8\u1796\u17bd\u1780\u1782\u17c1\u17d4 \u17a5\u17a1\u17bc\u179c\u1793\u17c1\u17c7\u179c\u17b6\u17a2\u17b6\u1785\u1791\u17c5\u179a\u17bd\u1785\u1780\u17d2\u1793\u17bb\u1784\u1780\u17b6\u179a\u179f\u17c6\u1797\u17b6\u179f\u1793\u17cd\u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u1780\u17d2\u179a\u17bb\u1798\u17a0\u17ca\u17bb\u1793\u1794\u179a\u1791\u17c1\u179f\u1793\u17b7\u1784\u1785\u17d2\u179a\u17be\u1793\u1791\u17c0\u178f\u17d4 \u17a2\u17d2\u1793\u1780\u1780\u17cf\u17a2\u17b6\u1785\u1785\u17b6\u1780\u17cb\u17af\u1780\u179f\u17b6\u179a\u17a2\u17bc\u178c\u17b8\u1799\u17c9\u17bc / \u179c\u17b8\u178a\u17c1\u17a2\u17bc\u1787\u17b6\u1797\u17b6\u179f\u17b6\u1794\u179a\u1791\u17c1\u179f\u17a0\u17be\u1799 hear \u179c\u17b6\u1787\u17b6\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17d4 \u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u1798\u17bd\u1799\u1785\u17c6\u17a0\u17c0\u1784\u1782\u17ba\u1787\u17b6\u1780\u17b6\u179a\u179f\u1793\u17d2\u1791\u1793\u17b6\u1787\u17b6\u1798\u17bd\u1799\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u1780\u17d2\u1793\u17bb\u1784\u1797\u17b6\u179f\u17b6\u178f\u17c2\u1798\u17bd\u1799\u1794\u17c9\u17bb\u1793\u17d2\u178f\u17c2\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1793\u17b9\u1784\u179b\u17ba\u179f\u17c6\u178a\u17b8\u178a\u17c2\u179b\u1794\u17b6\u1793\u1794\u1784\u17d2\u1780\u17be\u178f\u17d4 \u1798\u17b7\u1793\u1798\u17c2\u1793\u1787\u17b6\u179f\u17c6\u179b\u17c1\u1784\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1791\u17c1\u17d4 tois \u1793\u17c1\u17c7\u1782\u17ba\u1785\u17b6\u17c6\u1794\u17b6\u1785\u17cb\u17d4 \u1798\u17b6\u1793\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u1787\u17b6\u1785\u17d2\u179a\u17be\u1793\u178a\u17c2\u179b\u17a2\u17b6\u1785\u1792\u17d2\u179c\u17be\u1794\u17b6\u1793\u17d4", "\u1794\u17d2\u179a\u1796\u17d0\u1793\u17d2\u1792\u1794\u17d2\u179a\u178f\u17b7\u1794\u178f\u17d2\u178f\u17b7\u1780\u17b6\u179a\u179c\u17b8\u1793\u178a\u17bc 10 \u17ac\u179c\u17b8\u1793\u178a\u17bc 11 \u17d4", "\u1791\u17c6\u17a0\u17c6\u178a\u17d2\u179a\u17b6\u1799\u179c\u17cd\u179a\u17b9\u1784\u178a\u17c2\u179b\u1798\u17b6\u1793 8 \u1787\u17b8\u1780\u17b6\u1794\u17c3\u17d4", "RAM \u1796\u17b8 10 \u1787\u17b8\u1780\u17b6\u1794\u17c3\u17d4", "GPU (\u17af\u1780\u178f\u17b6\u178a\u17c6\u178e\u17be\u179a\u1780\u17b6\u179a\u1780\u17d2\u179a\u17b6\u17a0\u17d2\u179c\u17b7\u1780) \u178a\u17c2\u179b\u1798\u17b6\u1793 6 \u1787\u17b8\u1780\u17b6\u1794\u17c3\u17ac\u1785\u17d2\u179a\u17be\u1793\u1787\u17b6\u1784\u1793\u17c1\u17c7\u178a\u17c2\u179b\u1782\u17bd\u179a\u17b1\u17d2\u1799\u1785\u1784\u17cb\u1794\u17b6\u1793\u1794\u17c9\u17bb\u1793\u17d2\u178f\u17c2\u1798\u17b7\u1793\u1785\u17b6\u17c6\u1794\u17b6\u1785\u17cb\u1791\u17c1\u17d4", "\u1780\u17b6\u179f\u178a\u17c2\u179b\u1798\u17b6\u1793\u1798\u17b8\u1780\u17d2\u179a\u17bc\u17a0\u17d2\u179c\u17bc\u1793\u17d4", "\u1785\u17c6\u178e\u17bb\u1785\u1794\u17d2\u179a\u1791\u17b6\u1780\u17cb\u1791\u17b6\u17c6\u1784\u1798\u17bc\u179b\u1793\u17c3\u1780\u17b6\u179a\u1792\u17d2\u179c\u17be\u1780\u17b6\u179a\u1787\u17b6\u1798\u17bd\u1799\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u17a2\u1793\u17bb\u179c\u178f\u17d2\u178f\u1796\u17b8\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u179a\u17bb\u1780\u179a\u1780\u17d4", "\u1793\u17c5\u1796\u17c1\u179b\u17a2\u17d2\u1793\u1780\u1785\u17bb\u1785\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179a\u1785\u1793\u17b6\u179f\u1798\u17d2\u1796\u17d0\u1793\u17d2\u1792\" \u17a0\u17be\u1799\u179f\u17c6\u178e\u17bb\u17c6\u1794\u17c2\u1794\u1794\u1791\u178a\u17c2\u179b\u1798\u17b6\u1793\u1794\u17c9\u17b6\u179a\u17c9\u17b6\u1798\u17c9\u17c2\u178f\u17d2\u179a\u1794\u17d2\u179a\u178f\u17b7\u1794\u178f\u17d2\u178f\u17b7\u1780\u17b6\u179a\u179f\u17c6\u1781\u17b6\u1793\u17cb\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1794\u1784\u17d2\u17a0\u17b6\u1789\u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u1798\u17ba\u1793\u17bb\u1799\u1781\u17b6\u1784\u179b\u17be\u17d4 \u179f\u17bc\u1798\u1798\u17be\u179b\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 4 \u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 4 \u17d4 \u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179a\u1785\u1793\u17b6\u179f\u1798\u17d2\u1796\u17d0\u1793\u17d2\u1792\u17d4", "\u1795\u17d2\u1793\u17c2\u1780\u1793\u17c3\u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179a\u1785\u1793\u17b6\u179f\u1798\u17d2\u1796\u17d0\u1793\u17d2\u1792\u1798\u17b6\u1793\u1794\u17c9\u17b6\u179a\u17c9\u17b6\u1798\u17c9\u17c2\u178f\u17d2\u179a\u1794\u17d2\u179a\u178f\u17b7\u1794\u178f\u17d2\u178f\u17b7\u1780\u17b6\u179a\u179f\u17c6\u1781\u17b6\u1793\u17cb:", "\u1797\u17b6\u179f\u17b6 - \u1780\u17c6\u178e\u178f\u17cb\u1797\u17b6\u179f\u17b6\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u1793\u17b7\u1799\u17b6\u1799\u17d4", "\u179f\u17c6\u17a1\u17c1\u1784 - \u1788\u17d2\u1798\u17c4\u17c7\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1794\u17be\u1780\u1794\u179a\u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb\u17a7\u1794\u1780\u179a\u178e\u17cd\u179f\u17c6\u179b\u17c1\u1784\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17d4", "\u1798\u17b8\u1780\u17d2\u179a\u17bc\u17a0\u17d2\u179c\u17bc\u1793 - \u1788\u17d2\u1798\u17c4\u17c7\u17a2\u17d2\u1793\u1780\u1794\u17be\u1780\u1794\u179a\u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb\u1798\u17b8\u1780\u17d2\u179a\u17bc\u17a0\u17d2\u179c\u17bc\u1793\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17d4", "\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u179a\u17bb\u1780\u179a\u1780\u1782\u17c1\u17a0\u1791\u17c6\u1796\u17d0\u179a - \u1788\u17d2\u1798\u17c4\u17c7\u179a\u1794\u179f\u17cb\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u179a\u17bb\u1780\u179a\u1780\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u1793\u17b9\u1784\u1792\u17d2\u179c\u17be\u1780\u17b6\u179a\u17d4", "\u1793\u17c5\u1796\u17c1\u179b\u17a2\u17d2\u1793\u1780\u1795\u17d2\u179b\u17b6\u179f\u17cb\u1794\u17d2\u178f\u17bc\u179a\u1797\u17b6\u179f\u17b6\u17a0\u17be\u1799\u179a\u1780\u17d2\u179f\u17b6\u1791\u17bb\u1780\u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179a\u1785\u1793\u17b6\u179f\u1798\u17d2\u1796\u17d0\u1793\u17d2\u1792\u17a2\u178f\u17d2\u1790\u1794\u1791\u1791\u17b6\u17c6\u1784\u17a2\u179f\u17cb\u1780\u17b6\u179a\u1794\u1784\u17d2\u17a0\u17b6\u1789\u1788\u17d2\u1798\u17c4\u17c7\u1794\u17ca\u17bc\u178f\u17bb\u1784\u1793\u17b7\u1784\u17a2\u178f\u17d2\u1790\u1794\u1791\u1795\u17d2\u179f\u17c1\u1784\u1791\u17c0\u178f\u1793\u17b9\u1784\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1794\u1784\u17d2\u17a0\u17b6\u1789\u1787\u17b6\u1797\u17b6\u179f\u17b6\u1790\u17d2\u1798\u17b8\u17d4 \u1780\u17b6\u179a\u1787\u1787\u17c2\u1780\u1790\u17d2\u1798\u17b8\u1793\u17b9\u1784\u178f\u17d2\u179a\u17bc\u179c\u1794\u1780\u1794\u17d2\u179a\u17c2\u1791\u17c5\u1787\u17b6\u1797\u17b6\u179f\u17b6\u178a\u17c2\u179b\u1794\u17b6\u1793\u1787\u17d2\u179a\u17be\u179f\u179a\u17be\u179f\u17a0\u17be\u1799\u17a2\u17d2\u1793\u1780\u1793\u17b9\u1784\u179b\u17ba\u179f\u17c6\u178a\u17b8\u1780\u17d2\u1793\u17bb\u1784\u1797\u17b6\u179f\u17b6\u1790\u17d2\u1798\u17b8\u1793\u17c1\u17c7\u17d4 \u1785\u17c6\u178e\u17b6\u17c6\u179f\u17c6\u1781\u17b6\u1793\u17cb\u17a2\u17c6\u1796\u17b8\u1794\u17c9\u17b6\u179a\u17c9\u17b6\u1798\u17c9\u17c2\u178f\u17d2\u179a\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u179a\u17bb\u1780\u179a\u1780\u1782\u17c1\u17a0\u1791\u17c6\u1796\u17d0\u179a\u17d4 \u178f\u17b6\u1798\u179b\u17c6\u1793\u17b6\u17c6\u178a\u17be\u1798\u1794\u17c9\u17b6\u179a\u17c9\u17b6\u1798\u17c9\u17c2\u178f\u17d2\u179a\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u179a\u17bb\u1780\u179a\u1780\u1782\u17c1\u17a0\u1791\u17c6\u1796\u17d0\u179a\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1780\u17c6\u178e\u178f\u17cb\u1791\u17c5 Microsoft \u1782\u17c2\u1798\u1785\u17b6\u1794\u17cb\u178f\u17b6\u17c6\u1784\u1796\u17b8\u179c\u17b6\u178f\u17c2\u1784\u178f\u17c2\u1794\u17b6\u1793\u178a\u17c6\u17a1\u17be\u1784\u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u179c\u17b8\u1793\u178a\u17bc\u17d4 \u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb\u1794\u17c9\u17b6\u179a\u17c9\u17b6\u1798\u17c9\u17c2\u178f\u17d2\u179a\u1793\u17c1\u17c7\u179f\u17bc\u1798\u1787\u17d2\u179a\u17be\u179f\u179a\u17be\u179f\u178f\u17c2\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u179a\u17bb\u1780\u179a\u1780\u178a\u17c2\u179b\u1794\u17b6\u1793\u178f\u17c6\u17a1\u17be\u1784\u1793\u17b7\u1784\u178a\u17c6\u178e\u17be\u179a\u1780\u17b6\u179a\u179b\u17be\u1794\u17d2\u179a\u1796\u17d0\u1793\u17d2\u1792\u1794\u17d2\u179a\u178f\u17b7\u1794\u178f\u17d2\u178f\u17b7\u1780\u17b6\u179a\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1794\u17c9\u17bb\u178e\u17d2\u178e\u17c4\u17c7\u17d4", "\u1780\u17b6\u179a\u1785\u17bb\u1785\u1794\u17ca\u17bc\u178f\u17bb\u1784\u1790\u17d2\u1798\u17b8\u1794\u1784\u17d2\u17a0\u17b6\u1789\u1791\u1798\u17d2\u179a\u1784\u17cb\u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb\u1780\u17b6\u179a\u1794\u17c6\u1796\u17c1\u1789\u17a7\u1794\u1780\u179a\u178e\u17cd\u17a2\u17c1\u1798\u17a2\u17c1\u179f\u17a2\u17c1\u179f\u17a2\u17c1\u179f\u17d4 \u179f\u17bc\u1798\u1798\u17be\u179b\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 5 \u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 5 \u17d4 \u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u179a\u17bc\u1794\u17a2\u1793\u17d2\u178f\u179a\u1780\u17b6\u179a\u17b8\u1790\u17d2\u1798\u17b8", "\u1795\u17d2\u1793\u17c2\u1780 \"\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u179a\u17bc\u1794 Interlocutor \u1790\u17d2\u1798\u17b8\" \u1798\u17b6\u1793\u1794\u17c9\u17b6\u179a\u17c9\u17b6\u1798\u17c9\u17c2\u178f\u17d2\u179a\u1794\u17d2\u179a\u178f\u17b7\u1794\u178f\u17d2\u178f\u17b7\u1780\u17b6\u179a\u179f\u17c6\u1781\u17b6\u1793\u17cb:", "\u1788\u17d2\u1798\u17c4\u17c7\u17a0\u17c5\u1780\u17d2\u179a\u17c5 - \u1788\u17d2\u1798\u17c4\u17c7\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u1787\u17d2\u179a\u17be\u179f\u179a\u17be\u179f\u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17d4", "\u1797\u17b6\u179f\u17b6 - \u1797\u17b6\u179f\u17b6 Interlocutor \u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1793\u17b7\u1799\u17b6\u1799\u17d4", "\u1780\u17b6\u179a\u1796\u17b7\u1796\u178e\u17cc\u1793\u17b6 - \u1780\u17b6\u179a\u1796\u17b7\u1796\u178e\u17cc\u1793\u17b6\u17a2\u17c6\u1796\u17b8\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17d4", "\u1794\u17d2\u179a\u17be\u1798\u17b8\u1780\u17d2\u179a\u17bc\u17a0\u17d2\u179c\u17bc\u1793 - \u1780\u17c6\u178e\u178f\u17cb\u1791\u1784\u17cb\u1780\u17b6\u179a\u1794\u17d2\u179a\u17be\u1794\u17d2\u179a\u17b6\u179f\u17cb\u1798\u17b8\u1780\u17d2\u179a\u17bc\u17a0\u17d2\u179c\u17bc\u1793\u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796 - \u1780\u17c6\u178e\u178f\u17cb\u179a\u17bc\u1794\u178f\u17c6\u178e\u17b6\u1784\u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb\u17a2\u17d2\u1793\u1780\u1794\u1789\u17d2\u1785\u17bc\u179b\u17d4", "\u1794\u17d2\u179a\u179f\u17b7\u1793\u1794\u17be\u17a2\u17d2\u1793\u1780\u1798\u17b7\u1793\u1794\u17b6\u1793\u1787\u17d2\u179a\u17be\u179f\u179a\u17be\u179f\u179a\u17bc\u1794\u1797\u17b6\u1796\u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb Interloctor \u1791\u17c1\u179a\u17bc\u1794\u1797\u17b6\u1796\u179b\u17c6\u1793\u17b6\u17c6\u178a\u17be\u1798\u1793\u17b9\u1784\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1794\u17d2\u179a\u17be\u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb\u1782\u17b6\u178f\u17cb\u17d4", "\"\u1794\u17d2\u179a\u17be\u1798\u17b8\u1780\u17d2\u179a\u17bc\u17a0\u17d2\u179c\u17bc\u1793\" \u178e\u17b6\u1793\u17cb\u178e\u17c2\u178f\u1798\u17b7\u1793\u1798\u17b6\u1793\u1780\u179a\u178e\u17b8\u1793\u17c5\u1796\u17c1\u179b\u17a2\u17d2\u1793\u1780\u1780\u17c6\u1796\u17bb\u1784\u179f\u17d2\u178f\u17b6\u1794\u17cb (\u1796\u17d0\u178f\u17cc\u1798\u17b6\u1793\u17a2\u17bc\u178c\u17b8\u1799\u17c9\u17bc\u1798\u17c1\u179a\u17c0\u1793\u17d4 \u179b\u17d4 ) \u17d4", "\u179f\u17bb\u179c\u178f\u17d2\u1790\u17b7\u1797\u17b6\u1796 \"\u1787\u17c6\u1793\u17bd\u1799\" \u1796\u17b7\u1796\u178e\u17cc\u1793\u17b6\u17a2\u17c6\u1796\u17b8\u179a\u1794\u17c0\u1794\u1792\u17d2\u179c\u17be\u1780\u17b6\u179a\u1787\u17b6\u1798\u17bd\u1799\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u1787\u17b6\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17d4 \u179f\u17bc\u1798\u1798\u17be\u179b\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 6 \u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796 6 \u1795\u17d2\u1793\u17c2\u1780\u1787\u17c6\u1793\u17bd\u1799\u17d4", "\u1785\u17bb\u1785\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1785\u17c1\u1789\" \u1794\u1789\u17d2\u1785\u1794\u17cb\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u17d4 \u179f\u17bc\u1798\u1798\u17be\u179b\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 7 \u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 7 \u17d4 \u1794\u17ca\u17bc\u178f\u17bb\u1784\u1785\u17c1\u1789\u17d4", "\u1780\u17b6\u179a\u1794\u17b7\u1791\u1794\u1784\u17d2\u17a2\u17bd\u1785\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u179a\u17bb\u1780\u179a\u1780\u17ac\u1780\u17b6\u179a\u1794\u17b7\u1791\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u179a\u17bb\u1780\u179a\u1780\u1780\u17cf\u1794\u1789\u17d2\u1785\u1794\u17cb\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u178a\u17c2\u179a\u17d4", "\u1792\u17d2\u179c\u17be\u17b1\u17d2\u1799\u1791\u17c6\u1796\u17d0\u179a\u179f\u17d2\u179a\u179f\u17cb\u179f\u17d2\u179a\u17b6\u1799\u1780\u17cf\u1794\u1789\u17d2\u1785\u1794\u17cb\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u178a\u17c2\u179a\u17d4", "\u1793\u17c5\u1795\u17d2\u1793\u17c2\u1780\u1781\u17b6\u1784\u1786\u17d2\u179c\u17c1\u1784\u1793\u17c3\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u179a\u17bb\u1780\u179a\u1780\u1782\u17ba\u1787\u17b6\u1794\u1789\u17d2\u1787\u17b8\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17a2\u1793\u17d2\u178f\u179a\u1780\u1798\u17d2\u1798\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17d4 \u179f\u17bc\u1798\u1798\u17be\u179b\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 8 \u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 8 \u1794\u1789\u17d2\u1787\u17b8\u1788\u17d2\u1798\u17c4\u17c7\u17a2\u1793\u17d2\u178f\u179a\u1780\u1798\u17d2\u1798\u17d4", "\u179f\u1798\u17d2\u179a\u17b6\u1794\u17cb\u17a2\u1793\u17d2\u178f\u179a\u179a\u17bc\u1794\u178f\u17c6\u178e\u17b6\u1784\u179a\u17bc\u1794\u178f\u17c6\u178e\u17b6\u1784\u1780\u17b6\u179b\u1794\u179a\u17b7\u1785\u17d2\u1786\u17c1\u1791\u1793\u17c3\u179f\u17b6\u179a\u1785\u17bb\u1784\u1780\u17d2\u179a\u17c4\u1799\u1793\u17b7\u1784\u17a2\u178f\u17d2\u1790\u1794\u1791\u1793\u17c3\u179f\u17b6\u179a\u1785\u17bb\u1784\u1780\u17d2\u179a\u17c4\u1799\u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1794\u1784\u17d2\u17a0\u17b6\u1789\u17d4 \u1791\u17d2\u179a\u1784\u17cb\u1791\u17d2\u179a\u17b6\u1799\u1780\u17b6\u179b\u1794\u179a\u17b7\u1785\u17d2\u1786\u17c1\u1791\u1780\u17d2\u1793\u17bb\u1784\u1780\u17b6\u179a\u1792\u17d2\u179c\u17be\u1780\u17b7\u1785\u17d2\u1785\u1780\u17b6\u179a\u1793\u17c1\u17c7\u178f\u17d2\u179a\u17bc\u179c\u1793\u17b9\u1784\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17d4 \u1793\u17c5\u1796\u17c1\u179b\u17a2\u17d2\u1793\u1780\u1785\u17bb\u1785\u179b\u17be\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u1787\u1787\u17c2\u1780\u179a\u1794\u179f\u17cb\u1796\u17bd\u1780\u1782\u17c1\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1794\u1784\u17d2\u17a0\u17b6\u1789\u17d4", "\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u1787\u1787\u17c2\u1780\u1787\u1787\u17c2\u1780\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u1780\u1798\u17d2\u1798\u1798\u17b6\u1793\u1791\u17b8\u178f\u17b6\u17c6\u1784\u1793\u17c5\u1795\u17d2\u1793\u17c2\u1780\u1781\u17b6\u1784\u179f\u17d2\u178f\u17b6\u17c6\u1793\u17c3\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u17a2\u17ca\u17b8\u1793\u1792\u17ba\u178e\u17b7\u178f\u17d4 \u179f\u17bc\u1798\u1798\u17be\u179b\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 9 \u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796 9 \u17d4 \u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u1787\u1787\u17c2\u1780\u1787\u1787\u17c2\u1780\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bd\u178f\u1796\u17b7\u1793\u17b7\u178f\u17d2\u1799\u17d4", "\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u1787\u1787\u17c2\u1780\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1791\u17c6\u1793\u17b6\u1780\u17cb\u1791\u17c6\u1793\u1784\u1794\u17b6\u1793\u1794\u1784\u17d2\u17a0\u17b6\u1789\u17a2\u17d2\u1793\u1780\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u1785\u17bb\u1785\u179b\u17be\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u1793\u17c5\u1795\u17d2\u1793\u17c2\u1780\u1781\u17b6\u1784\u1786\u17d2\u179c\u17c1\u1784\u17d4", "\u1798\u17ba\u1793\u17bb\u1799\u1781\u17b6\u1784\u179b\u17be\u1798\u17b6\u1793:", "\u179a\u17bc\u1794\u178f\u17c6\u178e\u17b6\u1784\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1794\u17d2\u179a\u1799\u17bb\u1791\u17d2\u1792", "\u179f\u1798\u17d2\u1798\u178f\u17b7\u1793\u17b6\u1798\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bd\u178f\u1796\u17b7\u1793\u17b7\u178f\u17d2\u1799", "\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1785\u17b6\u1794\u17cb\u1795\u17d2\u178f\u17be\u1798\u1780\u17b6\u179a\u179f\u1793\u17d2\u1791\u1793\u17b6\"", "\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1785\u17d2\u1794\u17b6\u179f\u17cb\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\"", "\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u179b\u17bb\u1794\u17a2\u1793\u17d2\u178f\u179a onterlocutor\"", "\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u179a\u17bc\u1794\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1795\u17d2\u1791\u17b6\u179b\u17cb\"", "\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u1787\u1787\u17c2\u1780\u1787\u17b6\u1798\u17bd\u1799\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u178a\u17c2\u179b\u1794\u17b6\u1793\u1787\u17d2\u179a\u17be\u179f\u179a\u17be\u179f\u179b\u17c1\u1785\u17a1\u17be\u1784\u1793\u17c5\u1795\u17d2\u1793\u17c2\u1780\u1781\u17b6\u1784\u179f\u17d2\u178f\u17b6\u17c6\u17d4", "\u1785\u17c6\u178e\u1784\u1787\u17be\u1784\u1787\u1787\u17c2\u1780\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u178a\u17b6\u1780\u17cb\u179b\u17c1\u1781\u178a\u17c4\u1799\u1782\u17bc\u1798\u17bd\u1799\u1782\u17bc\u1782\u17ba \"\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17a2\u17b6\u1793\" \u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780 \"\u17d4", "\u1785\u17c6\u178e\u1784\u1787\u17be\u1784\u1787\u1787\u17c2\u1780\u1798\u17b6\u1793\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u179b\u17bb\u1794\u1787\u1787\u17c2\u1780\" \u17d4", "\u1793\u17c5\u1796\u17c1\u179b\u17a2\u17d2\u1793\u1780\u1785\u17bb\u1785\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u179b\u17bb\u1794\u1787\u1787\u17c2\u1780\" \"\u1787\u1787\u17c2\u1780\u1787\u1787\u17c2\u1780\u1780\u17c6\u179f\u17b6\u1793\u17d2\u178f\u1793\u17c1\u17c7\u1780\u17b6\u179a\u1787\u1787\u17c2\u1780\u1793\u17c1\u17c7\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u179b\u17bb\u1794\u1785\u17c1\u1789\u1796\u17b8\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u1787\u1787\u17c2\u1780\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1787\u1787\u17c2\u1780\u179c\u17c2\u1780\u1789\u17c2\u1780\u17d4", "\u179f\u17b6\u179a\u1791\u17b6\u17c6\u1784\u17a2\u179f\u17cb\u1785\u17c2\u1780\u1785\u17c1\u1789\u1787\u17b6 2 \u1780\u17d2\u179a\u17bb\u1798:", "\u179f\u17b6\u179a\u1796\u17b8\u17a2\u1793\u17d2\u178f\u179a\u1780\u17b6\u179a\u17b8\u17d4", "\u179f\u17b6\u179a\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17d4", "\u179f\u17b6\u179a\u1796\u17b8\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1795\u17d2\u179b\u17b6\u179f\u17cb\u1794\u17d2\u178f\u17bc\u179a\u1791\u17c5\u1781\u17b6\u1784\u1786\u17d2\u179c\u17c1\u1784\u17d4 \u179f\u17b6\u179a\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1795\u17d2\u179b\u17b6\u179f\u17cb\u1794\u17d2\u178f\u17bc\u179a\u1791\u17c5\u1781\u17b6\u1784\u179f\u17d2\u178f\u17b6\u17c6\u17d4", "\u1780\u17d2\u179a\u17bb\u1798\u179f\u17b6\u179a\u1793\u17b8\u1798\u17bd\u1799\u17d7\u1798\u17b6\u1793 2 \u1795\u17d2\u1793\u17c2\u1780:", "\u17a2\u178f\u17d2\u1790\u1794\u1791\u179f\u17b6\u179a\u1787\u17b6\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u1796\u178e\u17cc\u1793\u17c3\u179f\u17b6\u179a\u1793\u17c1\u17c7\u1782\u17ba\u1781\u17d2\u1798\u17c5\u17d4", "\u17a2\u178f\u17d2\u1790\u1794\u1791\u179f\u17b6\u179a\u1787\u17b6\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1796\u178e\u17cc\u1793\u17c3\u179f\u17b6\u179a\u1793\u17c1\u17c7\u1798\u17b6\u1793\u1796\u178e\u17cc\u1794\u17c3\u178f\u1784\u17d4", "\u1780\u17b6\u179b\u1794\u179a\u17b7\u1785\u17d2\u1786\u17c1\u1791\u179f\u17b6\u179a\u178f\u17d2\u179a\u17bc\u179c\u1793\u17b9\u1784\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17d4", "\u179f\u17b6\u179a\u1790\u17d2\u1798\u17b8\u1787\u17b6\u1784 (\u178f\u17b6\u1798\u1780\u17b6\u179b\u1794\u179a\u17b7\u1785\u17d2\u1786\u17c1\u1791) \u1798\u17b6\u1793\u1791\u17b8\u178f\u17b6\u17c6\u1784\u179f\u17d2\u1790\u17b7\u178f\u1793\u17c5\u1791\u17b6\u1794\u1787\u17b6\u1784\u17a2\u178e\u17d2\u178f\u17be\u1780\u1785\u17b6\u179f\u17cb\u17d4", "\u1793\u17c5\u1795\u17d2\u1793\u17c2\u1780\u1781\u17b6\u1784\u1780\u17d2\u179a\u17c4\u1798\u1793\u17c3\u1780\u17b6\u179a\u1787\u1787\u17c2\u1780\u179a\u1794\u179f\u17cb Interlocutor \u1782\u17ba\u1787\u17b6\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1785\u17b6\u1794\u17cb\u1795\u17d2\u178f\u17be\u1798\u1780\u17b6\u179a\u179f\u1793\u17d2\u1791\u1793\u17b6\" \u17d4 \u1793\u17c5\u1796\u17c1\u179b\u17a2\u17d2\u1793\u1780\u1785\u17bb\u1785\u179b\u17be\u179c\u17b6\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u1785\u17b6\u1794\u17cb\u1795\u17d2\u178f\u17be\u1798\u1780\u17d2\u179a\u17b7\u178f\u178f\u17b6\u1798\u1781\u17d2\u1793\u17b6\u178f\u1798\u17b8\u1780\u17d2\u179a\u17bc\u17a0\u17d2\u179c\u17bc\u1793\u1793\u17b7\u1784\u17a7\u1794\u1780\u179a\u178e\u17cd\u179f\u17c6\u17a1\u17c1\u1784\u178a\u17be\u1798\u17d2\u1794\u17b8\u1780\u17c6\u178e\u178f\u17cb\u1780\u17c6\u179a\u17b7\u178f\u179f\u1789\u17d2\u1789\u17b6 / \u179f\u17c6\u179b\u17c1\u1784\u179a\u17c6\u1781\u17b6\u1793\u17a0\u17be\u1799\u1794\u1784\u17d2\u17a0\u17b6\u1789\u179f\u17b6\u179a\u178a\u17c2\u179b\u178f\u17d2\u179a\u17bc\u179c\u1782\u17d2\u1793\u17b6\u17d4", "\u1794\u1793\u17d2\u1791\u17b6\u1794\u17cb\u1796\u17b8\u1780\u17d2\u179a\u17b7\u178f\u178f\u17b6\u1798\u1781\u17d2\u1793\u17b6\u178f\u17a7\u1794\u1780\u179a\u178e\u17cd\u179f\u17c6\u179b\u17c1\u1784\u1788\u17d2\u1798\u17c4\u17c7\u1794\u17ca\u17bc\u178f\u17bb\u1784\u1795\u17d2\u179b\u17b6\u179f\u17cb\u1794\u17d2\u178f\u17bc\u179a: \"\u1785\u17b6\u1794\u17cb\u1795\u17d2\u178f\u17be\u1798\u1780\u17b6\u179a\u179f\u1793\u17d2\u1791\u1793\u17b6\" -> \"\u1794\u1789\u17d2\u1788\u1794\u17cb\u1780\u17b6\u179a\u179f\u1793\u17d2\u1791\u1793\u17b6\" \u17d4", "\u1785\u17b6\u1794\u17cb\u1796\u17b8\u1785\u17c6\u178e\u17bb\u1785\u1793\u17c1\u17c7\u17a2\u17d2\u1793\u1780\u17a2\u17b6\u1785\u1785\u17b6\u1794\u17cb\u1795\u17d2\u178f\u17be\u1798\u1780\u17b6\u179a\u179f\u1793\u17d2\u1791\u1793\u17b6\u17ac\u1794\u17be\u1780\u178a\u17c6\u178e\u17be\u179a\u1780\u17b6\u179a\u17af\u1780\u179f\u17b6\u179a\u17a2\u17bc\u178c\u17b8\u1799\u17c9\u17bc / \u179c\u17b8\u178a\u17c1\u17a2\u17bc\u1791\u17c5\u1794\u1793\u17d2\u1791\u17b6\u178f\u17cb\u1791\u17c5\u17d4", "\u179f\u17b6\u179a\u1785\u17bc\u179b\u1791\u17b6\u17c6\u1784\u17a2\u179f\u17cb (\u1796\u17b8\u1798\u1793\u17bb\u179f\u17d2\u179f\u1798\u17d2\u1793\u17b6\u1780\u17cb\u1791\u17c0\u178f) \u1793\u17b9\u1784\u1794\u1784\u17d2\u17a0\u17b6\u1789\u1793\u17c5\u1781\u17b6\u1784\u1786\u17d2\u179c\u17c1\u1784\u17d4", "\u179f\u17b6\u179a\u1780\u17d2\u179a\u17c5\u1791\u17b6\u17c6\u1784\u17a2\u179f\u17cb (\u1796\u17b8\u17a2\u17d2\u1793\u1780) \u1793\u17b9\u1784\u179b\u17c1\u1785\u17a1\u17be\u1784\u1793\u17c5\u1781\u17b6\u1784\u179f\u17d2\u178f\u17b6\u17c6\u17d4", "\u17a2\u17d2\u1793\u1780\u1793\u17b9\u1784 ways \u179f\u17b6\u179a\u1787\u17b6\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17a0\u17be\u1799\u1798\u1793\u17bb\u179f\u17d2\u179f\u1798\u17d2\u1793\u17b6\u1780\u17cb\u1791\u17c0\u178f\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1793\u17b9\u1784\u179b\u17ba\u179f\u17b6\u179a\u1787\u17b6\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u1796\u17bd\u1780\u1782\u17c1\u17d4", "\u1793\u17c5\u1785\u17bb\u1784\u1794\u1789\u17d2\u1785\u1794\u17cb\u1793\u17c3\u1780\u17b6\u179a\u179f\u1793\u17d2\u1791\u1793\u17b6 / \u179f\u17d2\u178f\u17b6\u1794\u17cb\u179c\u17b8\u178a\u17c1\u17a2\u17bc\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bc\u179c\u1785\u17bb\u1785\u179b\u17be\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1794\u1789\u17d2\u1788\u1794\u17cb\u1780\u17b6\u179a\u179f\u1793\u17d2\u1791\u1793\u17b6\" \u1798\u17bd\u1799\u17d4", "\u1780\u17b6\u179a\u179f\u1793\u17d2\u1791\u1793\u17b6\u1780\u17cf\u1794\u1789\u17d2\u1785\u1794\u17cb\u1795\u1784\u178a\u17c2\u179a\u1793\u17c5\u1796\u17c1\u179b:", "\u1780\u17b6\u179a\u1785\u17bb\u1785\u179b\u17be\u1798\u1793\u17bb\u179f\u17d2\u179f\u1798\u17d2\u1793\u17b6\u1780\u17cb\u1791\u17c0\u178f\u1793\u17c5\u1795\u17d2\u1793\u17c2\u1780\u1781\u17b6\u1784\u1786\u17d2\u179c\u17c1\u1784\u1793\u17c3\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u179a\u17bb\u1780\u179a\u1780\u1780\u17d2\u1793\u17bb\u1784\u1794\u1789\u17d2\u1787\u17b8\u17a2\u1793\u17d2\u178f\u179a\u1780\u17b6\u179a\u17b8\u17d4", "\u1785\u17bb\u1785\u179b\u17be\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1790\u17d2\u1798\u17b8\" \u1793\u17c5\u1780\u17c6\u1796\u17bc\u179b\u1793\u17c3\u1794\u1789\u17d2\u1787\u17b8\u17a2\u1793\u17d2\u178f\u179a\u1780\u1798\u17d2\u1798\u17d4", "\u1785\u17bb\u1785\u179b\u17be\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1787\u17c6\u1793\u17bd\u1799\" \u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u1798\u17ba\u1793\u17bb\u1799\u1781\u17b6\u1784\u179b\u17be\u17d4", "\u1785\u17bb\u1785\u179b\u17be\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1785\u17d2\u1794\u17b6\u179f\u17cb\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\" \u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u1798\u17ba\u1793\u17bb\u1799\u1781\u17b6\u1784\u179b\u17be\u17d4", "\u1780\u17b6\u179a\u1785\u17bb\u1785\u179b\u17be \"\u179b\u17bb\u1794\u17a2\u1793\u17d2\u178f\u179a\u1780\u17b6\u179a\u17b8\" \"\u1793\u17c5\u179b\u17be\u1780\u17c6\u1796\u17bc\u179b\u1798\u17c9\u17ba\u1793\u17bb\u1799\u17d4", "\u178a\u17c4\u1799\u1785\u17bb\u1785\u179b\u17be\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1791\u1798\u17d2\u179a\u1784\u17cb InterlocoCutor\" \u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u1798\u17ba\u1793\u17bb\u1799\u1781\u17b6\u1784\u179b\u17be\u17d4", "\u178a\u17c4\u1799\u1785\u17bb\u1785\u179b\u17be\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1785\u17c1\u1789\" \u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u1798\u17ba\u1793\u17bb\u1799\u1781\u17b6\u1784\u179b\u17be\u17d4", "\u1780\u17b6\u179a\u1794\u1784\u17d2\u17a0\u17b6\u1789\u179f\u17b6\u179a\u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u1787\u1787\u17c2\u1780\u178a\u17c2\u179b\u1794\u17b6\u1793\u1792\u17d2\u179c\u17be\u178a\u17c4\u1799\u1787\u17d2\u179a\u17be\u179f\u179a\u17be\u179f\u1787\u1798\u17d2\u179a\u17be\u179f\u1794\u1784\u17d2\u17a0\u17b6\u1789\u179f\u17b6\u179a\u1793\u17c5\u1795\u17d2\u1793\u17c2\u1780\u1781\u17b6\u1784\u1786\u17d2\u179c\u17c1\u1784\u1781\u17b6\u1784\u179b\u17be\u1793\u17c3\u1798\u17c9\u17ba\u1793\u17bb\u1799 (\u1796\u17d2\u179a\u17bd\u1789\u1796\u178e\u17cc\u1794\u17c3\u178f\u1784) \u17d4", "\u1793\u17c5\u1796\u17c1\u179b\u1787\u17d2\u179a\u17be\u179f\u179a\u17be\u179f \"\u1797\u17b6\u179f\u17b6\u1791\u17b6\u17c6\u1784\u17a2\u179f\u17cb\" - \u179f\u17b6\u179a\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17a2\u1793\u17d2\u178f\u179a\u1794\u17bb\u1782\u17d2\u1782\u179b\u17a0\u17be\u1799\u179f\u17b6\u179a\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1794\u1784\u17d2\u17a0\u17b6\u1789\u1787\u17b6\u1797\u17b6\u179f\u17b6\u1791\u17b6\u17c6\u1784\u17a2\u179f\u17cb\u17d4", "\u1793\u17c5\u1796\u17c1\u179b\u1787\u17d2\u179a\u17be\u179f\u179a\u17be\u179f \"\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u1781\u17d2\u1789\u17bb\u17c6\" - \u200b\u200b\u179f\u17b6\u179a\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17a2\u1793\u17d2\u178f\u179a\u17a2\u17d2\u1793\u1780\u1793\u17b7\u1784\u179f\u17b6\u179a\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u1794\u17b6\u1793\u1794\u1784\u17d2\u17a0\u17b6\u1789\u178f\u17c2\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1794\u17c9\u17bb\u178e\u17d2\u178e\u17c4\u17c7\u17d4", "\u1793\u17c5\u1796\u17c1\u179b\u1787\u17d2\u179a\u17be\u179f\u179a\u17be\u179f \"\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bd\u178f\u1796\u17b7\u1793\u17b7\u178f\u17d2\u1799\" - \u179f\u17b6\u179a\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17a2\u1793\u17d2\u178f\u179a\u17a2\u17d2\u1793\u1780\u1793\u17b7\u1784\u179f\u17b6\u179a\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u1794\u17b6\u1793\u1794\u1784\u17d2\u17a0\u17b6\u1789\u178f\u17c2\u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u1797\u17b6\u179f\u17b6\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u178f\u17d2\u179a\u17bd\u178f\u1796\u17b7\u1793\u17b7\u178f\u17d2\u1799\u1794\u17c9\u17bb\u178e\u17d2\u178e\u17c4\u17c7\u17d4", "\u179a\u1794\u17c0\u1794\u1794\u1784\u17d2\u17a0\u17b6\u1789\u179f\u17b6\u179a\u179b\u17c6\u1793\u17b6\u17c6\u178a\u17be\u1798\u1782\u17ba \"\u1797\u17b6\u179f\u17b6\u1791\u17b6\u17c6\u1784\u17a2\u179f\u17cb\" \u17d4", "\u1793\u17c5\u1796\u17c1\u179b\u1785\u17bb\u1785\u179b\u17be\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1787\u1798\u17d2\u179a\u17c7\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\", \u1780\u17b6\u179a\u1787\u1787\u17c2\u1780\u1791\u17b6\u17c6\u1784\u17a2\u179f\u17cb\u178a\u17c2\u179b\u1798\u17b6\u1793\u17a2\u1793\u17d2\u178f\u179a\u1780\u17b6\u179a\u17b8\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u179b\u17bb\u1794\u1794\u17c9\u17bb\u1793\u17d2\u178f\u17c2\u17a2\u17d2\u1793\u1780\u17a2\u1793\u17d2\u178f\u179a\u179a\u178a\u17d2\u178b\u17b6\u1797\u17b7\u1794\u17b6\u179b\u1793\u17c5\u178f\u17c2\u1798\u17b6\u1793\u17d4 \u179f\u17bc\u1798\u1798\u17be\u179b\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 10 \u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 10 \u17d4 \u1788\u17bc\u179f\u1786\u17b6\u1799\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u17d4", "\u1794\u17d2\u179a\u179f\u17b7\u1793\u1794\u17be\u1780\u17b6\u179a\u1787\u1787\u17c2\u1780\u1787\u17b6\u1798\u17bd\u1799\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u1780\u17c6\u1796\u17bb\u1784\u178a\u17c6\u178e\u17be\u179a\u1780\u17b6\u179a\u1794\u1785\u17d2\u1785\u17bb\u1794\u17d2\u1794\u1793\u17d2\u1793\u179c\u17b6\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1794\u1789\u17d2\u1788\u1794\u17cb\u17d4", "\u1785\u17bb\u1785\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u179b\u17bb\u1794\u17a2\u1793\u17d2\u178f\u179a\u1780\u179a\u17bb\u1791\u178f\u1793\u17d2\u178f\u17d2\u179a\u17b8\" \u179b\u17bb\u1794\u1780\u17b6\u179a\u1787\u1787\u17c2\u1780\u1791\u17b6\u17c6\u1784\u17a2\u179f\u17cb\u1787\u17b6\u1798\u17bd\u1799 Interlocutor \u1793\u17b7\u1784 Interloctor \u1781\u17d2\u179b\u17bd\u1793\u17af\u1784\u17d4 \u179f\u17bc\u1798\u1798\u17be\u179b\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 11 \u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 11 \u1780\u17b6\u179a\u179b\u17bb\u1794\u17a2\u1784\u17d2\u1782\u17a2\u1793\u17d2\u178f\u179a\u1780\u1798\u17d2\u1798\u1793\u17c1\u17c7\u17d4", "\u1794\u17d2\u179a\u179f\u17b7\u1793\u1794\u17be\u1780\u17b6\u179a\u1787\u1787\u17c2\u1780\u1787\u17b6\u1798\u17bd\u1799\u17a2\u17d2\u1793\u1780\u179f\u1798\u17d2\u179a\u1794\u179f\u1798\u17d2\u179a\u17bd\u179b\u1780\u17c6\u1796\u17bb\u1784\u178a\u17c6\u178e\u17be\u179a\u1780\u17b6\u179a\u1794\u1785\u17d2\u1785\u17bb\u1794\u17d2\u1794\u1793\u17d2\u1793\u179c\u17b6\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u1794\u1789\u17d2\u1788\u1794\u17cb\u17d4", "\u1785\u17bb\u1785\u1794\u17ca\u17bc\u178f\u17bb\u1784 \"\u1791\u1798\u17d2\u179a\u1784\u17cb InternlocoCutor\" \u1794\u1784\u17d2\u17a0\u17b6\u1789\u179f\u17c6\u178e\u17bb\u17c6\u1794\u17c2\u1794\u1794\u1791\u178a\u17c2\u179b\u1794\u17b6\u1793\u1794\u17c6\u1796\u17c1\u1789\u178a\u17c4\u1799\u1791\u17b7\u1793\u17d2\u1793\u1793\u17d0\u1799\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u17a2\u1793\u17d2\u178f\u179a\u1780\u1798\u17d2\u1798\u17d4 \u179f\u17bc\u1798\u1798\u17be\u179b\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 12 \u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 12 \u1780\u17b6\u179a\u1798\u17be\u179b\u1794\u17d2\u179a\u179c\u178f\u17d2\u178f\u17b7\u179a\u17bc\u1794\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1791\u17c6\u1793\u17b6\u1780\u17cb\u1791\u17c6\u1793\u1784\u17d4", "\u1792\u17b6\u178f\u17bb\u1793\u17c1\u17c7\u1782\u17ba\u179f\u17d2\u179a\u178a\u17c0\u1784\u1793\u17b9\u1784\u1792\u17b6\u178f\u17bb", "\u17a7\u1794\u1780\u179a\u178e\u17cd\u1794\u17c6\u1794\u17c2\u1780\u1794\u1789\u17d2\u1788\u179a\u17a2\u1793\u17bb\u1789\u17d2\u1789\u17b6\u178f\u17b1\u17d2\u1799\u17a2\u17d2\u1793\u1780\u1795\u17d2\u179b\u17b6\u179f\u17cb\u1794\u17d2\u178f\u17bc\u179a\u1791\u1791\u17b9\u1784\u1793\u17c3\u178f\u17c6\u1794\u1793\u17cb\u1781\u17b6\u1784\u1786\u17d2\u179c\u17c1\u1784\u1793\u17b7\u1784\u1781\u17b6\u1784\u179f\u17d2\u178f\u17b6\u17c6\u1793\u17c3\u1780\u1793\u17d2\u179b\u17c2\u1784\u1792\u17d2\u179c\u17be\u1780\u17b6\u179a\u17d4 \u179f\u17bc\u1798\u1798\u17be\u179b\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 13 \u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 13 \u17d4 \u17a7\u1794\u1780\u179a\u178e\u17cd\u1794\u17c6\u1794\u17c2\u1780\u1794\u1789\u17d2\u1788\u179a\u1793\u17c3\u1795\u17d2\u1793\u17c2\u1780\u1781\u17b6\u1784\u1786\u17d2\u179c\u17c1\u1784\u1793\u17b7\u1784\u1781\u17b6\u1784\u179f\u17d2\u178f\u17b6\u17c6\u17d4", "\u1793\u17c5\u1796\u17c1\u179b\u17a2\u17d2\u1793\u1780\u1795\u17d2\u179b\u17b6\u179f\u17cb\u1791\u17b8\u17a7\u1794\u1780\u179a\u178e\u17cd\u1794\u17c6\u1794\u17c2\u1780\u1794\u1789\u17d2\u1788\u179a\u1791\u17b8\u178f\u17b6\u17c6\u1784\u179a\u1794\u179f\u17cb\u179c\u17b6\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u179a\u1780\u17d2\u179f\u17b6\u1791\u17bb\u1780\u17d4 \u1793\u17c5\u1796\u17c1\u179b\u17a2\u17d2\u1793\u1780\u1785\u17b6\u1794\u17cb\u1795\u17d2\u178f\u17be\u1798\u1780\u1798\u17d2\u1798\u179c\u17b7\u1792\u17b8\u17a1\u17be\u1784\u179c\u17b7\u1789\u1787\u17c6\u17a0\u179a\u1785\u17bb\u1784\u1780\u17d2\u179a\u17c4\u1799\u178a\u17c2\u179b\u17a2\u17d2\u1793\u1780\u1794\u17b6\u1793\u1780\u17c6\u178e\u178f\u17cb\u1793\u17b9\u1784\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u179f\u17d2\u178f\u17b6\u179a\u17a1\u17be\u1784\u179c\u17b7\u1789\u17d4", "\u1795\u17d2\u179b\u17b6\u179f\u17cb\u1791\u17b8\u1791\u179f\u17d2\u179f\u1793\u17cd\u1791\u17d2\u179a\u1793\u17b7\u1785\u1780\u178e\u17d2\u178f\u17bb\u179a\u179b\u17be\u179a\u17bc\u1794\u1797\u17b6\u1796\u17a2\u17bc\u1794\u17c9\u17b6\u179b\u17d0\u179a\u1793\u17c5\u1787\u17d2\u179a\u17bb\u1784\u1781\u17b6\u1784\u179f\u17d2\u178f\u17b6\u17c6\u1781\u17b6\u1784\u1780\u17d2\u179a\u17c4\u1798\u1793\u17c3\u17a2\u17c1\u1780\u17d2\u179a\u1784\u17cb\u17a0\u17be\u1799\u1785\u17bb\u1785\u1781\u17b6\u1784\u179f\u17d2\u178f\u17b6\u17c6\u179b\u17be\u1780\u17b6\u179a\u1787\u17d2\u179a\u17be\u179f\u179a\u17be\u179f\u1792\u17b6\u178f\u17bb\u1798\u17c9\u17ba\u1793\u17bb\u1799 \"\u1794\u17be\u1780\u179f\u17c6\u179b\u17c1\u1784\" \u178a\u17bc\u1785\u178a\u17c2\u179b\u1794\u17b6\u1793\u1794\u1784\u17d2\u17a0\u17b6\u1789\u1780\u17d2\u1793\u17bb\u1784\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 14 \u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 14 \u17d4 \u1794\u17be\u1780\u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179f\u17c6\u17a1\u17c1\u1784\u17d4", "\u17a2\u17c1\u1780\u17d2\u179a\u1784\u17cb\u178a\u17c2\u179b\u1798\u17b6\u1793\u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179f\u17c6\u17a1\u17c1\u1784\u1794\u1785\u17d2\u1785\u17bb\u1794\u17d2\u1794\u1793\u17d2\u1793\u1793\u17b9\u1784\u179b\u17c1\u1785\u17a1\u17be\u1784\u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 15 \u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179f\u17c6\u17a1\u17c1\u1784\u1794\u1785\u17d2\u1785\u17bb\u1794\u17d2\u1794\u1793\u17d2\u1793\u17d4", "\u179f\u17d2\u178f\u17b6\u179a\u178f\u1798\u17d2\u179b\u17c3\u178a\u17c6\u1794\u17bc\u1784\u178a\u17c2\u179b\u1798\u17bb\u1793\u1796\u17c1\u179b\u1785\u17b6\u1794\u17cb\u1795\u17d2\u178f\u17be\u1798\u1797\u17b6\u179a\u1780\u17b7\u1785\u17d2\u1785\u17d4 \u1780\u17d2\u1793\u17bb\u1784\u1780\u179a\u178e\u17b8\u179a\u1794\u179f\u17cb\u17a2\u17d2\u1793\u1780\u1788\u17d2\u1798\u17c4\u17c7\u1793\u17b9\u1784\u1781\u17bb\u179f\u1782\u17d2\u1793\u17b6\u17d4", "\u179a\u17bc\u1794\u1797\u17b6\u1796\u1791\u17b8 16 \u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u179f\u17c6\u179b\u17c1\u1784\u178a\u17c6\u1794\u17bc\u1784\u17d4", "\u1780\u17b6\u179a\u1780\u17c6\u178e\u178f\u17cb\u1794\u17d2\u179a\u1796\u17d0\u1793\u17d2\u1792\u178f\u17d2\u179a\u17bc\u179c\u1794\u17b6\u1793\u179f\u17d2\u178f\u17b6\u179a\u17a1\u17be\u1784\u179c\u17b7\u1789\u17a2\u17d2\u1793\u1780\u17a2\u17b6\u1785\u1792\u17d2\u179c\u17be\u1780\u17b6\u179a\u1793\u17c5\u1780\u17d2\u1793\u17bb\u1784\u179c\u17b8\u1793\u178a\u17bc\u17d4"]