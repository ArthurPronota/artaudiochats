02d\u102f\u1021\u102f\u1015\u103a\u1005\u102f 2 \u1005\u102f\u1001\u103d\u1032\u1011\u102c\u1038\u101e\u100a\u103a\u104b", "Interlocutor \u1019\u103e\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1019\u103b\u102c\u1038\u104b", "\u101e\u1004\u1037\u103a\u101b\u1032\u1037\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1019\u103b\u102c\u1038\u104b", "\u1021\u1015\u103c\u1014\u103a\u1021\u101c\u103e\u1014\u103a\u1006\u103d\u1031\u1038\u1014\u103d\u1031\u1038\u1019\u103e\u102f\u1019\u103e\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1019\u103b\u102c\u1038\u101e\u100a\u103a\u1018\u101a\u103a\u1018\u1000\u103a\u101e\u102d\u102f\u1037\u1015\u103c\u1031\u102c\u1004\u103a\u1038\u101b\u103d\u103e\u1031\u1037\u1014\u1031\u1000\u103c\u101e\u100a\u103a\u104b \u101e\u1004\u1037\u103a\u101b\u1032\u1037\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1000\u102d\u102f\u100a\u102c\u1018\u1000\u103a\u101e\u102d\u102f\u1037\u1015\u103c\u1031\u102c\u1004\u103a\u1038\u101b\u103d\u103e\u1031\u1037\u1014\u1031\u1000\u103c\u101e\u100a\u103a\u104b", "\u1010\u1005\u103a\u1001\u102f\u1001\u103b\u1004\u103a\u1038\u1005\u102e\u1000\u102d\u102f\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1010\u1005\u103a\u1001\u102f\u1005\u102e\u1010\u103d\u1004\u103a 2 \u1015\u102d\u102f\u1004\u103a\u1038\u1015\u102b\u101d\u1004\u103a\u1015\u102b\u101e\u100a\u103a\u104b", "Interlocutor \u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\u104f\u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\u1016\u103c\u1004\u1037\u103a\u1005\u102c\u1005\u102c\u101e\u102c\u1038\u101e\u100a\u103a\u1024\u101e\u1010\u1004\u103a\u1038\u1005\u1000\u102c\u1038\u104f\u1021\u101b\u1031\u102c\u1004\u103a\u101e\u100a\u103a\u1021\u1014\u1000\u103a\u101b\u1031\u102c\u1004\u103a\u1016\u103c\u1005\u103a\u101e\u100a\u103a\u104b", "\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1005\u102c\u101e\u102c\u1038\u1000\u102d\u102f\u101e\u1004\u103a\u104f\u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\u104f\u1021\u101b\u1031\u102c\u1004\u103a, \u1024\u101e\u1010\u1004\u103a\u1038\u1005\u1000\u102c\u1038\u104f\u1021\u101b\u1031\u102c\u1004\u103a\u101e\u100a\u103a\u1021\u1005\u102d\u1019\u103a\u1038\u101b\u1031\u102c\u1004\u103a\u1016\u103c\u1005\u103a\u101e\u100a\u103a\u104b", "\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u101b\u1000\u103a\u1005\u103d\u1032\u101e\u100a\u103a\u101e\u1004\u103a\u104f\u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\u1014\u103e\u1004\u1037\u103a\u1000\u102d\u102f\u1000\u103a\u100a\u102e\u101e\u100a\u103a\u104b", "\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1021\u101e\u1005\u103a\u1019\u103b\u102c\u1038 (\u101b\u1000\u103a\u1005\u103d\u1032\u1021\u102c\u1038\u1016\u103c\u1004\u1037\u103a) \u101e\u100a\u103a\u1021\u102d\u102f\u1019\u1004\u103a\u1038\u1000\u103c\u102e\u1038\u1019\u103b\u102c\u1038\u1011\u1000\u103a\u1014\u102d\u1019\u1037\u103a\u101e\u100a\u103a\u104b", "Interlocutor \u104f chats \u104f\u1021\u1031\u102c\u1000\u103a\u1006\u102f\u1036\u1038\u1010\u103d\u1004\u103a \"Start Condition\" \u1001\u101c\u102f\u1010\u103a\u1016\u103c\u1005\u103a\u101e\u100a\u103a\u104b \u104e\u1004\u103a\u1038\u1000\u102d\u102f\u101e\u1004\u103a\u1014\u103e\u102d\u1015\u103a\u101c\u102d\u102f\u1000\u103a\u101e\u1031\u102c\u1021\u1001\u102b, \u1015\u101b\u102d\u102f\u1002\u101b\u1019\u103a\u101e\u100a\u103a signal / noouse level \u1019\u103b\u102c\u1038\u1000\u102d\u102f\u1006\u102f\u1036\u1038\u1016\u103c\u1010\u103a\u101b\u1014\u103a Microphone \u1014\u103e\u1004\u1037\u103a\u1021\u101e\u1036\u1000\u102d\u101b\u102d\u101a\u102c\u1000\u102d\u102f\u1001\u103b\u102d\u1014\u103a\u100a\u103e\u102d\u1001\u103c\u1004\u103a\u1038\u1014\u103e\u1004\u1037\u103a\u101e\u1000\u103a\u1006\u102d\u102f\u1004\u103a\u101b\u102c\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1000\u102d\u102f\u1015\u103c\u101e\u101e\u100a\u103a\u104b", "\u1021\u101e\u1036\u1000\u102d\u101b\u102d\u101a\u102c\u1019\u103b\u102c\u1038\u1000\u102d\u102f\u1001\u103b\u102d\u1014\u103a\u100a\u103e\u102d\u1015\u103c\u102e\u1038\u1014\u1031\u102c\u1000\u103a\u1001\u101c\u102f\u1010\u103a\u1019\u103b\u102c\u1038\u104f\u1021\u1019\u100a\u103a\u1019\u103b\u102c\u1038\u1019\u103e\u102c \"Start Condition\" -> \"Stop \u1005\u1000\u102c\u1038\u1015\u103c\u1031\u102c\u1006\u102d\u102f\u1019\u103e\u102f\"", "\u1024\u1021\u1001\u103b\u1000\u103a \u1019\u103e\u1014\u1031. \u101e\u1004\u103a\u101e\u100a\u103a\u1005\u1000\u102c\u1038\u101c\u1000\u103a\u1006\u102f\u1036\u1015\u103c\u1031\u102c\u1006\u102d\u102f\u1001\u103c\u1004\u103a\u1038\u101e\u102d\u102f\u1037\u1019\u101f\u102f\u1010\u103a\u1021\u101e\u1036 / \u1017\u103d\u102e\u1012\u102e\u101a\u102d\u102f\u1016\u102d\u102f\u1004\u103a\u1000\u102d\u102f\u101c\u102d\u102f\u1004\u103a\u1038\u101e\u102d\u102f\u1037\u1016\u103d\u1004\u1037\u103a\u1014\u102d\u102f\u1004\u103a\u101e\u100a\u103a\u104b", "(\u1021\u1001\u103c\u102c\u1038\u101e\u1030\u1011\u1036\u1019\u103e) \u1021\u101d\u1004\u103a\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1019\u103b\u102c\u1038\u1021\u102c\u1038\u101c\u102f\u1036\u1038\u1018\u101a\u103a\u1018\u1000\u103a\u1010\u103d\u1004\u103a\u1015\u1031\u102b\u103a\u101c\u102c\u101c\u102d\u1019\u1037\u103a\u1019\u100a\u103a\u104b", "\u1021\u102c\u1038\u101c\u102f\u1036\u1038 outing \u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1019\u103b\u102c\u1038 (\u101e\u1004\u103a\u1010\u102d\u102f\u1037\u1011\u1036\u1019\u103e) \u100a\u102c\u1018\u1000\u103a\u1015\u1031\u102b\u103a\u101c\u102c\u101c\u102d\u1019\u1037\u103a\u1019\u100a\u103a\u104b", "\u101e\u1004\u103a\u104f\u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\u1016\u103c\u1004\u1037\u103a\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1019\u103b\u102c\u1038\u1000\u102d\u102f\u101e\u1004\u103a\u1000\u103c\u102c\u1038\u1015\u1031\u1038\u101c\u102d\u1019\u1037\u103a\u1019\u100a\u103a\u104b \u101e\u1004\u103a\u104f\u1021\u1001\u103c\u102c\u1038\u101e\u1030\u101e\u100a\u103a\u101e\u1030\u1010\u102d\u102f\u1037\u104f\u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\u1016\u103c\u1004\u1037\u103a\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1019\u103b\u102c\u1038\u1000\u103c\u102c\u1038\u101c\u102d\u1019\u1037\u103a\u1019\u100a\u103a\u104b", "\u1005\u1000\u102c\u1038\u101d\u102d\u102f\u1004\u103a\u1038\u1021\u1006\u102f\u1036\u1038\u1010\u103d\u1004\u103a / \u1017\u103d\u102e\u1012\u102e\u101a\u102d\u102f\u1000\u102d\u102f\u1014\u102c\u1038\u1011\u1031\u102c\u1004\u103a\u1001\u103c\u1004\u103a\u1038\u101e\u100a\u103a \"Stop \u1005\u1000\u102c\u1038\u1015\u103c\u1031\u102c\u1006\u102d\u102f\u1019\u103e\u102f\" \u1001\u101c\u102f\u1010\u103a\u1019\u103b\u102c\u1038\u1011\u1032\u1019\u103e\u1010\u1005\u103a\u1001\u102f\u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u101b\u1014\u103a\u101c\u102d\u102f\u1021\u1015\u103a\u101e\u100a\u103a\u104b", "\u1005\u1000\u102c\u1038\u101c\u1000\u103a\u1006\u102f\u1036\u1015\u103c\u1031\u102c\u1006\u102d\u102f\u1019\u103e\u102f\u101c\u100a\u103a\u1038\u1021\u1006\u102f\u1036\u1038\u101e\u1010\u103a\u101e\u100a\u103a\u104b", "Interlocutors \u104f\u1005\u102c\u101b\u1004\u103a\u1038\u1010\u103d\u1004\u103a browser \u104f\u1018\u101a\u103a\u1018\u1000\u103a\u1001\u103c\u1019\u103a\u1038\u101b\u103e\u102d\u1021\u1001\u103c\u102c\u1038\u101e\u1030\u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u1015\u102b\u104b", "\"New\" \u1001\u101c\u102f\u1010\u103a\u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u1001\u103c\u1004\u103a\u1038 interlocutors \u1005\u102c\u101b\u1004\u103a\u1038\u104f\u1011\u102d\u1015\u103a\u101b\u103e\u102d \"New\" \u1001\u101c\u102f\u1010\u103a\u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u1015\u102b\u104b", "\u1011\u102d\u1015\u103a\u1019\u102e\u1014\u1030\u1038\u101b\u103e\u102d \"\u1021\u1000\u1030\u1021\u100a\u102e\" \u1001\u101c\u102f\u1010\u103a\u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u1001\u103c\u1004\u103a\u1038\u104b", "\u1011\u102d\u1015\u103a\u1006\u102f\u1036\u1038\u1019\u102e\u1014\u1030\u1038\u1010\u103d\u1004\u103a \"Clear History\" \u1001\u101c\u102f\u1010\u103a\u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u1001\u103c\u1004\u103a\u1038\u104b", "\u1011\u102d\u1015\u103a\u1019\u102e\u1014\u1030\u1038\u1010\u103d\u1004\u103a \"Delete interlocutor\" \u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u1001\u103c\u1004\u103a\u1038\u104b", "\u1011\u102d\u1015\u103a\u1019\u102e\u1014\u1030\u1038\u1010\u103d\u1004\u103a \"Interlocutor \u104f\u1015\u101b\u102d\u102f\u1016\u102d\u102f\u1004\u103a\u1038\" \u1001\u101c\u102f\u1010\u103a\u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u1001\u103c\u1004\u103a\u1038\u1021\u102c\u1038\u1016\u103c\u1004\u1037\u103a\u104b", "\u1011\u102d\u1015\u103a\u1019\u102e\u1014\u1030\u1038\u1010\u103d\u1004\u103a \"Exit\" \u1001\u101c\u102f\u1010\u103a\u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u1001\u103c\u1004\u103a\u1038\u1021\u102c\u1038\u1016\u103c\u1004\u1037\u103a\u104b", "Menu \u104f\u1018\u101a\u103a\u1018\u1000\u103a\u1021\u1031\u102c\u1000\u103a\u1015\u102d\u102f\u1004\u103a\u1038 (\u1021\u1005\u102d\u1019\u103a\u1038\u101b\u1031\u102c\u1004\u103a\u1019\u103c\u103e\u102c\u1038) \u101b\u103e\u102d\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1000\u102d\u102f display option \u1000\u102d\u102f\u101b\u103d\u1031\u1038\u1001\u103b\u101a\u103a\u1001\u103c\u1004\u103a\u1038\u1021\u102c\u1038\u1016\u103c\u1004\u1037\u103a chat history scust \u101c\u102f\u1015\u103a\u1001\u103c\u1004\u103a\u1038\u1016\u103c\u1004\u1037\u103a\u101e\u1036\u1019\u100f\u102d\u1015\u103c\u102c\u1038\u1019\u103b\u102c\u1038\u1016\u103c\u1004\u1037\u103a\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1019\u103b\u102c\u1038\u1015\u103c\u101e\u1001\u103c\u1004\u103a\u1038\u104b", "\"\u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\u1019\u103b\u102c\u1038\u1021\u102c\u1038\u101c\u102f\u1036\u1038\" \u1000\u102d\u102f\u101b\u103d\u1031\u1038\u1001\u103b\u101a\u103a\u101e\u100a\u1037\u103a\u1021\u1001\u102b\u1021\u1015\u103c\u1014\u103a\u1021\u101c\u103e\u1014\u103a\u1006\u103d\u1031\u1038\u1014\u103d\u1031\u1038\u1001\u103c\u1004\u103a\u1038\u104f\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1019\u103b\u102c\u1038\u1014\u103e\u1004\u1037\u103a\u101e\u1004\u103a\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1019\u103b\u102c\u1038\u1000\u102d\u102f\u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\u1021\u102c\u1038\u101c\u102f\u1036\u1038\u1010\u103d\u1004\u103a\u1016\u1031\u102c\u103a\u1015\u103c\u1011\u102c\u1038\u101e\u100a\u103a\u104b", "\"My Language\" \u1000\u102d\u102f\u101b\u103d\u1031\u1038\u1001\u103b\u101a\u103a\u1010\u1032\u1037\u1021\u1001\u102b\u1019\u103e\u102c\u1021\u1015\u103c\u1014\u103a\u1021\u101c\u103e\u1014\u103a\u1006\u1000\u103a\u101e\u103d\u101a\u103a\u101b\u1031\u1038\u101b\u1032\u1037\u101e\u1010\u1004\u103a\u1038\u1005\u1000\u102c\u1038\u1010\u103d\u1031\u1014\u1032\u1037\u101e\u1004\u103a\u1005\u102c\u1010\u102d\u102f\u1010\u103d\u1031\u1000\u1019\u1004\u103a\u1038\u101b\u1032\u1037\u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\u1014\u1032\u1037\u101e\u102c\u1015\u103c\u101e\u1011\u102c\u1038\u1010\u101a\u103a\u104b", "\"Interlocutor \u104f\u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\" \u1000\u102d\u102f\u101b\u103d\u1031\u1038\u1001\u103b\u101a\u103a\u101e\u100a\u1037\u103a\u1021\u1001\u102b\u1021\u1015\u103c\u1014\u103a\u1021\u101c\u103e\u1014\u103a\u1006\u103d\u1031\u1038\u1014\u103d\u1031\u1038\u1001\u103c\u1004\u103a\u1038\u104f\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1019\u103b\u102c\u1038\u1014\u103e\u1004\u1037\u103a\u101e\u1004\u103a\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1019\u103b\u102c\u1038\u1000\u102d\u102f\u1021\u1015\u103c\u1014\u103a\u1021\u101c\u103e\u1014\u103a\u1006\u1000\u103a\u101e\u103d\u101a\u103a\u101b\u1031\u1038\u104f\u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\u1016\u103c\u1004\u1037\u103a\u101e\u102c\u1015\u103c\u101e\u101e\u100a\u103a\u104b", "\u1015\u102f\u1036\u1019\u103e\u1014\u103a\u1019\u1000\u103a\u1006\u1031\u1037\u1001\u103a\u103b\u1000\u102d\u102f display mode \u101e\u100a\u103a \"\u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\u1019\u103b\u102c\u1038\" \u1016\u103c\u1005\u103a\u101e\u100a\u103a\u104b", "\"Clear History\" \u1001\u101c\u102f\u1010\u103a\u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u101e\u1031\u102c\u1021\u1001\u102b interlocutor \u1014\u103e\u1004\u1037\u103a\u1005\u1000\u102c\u1038\u1015\u103c\u1031\u102c\u101e\u1031\u102c\u1021\u1001\u102b\u1021\u102c\u1038\u101c\u102f\u1036\u1038 chats \u1021\u102c\u1038\u101c\u102f\u1036\u1038\u1000\u102d\u102f\u1016\u103b\u1000\u103a\u1015\u1005\u103a\u101e\u100a\u103a\u104b \u1015\u102f\u1036 10 \u1000\u102d\u102f\u1000\u103c\u100a\u1037\u103a\u1015\u102b\u104b", "\u1015\u102f\u1036 10 \u104b Interlocutor \u104f\u101e\u1019\u102d\u102f\u1004\u103a\u1038\u1000\u102d\u102f\u101b\u103e\u1004\u103a\u1038\u101c\u1004\u103a\u1038\u1001\u103c\u1004\u103a\u1038\u104b", "Interlocutor \u1014\u103e\u1004\u1037\u103a\u1005\u1000\u102c\u1038\u1015\u103c\u1031\u102c\u1001\u103c\u1004\u103a\u1038\u101e\u100a\u103a\u101c\u1000\u103a\u101b\u103e\u102d\u1010\u102d\u102f\u1038\u1010\u1000\u103a\u1019\u103e\u102f\u101b\u103e\u102d\u101c\u103b\u103e\u1004\u103a\u104e\u1004\u103a\u1038\u1000\u102d\u102f\u101b\u1015\u103a\u1010\u1014\u1037\u103a\u101e\u103d\u102c\u1038\u1015\u102b\u1000\u104e\u1004\u103a\u1038\u1000\u102d\u102f\u101b\u1015\u103a\u1010\u1014\u1037\u103a\u1011\u102c\u1038\u101e\u100a\u103a\u104b", "\"Delete Interlocutor Interlocutor\" \u1001\u101c\u102f\u1010\u103a\u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u1001\u103c\u1004\u103a\u1038\u1001\u101c\u102f\u1010\u103a\u1000\u102d\u102f\u1016\u103c\u1014\u1037\u103a\u1016\u103c\u1030\u1038\u1001\u103c\u1004\u103a\u1038\u1014\u103e\u1004\u1037\u103a\u1021\u1015\u103c\u1014\u103a\u1021\u101c\u103e\u1014\u103a\u1006\u103d\u1031\u1038\u1014\u103d\u1031\u1038\u1001\u103c\u1004\u103a\u1038\u1000\u102d\u102f\u101a\u103a\u1010\u102d\u102f\u1004\u103a\u1014\u103e\u1004\u1037\u103a\u1021\u1010\u1030 chats \u1021\u102c\u1038\u101c\u102f\u1036\u1038\u1000\u102d\u102f\u1016\u103b\u1000\u103a\u1015\u1005\u103a\u101e\u100a\u103a\u104b \u1015\u102f\u1036 11 \u1000\u102d\u102f\u1000\u103c\u100a\u1037\u103a\u1015\u102b\u104b", "\u1015\u102f\u1036 11 \u104b Interlocutor \u1000\u102d\u102f\u1016\u103b\u1000\u103a\u1001\u103c\u1004\u103a\u1038\u104b", "Interlocutor \u1014\u103e\u1004\u1037\u103a\u1005\u1000\u102c\u1038\u1015\u103c\u1031\u102c\u1001\u103c\u1004\u103a\u1038\u101e\u100a\u103a\u101c\u1000\u103a\u101b\u103e\u102d\u1010\u102d\u102f\u1038\u1010\u1000\u103a\u1019\u103e\u102f\u101b\u103e\u102d\u101c\u103b\u103e\u1004\u103a\u104e\u1004\u103a\u1038\u1000\u102d\u102f\u101b\u1015\u103a\u1010\u1014\u1037\u103a\u101e\u103d\u102c\u1038\u1015\u102b\u1000\u104e\u1004\u103a\u1038\u1000\u102d\u102f\u101b\u1015\u103a\u1010\u1014\u1037\u103a\u1011\u102c\u1038\u101e\u100a\u103a\u104b", "\"Interlocutor \u104f\u1015\u101b\u102d\u102f\u1016\u102d\u102f\u1004\u103a\" \u1001\u101c\u102f\u1010\u103a\u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u1001\u103c\u1004\u103a\u1038 \"\u1001\u101c\u102f\u1010\u103a\u1000\u102d\u102f\u1014\u103e\u102d\u1015\u103a\u1001\u103c\u1004\u103a\u1038\u1000\u1021\u1015\u103c\u1014\u103a\u1021\u101c\u103e\u1014\u103a\u1006\u1000\u103a\u101e\u103d\u101a\u103a\u101b\u1031\u1038\u104f\u1021\u1001\u103b\u1000\u103a\u1021\u101c\u1000\u103a\u1019\u103b\u102c\u1038\u1014\u103e\u1004\u1037\u103a\u1015\u103c\u100a\u1037\u103a\u1005\u102f\u1036\u101e\u100a\u1037\u103a\u1015\u102f\u1036\u1005\u1036\u1000\u102d\u102f\u1016\u1031\u102c\u103a\u1015\u103c\u101e\u100a\u103a\u104b \u1015\u102f\u1036 12 \u1000\u102d\u102f\u1000\u103c\u100a\u1037\u103a\u1015\u102b\u104b", "\u1015\u102f\u1036 12 \u104b Interlocutor \u101b\u1032\u1037\u1015\u101b\u102d\u102f\u1016\u102d\u102f\u1004\u103a\u1038\u1000\u102d\u102f\u1000\u103c\u100a\u1037\u103a\u1001\u103c\u1004\u103a\u1038\u104b", "\u1012\u102e\u1