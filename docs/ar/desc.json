["\u0648\u0635\u0641 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \"\u0627\u0644\u062f\u0631\u062f\u0634\u0627\u062a \u0627\u0644\u0635\u0648\u062a\u064a\u0629\"", "\u0645\u062d\u062a\u0648\u064a\u0627\u062a", "1. \u0642\u0628\u0644 \u0623\u0646 \u062a\u0628\u062f\u0623", "2. \u0648\u0635\u0641 \u0645\u0648\u062c\u0632", "3. \u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0644\u063a\u0627\u062a \u0627\u0644\u0645\u062a\u0627\u062d\u0629 \u0644\u0644\u0627\u062a\u0635\u0627\u0644", "4. \u0645\u0627 \u062a\u062d\u062a\u0627\u062c\u0647 \u0644\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0644\u0644\u0639\u0645\u0644", "5. \u0627\u0644\u0639\u0645\u0644 \u0645\u0639 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c", "5.1 \u0627\u0644\u062a\u0643\u0648\u064a\u0646", "5.2 \u0645\u0644\u0641 \u062a\u0639\u0631\u064a\u0641 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0627\u0644\u062c\u062f\u064a\u062f", "5.3 \u0642\u0633\u0645 \u0627\u0644\u0645\u0633\u0627\u0639\u062f\u0629", "5.4 \u0632\u0631 \u0627\u0644\u062e\u0631\u0648\u062c", "5.5 \u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0631\u064a\u0646", "5.6 \u062a\u0627\u0631\u064a\u062e \u062f\u0631\u062f\u0634\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "5.7 \u062a\u0637\u0647\u064a\u0631 \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "5.8 \u062d\u0630\u0641 \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "5.9 \u0639\u0631\u0636 \u0645\u0644\u0641 \u062a\u0639\u0631\u064a\u0641 \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "5.10 \u0641\u0627\u0635\u0644 \u0639\u0645\u0648\u062f\u064a \u0628\u064a\u0646 \u0627\u0644\u0623\u062c\u0632\u0627\u0621 \u0627\u0644\u064a\u0633\u0631\u0649 \u0648\u0627\u0644\u064a\u0645\u0646\u0649", "6. \u0628\u0639\u062f \u0627\u0644\u0627\u0646\u062a\u0647\u0627\u0621 \u0645\u0646 \u0627\u0644\u0639\u0645\u0644", "\u0627\u062d\u0645\u0631 \u0645\u0624\u0634\u0631 \u0627\u0644\u0645\u0627\u0648\u0633 \u0641\u0648\u0642 \u0635\u0648\u0631\u0629 \u0627\u0644\u0633\u0645\u0627\u0639\u0629 \u0641\u064a \u0627\u0644\u0632\u0627\u0648\u064a\u0629 \u0627\u0644\u064a\u0645\u0646\u0649 \u0627\u0644\u0633\u0641\u0644\u0649 \u0645\u0646 \u0627\u0644\u0634\u0627\u0634\u0629 \u0648\u0627\u0644\u0646\u0642\u0631 \u0628\u0632\u0631 \u0627\u0644\u0645\u0627\u0648\u0633 \u0627\u0644\u0623\u064a\u0645\u0646 \u060c \u0639\u0646\u0635\u0631 \u0627\u0644\u0642\u0627\u0626\u0645\u0629 \"\u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0635\u0648\u062a \u0627\u0644\u0645\u0641\u062a\u0648\u062d\u0629\" \u060c \u0643\u0645\u0627 \u0634\u0648\u0646 \u0641\u064a \u0627\u0644\u0634\u0643\u0644 1", "\u0627\u0644\u0634\u0643\u0644 1. \u0641\u062a\u062d \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0635\u0648\u062a", "\u0633\u062a\u0638\u0647\u0631 \u0634\u0627\u0634\u0629 \u0645\u0639 \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0635\u0648\u062a \u0627\u0644\u062d\u0627\u0644\u064a\u0629. \u062a\u0630\u0643\u0631 \u0645\u0627 \u0627\u0644\u0630\u064a \u062a\u0645 \u062a\u0639\u064a\u064a\u0646\u0647 \u0644\u0623\u062c\u0647\u0632\u0629 \u0627\u0644\u0635\u0648\u062a \u0648\u0627\u0644\u0645\u062e\u0631\u062c\u0627\u062a. \u0633\u062a\u062d\u062a\u0627\u062c \u0625\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0628\u0639\u062f \u0627\u0644\u0627\u0646\u062a\u0647\u0627\u0621 \u0645\u0646 \u0627\u0644\u0639\u0645\u0644. \u0641\u064a \u0627\u0644\u0634\u0643\u0644 2 \u060c \u062a\u064f\u0638\u0647\u0631 \u0627\u0644\u0623\u0633\u0647\u0645 \u0627\u0644\u062d\u0645\u0631\u0627\u0621 \u0645\u0627 \u062a\u062d\u062a\u0627\u062c \u0625\u0644\u0649 \u062a\u0630\u0643\u0631\u0647. \u0641\u064a \u062d\u0627\u0644\u062a\u0643 \u060c \u0633\u062a\u0643\u0648\u0646 \u0627\u0644\u0623\u0633\u0645\u0627\u0621 \u0645\u062e\u062a\u0644\u0641\u0629", "\u0627\u0644\u0634\u0643\u0644 2. \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0635\u0648\u062a \u0627\u0644\u0623\u0648\u0644\u064a\u0629", "\u0627\u0636\u0628\u0637 \u062c\u0647\u0627\u0632 \u0625\u062e\u0631\u0627\u062c \u0627\u0644\u0635\u0648\u062a \u0639\u0644\u0649", "\u0627\u0636\u0628\u0637 \u062c\u0647\u0627\u0632 \u0625\u062f\u062e\u0627\u0644 \u0627\u0644\u0635\u0648\u062a \u0639\u0644\u0649", "\u0641\u064a \u0627\u0644\u0634\u0643\u0644 3 \u060c \u062a\u064f\u0638\u0647\u0631 \u0627\u0644\u0623\u0633\u0647\u0645 \u0627\u0644\u062d\u0645\u0631\u0627\u0621 \u0645\u0627 \u0627\u0644\u0630\u064a \u0643\u0646\u062a \u0628\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0636\u0628\u0637\u0647", "\u0627\u0644\u0634\u0643\u0644 3. \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0635\u0648\u062a \u0627\u0644\u0639\u0645\u0644", "\u0627\u0643\u062a\u0645\u0627\u0644 \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0646\u0638\u0627\u0645 \u060c \u064a\u0645\u0643\u0646\u0643 \u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c", "\u0623\u0646\u062a \u062a\u062a\u062d\u062f\u062b \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u062a\u064a \u062a\u0639\u0631\u0641\u0647\u0627 \u060c \u062a\u064f\u0633\u0645\u0639 \u0641\u064a \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u062a\u064a \u064a\u0641\u0647\u0645\u0647\u0627 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0627\u0644\u062e\u0627\u0635 \u0628\u0643. \u064a\u062a\u0645 \u0627\u0644\u0627\u062d\u062a\u0641\u0627\u0638 \u0628\u0633\u062c\u0644 \u0645\u0646 concversets \u0627\u0644\u062e\u0627\u0635 \u0628\u0643 \u060c \u0648\u0647\u0648 \u0645\u0627 \u0643\u0646\u062a \u0646\u0627\u062c. \u064a\u062a\u0645 \u062a\u0646\u0641\u064a\u0630 \u062c\u0645\u064a\u0639 \u0627\u0644\u0639\u0645\u0644\u064a\u0627\u062a \u0645\u062d\u0644\u064a\u064b\u0627 \u0639\u0644\u0649 \u062c\u0647\u0627\u0632 \u0627\u0644\u0643\u0645\u0628\u064a\u0648\u062a\u0631 \u0627\u0644\u062e\u0627\u0635 \u0628\u0643 \u0627\u0644\u0630\u064a \u064a\u0639\u0645\u0644 \u0628\u0646\u0638\u0627\u0645 \u0627\u0644\u062a\u0634\u063a\u064a\u0644 Windows 10 \u0623\u0648 Windows 11. \u0645\u0639\u0627\u0644\u062c \u0627\u0644\u0631\u0633\u0648\u0645\u0627\u062a \u0623\u0645\u0631 \u0645\u0631\u063a\u0648\u0628 \u0641\u064a\u0647 \u060c \u0648\u0644\u0643\u0646\u0647 \u0644\u0627 \u064a\u0644\u0632\u0645 \u060c \u062d\u062a\u0649 \u064a\u0639\u0645\u0644 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c. \u062a\u0645 \u062a\u062d\u0633\u064a\u0646 \u062c\u0648\u062f\u0629 \u0627\u0644\u062a\u0631\u062c\u0645\u0629 \u0645\u0639 \u0645\u0639\u0627\u0644\u062c \u0627\u0644\u0631\u0633\u0648\u0645\u0627\u062a", "\u0625\u0630\u0627 \u0641\u0647\u0645\u062a \u0625\u062d\u062f\u0649 \u0627\u0644\u0644\u063a\u0627\u062a \u0645\u0646 \u0647\u0630\u0647 \u0627\u0644\u0642\u0627\u0626\u0645\u0629 \u060c \u0641\u0633\u062a\u062a\u0645\u0643\u0646 \u0645\u0646 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0645\u0639 \u0634\u0631\u0643\u0629 SPEALERO \u0627\u0644\u0623\u0635\u0644\u064a\u0629 \u0644\u0623\u064a \u0644\u063a\u0629 \u0623\u0648\u0631\u064a \u0645\u0646 \u0647\u0630\u0647 \u0627\u0644\u0642\u0627\u0626\u0645\u0629. \u064a\u0645\u0643\u0646 \u0623\u0646 \u064a\u0643\u0648\u0646 \u0627\u0644\u0627\u062a\u0635\u0627\u0644 \u0641\u064a Telegram \u0623\u0648 WhatsApp \u0623\u0648 Google Meet \u0623\u0648 Vkmessenger \u0623\u0648 Yandexmessenger \u0623\u0648 \u0623\u064a \u0631\u0633\u0648\u0644 \u0622\u062e\u0631. \u064a\u0645\u0643\u0646\u0643 \u0627\u0644\u0627\u0633\u062a\u0645\u0627\u0639 \u0625\u0644\u0649 \u0627\u0644\u0623\u062e\u0628\u0627\u0631 \u0648\u0627\u0644\u062f\u0648\u0631\u0629 \u0627\u0644\u062a\u062f\u0631\u064a\u0628\u064a\u0629 \u0648\u0623\u064a \u0628\u0648\u062f\u0643\u0627\u0633\u062a \u0622\u062e\u0631 \u0641\u064a \u0623\u064a \u0645\u0646 \u0627\u0644\u0644\u063a\u0627\u062a Mentio \u0648\u0641\u0647\u0645\u0647\u0627. \u0627\u0644\u0622\u0646 \u0645\u0646 \u0627\u0644\u0645\u0645\u0643\u0646 \u0627\u062c\u062a\u064a\u0627\u0632 \u0627\u0644\u0645\u0642\u0627\u0628\u0644\u0627\u062a \u0641\u064a \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0623\u062c\u0646\u0628\u064a\u0629 \u0648\u0623\u0643\u062b\u0631 \u0645\u0646 \u0630\u0644\u0643 \u0628\u0643\u062b\u064a\u0631. \u064a\u0645\u0643\u0646\u0643 \u0623\u064a\u0636\u064b\u0627 \u062a\u0634\u063a\u064a\u0644 \u0645\u0644\u0641 \u0627\u0644\u0635\u0648\u062a / \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0628\u0644\u063a\u0629 \u0623\u062c\u0646\u0628\u064a\u0629 \u0648\u0633\u0645\u0627\u0639\u0647\u0627 \u0628\u0644\u063a\u062a\u0643. \u0623\u062d\u062f \u0627\u0644\u062a\u0637\u0628\u064a\u0642\u0627\u062a \u0627\u0644\u062c\u0627\u0646\u0628\u064a\u0629 \u0647\u0648 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0627\u062a \u0645\u0639 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0641\u064a \u0646\u0641\u0633 \u0627\u0644\u0644\u063a\u0629 \u060c \u0644\u0643\u0646 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0627\u0644\u062e\u0627\u0635 \u0628\u0643 \u0633\u0648\u0641 \u064a\u0633\u0645\u0639 \u0623\u0646\u0634\u0623. \u0644\u064a\u0633 \u0635\u0648\u062a\u0643. TOIS \u0647\u0630\u0627 \u0636\u0631\u0648\u0631\u064a. \u0647\u0646\u0627\u0643 \u0627\u0644\u0639\u062f\u064a\u062f \u0645\u0646 \u0627\u0644\u062a\u0637\u0628\u064a\u0642\u0627\u062a \u0627\u0644\u0645\u0645\u0643\u0646\u0629", "\u0646\u0638\u0627\u0645 \u0627\u0644\u062a\u0634\u063a\u064a\u0644 Windows 10 \u0623\u0648 Windows 11", "\u0645\u0633\u0627\u062d\u0629 \u0627\u0644\u0642\u0631\u0635 \u0627\u0644\u0635\u0644\u0628 \u0627\u0644\u0645\u062a\u0627\u062d\u0629 8 \u062c\u064a\u062c\u0627\u0628\u0627\u064a\u062a", "\u0631\u0627\u0645 \u0645\u0646 10 \u062c\u064a\u062c\u0627\u0628\u0627\u064a\u062a", "GPU (\u0648\u062d\u062f\u0629 \u0645\u0639\u0627\u0644\u062c\u0629 \u0627\u0644\u0631\u0633\u0648\u0645\u0627\u062a) \u0645\u0639 6 \u063a\u064a\u063a\u0627\u0628\u0627\u064a\u062a \u0623\u0648 \u0623\u0643\u062b\u0631 \u060c \u0645\u0631\u063a\u0648\u0628 \u0641\u064a\u0647\u0627 \u0648\u0644\u0643\u0646 \u0644\u064a\u0633 \u0636\u0631\u0648\u0631\u064a", "\u0633\u0645\u0627\u0639\u0627\u062a \u0627\u0644\u0631\u0623\u0633 \u0645\u0639 \u0627\u0644\u0645\u064a\u0643\u0631\u0648\u0641\u0648\u0646", "\u064a\u062a\u0645 \u062a\u0646\u0641\u064a\u0630 \u0627\u0644\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0643\u0627\u0645\u0644\u0629 \u0644\u0644\u0639\u0645\u0644 \u0645\u0639 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0645\u0646 \u0627\u0644\u0645\u062a\u0635\u0641\u062d", "\u0639\u0646\u062f \u0627\u0644\u0646\u0642\u0631 \u0641\u0648\u0642 \u0627\u0644\u0632\u0631 \"\u0627\u0644\u062a\u0643\u0648\u064a\u0646\" \u060c \u0648\u064a\u062a\u0645 \u0639\u0631\u0636 \u0627\u0644\u0646\u0645\u0648\u0630\u062c \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0645\u0639\u0644\u0645\u0627\u062a \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u0631\u0626\u064a\u0633\u064a\u0629 \u0641\u064a \u0627\u0644\u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0639\u0644\u064a\u0627. \u0627\u0646\u0638\u0631 \u0627\u0644\u0634\u0643\u0644 4", "\u0627\u0644\u0634\u0643\u0644 4. \u0627\u0644\u062a\u0643\u0648\u064a\u0646", "\u064a\u062d\u062a\u0648\u064a \u0642\u0633\u0645 \u0627\u0644\u062a\u0643\u0648\u064a\u0646 \u0639\u0644\u0649 \u0645\u0639\u0644\u0645\u0627\u062a \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u0631\u0626\u064a\u0633\u064a\u0629:", "\u0627\u0644\u0644\u063a\u0629 - \u062a\u0639\u064a\u064a\u0646 \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u062a\u064a \u062a\u062a\u062d\u062f\u062b\u0647\u0627", "\u0627\u0644\u0635\u0648\u062a - \u0627\u0633\u0645 \u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0644\u062c\u0647\u0627\u0632 \u0627\u0644\u0635\u0648\u062a\u064a \u0627\u0644\u062e\u0627\u0635 \u0628\u0643", "\u0627\u0644\u0645\u064a\u0643\u0631\u0648\u0641\u0648\u0646 - \u0627\u0633\u0645 \u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0644\u0644\u0645\u064a\u0643\u0631\u0648\u0641\u0648\u0646 \u0627\u0644\u062e\u0627\u0635 \u0628\u0643", "\u0645\u062a\u0635\u0641\u062d \u0627\u0644\u0648\u064a\u0628 - \u0627\u0633\u0645 \u0627\u0644\u0645\u0633\u062a\u0639\u0631\u0636 \u0627\u0644\u0630\u064a \u0633\u062a\u0639\u0645\u0644 \u0641\u064a\u0647", "\u0639\u0646\u062f \u062a\u063a\u064a\u064a\u0631 \u0627\u0644\u0644\u063a\u0629 \u0648\u062d\u0641\u0638 \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u062a\u0643\u0648\u064a\u0646 \u060c \u0633\u064a\u062a\u0645 \u0639\u0631\u0636 \u062c\u0645\u064a\u0639 \u0627\u0644\u0646\u0635\u0648\u0635 \u0648\u0627\u0644\u062a\u0639\u0628\u064a\u0631\u0627\u062a \u0648\u0623\u0633\u0645\u0627\u0621 \u0627\u0644\u0623\u0632\u0631\u0627\u0631 \u0648\u0627\u0644\u0646\u0635 \u0627\u0644\u0622\u062e\u0631 \u0628\u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u062c\u062f\u064a\u062f\u0629. \u0633\u064a\u062a\u0645 \u062a\u0631\u062c\u0645\u0629 \u0627\u0644\u062f\u0631\u062f\u0634\u0627\u062a \u0627\u0644\u062c\u062f\u064a\u062f\u0629 \u0625\u0644\u0649 \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u0645\u062d\u062f\u062f\u0629 \u060c \u0648\u0633\u0648\u0641 \u062a\u0633\u0645\u0639 \u0627\u0644\u0643\u0644\u0627\u0645 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u062c\u062f\u064a\u062f\u0629. \u0645\u0644\u0627\u062d\u0638\u0629 \u0645\u0647\u0645\u0629 \u062d\u0648\u0644 \u0645\u0639\u0644\u0645\u0629 \u0645\u062a\u0635\u0641\u062d \u0627\u0644\u0648\u064a\u0628. \u0628\u0634\u0643\u0644 \u0627\u0641\u062a\u0631\u0627\u0636\u064a \u060c \u064a\u062a\u0645 \u0636\u0628\u0637 \u0645\u0639\u0644\u0645\u0629 \u0645\u062a\u0635\u0641\u062d \u0627\u0644\u0648\u064a\u0628 \u0639\u0644\u0649 Microsoft Edge \u060c \u0646\u0638\u0631\u064b\u0627 \u0644\u0623\u0646\u0647\u0627 \u0645\u062b\u0628\u062a\u0629 \u062f\u0627\u0626\u0645\u064b\u0627 \u0641\u064a Windows. \u0628\u0627\u0644\u0646\u0633\u0628\u0629 \u0644\u0647\u0630\u0647 \u0627\u0644\u0645\u0639\u0644\u0645\u0629 \u060c \u062d\u062f\u062f \u0641\u0642\u0637 \u0627\u0644\u0645\u0633\u062a\u0639\u0631\u0636 \u0627\u0644\u0630\u064a \u064a\u062a\u0645 \u062a\u062b\u0628\u064a\u062a\u0647 \u0648\u062a\u0634\u063a\u064a\u0644\u0647 \u0639\u0644\u0649 \u0646\u0638\u0627\u0645 \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u062e\u0627\u0635 \u0628\u0643", "\u064a\u0639\u0631\u0636 \u0627\u0644\u0646\u0642\u0631 \u0641\u0648\u0642 \u0627\u0644\u0632\u0631 \u0627\u0644\u062c\u062f\u064a\u062f \u0646\u0645\u0648\u0630\u062c\u064b\u0627 \u0644\u0645\u0644\u0621 AWW \u0627\u0644\u0645\u062d\u0627\u0648\u0631. \u0627\u0646\u0638\u0631 \u0627\u0644\u0634\u0643\u0644 5", "\u0627\u0644\u0634\u0643\u0644 5", "\u064a\u062d\u062a\u0648\u064a \u0642\u0633\u0645 \"\u0645\u0644\u0641 \u062a\u0639\u0631\u064a\u0641 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0627\u0644\u062c\u062f\u064a\u062f\" \u0639\u0644\u0649 \u0645\u0639\u0644\u0645\u0627\u062a \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u0631\u0626\u064a\u0633\u064a\u0629:", "\u0627\u0644\u0644\u0642\u0628 - \u0627\u0644\u0627\u0633\u0645 \u0627\u0644\u0630\u064a \u062a\u062e\u062a\u0627\u0631\u0647 \u0644\u0644\u0648\u0627\u062d\u062f \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0627\u0644\u062e\u0627\u0635 \u0628\u0643", "\u0627\u0644\u0644\u063a\u0629 - \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u062a\u064a \u064a\u062a\u062d\u062f\u062b \u0628\u0647\u0627 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0627\u0644\u062e\u0627\u0635 \u0628\u0643", "\u0627\u0644\u0648\u0635\u0641 - \u0648\u0635\u0641 \u0644\u0644\u0645\u062d\u0627\u0648\u0631 \u0627\u0644\u062e\u0627\u0635 \u0628\u0643", "\u0627\u0633\u062a\u062e\u062f\u0645 \u0627\u0644\u0645\u064a\u0643\u0631\u0648\u0641\u0648\u0646 - \u0627\u0636\u0628\u0637 \u0639\u0644\u0627\u0645\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u064a\u0643\u0631\u0648\u0641\u0648\u0646", "\u0627\u0644\u0635\u0648\u0631\u0629 - \u0627\u0636\u0628\u0637 \u0623\u064a\u0642\u0648\u0646\u0629 \u0644\u0644\u0645\u062d\u0627\u0648\u0631", "\u0625\u0630\u0627 \u0644\u0645 \u062a\u0643\u0646 \u0642\u062f \u062d\u062f\u062f\u062a \u0635\u0648\u0631\u0629 \u0644\u0644\u0645\u062d\u0627\u0648\u0631 \u060c \u0641\u0633\u064a\u062a\u0645 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0635\u0648\u0631\u0629 \u0627\u0644\u0627\u0641\u062a\u0631\u0627\u0636\u064a\u0629 \u0644\u0647", "\u0645\u0639\u0644\u0645\u0629 \"\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u064a\u0643\u0631\u0648\u0641\u0648\u0646\" Canet Canet \u0644\u0644\u062d\u0627\u0644\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u0633\u062a\u0645\u0639 \u0625\u0644\u064a\u0647\u0627 (\u0627\u0644\u0623\u062e\u0628\u0627\u0631 \u060c \u062f\u0631\u0648\u0633 \u0627\u0644\u0635\u0648\u062a \u060c \u0625\u0644\u062e)", "\u064a\u0635\u0641 \u0623\u0645\u0627\u0646 \"\u0627\u0644\u0645\u0633\u0627\u0639\u062f\u0629\" \u0643\u064a\u0641\u064a\u0629 \u0627\u0644\u0639\u0645\u0644 \u0645\u0639 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0628\u0644\u063a\u062a\u0643. \u0627\u0646\u0638\u0631 \u0627\u0644\u0634\u0643\u0644 6", "\u0627\u0644\u0634\u0643\u0644 6. \u0642\u0633\u0645 \u0627\u0644\u0645\u0633\u0627\u0639\u062f\u0629", "\u0627\u0644\u0646\u0642\u0631 \u0641\u0648\u0642 \u0627\u0644\u0632\u0631 \"\u062e\u0631\u0648\u062c\" \u064a\u0646\u0647\u064a \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c. \u0627\u0646\u0638\u0631 \u0627\u0644\u0634\u0643\u0644 7", "\u0627\u0644\u0634\u0643\u0644 7. \u0632\u0631 \u0627\u0644\u062e\u0631\u0648\u062c", "\u0625\u063a\u0644\u0627\u0642 \u0646\u0627\u0641\u0630\u0629 \u0627\u0644\u0645\u062a\u0635\u0641\u062d \u0623\u0648 \u0625\u063a\u0644\u0627\u0642 \u0627\u0644\u0645\u062a\u0635\u0641\u062d \u064a\u0646\u0647\u064a \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0623\u064a\u0636\u064b\u0627", "\u062a\u062d\u062f\u064a\u062b \u0627\u0644\u0635\u0641\u062d\u0629 \u062a\u0646\u0647\u064a \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0623\u064a\u0636\u064b\u0627", "\u0639\u0644\u0649 \u0627\u0644\u062c\u0627\u0646\u0628 \u0627\u0644\u0623\u064a\u0633\u0631 \u0645\u0646 \u0627\u0644\u0645\u062a\u0635\u0641\u062d \u062a\u0648\u062c\u062f \u0642\u0627\u0626\u0645\u0629 \u0645\u0646 \u0645\u062d\u0627\u0648\u0631\u0643. \u0627\u0646\u0638\u0631 \u0627\u0644\u0634\u0643\u0644 8", "\u0627\u0644\u0634\u0643\u0644 8. \u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0631\u064a\u0646", "\u0644\u0643\u0644 \u0645\u062d\u0627\u0648\u0631 \u060c \u064a\u062a\u0645 \u0639\u0631\u0636 \u0623\u064a\u0642\u0648\u0646\u0629\u0647\u0645 \u0648\u062a\u0627\u0631\u064a\u062e \u0622\u062e\u0631 \u0631\u0633\u0627\u0644\u0629 \u0648\u0646\u0635 \u0622\u062e\u0631 \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0628\u0644\u063a\u062a\u0643. \u062a\u0646\u0633\u064a\u0642 \u0627\u0644\u062a\u0627\u0631\u064a\u062e \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0647\u0645\u0629 \u062a\u062a\u0648\u0627\u0641\u0642 \u0645\u0639 \u0644\u063a\u062a\u0643. \u0639\u0646\u062f \u0627\u0644\u0646\u0642\u0631 \u0639\u0644\u0649 \u0645\u062d\u0627\u0648\u0631 \u060c \u064a\u062a\u0645 \u0639\u0631\u0636 \u0633\u062c\u0644 \u0627\u0644\u062f\u0631\u062f\u0634\u0629 \u0627\u0644\u062e\u0627\u0635 \u0628\u0647\u0645", "\u064a\u0642\u0639 \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u062f\u0631\u062f\u0634\u0629 \u0641\u064a \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0639\u0644\u0649 \u0627\u0644\u062c\u0627\u0646\u0628 \u0627\u0644\u0623\u064a\u0645\u0646 \u0645\u0646 \u0627\u0644\u0645\u062a\u0635\u0641\u062d. \u0627\u0646\u0638\u0631 \u0627\u0644\u0634\u0643\u0644 9", "\u0627\u0644\u0634\u0643\u0644 9. \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u062f\u0631\u062f\u0634\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "\u0642\u0627\u0645 \u062a\u0627\u0631\u064a\u062e \u062f\u0631\u062f\u0634\u0629 \u0627\u0644\u0645\u062d\u0642\u0631\u064a\u0646 \u0628\u062a\u0634\u0648\u064a\u0634\u0643 \u0639\u0644\u0649 \u0627\u0644\u0646\u0642\u0631 \u0639\u0644\u0649 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0641\u064a \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u0623\u064a\u0633\u0631", "\u0627\u0644\u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0639\u0644\u064a\u0627 \u062a\u062d\u062a\u0648\u064a \u0639\u0644\u0649:", "\u0623\u064a\u0642\u0648\u0646\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "\u0644\u0642\u0628 \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "\u0632\u0631 \"\u0628\u062f\u0621 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0629\"", "\u0632\u0631 \"\u062a\u0627\u0631\u064a\u062e \u0648\u0627\u0636\u062d\"", "\u0632\u0631 \"\u062d\u0630\u0641 \u0627\u0644\u0645\u062d\u0627\u0648\u0631\"", "\u0632\u0631 \"\u0645\u0644\u0641 \u062a\u0639\u0631\u064a\u0641 \u0627\u0644\u0645\u062d\u0627\u0648\u0631\"", "\u064a\u0638\u0647\u0631 \u0633\u062c\u0644 \u0627\u0644\u062f\u0631\u062f\u0634\u0629 \u0645\u0639 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0627\u0644\u0645\u062d\u062f\u062f \u0641\u064a \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u0623\u064a\u0645\u0646", "\u064a\u062a\u0645 \u062a\u0631\u0642\u064a\u0645 \u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u062f\u0631\u062f\u0634\u0629 \u0645\u0639 \u0632\u0648\u062c \u0645\u0646 \u0627\u0644\u064a\u0627\u0643: \"\u0644\u063a\u0629 \u0627\u0644\u0645\u0628\u062a\u062f\u0626\u064a\u0646\"/\"\u0644\u063a\u062a\u0643\"", "\u064a\u062d\u062a\u0648\u064a \u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u062f\u0631\u062f\u0634\u0629 \u0639\u0644\u0649 \u0632\u0631 \"\u062d\u0630\u0641 \u0647\u0630\u0627 \u0627\u0644\u062f\u0631\u062f\u0634\u0629\"", "\u0639\u0646\u062f \u0627\u0644\u0646\u0642\u0631 \u0641\u0648\u0642 \u0627\u0644\u0632\u0631 \"\u062d\u0630\u0641 \u0647\u0630\u0627 \u0627\u0644\u062f\u0631\u062f\u0634\u0629\" \u060c \u064a\u062a\u0645 \u062d\u0630\u0641 \u0647\u0630\u0647 \u0627\u0644\u062f\u0631\u062f\u0634\u0629 \u0645\u0646 \u0633\u062c\u0644 \u062f\u0631\u062f\u0634\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "\u062c\u0645\u064a\u0639 \u0627\u0644\u0631\u0633\u0627\u0626\u0644 \u0645\u0642\u0633\u0645\u0629 \u0625\u0644\u0649 \u0645\u062c\u0645\u0648\u0639\u062a\u064a\u0646:", "\u0631\u0633\u0627\u0626\u0644 \u0645\u0646 \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "\u0631\u0633\u0627\u0626\u0644\u0643", "\u064a\u062a\u0645 \u0646\u0642\u0644 \u0627\u0644\u0631\u0633\u0627\u0626\u0644 \u0645\u0646 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0625\u0644\u0649 \u0627\u0644\u064a\u0633\u0627\u0631. \u064a\u062a\u0645 \u0646\u0642\u0644 \u0631\u0633\u0627\u0626\u0644\u0643 \u0625\u0644\u0649 \u0627\u0644\u064a\u0645\u064a\u0646", "\u062a\u062a\u0643\u0648\u0646 \u0643\u0644 \u0645\u062c\u0645\u0648\u0639\u0629 \u0631\u0633\u0627\u0626\u0644 \u0645\u0646 \u062c\u0632\u0623\u064a\u0646:", "\u0646\u0635 \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0628\u0644\u063a\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u060c \u0644\u0648\u0646 \u0647\u0630\u0647 \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0623\u0633\u0648\u062f", "\u0646\u0635 \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0628\u0644\u063a\u062a\u0643 \u060c \u0644\u0648\u0646 \u0647\u0630\u0647 \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u062e\u0636\u0631\u0627\u0621", "\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u064a\u062a\u0648\u0627\u0641\u0642 \u0645\u0639 \u0644\u063a\u062a\u0643", "\u062a\u0648\u062c\u062f \u0631\u0633\u0627\u0626\u0644 \u0623\u062d\u062f\u062b (\u062d\u0633\u0628 \u0627\u0644\u062a\u0627\u0631\u064a\u062e) \u0623\u0642\u0644 \u0645\u0646 Oones \u0627\u0644\u0623\u0642\u062f\u0645", "\u0641\u064a \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u0633\u0641\u0644\u064a \u0645\u0646 \u062f\u0631\u062f\u0634\u0627\u062a \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u060c \u064a\u0648\u062c\u062f \u0632\u0631 \"\u0628\u062f\u0621 \u0645\u062d\u0627\u062f\u062b\u0629\". \u0639\u0646\u062f \u0627\u0644\u0646\u0642\u0631 \u0641\u0648\u0642\u0647 \u060c \u064a\u0628\u062f\u0623 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0641\u064a \u0645\u0639\u0627\u064a\u0631\u0629 \u0627\u0644\u0645\u064a\u0643\u0631\u0648\u0641\u0648\u0646 \u0648\u062c\u0647\u0627\u0632 \u0627\u0644\u0635\u0648\u062a \u0644\u062a\u062d\u062f\u064a\u062f \u0645\u0633\u062a\u0648\u064a\u0627\u062a \u0627\u0644\u0625\u0634\u0627\u0631\u0629/\u0627\u0644\u0636\u0648\u0636\u0627\u0621 \u0648\u064a\u0639\u0631\u0636 \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0627\u0644\u0645\u0642\u0627\u0628\u0644\u0629", "\u0628\u0639\u062f \u0645\u0639\u0627\u064a\u0631\u0629 \u0623\u062c\u0647\u0632\u0629 \u0627\u0644\u0635\u0648\u062a \u060c \u062a\u062a\u063a\u064a\u0631 \u0623\u0633\u0645\u0627\u0621 \u0627\u0644\u0623\u0632\u0631\u0627\u0631: \"\u0627\u0628\u062f\u0623 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0629\" -> \"\u062a\u0648\u0642\u0641 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0629\"", "\u0645\u0646 \u0647\u0630\u0647 \u0627\u0644\u0646\u0642\u0637\u0629 \u0641\u0635\u0627\u0639\u062f\u064b\u0627 \u060c \u064a\u0645\u0643\u0646\u0643 \u0628\u062f\u0621 \u0645\u062d\u0627\u062f\u062b\u0629 \u0623\u0648 \u062a\u0634\u063a\u064a\u0644 \u0645\u0644\u0641 \u0635\u0648\u062a/\u0641\u064a\u062f\u064a\u0648 \u0625\u0644\u0649 \u062e\u0637 \u0625\u0644\u0649", "\u0633\u062a\u0638\u0647\u0631 \u062c\u0645\u064a\u0639 \u0627\u0644\u0631\u0633\u0627\u0626\u0644 \u0627\u0644\u0648\u0627\u0631\u062f\u0629 (\u0645\u0646 \u0627\u0644\u0634\u062e\u0635 \u0627\u0644\u0622\u062e\u0631) \u0639\u0644\u0649 \u0627\u0644\u064a\u0633\u0627\u0631", "\u0633\u062a\u0638\u0647\u0631 \u062c\u0645\u064a\u0639 \u0631\u0633\u0627\u0626\u0644 \u0627\u0644\u0646\u0632\u0647\u0629 (\u0645\u0646\u0643) \u0639\u0644\u0649 \u0627\u0644\u064a\u0645\u064a\u0646", "\u0633\u0648\u0641 \u062a\u0633\u0645\u0639 \u0631\u0633\u0627\u0626\u0644 \u0628\u0644\u063a\u062a\u0643 \u0648\u0633\u064a\u0633\u0645\u0639 \u0634\u062e\u0635\u0643 \u0627\u0644\u0622\u062e\u0631 \u0631\u0633\u0627\u0626\u0644 \u0628\u0644\u063a\u062a\u0647\u0645", "\u0641\u064a \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0629/\u0627\u0644\u0627\u0633\u062a\u0645\u0627\u0639 \u0625\u0644\u0649 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u060c \u062a\u062d\u062a\u0627\u062c \u0625\u0644\u0649 \u0627\u0644\u0646\u0642\u0631 \u0639\u0644\u0649 \u0623\u062d\u062f \u0623\u0632\u0631\u0627\u0631 \"STOP ENTILIGY\"", "\u062a\u0646\u062a\u0647\u064a \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0629 \u0623\u064a\u0636\u064b\u0627 \u0639\u0646\u062f\u0645\u0627:", "\u0627\u0644\u0646\u0642\u0631 \u0639\u0644\u0649 \u0627\u0644\u0634\u062e\u0635 \u0627\u0644\u0622\u062e\u0631 \u0641\u064a \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u0623\u064a\u0633\u0631 \u0645\u0646 \u0627\u0644\u0645\u062a\u0635\u0641\u062d \u0641\u064a \u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0631\u064a\u0646", "\u0627\u0644\u0646\u0642\u0631 \u0641\u0648\u0642 \u0627\u0644\u0632\u0631 \"\u0627\u0644\u062c\u062f\u064a\u062f\" \u0641\u064a \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u0639\u0644\u0648\u064a \u0645\u0646 \u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "\u0627\u0644\u0646\u0642\u0631 \u0641\u0648\u0642 \u0627\u0644\u0632\u0631 \"\u062a\u0639\u0644\u064a\u0645\u0627\u062a\" \u0641\u064a \u0627\u0644\u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0639\u0644\u064a\u0627", "\u0627\u0644\u0646\u0642\u0631 \u0639\u0644\u0649 \u0632\u0631 \"Clear History\" \u0641\u064a \u0627\u0644\u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0639\u0644\u064a\u0627", "\u0627\u0644\u0646\u0642\u0631 \u0641\u0648\u0642 \"\u062d\u0630\u0641 \u0627\u0644\u0645\u062d\u0627\u0648\u0631\" \u0641\u064a \u0627\u0644\u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0639\u0644\u064a\u0627", "\u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0646\u0642\u0631 \u0641\u0648\u0642 \u0627\u0644\u0632\u0631 \"\u0645\u0644\u0641 \u062a\u0639\u0631\u064a\u0641 \u0627\u0644\u0645\u062d\u0627\u0648\u0631\" \u0641\u064a \u0627\u0644\u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0639\u0644\u064a\u0627", "\u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0646\u0642\u0631 \u0639\u0644\u0649 \u0632\u0631 \"\u0627\u0644\u062e\u0631\u0648\u062c\" \u0641\u064a \u0627\u0644\u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0639\u0644\u064a\u0627", "\u0639\u0631\u0636 \u0627\u0644\u0631\u0633\u0627\u0626\u0644 \u0641\u064a \u0633\u062c\u0644 \u0627\u0644\u062f\u0631\u062f\u0634\u0629 \u0627\u0644\u062a\u064a \u062a\u0645 \u062a\u062d\u062f\u064a\u062f\u0647\u0627 \u0639\u0646 \u0637\u0631\u064a\u0642 \u062a\u062d\u062f\u064a\u062f \u062e\u064a\u0627\u0631 \u0639\u0631\u0636 \u0627\u0644\u0631\u0633\u0627\u0626\u0644 \u0641\u064a \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u0639\u0644\u0648\u064a \u0627\u0644\u0623\u064a\u0633\u0631 \u0645\u0646 \u0627\u0644\u0642\u0627\u0626\u0645\u0629 (\u0627\u0644\u0633\u0647\u0645 \u0627\u0644\u0623\u062e\u0636\u0631)", "\u0639\u0646\u062f \u0627\u062e\u062a\u064a\u0627\u0631 \"\u062c\u0645\u064a\u0639 \u0627\u0644\u0644\u063a\u0627\u062a\" - \u064a\u062a\u0645 \u0639\u0631\u0636 \u0631\u0633\u0627\u0626\u0644 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0648\u0631\u0633\u0627\u0626\u0644\u0643 \u0628\u062c\u0645\u064a\u0639 \u0627\u0644\u0644\u063a\u0627\u062a", "\u0639\u0646\u062f \u0627\u062e\u062a\u064a\u0627\u0631 \"\u0644\u063a\u062a\u064a\" - \u064a\u062a\u0645 \u0639\u0631\u0636 \u0631\u0633\u0627\u0626\u0644 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0648\u0631\u0633\u0627\u0626\u0644\u0643 \u0641\u0642\u0637 \u0628\u0644\u063a\u062a\u0643", "\u0639\u0646\u062f \u0627\u062e\u062a\u064a\u0627\u0631 \"\u0644\u063a\u0629 \u0627\u0644\u0645\u0628\u062a\u062f\u0626\u064a\u0646\" - \u064a\u062a\u0645 \u0639\u0631\u0636 \u0631\u0633\u0627\u0626\u0644 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0648\u0631\u0633\u0627\u0626\u0644\u0643 \u0641\u0642\u0637 \u0628\u0644\u063a\u0629 \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "\u0648\u0636\u0639 \u0639\u0631\u0636 \u0627\u0644\u0631\u0633\u0627\u0626\u0644 \u0627\u0644\u0627\u0641\u062a\u0631\u0627\u0636\u064a \u0647\u0648 \"\u062c\u0645\u064a\u0639 \u0627\u0644\u0644\u063a\u0627\u062a\"", "\u0639\u0646\u062f \u0627\u0644\u0646\u0642\u0631 \u0639\u0644\u0649 \u0632\u0631 \"Clear History\" \u060c \u064a\u062a\u0645 \u062d\u0630\u0641 \u062c\u0645\u064a\u0639 \u0627\u0644\u062f\u0631\u062f\u0634\u0627\u062a \u0645\u0639 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u060c \u0648\u0644\u0643\u0646 \u064a\u0628\u0642\u0649 \u0627\u0644\u0645\u062d\u0627\u0648\u0631. \u0627\u0646\u0638\u0631 \u0627\u0644\u0634\u0643\u0644 10", "\u0627\u0644\u0634\u0643\u0644 10. \u062a\u0637\u0647\u064a\u0631 \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "\u0625\u0630\u0627 \u0643\u0627\u0646\u062a \u0627\u0644\u062f\u0631\u062f\u0634\u0629 \u0645\u0639 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0642\u064a\u062f \u0627\u0644\u062a\u0642\u062f\u0645 \u062d\u0627\u0644\u064a\u064b\u0627 \u060c \u0641\u0633\u064a\u062a\u0645 \u0625\u064a\u0642\u0627\u0641\u0647\u0627", "\u0627\u0644\u0646\u0642\u0631 \u0641\u0648\u0642 \u0627\u0644\u0632\u0631 \"\u062d\u0630\u0641 \u0627\u0644\u0645\u062d\u0627\u0648\u0631\" \u064a\u062d\u0630\u0641 \u062c\u0645\u064a\u0639 \u0627\u0644\u062f\u0631\u062f\u0634\u0627\u062a \u0645\u0639 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0648\u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0646\u0641\u0633\u0647. \u0627\u0646\u0638\u0631 \u0627\u0644\u0634\u0643\u0644 11", "\u0627\u0644\u0634\u0643\u0644 11. \u062d\u0630\u0641 \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "\u0625\u0630\u0627 \u0643\u0627\u0646\u062a \u0627\u0644\u062f\u0631\u062f\u0634\u0629 \u0645\u0639 \u0627\u0644\u0645\u062d\u0627\u0648\u0631 \u0642\u064a\u062f \u0627\u0644\u062a\u0642\u062f\u0645 \u062d\u0627\u0644\u064a\u064b\u0627 \u060c \u0641\u0633\u064a\u062a\u0645 \u0625\u064a\u0642\u0627\u0641\u0647\u0627", "\u064a\u0639\u0631\u0636 \u0627\u0644\u0646\u0642\u0631 \u0641\u0648\u0642 \u0627\u0644\u0632\u0631 \"\u0645\u0644\u0641 \u062a\u0639\u0631\u064a\u0641 interlocutor\" \u0646\u0645\u0648\u0630\u062c\u064b\u0627 \u0645\u0645\u0644\u0648\u0621\u064b\u0627 \u0628\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u062d\u0627\u0648\u0631. \u0627\u0646\u0638\u0631 \u0627\u0644\u0634\u0643\u0644 12", "\u0627\u0644\u0634\u0643\u0644 12. \u0639\u0631\u0636 \u0645\u0644\u0641 \u062a\u0639\u0631\u064a\u0641 \u0627\u0644\u0645\u062d\u0627\u0648\u0631", "\u0647\u0630\u0627 \u0627\u0644\u0639\u0646\u0635\u0631 \u0645\u0634\u0627\u0628\u0647 \u0644\u0644\u0639\u0646\u0635\u0631", "\u064a\u062a\u064a\u062d \u0644\u0643 \u0627\u0644\u0641\u0627\u0635\u0644 \u0627\u0644\u0639\u0645\u0648\u062f\u064a \u062a\u063a\u064a\u064a\u0631 \u0639\u0631\u0636 \u0627\u0644\u0645\u0646\u0627\u0637\u0642 \u0627\u0644\u064a\u0645\u0646\u0649 \u0648\u0627\u0644\u064a\u0633\u0631\u0649 \u0645\u0646 \u0645\u0633\u0627\u062d\u0629 \u0627\u0644\u0639\u0645\u0644. \u0627\u0646\u0638\u0631 \u0627\u0644\u0634\u0643\u0644 13", "\u0627\u0644\u0634\u0643\u0644 13. \u0627\u0644\u0641\u0627\u0635\u0644 \u0627\u0644\u0631\u0623\u0633\u064a \u0644\u0644\u0623\u062c\u0632\u0627\u0621 \u0627\u0644\u064a\u0645\u0646\u0649 \u0648\u0627\u0644\u064a\u0633\u0631\u0649", "\u0639\u0646\u062f \u062a\u062d\u0631\u064a\u0643 \u0627\u0644\u0641\u0627\u0635\u0644 \u0627\u0644\u0639\u0645\u0648\u062f\u064a \u060c \u064a\u062a\u0645 \u062d\u0641\u0638 \u0645\u0648\u0642\u0641\u0647. \u0639\u0646\u062f \u0625\u0639\u0627\u062f\u0629 \u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u060c \u0633\u064a\u062a\u0645 \u0627\u0633\u062a\u0639\u0627\u062f\u0629 \u0622\u062e\u0631 \u0648\u0638\u064a\u0641\u0629 \u0642\u0645\u062a \u0628\u062a\u0639\u064a\u064a\u0646\u0647\u0627", "\u062d\u0631\u0643 \u0645\u0624\u0634\u0631 \u0627\u0644\u0645\u0627\u0648\u0633 \u0641\u0648\u0642 \u0635\u0648\u0631\u0629 \u0627\u0644\u0633\u0645\u0627\u0639\u0629 \u0641\u064a \u0627\u0644\u0632\u0627\u0648\u064a\u0629 \u0627\u0644\u064a\u0645\u0646\u0649 \u0627\u0644\u0633\u0641\u0644\u0649 \u0645\u0646 \u0627\u0644\u0634\u0627\u0634\u0629 \u0648\u0627\u0644\u0646\u0642\u0631 \u0628\u0632\u0631 \u0627\u0644\u0645\u0627\u0648\u0633 \u0627\u0644\u0623\u064a\u0645\u0646 \u060c \u062d\u062f\u062f \u0639\u0646\u0635\u0631 \u0642\u0627\u0626\u0645\u0629 \"\u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0635\u0648\u062a \u0627\u0644\u0645\u0641\u062a\u0648\u062d\u0629\" \u060c \u0643\u0645\u0627 \u0647\u0648 \u0645\u0648\u0636\u062d \u0641\u064a \u0627\u0644\u0634\u0643\u0644 14", "\u0627\u0644\u0634\u0643\u0644 14. \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0635\u0648\u062a \u0627\u0644\u0645\u0641\u062a\u0648\u062d\u0629", "\u0633\u062a\u0638\u0647\u0631 \u0634\u0627\u0634\u0629 \u0645\u0639 \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0635\u0648\u062a \u0627\u0644\u062d\u0627\u0644\u064a\u0629", "\u0627\u0644\u0634\u0643\u0644 15. \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0635\u0648\u062a \u0627\u0644\u062d\u0627\u0644\u064a\u0629", "\u0627\u0633\u062a\u0639\u0627\u062f\u0629 \u0627\u0644\u0642\u064a\u0645 \u0627\u0644\u0623\u0648\u0644\u064a\u0629 \u0627\u0644\u062a\u064a \u0643\u0627\u0646\u062a \u0642\u0628\u0644 \u0628\u062f\u0621 \u0627\u0644\u0645\u0647\u0645\u0629. \u0641\u064a \u062d\u0627\u0644\u062a\u0643 \u060c \u0633\u062a\u0643\u0648\u0646 \u0627\u0644\u0623\u0633\u0645\u0627\u0621 \u0645\u062e\u062a\u0644\u0641\u0629", "\u0627\u0644\u0634\u0643\u0644 16. \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0635\u0648\u062a \u0627\u0644\u0623\u0648\u0644\u064a\u0629", "\u062a\u0645\u062a \u0627\u0633\u062a\u0639\u0627\u062f\u0629 \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0646\u0638\u0627\u0645 \u060c \u064a\u0645\u0643\u0646\u0643 \u0627\u0644\u0639\u0645\u0644 \u0641\u064a Windows"]