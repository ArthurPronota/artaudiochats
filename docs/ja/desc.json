["\u30d7\u30ed\u30b0\u30e9\u30e0\u300c\u30aa\u30fc\u30c7\u30a3\u30aa\u30c1\u30e3\u30c3\u30c8\u300d\u306e\u8aac\u660e\u3002", "\u30b3\u30f3\u30c6\u30f3\u30c4", "1\u3002\u59cb\u3081\u308b\u524d\u306b\u3002", "2\u3002\u7c21\u5358\u306a\u8aac\u660e\u3002", "3\u3002\u901a\u4fe1\u306e\u305f\u3081\u306e\u5229\u7528\u53ef\u80fd\u306a\u8a00\u8a9e\u306e\u30ea\u30b9\u30c8\u3002", "4.\u30d7\u30ed\u30b0\u30e9\u30e0\u304c\u6a5f\u80fd\u3059\u308b\u305f\u3081\u306b\u5fc5\u8981\u306a\u3082\u306e\u3002", "5\u3002\u30d7\u30ed\u30b0\u30e9\u30e0\u306e\u64cd\u4f5c\u3002", "5.1\u69cb\u6210\u3002", "5.2\u65b0\u3057\u3044\u5bfe\u8ac7\u8005\u306e\u30d7\u30ed\u30d5\u30a1\u30a4\u30eb\u3002", "5.3\u30d8\u30eb\u30d7\u30bb\u30af\u30b7\u30e7\u30f3\u3002", "5.4\u7d42\u4e86\u30dc\u30bf\u30f3\u3002", "5.5\u5bfe\u8a71\u8005\u306e\u30ea\u30b9\u30c8\u3002", "5.6\u5bfe\u8a71\u8005\u306e\u30c1\u30e3\u30c3\u30c8\u5c65\u6b74\u3002", "5.7\u5bfe\u8ac7\u8005\u306e\u6b74\u53f2\u306e\u30af\u30ea\u30a2\u3002", "5.8\u5bfe\u8ac7\u8005\u306e\u524a\u9664\u3002", "5.9\u5bfe\u8a71\u8005\u306e\u30d7\u30ed\u30d5\u30a3\u30fc\u30eb\u306e\u8868\u793a\u3002", "5.10\u5de6\u90e8\u3068\u53f3\u90e8\u306e\u9593\u306e\u5782\u76f4\u30bb\u30d1\u30ec\u30fc\u30bf\u30fc\u3002", "6\u3002\u4f5c\u696d\u3092\u7d42\u3048\u305f\u5f8c\u3002", "\u753b\u9762\u306e\u53f3\u4e0b\u9685\u306b\u3042\u308b\u30b9\u30d4\u30fc\u30ab\u30fc\u753b\u50cf\u306e\u4e0a\u306b\u30de\u30a6\u30b9\u30ab\u30fc\u30bd\u30eb\u3092\u30db\u30d0\u30ea\u30f3\u30b0\u3057\u3001\u53f3\u30af\u30ea\u30c3\u30af\u3057\u307e\u3059\u3002\u3053\u308c\u306f\u3001\u56f31\u306e\u30b7\u30e7\u30fc\u30f3\u306e\u3088\u3046\u306b\u3001\u30aa\u30fc\u30d7\u30f3\u30b5\u30a6\u30f3\u30c9\u8a2d\u5b9a\u300c\u30e1\u30cb\u30e5\u30fc\u9805\u76ee\u300d\u30e1\u30cb\u30e5\u30fc\u9805\u76ee\u3067\u3059\u3002", "\u56f31\u3002\u958b\u304f\u30b5\u30a6\u30f3\u30c9\u8a2d\u5b9a\u3002", "\u73fe\u5728\u306e\u30b5\u30a6\u30f3\u30c9\u8a2d\u5b9a\u304c\u3042\u308b\u753b\u9762\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002\u5165\u529b\u304a\u3088\u3073\u51fa\u529b\u30aa\u30fc\u30c7\u30a3\u30aa\u30c7\u30d0\u30a4\u30b9\u306b\u8a2d\u5b9a\u3055\u308c\u3066\u3044\u308b\u3082\u306e\u3092\u899a\u3048\u3066\u304a\u3044\u3066\u304f\u3060\u3055\u3044\u3002\u4f5c\u696d\u3092\u7d42\u4e86\u3057\u305f\u3089\u3001\u3053\u306e\u60c5\u5831\u304c\u5fc5\u8981\u306b\u306a\u308a\u307e\u3059\u3002\u56f32\u3067\u306f\u3001\u8d64\u3044\u77e2\u5370\u306f\u899a\u3048\u3066\u304a\u304f\u3079\u304d\u3053\u3068\u3092\u793a\u3057\u3066\u3044\u307e\u3059\u3002\u3042\u306a\u305f\u306e\u5834\u5408\u3001\u540d\u524d\u306f\u7570\u306a\u308a\u307e\u3059\u3002", "\u56f32\u3002\u521d\u671f\u30b5\u30a6\u30f3\u30c9\u8a2d\u5b9a", "\u30b5\u30a6\u30f3\u30c9\u51fa\u529b\u30c7\u30d0\u30a4\u30b9\u3092\u306b\u8a2d\u5b9a\u3057\u307e\u3059", "\u30b5\u30a6\u30f3\u30c9\u5165\u529b\u30c7\u30d0\u30a4\u30b9\u3092\u306b\u8a2d\u5b9a\u3057\u307e\u3059", "\u56f33\u3067\u306f\u3001\u8d64\u3044\u77e2\u5370\u306f\u4f55\u3092\u793a\u3057\u3001\u8a2d\u5b9a\u3059\u308b\u5fc5\u8981\u304c\u3042\u308a\u307e\u3057\u305f\u304b\u3002", "\u56f33\u3002\u52d5\u4f5c\u30b5\u30a6\u30f3\u30c9\u8a2d\u5b9a", "\u30b7\u30b9\u30c6\u30e0\u8a2d\u5b9a\u304c\u5b8c\u4e86\u3057\u3001\u30d7\u30ed\u30b0\u30e9\u30e0\u3092\u5b9f\u884c\u3067\u304d\u307e\u3059", "\u3042\u306a\u305f\u306f\u3042\u306a\u305f\u304c\u77e5\u3063\u3066\u3044\u308b\u8a00\u8a9e\u3092\u8a71\u3057\u307e\u3059\u3001\u3042\u306a\u305f\u306f\u3042\u306a\u305f\u306e\u5bfe\u8ac7\u8005\u304c\u7406\u89e3\u3057\u3066\u3044\u308b\u8a00\u8a9e\u3067\u805e\u304b\u308c\u307e\u3059\u3002\u30b3\u30f3\u30d0\u30fc\u30b9\u30bb\u30c3\u30c8\u306e\u30ed\u30b0\u304c\u4fdd\u6301\u3055\u308c\u307e\u3059\u3002\u3059\u3079\u3066\u306e\u64cd\u4f5c\u306f\u3001Windows 10\u307e\u305f\u306fWindows 11\u3092\u5b9f\u884c\u3057\u3066\u3044\u308b\u30b3\u30f3\u30d4\u30e5\u30fc\u30bf\u30fc\u3067\u30ed\u30fc\u30ab\u30eb\u306b\u5b9f\u884c\u3055\u308c\u307e\u3059\u3002\u30b0\u30e9\u30d5\u30a3\u30c3\u30af\u30b9\u30d7\u30ed\u30bb\u30c3\u30b5\u306f\u3001\u30d7\u30ed\u30b0\u30e9\u30e0\u304c\u6a5f\u80fd\u3059\u308b\u305f\u3081\u306b\u671b\u307e\u3057\u3044\u304c\u3001\u5fc5\u8981\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u30b0\u30e9\u30d5\u30a3\u30c3\u30af\u30b9\u30d7\u30ed\u30bb\u30c3\u30b5\u3067\u306f\u3001\u7ffb\u8a33\u306e\u54c1\u8cea\u304c\u5411\u4e0a\u3057\u307e\u3059\u3002", "\u3053\u306e\u30ea\u30b9\u30c8\u306e\u8a00\u8a9e\u306e\u3044\u305a\u308c\u304b\u3092\u7406\u89e3\u3057\u3066\u3044\u308b\u5834\u5408\u3001\u3053\u306e\u30ea\u30b9\u30c8\u304b\u3089\u3069\u306e\u3088\u3046\u306a\u8a00\u8a9e\u306e\u30cd\u30a4\u30c6\u30a3\u30d6Speakero\u3068\u901a\u4fe1\u3067\u304d\u308b\u3088\u3046\u306b\u306a\u308a\u307e\u3059\u3002\u30b3\u30df\u30e5\u30cb\u30b1\u30fc\u30b7\u30e7\u30f3\u306f\u3001Telegram\u3001WhatsApp\u3001Google Meet\u3001VKMessenger\u3001Yandexmessenger\u3001\u307e\u305f\u306f\u305d\u306e\u4ed6\u306e\u30e1\u30c3\u30bb\u30f3\u30b8\u30e3\u30fc\u306b\u3042\u308a\u307e\u3059\u3002 Mentio\u8a00\u8a9e\u306e\u3044\u305a\u308c\u304b\u3067\u30cb\u30e5\u30fc\u30b9\u3001\u30c8\u30ec\u30fc\u30cb\u30f3\u30b0\u30b3\u30fc\u30b9\u3001\u305d\u306e\u4ed6\u306e\u30dd\u30c3\u30c9\u30ad\u30e3\u30b9\u30c8\u3092\u8074\u304d\u3001\u305d\u308c\u3089\u3092\u7406\u89e3\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\u4eca\u3067\u306f\u3001\u5916\u56fd\u4f01\u696d\u306e\u30a4\u30f3\u30bf\u30d3\u30e5\u30fc\u306a\u3069\u306b\u5408\u683c\u3059\u308b\u53ef\u80fd\u6027\u304c\u3042\u308a\u307e\u3059\u3002\u307e\u305f\u3001\u5916\u56fd\u8a9e\u3067\u30aa\u30fc\u30c7\u30a3\u30aa /\u30d3\u30c7\u30aa\u30d5\u30a1\u30a4\u30eb\u3092\u518d\u751f\u3057\u3066\u3001\u3042\u306a\u305f\u306e\u8a00\u8a9e\u3067\u305d\u308c\u3092\u805e\u304f\u3053\u3068\u3082\u3067\u304d\u307e\u3059\u3002\u30b5\u30a4\u30c9\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u306e1\u3064\u306f\u3001\u540c\u3058\u8a00\u8a9e\u3067\u5bfe\u8a71\u8005\u3068\u306e\u4f1a\u8a71\u3067\u3059\u304c\u3001\u5bfe\u8a71\u8005\u306f\u751f\u6210\u3055\u308c\u305fTheice\u3092\u805e\u304d\u307e\u3059\u3002\u3042\u306a\u305f\u81ea\u8eab\u306e\u58f0\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u3053\u308c\u306f\u5fc5\u8981\u3067\u3059\u3002\u53ef\u80fd\u306a\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u306f\u305f\u304f\u3055\u3093\u3042\u308a\u307e\u3059\u3002", "\u30aa\u30da\u30ec\u30fc\u30c6\u30a3\u30f3\u30b0\u30b7\u30b9\u30c6\u30e0Windows 10\u307e\u305f\u306fWindows 11\u3002", "\u5229\u7528\u53ef\u80fd\u306a\u30cf\u30fc\u30c9\u30c9\u30e9\u30a4\u30d6\u30b9\u30da\u30fc\u30b98 GB\u3002", "10 GB\u306eRAM\u3002", "6 GB\u4ee5\u4e0a\u306eGPU\uff08\u30b0\u30e9\u30d5\u30a3\u30c3\u30af\u30d7\u30ed\u30bb\u30c3\u30b7\u30f3\u30b0\u30e6\u30cb\u30c3\u30c8\uff09\u3001\u671b\u307e\u3057\u3044\u304c\u5fc5\u8981\u3067\u306f\u306a\u3044\u3002", "\u30de\u30a4\u30af\u4ed8\u304d\u306e\u30d8\u30c3\u30c9\u30d5\u30a9\u30f3\u3002", "\u30d7\u30ed\u30b0\u30e9\u30e0\u3092\u64cd\u4f5c\u3059\u308b\u30a4\u30f3\u30bf\u30fc\u30d5\u30a7\u30a4\u30b9\u5168\u4f53\u304c\u30d6\u30e9\u30a6\u30b6\u304b\u3089\u5b9f\u884c\u3055\u308c\u307e\u3059\u3002", "[\u69cb\u6210]\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3057\u3001\u30e1\u30a4\u30f3\u306e\u64cd\u4f5c\u30d1\u30e9\u30e1\u30fc\u30bf\u30fc\u3092\u5099\u3048\u305f\u30d5\u30a9\u30fc\u30e0\u3092\u30af\u30ea\u30c3\u30af\u3059\u308b\u3068\u3001\u30c8\u30c3\u30d7\u30e1\u30cb\u30e5\u30fc\u306b\u8868\u793a\u3055\u308c\u307e\u3059\u3002\u56f34\u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002", "\u56f34\u3002\u69cb\u6210\u3002", "\u69cb\u6210\u30bb\u30af\u30b7\u30e7\u30f3\u306b\u306f\u3001\u4e3b\u306a\u52d5\u4f5c\u30d1\u30e9\u30e1\u30fc\u30bf\u30fc\u304c\u542b\u307e\u308c\u3066\u3044\u307e\u3059\u3002", "\u8a00\u8a9e - \u3042\u306a\u305f\u304c\u8a71\u3059\u8a00\u8a9e\u306e\u8a2d\u5b9a\u3002", "\u30b5\u30a6\u30f3\u30c9 - \u30b5\u30a6\u30f3\u30c9\u30a8\u30df\u30c3\u30c8\u30c7\u30d0\u30a4\u30b9\u306e\u30c9\u30e9\u30a4\u30d0\u30fc\u306e\u540d\u524d\u3002", "\u30de\u30a4\u30af - \u30de\u30a4\u30af\u306e\u30c9\u30e9\u30a4\u30d0\u30fc\u306e\u540d\u524d\u3002", "Web\u30d6\u30e9\u30a6\u30b6 - \u52d5\u4f5c\u3059\u308b\u30d6\u30e9\u30a6\u30b6\u306e\u540d\u524d\u3002", "\u8a00\u8a9e\u3092\u5909\u66f4\u3057\u3066\u69cb\u6210\u8a2d\u5b9a\u3092\u4fdd\u5b58\u3059\u308b\u3068\u3001\u3059\u3079\u3066\u306e\u30c6\u30ad\u30b9\u30c8\u3001\u5f0f\u3001\u30dc\u30bf\u30f3\u540d\u3001\u304a\u3088\u3073\u305d\u306e\u4ed6\u306e\u30c6\u30ad\u30b9\u30c8\u304c\u65b0\u3057\u3044\u8a00\u8a9e\u3067\u8868\u793a\u3055\u308c\u307e\u3059\u3002\u65b0\u3057\u3044\u30c1\u30e3\u30c3\u30c8\u306f\u9078\u629e\u3055\u308c\u305f\u8a00\u8a9e\u306b\u7ffb\u8a33\u3055\u308c\u3001\u3053\u306e\u65b0\u3057\u3044\u8a00\u8a9e\u3067\u30b9\u30d4\u30fc\u30c1\u304c\u805e\u3053\u3048\u307e\u3059\u3002 Web\u30d6\u30e9\u30a6\u30b6\u30d1\u30e9\u30e1\u30fc\u30bf\u30fc\u306b\u95a2\u3059\u308b\u91cd\u8981\u306a\u6ce8\u610f\u3002\u30c7\u30d5\u30a9\u30eb\u30c8\u3067\u306f\u3001Web\u30d6\u30e9\u30a6\u30b6\u30fc\u30d1\u30e9\u30e1\u30fc\u30bf\u30fc\u306f\u5e38\u306bWindows\u306b\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u3055\u308c\u3066\u3044\u308b\u305f\u3081\u3001Microsoft Edge\u306b\u8a2d\u5b9a\u3055\u308c\u3066\u3044\u307e\u3059\u3002\u3053\u306e\u30d1\u30e9\u30e1\u30fc\u30bf\u30fc\u3067\u306f\u3001\u30aa\u30da\u30ec\u30fc\u30c6\u30a3\u30f3\u30b0\u30b7\u30b9\u30c6\u30e0\u3067\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u3055\u308c\u3066\u5b9f\u884c\u3055\u308c\u3066\u3044\u308b\u30d6\u30e9\u30a6\u30b6\u306e\u307f\u3092\u9078\u629e\u3057\u307e\u3059\u3002", "\u65b0\u3057\u3044\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3059\u308b\u3068\u3001AWW\u5bfe\u8a71\u8005\u306b\u8a18\u5165\u3059\u308b\u305f\u3081\u306e\u30d5\u30a9\u30fc\u30e0\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002\u56f35\u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002", "\u56f35\u3002\u65b0\u3057\u3044\u5bfe\u8a71\u8005\u30d7\u30ed\u30d5\u30a1\u30a4\u30eb", "\u300c\u65b0\u3057\u3044\u5bfe\u8a71\u8005\u30d7\u30ed\u30d5\u30a1\u30a4\u30eb\u300d\u30bb\u30af\u30b7\u30e7\u30f3\u306b\u306f\u3001\u4e3b\u306a\u52d5\u4f5c\u30d1\u30e9\u30e1\u30fc\u30bf\u30fc\u304c\u542b\u307e\u308c\u3066\u3044\u307e\u3059\u3002", "\u30cb\u30c3\u30af\u30cd\u30fc\u30e0 - \u5bfe\u8ac7\u8005\u306b\u9078\u629e\u3057\u305f\u540d\u524d\u3002", "\u8a00\u8a9e - \u3042\u306a\u305f\u306e\u5bfe\u8ac7\u8005\u304c\u8a71\u3059\u8a00\u8a9e\u3002", "\u8aac\u660e - \u5bfe\u8ac7\u8005\u306e\u8aac\u660e\u3002", "\u30de\u30a4\u30af\u3092\u4f7f\u7528 - \u30de\u30a4\u30af\u4f7f\u7528\u30d5\u30e9\u30b0\u3092\u8a2d\u5b9a\u3057\u307e\u3059\u3002", "\u753b\u50cf - \u5bfe\u8ac7\u8005\u306e\u30a2\u30a4\u30b3\u30f3\u3092\u8a2d\u5b9a\u3057\u307e\u3059\u3002", "\u5bfe\u8a71\u8005\u306e\u753b\u50cf\u3092\u9078\u629e\u3057\u3066\u3044\u306a\u3044\u5834\u5408\u3001\u30c7\u30d5\u30a9\u30eb\u30c8\u306e\u753b\u50cf\u304c\u5f7c\u306b\u4f7f\u7528\u3055\u308c\u307e\u3059\u3002", "\u300c\u30de\u30a4\u30af\u306e\u4f7f\u7528\u300d\u30d1\u30e9\u30e1\u30fc\u30bf\u30fc\u30ab\u30cd\u30c3\u30c8\u306f\u3001\u30ea\u30b9\u30cb\u30f3\u30b0\u6642\u306b\u30b1\u30fc\u30b9\uff08\u30cb\u30e5\u30fc\u30b9\u3001\u30aa\u30fc\u30c7\u30a3\u30aa\u30ec\u30c3\u30b9\u30f3\u306a\u3069\uff09\u306b\u8a2d\u5b9a\u3055\u308c\u3066\u3044\u307e\u305b\u3093\u3002", "\u300c\u30d8\u30eb\u30d7\u300d\u30bb\u30ad\u30e5\u30ea\u30c6\u30a3\u306f\u3001\u3042\u306a\u305f\u306e\u8a00\u8a9e\u3067\u30d7\u30ed\u30b0\u30e9\u30e0\u3092\u64cd\u4f5c\u3059\u308b\u65b9\u6cd5\u3092\u8aac\u660e\u3057\u3066\u3044\u307e\u3059\u3002\u56f36\u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002", "\u56f36\u3002\u30d8\u30eb\u30d7\u30bb\u30af\u30b7\u30e7\u30f3\u3002", "[\u7d42\u4e86]\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3059\u308b\u3068\u3001\u30d7\u30ed\u30b0\u30e9\u30e0\u304c\u7d42\u4e86\u3057\u307e\u3059\u3002\u56f37\u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002", "\u56f37\u3002\u7d42\u4e86\u30dc\u30bf\u30f3\u3002", "\u30d6\u30e9\u30a6\u30b6\u30a6\u30a3\u30f3\u30c9\u30a6\u3092\u9589\u3058\u308b\u304b\u3001\u30d6\u30e9\u30a6\u30b6\u3092\u9589\u3058\u308b\u3053\u3068\u3082\u30d7\u30ed\u30b0\u30e9\u30e0\u3092\u7d42\u4e86\u3057\u307e\u3059\u3002", "\u30da\u30fc\u30b8\u3092\u66f4\u65b0\u3059\u308b\u3053\u3068\u3082\u30d7\u30ed\u30b0\u30e9\u30e0\u3092\u7d42\u4e86\u3057\u307e\u3059\u3002", "\u30d6\u30e9\u30a6\u30b6\u306e\u5de6\u5074\u306b\u306f\u3001\u5bfe\u8a71\u8005\u306e\u30ea\u30b9\u30c8\u304c\u3042\u308a\u307e\u3059\u3002\u56f38\u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002", "\u56f38\u3002\u5bfe\u8a71\u8005\u306e\u30ea\u30b9\u30c8\u3002", "\u5bfe\u8a71\u8005\u3054\u3068\u306b\u3001\u30a2\u30a4\u30b3\u30f3\u3001\u6700\u5f8c\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u306e\u65e5\u4ed8\u3001\u304a\u3088\u3073\u8a00\u8a9e\u306e\u6700\u5f8c\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u306e\u30c6\u30ad\u30b9\u30c8\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002\u30bf\u30b9\u30af\u3092\u4ecb\u3057\u305f\u65e5\u4ed8\u5f62\u5f0f\u306f\u3001\u8a00\u8a9e\u306b\u5bfe\u5fdc\u3057\u307e\u3059\u3002\u5bfe\u8ac7\u8005\u3092\u30af\u30ea\u30c3\u30af\u3059\u308b\u3068\u3001\u30c1\u30e3\u30c3\u30c8\u5c65\u6b74\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002", "\u5bfe\u8a71\u8005\u306e\u30c1\u30e3\u30c3\u30c8\u5c65\u6b74\u306f\u3001\u30d6\u30e9\u30a6\u30b6\u306e\u53f3\u5074\u306b\u3042\u308a\u307e\u3059\u3002\u56f39\u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002", "\u56f39\u3002\u5bfe\u8ac7\u8005\u306e\u30c1\u30e3\u30c3\u30c8\u5c65\u6b74\u3002", "\u5bfe\u8a71\u8005\u306e\u30c1\u30e3\u30c3\u30c8\u5c65\u6b74\u306f\u3001\u5de6\u5074\u306e\u5bfe\u8ac7\u8005\u3092\u30af\u30ea\u30c3\u30af\u3059\u308b\u3068\u30d7\u30ec\u30a4\u3055\u308c\u307e\u3059\u3002", "\u30c8\u30c3\u30d7\u30e1\u30cb\u30e5\u30fc\u306b\u306f\u6b21\u306e\u3088\u3046\u306a\u3082\u306e\u304c\u542b\u307e\u308c\u3066\u3044\u307e\u3059\u3002", "\u5bfe\u8a71\u8005\u306e\u30a2\u30a4\u30b3\u30f3", "\u5bfe\u8a71\u8005\u306e\u30cb\u30c3\u30af\u30cd\u30fc\u30e0", "\u300c\u4f1a\u8a71\u306e\u958b\u59cb\u300d\u30dc\u30bf\u30f3", "\u300c\u30af\u30ea\u30a2\u5c65\u6b74\u300d\u30dc\u30bf\u30f3", "\u300c\u5bfe\u8a71\u8005\u306e\u524a\u9664\u300d\u30dc\u30bf\u30f3", "\u300c\u5bfe\u8a71\u8005\u306e\u30d7\u30ed\u30d5\u30a3\u30fc\u30eb\u300d\u30dc\u30bf\u30f3", "\u9078\u629e\u3057\u305f\u5bfe\u8ac7\u8005\u3068\u306e\u30c1\u30e3\u30c3\u30c8\u5c65\u6b74\u306f\u3001\u6b63\u3057\u3044\u90e8\u5206\u306b\u8868\u793a\u3055\u308c\u307e\u3059\u3002", "\u30c1\u30e3\u30c3\u30c8\u30bf\u30a4\u30c8\u30eb\u306b\u306f\u3001\u300c\u5bfe\u8a71\u8005\u306e\u8a00\u8a9e\u300d/\u300c\u3042\u306a\u305f\u306e\u8a00\u8a9e\u300d\u306e\u30da\u30a2\u304c\u756a\u53f7\u304c\u4ed8\u3051\u3089\u308c\u3066\u3044\u307e\u3059\u3002", "\u30c1\u30e3\u30c3\u30c8\u30bf\u30a4\u30c8\u30eb\u306b\u306f\u3001\u300c\u3053\u306e\u30c1\u30e3\u30c3\u30c8\u306e\u524a\u9664\u300d\u30dc\u30bf\u30f3\u304c\u542b\u307e\u308c\u3066\u3044\u307e\u3059\u3002", "[\u3053\u306e\u30c1\u30e3\u30c3\u30c8\u306e\u524a\u9664]\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3059\u308b\u3068\u3001\u3053\u306e\u30c1\u30e3\u30c3\u30c8\u306f\u5bfe\u8a71\u8005\u306e\u30c1\u30e3\u30c3\u30c8\u5c65\u6b74\u304b\u3089\u524a\u9664\u3055\u308c\u307e\u3059\u3002", "\u3059\u3079\u3066\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u306f2\u3064\u306e\u30b0\u30eb\u30fc\u30d7\u306b\u5206\u304b\u308c\u3066\u3044\u307e\u3059\u3002", "\u5bfe\u8a71\u8005\u304b\u3089\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u3002", "\u3042\u306a\u305f\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u3002", "\u5bfe\u8ac7\u8005\u304b\u3089\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u306f\u5de6\u306b\u30b7\u30d5\u30c8\u3055\u308c\u307e\u3059\u3002\u3042\u306a\u305f\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u306f\u53f3\u306b\u30b7\u30d5\u30c8\u3055\u308c\u307e\u3059\u3002", "\u5404\u30e1\u30c3\u30bb\u30fc\u30b8\u30b0\u30eb\u30fc\u30d7\u306f2\u3064\u306e\u30d1\u30fc\u30c4\u3067\u69cb\u6210\u3055\u308c\u3066\u3044\u307e\u3059\u3002", "\u30e1\u30c3\u30bb\u30fc\u30b8\u30c6\u30ad\u30b9\u30c8\u5bfe\u8a71\u8005\u306e\u8a00\u8a9e\u3067\u306f\u3001\u3053\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u306e\u8272\u306f\u9ed2\u3067\u3059\u3002", "\u3042\u306a\u305f\u306e\u8a00\u8a9e\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u30c6\u30ad\u30b9\u30c8\u3001\u3053\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u306e\u8272\u306f\u7dd1\u3067\u3059\u3002", "\u30e1\u30c3\u30bb\u30fc\u30b8\u306e\u65e5\u4ed8\u306f\u3042\u306a\u305f\u306e\u8a00\u8a9e\u306b\u5bfe\u5fdc\u3057\u307e\u3059\u3002", "\u65b0\u3057\u3044\u30e1\u30c3\u30bb\u30fc\u30b8\uff08\u65e5\u4ed8\u3054\u3068\u306b\uff09\u306f\u3001\u53e4\u3044OONE\u3088\u308a\u3082\u4f4e\u304f\u914d\u7f6e\u3055\u308c\u3066\u3044\u307e\u3059\u3002", "\u5bfe\u8a71\u8005\u306e\u30c1\u30e3\u30c3\u30c8\u306e\u4e00\u756a\u4e0b\u306b\u306f\u3001\u300c\u4f1a\u8a71\u306e\u958b\u59cb\u300d\u30dc\u30bf\u30f3\u304c\u3042\u308a\u307e\u3059\u3002\u30af\u30ea\u30c3\u30af\u3059\u308b\u3068\u3001\u30d7\u30ed\u30b0\u30e9\u30e0\u306f\u30de\u30a4\u30af\u3068\u30b5\u30a6\u30f3\u30c9\u30c7\u30d0\u30a4\u30b9\u306e\u6821\u6b63\u3092\u958b\u59cb\u3057\u3066\u3001\u4fe1\u53f7/\u30ce\u30a4\u30ba\u30ec\u30d9\u30eb\u3092\u6c7a\u5b9a\u3057\u3001\u5bfe\u5fdc\u3059\u308b\u30e1\u30c3\u30bb\u30fc\u30b8\u3092\u8868\u793a\u3057\u307e\u3059\u3002", "\u30b5\u30a6\u30f3\u30c9\u30c7\u30d0\u30a4\u30b9\u3092\u6821\u6b63\u3057\u305f\u5f8c\u3001\u30dc\u30bf\u30f3\u306e\u540d\u524d\u304c\u5909\u66f4\u3055\u308c\u307e\u3059\uff1a\u300c\u4f1a\u8a71\u3092\u958b\u59cb\u300d - >\u300c\u4f1a\u8a71\u3092\u505c\u6b62\u3057\u307e\u3059\u300d\u3002", "\u3053\u306e\u6642\u70b9\u304b\u3089\u3001\u4f1a\u8a71\u3092\u958b\u59cb\u3057\u305f\u308a\u3001\u30aa\u30fc\u30c7\u30a3\u30aa/\u30d3\u30c7\u30aa\u30d5\u30a1\u30a4\u30eb\u3092\u8d77\u52d5\u3057\u3066\u30e9\u30a4\u30f3\u306b\u8d77\u52d5\u3057\u305f\u308a\u3067\u304d\u307e\u3059\u3002", "\u3059\u3079\u3066\u306e\u7740\u4fe1\u30e1\u30c3\u30bb\u30fc\u30b8\uff08\u4ed6\u306e\u4eba\u304b\u3089\uff09\u304c\u5de6\u306b\u8868\u793a\u3055\u308c\u307e\u3059\u3002", "\uff08\u3042\u306a\u305f\u304b\u3089\uff09\u3059\u3079\u3066\u306e\u5916\u51fa\u30e1\u30c3\u30bb\u30fc\u30b8\u304c\u53f3\u306b\u8868\u793a\u3055\u308c\u307e\u3059\u3002", "\u3042\u306a\u305f\u306f\u3042\u306a\u305f\u306e\u8a00\u8a9e\u3067\u30e1\u30c3\u30bb\u30fc\u30b8\u3092\u805e\u304d\u3001\u3042\u306a\u305f\u306e\u4ed6\u306e\u4eba\u306f\u5f7c\u3089\u306e\u8a00\u8a9e\u3067\u30e1\u30c3\u30bb\u30fc\u30b8\u3092\u805e\u304f\u3067\u3057\u3087\u3046\u3002", "\u4f1a\u8a71\u306e\u6700\u5f8c\u306b\u3001\u30d3\u30c7\u30aa\u3092\u805e\u3044\u3066\u3044\u308b\u3068\u304d\u306b\u3001\u300c\u4f1a\u8a71\u3092\u505c\u6b62\u3059\u308b\u300d\u30dc\u30bf\u30f3\u306e1\u3064\u3092\u30af\u30ea\u30c3\u30af\u3059\u308b\u5fc5\u8981\u304c\u3042\u308a\u307e\u3059\u3002", "\u4f1a\u8a71\u306f\u6b21\u306e\u5834\u5408\u306b\u3082\u7d42\u4e86\u3057\u307e\u3059\u3002", "\u30a4\u30f3\u30bf\u30fc\u30ed\u30af\u30bf\u30fc\u306e\u30ea\u30b9\u30c8\u306e\u30d6\u30e9\u30a6\u30b6\u306e\u5de6\u5074\u306e\u4ed6\u306e\u4eba\u3092\u30af\u30ea\u30c3\u30af\u3057\u307e\u3059\u3002", "\u5bfe\u8a71\u8005\u306e\u30ea\u30b9\u30c8\u306e\u4e0a\u90e8\u306b\u3042\u308b\u300c\u65b0\u3057\u3044\u300d\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3057\u307e\u3059\u3002", "\u30c8\u30c3\u30d7\u30e1\u30cb\u30e5\u30fc\u306e[\u30d8\u30eb\u30d7]\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3057\u307e\u3059\u3002", "\u30c8\u30c3\u30d7\u30e1\u30cb\u30e5\u30fc\u306e[\u5c65\u6b74\u3092\u30af\u30ea\u30a2]\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3057\u307e\u3059\u3002", "\u30c8\u30c3\u30d7\u30e1\u30cb\u30e5\u30fc\u306e\u300cdreate interlocutor\u300d\u3092\u30af\u30ea\u30c3\u30af\u3057\u307e\u3059\u3002", "\u30c8\u30c3\u30d7\u30e1\u30cb\u30e5\u30fc\u306e[\u5bfe\u8a71\u8005\u306e\u30d7\u30ed\u30d5\u30a1\u30a4\u30eb]\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3057\u307e\u3059\u3002", "\u30c8\u30c3\u30d7\u30e1\u30cb\u30e5\u30fc\u306e[\u7d42\u4e86]\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3057\u307e\u3059\u3002", "\u30e1\u30cb\u30e5\u30fc\u306e\u5de6\u4e0a\u90e8\u5206\uff08\u7dd1\u8272\u306e\u77e2\u5370\uff09\u306b\u30e1\u30c3\u30bb\u30fc\u30b8\u8868\u793a\u30aa\u30d7\u30b7\u30e7\u30f3\u3092\u9078\u629e\u3059\u308b\u3053\u3068\u306b\u3088\u308a\u3001\u30c1\u30e3\u30c3\u30c8\u5c65\u6b74\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u306e\u8868\u793a\u304c\u30ab\u30e9\u30b9\u306b\u306a\u308a\u307e\u3057\u305f\u3002", "\u300c\u3059\u3079\u3066\u306e\u8a00\u8a9e\u300d\u3092\u9078\u629e\u3059\u308b\u3068\u304d - \u5bfe\u8a71\u8005\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u3068\u30e1\u30c3\u30bb\u30fc\u30b8\u306f\u3059\u3079\u3066\u306e\u8a00\u8a9e\u3067\u8868\u793a\u3055\u308c\u307e\u3059\u3002", "\u300c\u79c1\u306e\u8a00\u8a9e\u300d\u3092\u9078\u629e\u3059\u308b\u3068\u304d - \u5bfe\u8a71\u8005\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u3068\u3042\u306a\u305f\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u306f\u3042\u306a\u305f\u306e\u8a00\u8a9e\u3067\u306e\u307f\u8868\u793a\u3055\u308c\u307e\u3059\u3002", "\u300c\u5bfe\u8a71\u8005\u306e\u8a00\u8a9e\u300d\u3092\u9078\u629e\u3059\u308b\u5834\u5408\u3001\u5bfe\u8a71\u8005\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u3068\u30e1\u30c3\u30bb\u30fc\u30b8\u306f\u5bfe\u8ac7\u8005\u306e\u8a00\u8a9e\u3067\u306e\u307f\u8868\u793a\u3055\u308c\u307e\u3059\u3002", "\u30c7\u30d5\u30a9\u30eb\u30c8\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u8868\u793a\u30e2\u30fc\u30c9\u306f\u300c\u3059\u3079\u3066\u306e\u8a00\u8a9e\u300d\u3067\u3059\u3002", "\u300c\u30af\u30ea\u30a2\u5c65\u6b74\u300d\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3059\u308b\u3068\u3001\u5bfe\u8ac7\u8005\u3068\u306e\u3059\u3079\u3066\u306e\u30c1\u30e3\u30c3\u30c8\u304c\u524a\u9664\u3055\u308c\u307e\u3059\u304c\u3001\u5bfe\u8ac7\u8005\u306f\u6b8b\u308a\u307e\u3059\u3002\u56f310\u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002", "\u56f310\u3002\u5bfe\u8ac7\u8005\u306e\u6b74\u53f2\u306e\u30af\u30ea\u30a2\u3002", "\u5bfe\u8ac7\u8005\u3068\u306e\u30c1\u30e3\u30c3\u30c8\u304c\u73fe\u5728\u9032\u884c\u4e2d\u3067\u3042\u308b\u5834\u5408\u3001\u505c\u6b62\u3057\u307e\u3059\u3002", "\u300c\u4ecb\u8b77\u8005\u300d\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3059\u308b\u3068\u3001\u5bfe\u8a71\u8005\u3068\u5bfe\u8ac7\u8005\u81ea\u8eab\u3068\u306e\u3059\u3079\u3066\u306e\u30c1\u30e3\u30c3\u30c8\u3092\u524a\u9664\u3057\u307e\u3059\u3002\u56f311\u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002", "\u56f311\u3002\u5bfe\u8ac7\u8005\u306e\u524a\u9664\u3002", "\u5bfe\u8ac7\u8005\u3068\u306e\u30c1\u30e3\u30c3\u30c8\u304c\u73fe\u5728\u9032\u884c\u4e2d\u3067\u3042\u308b\u5834\u5408\u3001\u505c\u6b62\u3057\u307e\u3059\u3002", "[\u5bfe\u8a71\u8005\u306e\u30d7\u30ed\u30d5\u30a1\u30a4\u30eb]\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3059\u308b\u3068\u3001\u5bfe\u8a71\u8005\u306e\u30c7\u30fc\u30bf\u3067\u6e80\u305f\u3055\u308c\u305f\u30d5\u30a9\u30fc\u30e0\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002\u56f312\u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002", "\u56f312\u3002\u5bfe\u8ac7\u8005\u306e\u30d7\u30ed\u30d5\u30a3\u30fc\u30eb\u306e\u8868\u793a\u3002", "\u3053\u306e\u30a2\u30a4\u30c6\u30e0\u306f\u30a2\u30a4\u30c6\u30e0\u306b\u4f3c\u3066\u3044\u307e\u3059", "\u5782\u76f4\u30bb\u30d1\u30ec\u30fc\u30bf\u30fc\u3092\u4f7f\u7528\u3059\u308b\u3068\u3001\u30ef\u30fc\u30af\u30b9\u30da\u30fc\u30b9\u306e\u5de6\u53f3\u306e\u9818\u57df\u306e\u5e45\u3092\u5909\u66f4\u3067\u304d\u307e\u3059\u3002\u56f313\u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002", "\u56f313\u3002\u5de6\u304a\u3088\u3073\u53f3\u90e8\u306e\u5782\u76f4\u30bb\u30d1\u30ec\u30fc\u30bf\u30fc\u3002", "\u5782\u76f4\u30bb\u30d1\u30ec\u30fc\u30bf\u30fc\u3092\u79fb\u52d5\u3059\u308b\u3068\u3001\u305d\u306e\u4f4d\u7f6e\u304c\u4fdd\u5b58\u3055\u308c\u307e\u3059\u3002\u30d7\u30ed\u30b0\u30e9\u30e0\u3092\u518d\u8d77\u52d5\u3059\u308b\u3068\u3001\u8a2d\u5b9a\u3057\u305f\u6700\u5f8c\u306e\u4f4d\u7f6e\u304c\u5fa9\u5143\u3055\u308c\u307e\u3059\u3002", "\u753b\u9762\u306e\u53f3\u4e0b\u9685\u306b\u3042\u308b\u30b9\u30d4\u30fc\u30ab\u30fc\u753b\u50cf\u306e\u4e0a\u306b\u30de\u30a6\u30b9\u30ab\u30fc\u30bd\u30eb\u3092\u79fb\u52d5\u3057\u3001\u53f3\u30af\u30ea\u30c3\u30af\u3057\u3066\u3001\u56f314\u306b\u793a\u3059\u3088\u3046\u306b\u300c\u30aa\u30fc\u30d7\u30f3\u30b5\u30a6\u30f3\u30c9\u8a2d\u5b9a\u300d\u30e1\u30cb\u30e5\u30fc\u9805\u76ee\u3092\u9078\u629e\u3057\u307e\u3059\u3002", "\u56f314\u3002\u958b\u304f\u30b5\u30a6\u30f3\u30c9\u8a2d\u5b9a\u3002", "\u73fe\u5728\u306e\u30b5\u30a6\u30f3\u30c9\u8a2d\u5b9a\u304c\u3042\u308b\u753b\u9762\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002", "\u56f315\u3002\u73fe\u5728\u306e\u30b5\u30a6\u30f3\u30c9\u8a2d\u5b9a\u3002", "\u30bf\u30b9\u30af\u3092\u958b\u59cb\u3059\u308b\u524d\u306b\u3042\u3063\u305f\u521d\u671f\u5024\u3092\u5fa9\u5143\u3057\u307e\u3059\u3002\u3042\u306a\u305f\u306e\u5834\u5408\u3001\u540d\u524d\u306f\u7570\u306a\u308a\u307e\u3059\u3002", "\u56f316\u3002\u521d\u671f\u30b5\u30a6\u30f3\u30c9\u8a2d\u5b9a\u3002", "\u30b7\u30b9\u30c6\u30e0\u8a2d\u5b9a\u304c\u5fa9\u5143\u3055\u308c\u3066\u304a\u308a\u3001Windows\u3067\u52d5\u4f5c\u3067\u304d\u307e\u3059\u3002"]