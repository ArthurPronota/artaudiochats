["\u12e8\u1355\u122e\u130d\u122b\u1219 \"\u12e8\u12f5\u121d\u1345 \u12cd\u12ed\u12ed\u1276\u127d\" \u1218\u130d\u1208\u132b.", "\u12ed\u12d8\u1276\u127d", "1. \u12a8\u1218\u1300\u1218\u122d\u12ce \u1260\u134a\u1275.", "2. \u12a0\u132d\u122d \u1218\u130d\u1208\u132b.", "3. \u1208\u1218\u130d\u1263\u1263\u1275 \u12e8\u121a\u1308\u1299\u1275\u1295 \u124b\u1295\u124b\u12ce\u127d \u12dd\u122d\u12dd\u122d.", "4. \u1218\u122d\u1203\u130d\u1265\u1229 \u12a5\u1295\u12f2\u1220\u122b \u12e8\u121a\u1348\u120d\u1309\u1275 \u1290\u1308\u122d.", "5. \u12a8\u1355\u122e\u130d\u122b\u1219 \u130b\u122d \u12a0\u1265\u122e \u1218\u1225\u122b\u1275.", "5.1 \u12cd\u1245\u122d.", "5.2 \u12e8\u12a0\u12f2\u1235 \u1270\u12a8\u120b\u12ab\u12ed \u1218\u1308\u1208\u132b.", "5.3 \u12e8\u12a5\u1308\u12db \u12ad\u134d\u120d.", "5.4 \u1218\u12cd\u132b \u1241\u120d\u134d.", "5.5 \u12e8\u1218\u1308\u1293\u129b\u12ce\u127d \u12dd\u122d\u12dd\u122d.", "5.6 \u12e8\u1218\u122b\u1260\u122a\u12eb \u1308\u1260\u12eb \u1273\u122a\u12ad.", "5.7 \u12e8\u12a0\u12ab\u1263\u1262\u12eb\u12ca\u12cd\u1295 \u1273\u122a\u12ad \u121b\u133d\u12f3\u1275.", "5.8 \u12a0\u1295\u12f5 \u1323\u120d\u1243 \u1308\u1265\u1290\u1275 \u1218\u1230\u1228\u12dd.", "5.9 \u12e8\u12cb\u1293 \u1218\u130e\u1293\u1338\u134a\u12eb \u1218\u1308\u1208\u132b\u12cd\u1295 \u1218\u1218\u120d\u12a8\u1275.", "\u1260\u130d\u122b \u12a5\u1293 \u1260\u1240\u129d \u12ad\u134d\u120e\u1279 \u1218\u12ab\u12a8\u120d 5.10 \u12a0\u1240\u1263\u12ca \u1218\u1208\u12eb\u12e8\u1275.", "6. \u1225\u122b\u1295 \u12a8\u1328\u1228\u1231 \u1260\u128b\u120b.", "\u12e8\u1218\u12f3\u134a\u1275 \u1320\u124b\u121a \u1260\u121b\u12eb\u1313\u121a \u121d\u1235\u1209 \u1260\u1273\u127d\u129b\u12cd \u1240\u129d \u12a0\u132b\u132d\u122d \u1325\u130d \u120b\u12ed \u1263\u1208\u12cd \u12a5\u1293 \u1260\u121b\u12eb\u1313\u121a\u12cd \u121d\u1235\u1209 \u120b\u12ed \u12a5\u1293 \u1260\u1240\u129d \u1320\u1245\u1273 \u1260\u1270\u1293\u1325\u120d \u120b\u12ed \u12eb\u1208\u12cd \u12e8\u12f5\u121d\u1345 \u121b\u1309\u12eb \u12a0\u132b\u12cd\u1275, \u12ad\u134d\u1275 \u12e8\u12f5\u121d\u1345 \u1245\u1295\u1265\u122e\u127d \"\u121d\u1293\u120c \u1295\u1325\u120d, \u12a5\u1295\u12f0 Sharness.", "\u121d\u1235\u120d 1. \u12ad\u134d\u1275 \u12e8\u12f5\u121d\u1345 \u1245\u1295\u1305\u1276\u127d.", "\u12a0\u1201\u1295 \u12ab\u1208\u12cd \u12e8\u12f5\u121d\u1345 \u1245\u1295\u1265\u122e\u127d \u130b\u122d \u12a0\u1295\u12f5 \u121b\u12eb \u1308\u133d \u12ed\u1273\u12eb\u120d. \u1208\u130d\u1264\u1275 \u12a5\u1293 \u12cd\u132b\u12ca \u12e8\u12f5\u121d\u1345 \u1218\u1223\u122a\u12eb\u12ce\u127d \u121d\u1295 \u12a5\u1295\u12f0\u121a\u12cb\u1240\u122d \u12eb\u1235\u1273\u12cd\u1231. \u1225\u122b\u1295 \u12a8\u1328\u1228\u1231 \u1260\u128b\u120b \u12ed\u1205\u1295\u1295 \u1218\u1228\u1303 \u12eb\u1235\u1348\u120d\u130d\u12ce\u1273\u120d. \u1260\u1235\u12a5\u120d 2, \u1240\u12ed \u134d\u120b\u133b\u12ce\u127d \u1208\u121b\u1235\u1273\u12c8\u1235 \u12e8\u121a\u1348\u120d\u1309\u1275\u1295 \u12eb\u1233\u12eb\u1209. \u1260\u1309\u12f3\u12ed\u12ce \u12cd\u1235\u1325 \u1235\u121e\u1279 \u12e8\u1270\u1208\u12eb\u12e9 \u12ed\u1206\u1293\u1209.", "\u121d\u1235\u120d 2 \u12e8\u1218\u1300\u1218\u122a\u12eb \u12e8\u12f5\u121d\u1345 \u1245\u1295\u1305\u1276\u127d", "\u12e8\u12f5\u121d\u1345 \u12cd\u1345\u12d3\u1275 \u1218\u1223\u122a\u12eb\u12cd\u1295 \u1208", "\u12e8\u12f5\u121d\u1345 \u130d\u1264\u1275 \u1218\u1223\u122a\u12eb\u12cd\u1295 \u1208", "\u1260\u1235\u12a5\u120d 3, \u12e8\u1240\u12ed \u134d\u120b\u133b\u12ce\u127d \u121d\u1295 \u12a5\u1295\u12f0\u121a\u12eb\u12f0\u122d\u1309 \u12a5\u1293 \u121d\u1295 \u121b\u12d8\u130b\u1300\u1275 \u12a5\u1295\u12f3\u1208\u1265\u12ce \u12eb\u1233\u12eb\u1209.", "\u1235\u12a5\u120d 3; \u12e8\u1235\u122b \u12e8\u12f5\u121d\u1345 \u1245\u1295\u1305\u1276\u127d", "\u12e8\u1235\u122d\u12d3\u1275 \u1245\u1295\u1265\u122e\u127d \u12e8\u1270\u1320\u1293\u1240\u1241 \u1293\u1278\u12cd, \u1355\u122e\u130d\u122b\u1219\u1295 \u121b\u12ab\u1204\u12f5 \u12ed\u127d\u120b\u1209", "\u12a5\u122d\u1235\u12ce \u12e8\u121a\u12eb\u12cd\u1241\u1275\u1295 \u124b\u1295\u124b \u12ed\u1293\u1308\u122b\u1209, \u1323\u120d\u1243 \u1308\u1265\u1290\u1275\u12ce \u1260\u121a\u1308\u1263\u12cd \u124b\u1295\u124b \u1232\u1230\u121b \u12a5\u122d\u1235\u12ce \u12ed\u1230\u121b\u1209. \u12a5\u122d\u1235\u12ce \u12e8\u121a\u1348\u120d\u1313\u1278\u12cd \u12e8\u12ae\u1295\u1230\u122d\u1275\u12ce \u1235\u122d \u121d\u12dd\u1308\u1263 \u12ed\u12f0\u1228\u130b\u120d. \u1201\u1209\u121d \u12ad\u12cb\u1294\u12ce\u127d \u1260\u12ae\u121d\u1352\u1270\u122d\u12ce \u120b\u12ed \u12e8\u121a\u12a8\u1293\u12c8\u1290\u12cd \u1260\u12ca\u1295\u12f6\u12cd\u1235 10 \u12c8\u12ed\u121d \u12ca\u1295\u12f6\u12cd\u1235 11 \u120b\u12ed \u1260\u121a\u1230\u1229\u1260\u1275 \u1260\u12ae\u121d\u1352\u1270\u122d\u12ce \u120b\u12ed \u12e8\u121a\u12a8\u1293\u12c8\u1291 \u1293\u1278\u12cd. \u1218\u122d\u1203\u130d\u1265\u1229 \u12a5\u1295\u12f2\u1220\u122b \u12e8\u130d\u122b\u134a\u12ad\u1235 \u1355\u122e\u1304\u12ad\u1275 \u12e8\u1270\u1348\u1208\u1308\u12cd \u1290\u12cd, \u130d\u1295 \u12a0\u12ed\u1320\u12e8\u1245\u121d, \u130d\u1295 \u12a0\u12ed\u1320\u12e8\u1245\u121d, \u12a0\u12ed\u1320\u12e8\u1245\u121d, \u12a0\u12ed\u1320\u12e8\u1245\u121d, \u12a0\u12ed\u12f0\u1208\u121d. \u12e8\u1275\u122d\u1309\u1219 \u1325\u122b\u1275 \u1260\u130d\u122b\u134a\u12ad\u1235 \u12a0\u1295\u130e\u1208\u129d \u1270\u123b\u123d\u120f\u120d.", "\u12a8\u12da\u1205 \u12dd\u122d\u12dd\u122d \u12cd\u1235\u1325 \u12a0\u1295\u12f1\u1295 \u12a8\u1270\u1228\u12f1 \u12a8\u12da\u1205 \u12dd\u122d\u12dd\u122d \u12cd\u1235\u1325 \u12a8\u121b\u1295\u129b\u12cd\u121d \u1230\u12cd \u124b\u1295\u124b \u12a8\u12a0\u1308\u122d \u12cd\u1235\u1325 \u1270\u1293\u130b\u122a \u130b\u122d \u1218\u1308\u1293\u1298\u1275 \u12ed\u127d\u120b\u1209. \u1218\u130d\u1263\u1263\u1275 \u1260\u1274\u120c\u130d\u122b\u121d, WhatsApp, WhatsApp, Google \u1270\u1308\u1293\u129d, \u12ce\u12ac\u121a\u1295\u130d, \u12e9\u1293\u12ed\u1275\u12f5 \u1235\u1274\u1275\u1235 \u12a5\u1293 \u121b\u1295\u129b\u12cd\u121d \u120c\u120b \u1218\u120d\u12a5\u12ad\u1275. \u1260\u121b\u1295\u129b\u12cd\u121d \u12e8\u1292\u12ac\u1272 \u124b\u1295\u124b\u12ce\u127d \u12dc\u1293, \u12e8\u1225\u120d\u1320\u1293 \u12ae\u122d\u1235 \u12a5\u1293 \u120c\u120e\u127d \u1356\u12f5\u12ab\u12ce\u127d\u1295 \u121b\u12f3\u1218\u1325 \u12ed\u127d\u120b\u1209. \u12a0\u1201\u1295 \u1260\u12cd\u132d \u12a9\u1263\u1295\u12eb\u12ce\u127d \u12a5\u1293 \u1265\u12d9 \u12cd\u1235\u1325 \u1243\u1208\u1218\u1320\u12ed\u1246\u12ce\u127d\u1295 \u121b\u1208\u134d \u12ed\u127b\u120b\u120d. \u12a5\u1295\u12f2\u1201\u121d \u12a6\u12f2\u12ee / \u126a\u12f2\u12ee \u134b\u12ed\u120d\u1295 \u1260\u12cd\u132d \u12a0\u1308\u122d \u124b\u1295\u124b \u1218\u132b\u12c8\u1275 \u12a5\u1293 \u1260\u124b\u1295\u124b\u12ce \u12cd\u1235\u1325 \u1218\u1235\u121b\u1275 \u12ed\u127d\u120b\u1209. \u12a8\u130e\u1295 \u12a0\u1355\u120a\u12ac\u123d\u1291 \u12cd\u1235\u1325 \u12a0\u1295\u12f1 \u1270\u1218\u1233\u1233\u12ed \u124b\u1295\u124b \u12a8\u1270\u1218\u1233\u1230\u1208 \u124b\u1295\u124b \u130b\u122d \u12cd\u12ed\u12ed\u1275 \u1290\u12cd, \u130d\u1295 \u12e8\u12a5\u122d\u1235\u12ce \u1323\u120d\u1243\u1308\u1265\u1290\u1275 \u12e8\u1218\u1290\u1328\u12cd\u1295 \u1205\u120a\u1293 \u12ed\u1230\u121b\u120d. \u12e8\u12a5\u122b\u1235\u12ce \u12f5\u121d\u1345 \u12a0\u12ed\u12f0\u1208\u121d. \u1276\u1235 \u12ed\u1205 \u12a0\u1235\u1348\u120b\u130a \u1290\u12cd. \u1265\u12d9 \u120a\u1206\u1291 \u12e8\u121a\u127d\u1209 \u1275\u130d\u1260\u122b\u12ce\u127d \u12a0\u1209.", "\u12a6\u1355\u122c\u1272\u1295\u130d \u1232\u1235\u1270\u121d \u12ca\u1295\u12f6\u12cd\u1235 10 \u12c8\u12ed\u121d \u12ca\u1295\u12f6\u12cd\u1235 11.", "\u1203\u122d\u12f5 \u12f5\u122b\u12ed\u126d \u1266\u1273 8 \u130a\u1263 \u12ed\u1308\u129b\u120d.", "\u122b\u121d \u12a8 10 \u130a\u1263.", "\u1302\u1352\u12e9 (\u130d\u122b\u134a\u12ad\u1235 \u121b\u1240\u1290\u1263\u1260\u122a\u12eb \u12a0\u1203\u12f5) \u12a8 6 \u130a\u1263 \u12c8\u12ed\u121d \u12a8\u12da\u12eb \u1260\u120b\u12ed, \u12a8\u1270\u1348\u1208\u1308 \u130d\u1295 \u12a0\u1235\u1348\u120b\u130a \u12a0\u12ed\u12f0\u1208\u121d.", "\u12e8\u1306\u122e \u121b\u12f3\u1218\u132b\u12ce\u127d \u121b\u12ed\u12ad\u122e\u134e\u1296\u127d \u130b\u122d.", "\u12a8\u1355\u122e\u130d\u122b\u1219 \u130b\u122d \u12a0\u1265\u122e \u12e8\u1218\u1235\u122b\u1275 \u12a0\u1320\u1243\u120b\u12ed \u1260\u12ed\u1290\u1308\u133d \u12a8\u12a0\u1233\u1239 \u12ed\u12a8\u1293\u12c8\u1293\u120d.", "\"\u12cd\u1245\u122d\" \u1241\u120d\u134d\u1295 \u1320\u1245 \u1232\u12eb\u12f0\u122d\u1309, \u12a5\u1293 \u12a8\u12cb\u1293\u12cd \u12e8\u1235\u122b \u121b\u1235\u1308\u1262\u12eb \u1218\u1208\u12aa\u12eb\u12ce\u127d \u130b\u122d \u1245\u133d \u1260\u1273\u12e8 \u121d\u1293\u120c \u12cd\u1235\u1325 \u12ed\u1273\u12eb\u120d. \u121d\u1235\u120d 4 \u1295 \u12ed\u1218\u120d\u12a8\u1271.", "\u1235\u12a5\u120d 4. \u12cd\u1245\u122d.", "\u12e8\u12cd\u1245\u1228\u1275 \u12ad\u134d\u120d \u12cb\u1293 \u12cb\u1293 \u12e8\u1235\u122b \u121b\u1235\u12ac\u1303 \u1218\u1208\u12aa\u12eb\u12ce\u127d \u12ed contains \u120d", "\u124b\u1295\u124b - \u12e8\u121d\u1275\u1293\u1308\u122f\u1278\u12cd\u1295 \u124b\u1295\u124b \u121b\u12d8\u130b\u1300\u1275.", "\u12f5\u121d\u1345 - \u12e8\u12a0\u123d\u12a8\u122d\u12ab\u122a\u12cd \u1235\u121d \u1208\u12f5\u121d\u133d\u12ce-\u1270\u12ae\u122d \u1218\u1223\u122a\u12eb\u12ce.", "\u121b\u12ed\u12ad\u122e\u134e\u1295 - \u12e8\u121b\u123d\u12a8\u122d\u12a8\u122a\u12eb \u1235\u121d \u121b\u12ed\u12ad\u122e\u134e\u1291 \u1235\u121d.", "\u12e8\u12f5\u122d \u12a0\u1233\u123d - \u12e8\u121a\u1230\u1229\u1260\u1275 \u12a0\u1233\u123d \u1235\u121d.", "\u124b\u1295\u124b\u12cd\u1295 \u1232\u1240\u12ed\u1229 \u12a5\u1293 \u12e8\u12cd\u1245\u1228\u1275 \u1245\u1295\u1265\u122e\u127d\u1295 \u1232\u1240\u12f0\u12f1, \u1201\u1209\u121d \u133d\u1211\u134d, \u1218\u130d\u1208\u132b\u12ce\u127d, \u12e8\u12a0\u1228\u1349 \u1235\u121e\u127d \u12a5\u1293 \u120c\u120e\u127d \u133d\u1211\u134e\u127d \u1260\u12a0\u12f2\u1231 \u124b\u1295\u124b \u12ed\u1273\u12eb\u1209. \u12a0\u12f2\u1235 \u127b\u1275\u1235 \u12c8\u12f0\u1270\u1218\u1228\u1320\u12cd \u124b\u1295\u124b \u12ed\u1270\u1228\u1309\u121b\u1209, \u12a5\u1293\u121d \u1260\u12da\u1205 \u12a0\u12f2\u1235 \u124b\u1295\u124b \u1295\u130d\u130d\u122d\u1295 \u12ed\u1230\u121b\u1209. \u1235\u1208 \u12e8\u12f5\u122d \u1230\u134b\u12cd \u1218\u1208\u12aa\u12eb \u12a0\u1235\u1348\u120b\u130a \u121b\u1235\u1273\u12c8\u123b. \u1260\u1290\u1263\u122a, \u12e8\u12f5\u122d \u1230\u122b\u123d \u130d\u1264\u1275 \u1201\u120d\u130a\u12dc \u1260\u12ca\u1295\u12f6\u12cd\u1235 \u12cd\u1235\u1325 \u12e8\u1270\u132b\u1290 \u1235\u1208\u1206\u1290 \u12c8\u12f0 \u121b\u12ed\u12ad\u122e\u1236\u134d\u1275 \u1320\u122d\u12dd \u1270\u12d8\u130b\u1305\u1277\u120d. \u1208\u12da\u1205 \u130d\u1264\u1275, \u12e8\u1270\u132b\u1290\u12cd\u1295 \u12a0\u1233\u123d \u1265\u127b \u12ed\u121d\u1228\u1321 \u12a5\u1293 \u1260\u12a0\u1220\u122b\u122d \u1235\u122d\u12d3\u1275\u12ce \u120b\u12ed \u12e8\u121a\u1230\u122b\u12cd\u1295 \u12a0\u1233\u123d \u1265\u127b \u12ed\u121d\u1228\u1321.", "\u12a0\u12f2\u1231\u1295 \u1241\u120d\u134d \u1320\u1245 \u121b\u12f5\u1228\u130d Aww parlogergorder \u1208\u1218\u1219\u120b\u1275 \u12a0\u1295\u12f5 \u1245\u133d \u12eb\u1233\u12eb\u120d. \u121d\u1235\u120d 5 \u1295 \u12ed\u1218\u120d\u12a8\u1271.", "\u1235\u12a5\u120d 5; \u12a0\u12f2\u1235 \u12e8\u12a0\u12ed\u1272 \u1218\u1246\u1323\u1320\u122a\u12eb \u1218\u1308\u1208\u132b", "\"\u12a0\u12f2\u1231 \u12e8\u1218\u1208\u1320\u1325 \u12a6\u1355\u122c\u123d\u1295 \u1218\u1308\u1208\u132b\" \u12ad\u134d\u120d \u12cb\u1293\u12cd\u1295 \u12e8\u1225\u122b \u121b\u1235\u12ac\u1303 \u1218\u1208\u12aa\u12eb\u12ce\u127d \u12ed contains \u120d", "\u1245\u133d\u120d \u1235\u121d - \u1208\u12ad\u134d\u12eb\u12ce \u12e8\u1218\u1228\u1321\u1275 \u1235\u121d.", "\u124b\u1295\u124b - \u12e8\u12a5\u122d\u1235\u12ce \u1323\u120d\u1243-\u1308\u1265\u1290\u1275\u12ce \u12e8\u121a\u1293\u1308\u122d\u1260\u1275 \u124b\u1295\u124b.", "\u1218\u130d\u1208\u132b - \u12e8\u12a0\u12ab\u1263\u1262\u12eb\u12ca\u12ce \u1218\u130d\u1208\u132b \u1218\u130d\u1208\u132b.", "\u121b\u12ed\u12ad\u122e\u134e\u1295 \u12ed\u1320\u1240\u1219 - \u12e8\u121b\u12ed\u12ad\u122e\u134e\u1291\u1295 \u12e8\u12a0\u1320\u1243\u1240\u121d \u1263\u1295\u12f2\u122b \u12eb\u12d8\u130b\u1301.", "\u121d\u1235\u120d - \u1208\u12a0\u12f6\u12ce\u127d \u12a0\u12f6\u12cd\u1295 \u12eb\u12d8\u130b\u1301.", "\u1208\u12ad\u134d\u1208-\u1218\u1208\u12a8\u1275 \u121d\u1235\u120d \u12ab\u120d\u1218\u1228\u1321 \u1290\u1263\u122a\u12cd \u121d\u1235\u120d \u1208\u12a5\u1231 \u1325\u1245\u121d \u120b\u12ed \u12ed\u12cd\u120b\u120d.", "\"\u121b\u12ed\u12ad\u122e\u134e\u1291\u1295\" \u121b\u12ed\u12ad\u122e\u134e\u1295 \u12ed\u1320\u1240\u1219 \u12ab\u1295\u1275 (\u12dc\u1293, \u12a6\u12f2\u12ee \u1275\u121d\u1205\u122d\u1276\u127d, \u12c8\u12d8\u1270).", "\"\u12e8\u12a5\u1308\u12db\" \u12f0\u1205\u1295\u1290\u1275 \u1260\u124b\u1295\u124b\u12ce \u12a8\u1355\u122e\u130d\u122b\u1219 \u130b\u122d \u12a5\u1295\u12f4\u1275 \u12a5\u1295\u12f0\u121a\u1220\u122b \u12ed\u1308\u120d\u133b\u120d. \u1235\u12a5\u120d 6 \u1295 \u12ed\u1218\u120d\u12a8\u1271.", "\u1235\u12a5\u120d 6; \u12e8\u12a5\u122d\u12f3\u1273 \u12ad\u134d\u120d.", "\"\u1218\u12cd\u132b\" \u1241\u120d\u134d\u1295 \u1320\u1245 \u121b\u12f5\u1228\u130d \u1355\u122e\u130d\u122b\u1219\u1295 \u12eb\u124b\u122d\u1323\u120d. \u121d\u1235\u120d 7 \u1295 \u12ed\u1218\u120d\u12a8\u1271.", "\u1235\u12a5\u120d 7; \u12a8\u122d\u1240\u1275 \u12ed\u12cd\u1321.", "\u12e8\u12a0\u1233\u1239 \u1218\u1235\u12ae\u1271\u1295 \u1218\u12dd\u130b\u1275 \u12c8\u12ed\u121d \u12a0\u1233\u1239\u1295 \u1218\u12dd\u130b\u1275 \u1355\u122e\u130d\u122b\u1219\u1295 \u12eb\u1260\u1243\u120d.", "\u1308\u1339\u1295 \u12e8\u121a\u12eb\u12f5\u1235 \u1308\u1339\u1295 \u12e8\u121a\u12eb\u12f5\u1235 \u1206\u1296 \u1355\u122e\u130d\u122b\u1219\u1295 \u12eb\u1260\u1243\u120d.", "\u1260\u12a0\u1233\u1239 \u1260\u130d\u122b \u1260\u12a9\u120d \u12e8\u12a0\u12ab\u1263\u1262\u12eb\u12ca\u12ce \u12dd\u122d\u12dd\u122d \u1290\u12cd. \u121d\u1235\u120d 8 \u1295 \u12ed\u1218\u120d\u12a8\u1271.", "\u121d\u1235\u120d 8 \u12e8\u1218\u1308\u1293\u129b\u12ce\u127d \u12dd\u122d\u12dd\u122d.", "\u1208\u12a5\u12eb\u1295\u12f3\u1295\u12f1 \u1323\u120d\u1243 \u1308\u1265\u1290\u1275, \u12a0\u12f6\u12ce, \u12e8\u1218\u1328\u1228\u123b\u12cd \u1218\u120d\u12a5\u12ad\u1275 \u12a5\u1293 \u12e8\u1218\u1328\u1228\u123b\u12cd \u1218\u120d\u12a5\u12ad\u1275 \u133d\u1211\u134d \u1270\u1345\u12a5\u1296\u12ce\u127d \u12ed\u1273\u12eb\u1209. \u1270\u130d\u1263\u1229 \u12a8\u124b\u1295\u124b\u12ce \u130b\u122d \u12ed\u12db\u1218\u12f3\u120d. \u1260\u12a0\u1295\u12f5 \u1323\u120d\u1243\u1308\u1265\u1290\u1275 \u120b\u12ed \u1320\u1245 \u1232\u12eb\u12f0\u122d\u1309 \u12e8\u127b\u1275\u122a\u12ad \u1273\u122a\u12ad \u12ed\u1273\u12eb\u120d.", "\u12e8\u1218\u130d\u1263\u1262\u12eb\u12cd \u12e8\u12cd\u12ed\u12ed\u1275 \u1273\u122a\u12ad \u1260\u12a0\u1233\u1239 \u1260\u1240\u129d \u1260\u12a9\u120d \u12ed\u1308\u129b\u120d. \u121d\u1235\u120d 9 \u1295 \u12ed\u1218\u120d\u12a8\u1271.", "\u1235\u12a5\u120d 9; \u12e8\u1218\u122d\u12a8\u1265 \u12cb\u120d\u1273 \u12cd\u12ed\u12ed\u1275 \u1273\u122a\u12ad.", "\u12e8 Waterlackery \u12e8\u12cd\u12ed\u12ed\u1275 \u1273\u122a\u12ad \u1260\u130d\u122b \u1260\u12a9\u120d \u1260\u1270\u12ab\u1204\u12f0\u12cd \u1323\u120d\u1243\u1308\u1265\u1290\u1275 \u120b\u12ed \u1320\u1245 \u12ab\u12f0\u1228\u1309.", "\u12e8\u120b\u12ed\u129b\u12cd \u121d\u1293\u120c \u12ed\u12ed\u12db\u120d-", "\u12e8\u12cb\u130b \u1218\u120e\u130a\u12eb \u12a0\u12f6", "\u12e8\u12cb\u130b \u1218\u120e\u130a\u12eb \u1245\u133d\u120d \u1235\u121d", "\"\u1305\u121d\u122d \u12cd\u12ed\u12ed\u1275\" \u1241\u120d\u134d", "\"\u130d\u120d\u133d \u1273\u122a\u12ad\" \u1241\u120d\u134d", "\"\u12e8\u12cb\u130b \u1218\u120e\u130a\u12eb\" \u1241\u120d\u134d\u1295 \u1230\u122d\u12dd", "\"\u12e8\" ENGLACERORDRICER \u1218\u1308\u1208\u132b \"\u1241\u120d\u134d", "\u12a8\u1270\u1218\u1228\u1321\u1275 \u1353\u122d\u1272\u12ce\u127d \u130b\u122d \u12e8\u1270\u12f0\u1228\u1308\u12cd \u12e8\u12cd\u12ed\u12ed\u1275 \u1273\u122a\u12ad \u1260\u1275\u12ad\u12ad\u1208\u129b\u12cd \u12ad\u134d\u120d \u12ed\u1273\u12eb\u120d.", "\u12e8\u12cd\u12ed\u12ed\u1275 \u122d\u12d5\u1235 \u1260\u12a0\u1295\u12f5 \u1325\u1295\u12f5 \u121b\u1235\u1273\u12c8\u123b\u12ce\u127d \"intlayorder \u124b\u1295\u124b\" / \"\u124b\u1295\u124b\u1205\".", "\u12e8\u12cd\u12ed\u12ed\u1275 \u122d\u12d5\u1235 \"\u12ed\u1205\u1295 \u12cd\u12ed\u12ed\u1275 \u1230\u122d\u12dd\" \u1241\u120d\u134d\u1295 \u12ed contains \u120d.", "\"\u12ed\u1205\u1295 \u127b\u1275 \u1230\u122d\u12dd\" \u12e8\u121a\u1208\u12cd\u1295 \u1241\u120d\u134d \u1320\u1245 \u1232\u12eb\u12f0\u122d\u1309 \u12ed\u1205 \u12cd\u12ed\u12ed\u1275 \u12a8\u1225\u122b \u1308\u1260\u12eb\u122a \u12ce\u122d\u12ad \u1273\u122a\u12ad \u12ed\u1230\u1228\u12db\u120d.", "\u1201\u1209\u121d \u1218\u120d\u12a5\u12ad\u1276\u127d \u1260 2 \u1261\u12f5\u1296\u127d \u1270\u12a8\u134d\u1208\u12cb\u120d-", "\u12a8\u12ad\u134d\u1208-\u1218\u1208\u12a8\u12eb\u12cd \u12e8\u1218\u1321 \u1218\u120d\u12d5\u12ad\u1276\u127d.", "\u1218\u120d\u12a5\u12ad\u1276\u127d\u12ce.", "\u12a8\u12ad\u134d\u1208-\u1218\u1208\u12a8\u12eb\u12cd \u1218\u120d\u12d5\u12ad\u1276\u127d \u12c8\u12f0 \u130d\u122b \u1270\u12d8\u130d\u1270\u12cb\u120d. \u1218\u120d\u12d5\u12ad\u1276\u127d\u12ce \u12c8\u12f0 \u1240\u129d \u1270\u1208\u12c8\u1321.", "\u12a5\u12eb\u1295\u12f3\u1295\u12f1 \u12e8\u1218\u120d\u12a5\u12ad\u1275 \u1261\u12f5\u1295 \u12e8 2 \u12ad\u134d\u120e\u127d \u12a0\u1209\u1275", "\u12e8\u1218\u120d\u12a5\u12ad\u1275 \u133d\u1211\u134d \u1260 intloarder \u124b\u1295\u124b, \u12e8\u12da\u1205 \u1218\u120d\u12a5\u12ad\u1275 \u1240\u1208\u121d \u1325\u1241\u122d \u1290\u12cd.", "\u1218\u120d\u12a5\u12ad\u1275 \u133d\u1211\u134d \u1260\u124b\u1295\u124b\u12ce \u12cd\u1235\u1325, \u12e8\u12da\u1205 \u1218\u120d\u12a5\u12ad\u1275 \u1240\u1208\u121d \u12a0\u1228\u1295\u1313\u12f4 \u1290\u12cd.", "\u12e8\u1218\u120d\u12a5\u12ad\u1275 \u1240\u1295 \u12a8\u124b\u1295\u124b\u12ce \u130b\u122d \u12ed\u12db\u1218\u12f3\u120d.", "\u12a0\u12f3\u12f2\u1235 \u1218\u120d\u12a5\u12ad\u1276\u127d (\u1260\u1240\u1295) \u12a8\u1229\u1245 \u12a0\u12f6\u12ce\u127d \u1260\u1273\u127d \u12e8\u121a\u1308\u1299 \u1293\u1278\u12cd.", "\u12a8 <\u12e8\u1218\u1308\u1293\u129b \u1313\u1295\u1275 \u127b\u1275> \u1273\u127d\u129b\u12cd \u12ad\u134d\u120d \"\u1305\u121d\u122d \u12cd\u12ed\u12ed\u1275\" \u1241\u120d\u134d \u1290\u12cd. \u1260\u12da\u1205 \u120b\u12ed \u1320\u1245 \u1232\u12eb\u12f0\u122d\u1309 \u1218\u122d\u1203\u130d\u1265\u1229 \u121b\u12ed\u12ad\u122e\u134e\u1291\u1295 \u12a5\u1293 \u12e8\u121d\u120d\u12ad\u1275 / \u132b\u132b\u1273\u12cd\u1295 \u12f0\u1228\u1303 \u1208\u121b\u12c8\u1245 \u12a5\u1293 \u1270\u1313\u12f3\u129d \u1218\u120d\u12d5\u12ad\u1271\u1295 \u12eb\u1233\u12eb\u120d.", "\u12e8\u12f5\u121d\u1345 \u1218\u1223\u122a\u12eb\u12ce\u127d\u1295 \u12a8\u1270\u1208\u12cb\u12c8\u1321 \u1260\u128b\u120b \u12e8\u12a0\u1245\u122b\u1262\u12eb\u12ce\u1279 \u1235\u121e\u127d \u12ed\u1208\u12c8\u1323\u1209: - \"\u12cd\u12ed\u12ed\u1275 \u12ed\u1300\u121d\u1229\" -> \"\u12a0\u1241\u121d \u12cd\u12ed\u12ed\u1271\".", "\u12a8\u12da\u1205 \u1290\u1325\u1265 \u1300\u121d\u122e \u12cd\u12ed\u12ed\u1275 \u1218\u1300\u1218\u122d \u12c8\u12ed\u121d \u12e8\u12f5\u121d\u1345 / \u126a\u12f2\u12ee \u134b\u12ed\u120d\u1295 \u1208\u1218\u1300\u1218\u122d \u12ed\u127d\u120b\u1209.", "\u1201\u1209\u121d \u1308\u1262\u12ce\u127d \u1201\u1209\u121d \u1308\u1262\u12ce\u127d (\u12a8\u120c\u120b\u12cd \u1230\u12cd) \u1260\u130d\u122b \u1260\u12a9\u120d \u12ed\u1273\u12eb\u1209.", "\u1201\u1209\u121d \u1218\u12cd\u132b \u1218\u120d\u12d5\u12ad\u1276\u127d (\u12a8\u12a5\u122d\u1235\u12ce) \u1260\u1240\u129d \u1260\u12a9\u120d \u12ed\u1273\u12eb\u1209.", "\u1260\u124b\u1295\u124b\u12ce \u1218\u120d\u12d5\u12ad\u1276\u127d\u1295 \u1275\u1230\u121b\u1208\u1205, \u120c\u120b \u1230\u12cd\u12ce \u1260\u124b\u1295\u124b\u1278\u12cd \u1218\u120d\u12d5\u12ad\u1276\u127d\u1295 \u12ed\u1230\u121b\u120d.", "\u1260\u12cd\u12ed\u12ed\u1271 \u1218\u1328\u1228\u123b \u120b\u12ed / \u126a\u12f2\u12ee\u12cd\u1295 \u121b\u12f3\u1218\u1325 / \u126a\u12f2\u12ee\u12cd\u1295 \u1260\u121b\u12f3\u1218\u1325 \"\u12a0\u1241\u121d \u12cd\u12ed\u12ed\u1276\u127d\" \u12a0\u12dd\u122b\u122e\u127d \u120b\u12ed \u1320\u1245 \u121b\u12f5\u1228\u130d \u12eb\u1235\u1348\u120d\u130d\u12ce\u1273\u120d.", "\u132d\u12cd\u12cd\u1271 \u12f0\u130d\u121e \u12ed\u1320\u1293\u1240\u1243\u120d-", "\u1260\u12a0\u1233\u1239 \u12e8\u130d\u122b \u12ad\u134d\u120d \u12cd\u1235\u1325 \u1260\u130d\u122b \u1260\u12a9\u120d \u1263\u1208\u12cd \u12e8\u130d\u122b \u12ad\u134d\u120d \u12cd\u1235\u1325 \u1320\u1245 \u121b\u12f5\u1228\u130d \u1260\u12a0\u1233\u1239 \u12dd\u122d\u12dd\u122d \u12cd\u1235\u1325.", "\u1260 \"\u12a0\u12f2\u1231\" \u1241\u120d\u134d\u1295 \u12a0\u1293\u1275 \u120b\u12ed \u1320\u1245 \u121b\u12f5\u1228\u130d \u1260\u12a0\u12ab\u1263\u1262\u12eb\u12ca\u12cd \u12dd\u122d\u12dd\u122d \u12cd\u1235\u1325 \u1320\u1245 \u121b\u12f5\u1228\u130d.", "\u12a8\u120b\u12ed \u1263\u1208\u12cd \u121d\u1293\u120c \u12cd\u1235\u1325 \"\u12a5\u1308\u12db\" \u1241\u120d\u134d\u1295 \u1320\u1245 \u121b\u12f5\u1228\u130d.", "\u12a8\u120b\u12ed \u1263\u1208\u12cd \u121d\u1293\u120c \u12cd\u1235\u1325 \"\u130d\u120d\u133d \u1273\u122a\u12ad\" \u1241\u120d\u134d\u1295 \u1320\u1245 \u121b\u12f5\u1228\u130d.", "\u12a8\u120b\u12ed \u1260\u1270\u1320\u1240\u1230\u12cd \u121d\u1293\u120c \u12cd\u1235\u1325 \"\u1323\u120d\u1243\u1308\u1265\u1229\u1295 \u1230\u122d\u12dd\" \u120b\u12ed \u1320\u1245 \u121b\u12f5\u1228\u130d.", "\u1260 \"ELALLACERRODER \u1218\u1308\u1208\u132b\" \u12a0\u1293\u1275 \u120b\u12ed \"\u12e8\" Destlackrory \u1218\u1308\u1208\u132b \"\u1241\u120d\u134d\u1295 \u1320\u1245 \u1260\u121b\u12f5\u1228\u130d.", "\u12a8\u120b\u12ed \u1263\u1208\u12cd \u121d\u1293\u120c \u12cd\u1235\u1325 \"\u1218\u12cd\u132b\" \u1241\u120d\u134d\u1295 \u1320\u1245 \u1260\u121b\u12f5\u1228\u130d.", "\u1260\u12cd\u12ed\u12ed\u1275 \u1273\u122a\u12ad \u12cd\u1235\u1325 \u12e8\u1218\u120b\u12a5\u12ad\u1275 \u121b\u1233\u12eb \u1260\u121d\u1293\u120c\u12cd \u12e8\u120b\u12ed\u129b\u12cd \u130d\u122b \u12ad\u134d\u120d (\u12a0\u1228\u1295\u1313\u12f4 \u1240\u1235\u1275) \u120b\u12ed \u12e8\u1218\u1235\u12ad \u121b\u1233\u12eb \u121b\u1233\u12eb \u12a0\u121b\u122b\u132e\u127d\u1295 \u1260\u1218\u121d\u1228\u1325 \u1270\u127d\u120f\u120d.", "\"\u1201\u1209\u121d \u124b\u1295\u124b\u12ce\u127d\" \"\u124b\u1295\u124b\u12ce\u127d\" \u12a5\u1293 \u12a5\u122d\u1235\u12ce \u12a5\u1293 \u1218\u120d\u12a5\u12ad\u1276\u127d \u1260\u1201\u1209\u121d \u124b\u1295\u124b\u12ce\u127d \u12ed\u1273\u12eb\u1209.", "\"\u12e8\u12a5\u1294\u1295 \u124b\u1295\u124b\" \u1260\u121a\u1218\u122d\u1321\u1260\u1275 \u130a\u12dc - \u12e8\u1218\u122b\u1260\u122a\u12eb / \u127d \u1218\u120d\u12a5\u12ad\u1276\u127d \u12a5\u1293 \u1218\u120d\u12a5\u12ad\u1276\u127d \u1260\u124b\u1295\u124b\u12ce \u1265\u127b \u12ed\u1273\u12eb\u1209.", "\"Intlayorder \u124b\u1295\u124b\" \u1260\u121a\u1218\u122d\u1321\u1260\u1275 \u130a\u12dc - \u12e8\u1218\u1308\u1293\u129b\u12ce\u127d \u12a5\u1293 \u12a5\u122d\u1235\u12ce \u1218\u120d\u12d5\u12ad\u1276\u127d \u12e8\u121a\u1273\u12e9\u1275 \u12a5\u1293 \u1218\u120d\u12a5\u12ad\u1276\u127d \u12e8\u121a\u1308\u1208\u1321\u1275 \u1260\u1218\u12ab\u12a8\u1208 \u1218\u1320\u12ed\u1246\u127d \u124b\u1295\u124b \u1265\u127b \u1290\u12cd.", "\u1290\u1263\u122a\u12cd \u12e8\u1218\u120d\u12a5\u12ad\u1275 \u121b\u1233\u12eb \u121e\u12f0\u121d \"\u1201\u1209\u121d \u124b\u1295\u124b\u12ce\u127d\" \u1290\u12cd.", "\"\u130d\u120d\u1345 \u1273\u122a\u12ad\" \u1241\u120d\u134d\u1295 \u1232\u1320\u1245\u1231 \u12a8\u12ab.\u1232.\u1232. \u121d\u1235\u120d 10 \u1295 \u12ed\u1218\u120d\u12a8\u1271.", "\u1235\u12a5\u120d 10; \u12e8\u1218\u122b\u1262\u12eb\u12ce\u127d \u1273\u122a\u12ad\u1295 \u121b\u133d\u12f3\u1275.", "\u12a8\u12a0\u12ab\u134a\u12ce \u130b\u122d \u127b\u1275 \u1260\u12a0\u1201\u1291 \u130a\u12dc \u1260\u1202\u12f0\u1275 \u120b\u12ed \u12a8\u1206\u1290 \u1246\u121f\u120d.", "\"Inclaylder Drackor\" \u1241\u120d\u134d\u1295 \u1320\u1245 \u121b\u12f5\u1228\u130d, \u1201\u1209\u1295\u121d \u127b\u12c8\u1290\u122e\u127d \u12a8\u12a0\u12ab\u134a \u1313\u122a \u12a5\u1293 \u12a8\u12a0\u12ab\u134a\u12cd \u12a5\u122b\u1231 \u130b\u122d \u12ed\u1230\u122d\u12db\u120d. \u121d\u1235\u120d 11 \u1295 \u12ed\u1218\u120d\u12a8\u1271.", "\u1235\u12a5\u120d 11; \u12e8\u1218\u1308\u1293\u129b \u127d\u120e\u1273\u12cd\u1295 \u1218\u1230\u1228\u12dd.", "\u12a8\u12a0\u12ab\u134a\u12ce \u130b\u122d \u127b\u1275 \u1260\u12a0\u1201\u1291 \u130a\u12dc \u1260\u1202\u12f0\u1275 \u120b\u12ed \u12a8\u1206\u1290 \u1246\u121f\u120d.", "\"\u12e8\" ENGLALLLERER / \u1218\u1308\u1208\u132b \"\u1241\u120d\u134d\u1295 \u1320\u1245 \u121b\u12f5\u1228\u130d \u1260\u1270\u12db\u121b\u1305\u1290\u1275 \u1218\u1228\u1303\u12cd \u12e8\u1270\u121e\u120b \u1245\u133d \u12eb\u1233\u12eb\u120d. \u121d\u1235\u120d 12 \u1295 \u12ed\u1218\u120d\u12a8\u1271.", "\u1235\u12a5\u120d 12; \u12e8\u1218\u1308\u1293\u129b \u1245\u1325\u122d\u1295 \u1218\u1308\u1208\u132b \u12ed\u1218\u120d\u12a8\u1271.", "\u12ed\u1205 \u12d5\u1243 \u12a8\u12a5\u1243\u12cd \u130b\u122d \u1270\u1218\u1233\u1233\u12ed \u1290\u12cd", "\u12a0\u1240\u1263\u12ca \u1218\u1208\u12eb\u12cd \u12e8\u1218\u1208\u12eb\u12cd \u1218\u1208\u12cb\u12c8\u132b\u12cd\u1295 \u12e8\u130d\u122b \u12a5\u1293 \u12e8\u1240\u129d\u12cd\u1295 \u12e8\u1225\u122b \u1266\u1273\u12ce\u127d\u1295 \u1235\u134b\u1275 \u1208\u1218\u1208\u12c8\u1325 \u12eb\u1235\u127d\u120d\u12ce\u1273\u120d. \u121d\u1235\u120d 13 \u1295 \u12ed\u1218\u120d\u12a8\u1271.", "\u1235\u12a5\u120d 13; \u12e8\u130d\u122b \u12a5\u1293 \u12e8\u1240\u129d \u12ad\u134d\u120e\u127d \u12a0\u1240\u1263\u12ca \u1218\u1208\u12eb.", "\u12a0\u1240\u1263\u12ca \u1218\u1208\u12eb\u12e8\u1275 \u1232\u12eb\u1295\u1240\u1233\u1245\u1231, \u12a0\u124b\u1219 \u12e8\u1270\u1240\u1218\u1320 \u1290\u12cd. \u1355\u122e\u130d\u122b\u1219\u1295 \u12a5\u1295\u12f0\u1308\u1293 \u1232\u12eb\u1235\u1300\u121d\u1229 \u12eb\u12cb\u1245\u1229\u1275 \u12e8\u1218\u1328\u1228\u123b\u12cd \u1266\u1273 \u12ed\u1218\u1208\u1233\u1209.", "\u1260\u121b\u1309\u12eb\u12cd \u12e8\u1273\u127d\u129b\u12cd \u1240\u129d \u1325\u130d \u120b\u12ed \u1263\u1208\u12cd \u12a5\u1293 \u1260\u1240\u129d \u1320\u1245\u1273 \u1263\u1208\u12cd \u1270\u1293\u130b\u122a \u121d\u1235\u1209 \u120b\u12ed \u12e8\u1218\u12f3\u134a\u1275 \u1320\u124b\u121a\u12cd\u1295 \u12ed\u12cd\u1230\u12f1, \u1260\u1235\u12a5\u120d 14 \u12a5\u1295\u12f0\u121a\u1273\u12e8\u12cd \"\u12e8\u1270\u12a8\u1348\u1270 \u12e8\u12f5\u121d\u1345 \u1245\u1295\u1305\u1276\u127d\" \u121d\u1293\u120c \u1295\u1325\u120d \u1295\u1325\u120d \u12ed\u121d\u1228\u1321.", "\u1235\u12a5\u120d 14; \u12ad\u134d\u1275 \u12e8\u12f5\u121d\u1345 \u1245\u1295\u1305\u1276\u127d.", "\u12a0\u1201\u1295 \u12ab\u1208\u12cd \u12e8\u12f5\u121d\u1345 \u1245\u1295\u1265\u122e\u127d \u130b\u122d \u12a0\u1295\u12f5 \u121b\u12eb \u1308\u133d \u12ed\u1273\u12eb\u120d.", "\u1235\u12a5\u120d 15; \u12e8\u12c8\u1245\u1271 \u12e8\u12f5\u121d\u1345 \u1245\u1295\u1305\u1276\u127d.", "\u1225\u122b\u12cd\u1295 \u12a8\u1218\u1300\u1218\u122d\u12ce \u1260\u134a\u1275 \u12e8\u1290\u1260\u1229\u1275\u1295 \u12e8\u1218\u1300\u1218\u122a\u12eb \u12a5\u1234\u1276\u127d \u12c8\u12f0\u1290\u1260\u1229\u1260\u1275 \u12ed\u1218\u120d\u1231. \u1260\u1309\u12f3\u12ed\u12ce \u12cd\u1235\u1325 \u1235\u121e\u1279 \u12e8\u1270\u1208\u12eb\u12e9 \u12ed\u1206\u1293\u1209.", "\u1235\u12a5\u120d 16; \u12e8\u1218\u1300\u1218\u122a\u12eb \u12e8\u12f5\u121d\u1345 \u1245\u1295\u1305\u1276\u127d.", "\u12e8\u1235\u122d\u12d3\u1275 \u1245\u1295\u1265\u122e\u127d \u1270\u1218\u120d\u1230\u12cb\u120d, \u1260\u12ca\u1295\u12f6\u12cd\u1235 \u12cd\u1235\u1325 \u1218\u1225\u122b\u1275 \u12ed\u127d\u120b\u1209."]