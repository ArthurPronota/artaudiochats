["\u00ab\u0410\u0443\u0434\u0438\u043e \u0447\u0430\u0442\u00bb \u0431\u0430\u0493\u0434\u0430\u0440\u043b\u0430\u043c\u0430\u0441\u044b\u043d\u044b\u04a3 \u0441\u0438\u043f\u0430\u0442\u0442\u0430\u043c\u0430\u0441\u044b.", "\u041c\u0430\u0437\u043c\u04b1\u043d", "1. \u0411\u0430\u0441\u0442\u0430\u0443\u0434\u0430\u043d \u0431\u04b1\u0440\u044b\u043d.", "2. \u049a\u044b\u0441\u049b\u0430\u0448\u0430 \u0441\u0438\u043f\u0430\u0442\u0442\u0430\u043c\u0430.", "3. \u0411\u0430\u0439\u043b\u0430\u043d\u044b\u0441 \u04af\u0448\u0456\u043d \u049b\u043e\u043b \u0436\u0435\u0442\u0456\u043c\u0434\u0456 \u0442\u0456\u043b\u0434\u0435\u0440\u0434\u0456\u04a3 \u0442\u0456\u0437\u0456\u043c\u0456.", "4. \u0411\u0430\u0493\u0434\u0430\u0440\u043b\u0430\u043c\u0430 \u04af\u0448\u0456\u043d \u0436\u04b1\u043c\u044b\u0441 \u0456\u0441\u0442\u0435\u0443 \u04af\u0448\u0456\u043d \u0441\u0456\u0437\u0433\u0435 \u043d\u0435 \u049b\u0430\u0436\u0435\u0442.", "5. \u0411\u0430\u0493\u0434\u0430\u0440\u043b\u0430\u043c\u0430\u043c\u0435\u043d \u0436\u04b1\u043c\u044b\u0441.", "5.1 \u041a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044f.", "5.2 \u0416\u0430\u04a3\u0430 \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443 \u043f\u0440\u043e\u0444\u0438\u043b\u0456.", "5.3 \u0410\u043d\u044b\u049b\u0442\u0430\u043c\u0430 \u0431\u04e9\u043b\u0456\u043c\u0456.", "5.4 \u0428\u044b\u0493\u0443 \u0442\u04af\u0439\u043c\u0435\u0441\u0456.", "5.5 \u04d8\u04a3\u0433\u0456\u043c\u0435\u043b\u0435\u0441\u0443\u0448\u0456\u043b\u0435\u0440\u0434\u0456\u04a3 \u0442\u0456\u0437\u0456\u043c\u0456.", "5.6 \u0421\u044b\u0439\u043b\u044b\u049b\u0442\u0430\u0493\u044b \u0441\u04b1\u0445\u0431\u0430\u0442 \u0442\u0430\u0440\u0438\u0445\u044b.", "5.7 \u0421\u0430\u0443\u0441\u0430\u0493\u0430\u0440\u0430\u043b\u044b\u049b \u0442\u0430\u0440\u0438\u0445\u0442\u044b \u0442\u0430\u0437\u0430\u0440\u0442\u0443.", "5.8 \u0421\u044b\u0439\u0493\u044b\u0448\u0442\u044b \u0436\u043e\u044e.", "5.9. \u0421\u0430\u043b\u0430\u0442\u0430 \u0431\u04e9\u043b\u0456\u043c\u0448\u0435\u0441\u0456\u043d\u0456\u04a3 \u043f\u0440\u043e\u0444\u0438\u043b\u0456\u043d \u049b\u0430\u0440\u0430\u0443.", "5.10 \u0421\u043e\u043b \u0436\u04d9\u043d\u0435 \u043e\u04a3 \u0436\u0430\u049b \u0431\u04e9\u043b\u0456\u043a\u0442\u0435\u0440 \u0430\u0440\u0430\u0441\u044b\u043d\u0434\u0430\u0493\u044b \u0442\u0456\u043a \u0441\u0435\u043f\u0430\u0440\u0430\u0442\u043e\u0440.", "6. \u0421\u0456\u0437 \u0436\u04b1\u043c\u044b\u0441\u0442\u044b \u0430\u044f\u049b\u0442\u0430\u0493\u0430\u043d\u043d\u0430\u043d \u043a\u0435\u0439\u0456\u043d.", "\u0422\u0456\u043d\u0442\u0443\u0456\u0440 \u043a\u0443\u0440\u0441\u043e\u0440\u044b\u043d \u044d\u043a\u0440\u0430\u043d\u043d\u044b\u04a3 \u0442\u04e9\u043c\u0435\u043d\u0433\u0456 \u043e\u04a3 \u0436\u0430\u049b \u0431\u04b1\u0440\u044b\u0448\u044b\u043d\u0434\u0430\u0493\u044b \u0434\u0438\u043d\u0430\u043c\u0438\u043a \u0441\u0443\u0440\u0435\u0442\u0456\u043d\u0435 \u0430\u043f\u0430\u0440\u044b\u04a3\u044b\u0437 \u0436\u04d9\u043d\u0435 \u0442\u0456\u043d\u0442\u0443\u0456\u0440\u0434\u0456\u04a3 \u043e\u04a3 \u0436\u0430\u049b \u0431\u0430\u0442\u044b\u0440\u043c\u0430\u0441\u044b\u043c\u0435\u043d \u043d\u04b1\u049b\u044b\u04a3\u044b\u0437, \u00ab\u0414\u044b\u0431\u044b\u0441\u00bb \u0434\u0438\u0430\u043f\u0430\u0437\u043e\u043d\u044b \u00ab\u0434\u0438\u043d\u0430\u043c\u0438\u043a \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456\u00bb 1-\u0441\u0443\u0440\u0435\u0442\u0442\u0435\u0433\u0456\u0434\u0435\u0439.", "1-\u0441\u0443\u0440\u0435\u0442. \u0414\u044b\u0431\u044b\u0441 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456.", "\u0410\u0493\u044b\u043c\u0434\u0430\u0493\u044b \u0434\u044b\u0431\u044b\u0441 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456 \u0431\u0430\u0440 \u044d\u043a\u0440\u0430\u043d \u043f\u0430\u0439\u0434\u0430 \u0431\u043e\u043b\u0430\u0434\u044b. \u041a\u0456\u0440\u0456\u0441 \u0436\u04d9\u043d\u0435 \u0448\u044b\u0493\u044b\u0441 \u0430\u0443\u0434\u0438\u043e \u049b\u04b1\u0440\u044b\u043b\u0493\u044b\u043b\u0430\u0440 \u04af\u0448\u0456\u043d \u043d\u0435 \u043e\u0440\u043d\u0430\u0442\u044b\u043b\u0493\u0430\u043d\u044b\u043d \u04b1\u043c\u044b\u0442\u043f\u0430\u04a3\u044b\u0437. \u0421\u0456\u0437 \u0431\u04b1\u043b \u0430\u049b\u043f\u0430\u0440\u0430\u0442\u0442\u044b \u0436\u04b1\u043c\u044b\u0441\u0442\u044b \u0430\u044f\u049b\u0442\u0430\u0493\u0430\u043d\u043d\u0430\u043d \u043a\u0435\u0439\u0456\u043d \u049b\u0430\u0436\u0435\u0442 \u0431\u043e\u043b\u0430\u0434\u044b. 2-\u0441\u0443\u0440\u0435\u0442\u0442\u0435 \u049b\u044b\u0437\u044b\u043b \u0436\u0435\u0431\u0435\u043b\u0435\u0440 \u0435\u0441\u0442\u0435 \u0441\u0430\u049b\u0442\u0430\u0443 \u043a\u0435\u0440\u0435\u043a \u043d\u04d9\u0440\u0441\u0435\u043d\u0456 \u043a\u04e9\u0440\u0441\u0435\u0442\u0435\u0434\u0456. \u0421\u0456\u0437\u0434\u0456\u04a3 \u0436\u0430\u0493\u0434\u0430\u0439\u044b\u04a3\u044b\u0437\u0434\u0430 \u0430\u0442\u0430\u0443\u043b\u0430\u0440 \u0431\u0430\u0441\u049b\u0430\u0448\u0430 \u0431\u043e\u043b\u0430\u0434\u044b.", "\u0421\u0443\u0440\u0435\u0442 2. \u0411\u0430\u0441\u0442\u0430\u043f\u049b\u044b \u0434\u044b\u0431\u044b\u0441 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456", "\u0414\u044b\u0431\u044b\u0441 \u0448\u044b\u0493\u044b\u0441\u044b\u043d \u043e\u0440\u043d\u0430\u0442\u044b\u04a3\u044b\u0437", "\u0414\u044b\u0431\u044b\u0441 \u0435\u043d\u0433\u0456\u0437\u0443 \u049b\u04b1\u0440\u044b\u043b\u0493\u044b\u0441\u044b\u043d \u043e\u0440\u043d\u0430\u0442\u044b\u04a3\u044b\u0437", "3-\u0441\u0443\u0440\u0435\u0442\u0442\u0435 \u049b\u044b\u0437\u044b\u043b \u0436\u0435\u0431\u0435\u043b\u0435\u0440 \u043d\u0435\u043d\u0456 \u0431\u0435\u043b\u0433\u0456\u043b\u0435\u0443 \u043a\u0435\u0440\u0435\u043a\u0442\u0456\u0433\u0456\u043d \u043a\u04e9\u0440\u0441\u0435\u0442\u0435\u0434\u0456.", "3-\u0441\u0443\u0440\u0435\u0442. \u0414\u044b\u0431\u044b\u0441 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456", "\u0416\u04af\u0439\u0435 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456 \u0430\u044f\u049b\u0442\u0430\u043b\u0434\u044b, \u0431\u0430\u0493\u0434\u0430\u0440\u043b\u0430\u043c\u0430\u043d\u044b \u0456\u0441\u043a\u0435 \u049b\u043e\u0441\u0443\u0493\u0430 \u0431\u043e\u043b\u0430\u0434\u044b", "\u0421\u0456\u0437 \u04e9\u0437\u0456\u04a3\u0456\u0437 \u0431\u0456\u043b\u0435\u0442\u0456\u043d \u0442\u0456\u043b\u0434\u0435 \u0441\u04e9\u0439\u043b\u0435\u0439\u0441\u0456\u0437, \u0441\u0456\u0437 \u04e9\u0437\u0456\u04a3\u0456\u0437\u0434\u0456\u04a3 \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u0430\u04a3\u044b\u0437 \u0442\u04af\u0441\u0456\u043d\u0433\u0435\u043d \u0442\u0456\u043b\u0434\u0435 \u0435\u0441\u0442\u0456\u043b\u0435\u0434\u0456. \u0421\u0456\u0437\u0434\u0456\u04a3 \u043a\u043e\u043d\u0446\u0435\u043d\u0442\u0440\u0435\u0442\u0442\u0435\u0440\u0456\u04a3\u0456\u0437\u0434\u0456\u04a3 \u0431\u04e9\u0440\u0435\u043d\u0435\u0441\u0456 \u0441\u0430\u049b\u0442\u0430\u043b\u0430\u0434\u044b, \u043e\u043b \u0441\u0456\u0437 \u049b\u0430\u043b\u0430\u043d\u0493\u0430\u043d. \u0411\u0430\u0440\u043b\u044b\u049b \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u044f\u043b\u0430\u0440 \u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440\u0434\u0435 Windows 10 \u043d\u0435\u043c\u0435\u0441\u0435 Windows 11 \u0436\u04b1\u043c\u044b\u0441 \u0456\u0441\u0442\u0435\u0439\u0442\u0456\u043d \u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440\u0434\u0435 \u043e\u0440\u044b\u043d\u0434\u0430\u043b\u0430\u0434\u044b. \u0413\u0440\u0430\u0444\u0438\u043a\u0430\u043b\u044b\u049b \u043f\u0440\u043e\u0446\u0435\u0441\u0441\u043e\u0440 \u049b\u0430\u0436\u0435\u0442, \u0431\u0456\u0440\u0430\u049b \u049b\u0430\u0436\u0435\u0442 \u0435\u043c\u0435\u0441, \u0436\u04b1\u043c\u044b\u0441 \u0456\u0441\u0442\u0435\u0443 \u04af\u0448\u0456\u043d \u049b\u0430\u0436\u0435\u0442. \u0410\u0443\u0434\u0430\u0440\u043c\u0430\u043d\u044b\u04a3 \u0441\u0430\u043f\u0430\u0441\u044b \u0433\u0440\u0430\u0444\u0438\u043a\u0430\u043b\u044b\u049b \u043f\u0440\u043e\u0446\u0435\u0441\u0441\u043e\u0440\u043c\u0435\u043d \u0436\u0435\u0442\u0456\u043b\u0434\u0456\u0440\u0456\u043b\u0433\u0435\u043d.", "\u0415\u0433\u0435\u0440 \u0441\u0456\u0437 \u043e\u0441\u044b \u0442\u0456\u0437\u0456\u043c\u0434\u0435\u0433\u0456 \u0442\u0456\u043b\u0434\u0435\u0440\u0434\u0456\u04a3 \u0431\u0456\u0440\u0456\u043d \u0442\u04af\u0441\u0456\u043d\u0441\u0435\u04a3\u0456\u0437, \u0441\u0456\u0437 \u043e\u0441\u044b \u0442\u0456\u0437\u0456\u043c\u043d\u0435\u043d \u043a\u0435\u0437-\u043a\u0435\u043b\u0433\u0435\u043d \u0442\u0456\u043b\u0434\u0456\u04a3 \u0434\u0438\u043d\u0430\u043c\u0438\u043a\u0456\u043c\u0435\u043d \u0431\u0430\u0439\u043b\u0430\u043d\u044b\u0441\u0430 \u0430\u043b\u0430\u0441\u044b\u0437. \u0411\u0430\u0439\u043b\u0430\u043d\u044b\u0441 \u0436\u0435\u0434\u0435\u043b\u0445\u0430\u0442, whatsapp, google, google, vkmessenger, vkmessenger, yandexmessenger \u043d\u0435\u043c\u0435\u0441\u0435 \u043a\u0435\u0437-\u043a\u0435\u043b\u0433\u0435\u043d \u0431\u0430\u0441\u049b\u0430 \u0435\u043b\u0448\u0456\u0441\u0456\u043d\u0434\u0435 \u0431\u043e\u043b\u0443\u044b \u043c\u04af\u043c\u043a\u0456\u043d. \u0421\u0456\u0437 Mentio \u0442\u0456\u043b\u0434\u0435\u0440\u0456\u043d\u0456\u04a3 \u043a\u0435\u0437-\u043a\u0435\u043b\u0433\u0435\u043d \u0442\u0456\u043b\u0456\u043d\u0434\u0435\u0433\u0456 \u0436\u0430\u04a3\u0430\u043b\u044b\u049b\u0442\u0430\u0440\u0434\u044b, \u0436\u0430\u0442\u0442\u044b\u0493\u0443 \u043a\u0443\u0440\u0441\u044b\u043d \u0436\u04d9\u043d\u0435 \u0431\u0430\u0441\u049b\u0430 \u043f\u043e\u0434\u043a\u0430\u0441\u0442\u0442\u0430\u0440\u0434\u044b \u0442\u044b\u04a3\u0434\u0430\u0439 \u0430\u043b\u0430\u0441\u044b\u0437 \u0436\u04d9\u043d\u0435 \u043e\u043b\u0430\u0440\u0434\u044b \u0442\u04af\u0441\u0456\u043d\u0435 \u0430\u043b\u0430\u0441\u044b\u0437. \u0415\u043d\u0434\u0456 \u0448\u0435\u0442\u0435\u043b\u0434\u0456\u043a \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u044f\u043b\u0430\u0440\u0434\u0430 \u0441\u04b1\u0445\u0431\u0430\u0442 \u0431\u0435\u0440\u0443\u0433\u0435 \u0431\u043e\u043b\u0430\u0434\u044b \u0436\u04d9\u043d\u0435 \u0431\u0430\u0441\u049b\u0430\u043b\u0430\u0440\u044b. \u0421\u043e\u043d\u0434\u0430\u0439-\u0430\u049b, \u0430\u0443\u0434\u0438\u043e / \u0432\u0438\u0434\u0435\u043e \u0444\u0430\u0439\u043b\u0434\u044b \u0448\u0435\u0442 \u0442\u0456\u043b\u0456\u043d\u0434\u0435 \u043e\u0439\u043d\u0430\u0442\u0443\u0493\u0430 \u0436\u04d9\u043d\u0435 \u043e\u043d\u044b \u0442\u0456\u043b\u0434\u0435 \u0442\u044b\u04a3\u0434\u0430\u0443\u0493\u0430 \u0431\u043e\u043b\u0430\u0434\u044b. \u0411\u04af\u0439\u0456\u0440\u043b\u0456\u043a \u049b\u043e\u0441\u044b\u043c\u0448\u0430\u043b\u0430\u0440\u0434\u044b\u04a3 \u0431\u0456\u0440\u0456 - \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043c\u0435\u043d \u0431\u0456\u0440 \u0442\u0456\u043b\u0434\u0435 \u04d9\u04a3\u0433\u0456\u043c\u0435\u043b\u0435\u0441\u0443, \u0431\u0456\u0440\u0430\u049b \u0441\u0456\u0437\u0434\u0456\u04a3 \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u04a3\u044b\u0437 \u04e9\u043d\u0434\u0456\u0440\u0456\u043b\u0433\u0435\u043d \u043e\u0439\u044b\u043d\u0448\u044b\u049b\u0442\u0430\u0440\u0434\u044b \u0442\u044b\u04a3\u0434\u0430\u0439\u0434\u044b. \u04e8\u0437 \u0434\u0430\u0443\u044b\u0441\u044b\u04a3\u044b\u0437 \u0435\u043c\u0435\u0441. \u0422\u043e\u0439\u044b\u049b \u0431\u04b1\u043b \u049b\u0430\u0436\u0435\u0442. \u041a\u04e9\u043f\u0442\u0435\u0433\u0435\u043d \u049b\u043e\u043b\u0434\u0430\u043d\u0431\u0430\u043b\u0430\u0440 \u0431\u0430\u0440.", "Windows 10 \u043d\u0435\u043c\u0435\u0441\u0435 Windows 11 \u0430\u043c\u0430\u043b\u0434\u044b\u049b \u0436\u04af\u0439\u0435\u0441\u0456.", "\u049a\u0430\u0442\u0442\u044b \u0434\u0438\u0441\u043a\u0456\u043d\u0456\u04a3 \u0431\u043e\u0441 \u043e\u0440\u043d\u044b 8 \u0413\u0411.", "10 \u0413\u0411-\u0434\u0430\u043d RAM.", "GPU (\u0433\u0440\u0430\u0444\u0438\u043a\u0430\u043b\u044b\u049b \u04e9\u04a3\u0434\u0435\u0443 \u049b\u043e\u043d\u0434\u044b\u0440\u0493\u044b\u0441\u044b) 6 \u0413\u0411 \u043d\u0435\u043c\u0435\u0441\u0435 \u043e\u0434\u0430\u043d \u043a\u04e9\u043f, \u049b\u0430\u0436\u0435\u0442, \u0431\u0456\u0440\u0430\u049b \u049b\u0430\u0436\u0435\u0442 \u0435\u043c\u0435\u0441.", "\u041c\u0438\u043a\u0440\u043e\u0444\u043e\u043d\u043c\u0435\u043d \u049b\u04b1\u043b\u0430\u049b\u049b\u0430\u043f\u0442\u0430\u0440.", "\u0411\u0430\u0493\u0434\u0430\u0440\u043b\u0430\u043c\u0430\u043c\u0435\u043d \u0436\u04b1\u043c\u044b\u0441\u0442\u044b\u04a3 \u0431\u04af\u043a\u0456\u043b \u0438\u043d\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u0456 \u0431\u0440\u0430\u0443\u0437\u0435\u0440\u0434\u0435\u043d \u0436\u04af\u0437\u0435\u0433\u0435 \u0430\u0441\u044b\u0440\u044b\u043b\u0430\u0434\u044b.", "\u00ab\u041a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044f\u00bb \u0442\u04af\u0439\u043c\u0435\u0441\u0456\u043d \u0431\u0430\u0441\u049b\u0430\u043d \u043a\u0435\u0437\u0434\u0435 \u0436\u04d9\u043d\u0435 \u043d\u0435\u0433\u0456\u0437\u0433\u0456 \u0430\u043c\u0430\u043b\u0434\u044b\u049b \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u043c\u0435\u043d \u0444\u043e\u0440\u043c\u0430 \u0436\u043e\u0493\u0430\u0440\u0493\u044b \u043c\u04d9\u0437\u0456\u0440\u0434\u0435 \u043a\u04e9\u0440\u0441\u0435\u0442\u0456\u043b\u0435\u0434\u0456. 4-\u0441\u0443\u0440\u0435\u0442\u0442\u0456 \u049b\u0430\u0440\u0430\u04a3\u044b\u0437.", "4-\u0441\u0443\u0440\u0435\u0442. \u041a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044f.", "\u041a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044f \u0431\u04e9\u043b\u0456\u043c\u0456\u043d\u0434\u0435 \u043d\u0435\u0433\u0456\u0437\u0433\u0456 \u0436\u04b1\u043c\u044b\u0441 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456 \u0431\u0430\u0440:", "\u0422\u0456\u043b - \u04e8\u0437\u0456\u04a3\u0456\u0437 \u0441\u04e9\u0439\u043b\u0435\u0439\u0442\u0456\u043d \u0442\u0456\u043b\u0434\u0456 \u043e\u0440\u043d\u0430\u0442\u0443.", "\u0414\u044b\u0431\u044b\u0441 - \u0434\u044b\u0431\u044b\u0441 \u0434\u0440\u0430\u0439\u0432\u0435\u0440\u0456\u043d\u0456\u04a3 \u0430\u0442\u044b-\u0436\u04e9\u043d\u0456.", "\u041c\u0438\u043a\u0440\u043e\u0444\u043e\u043d - \u043c\u0438\u043a\u0440\u043e\u0444\u043e\u043d \u04af\u0448\u0456\u043d \u0434\u0440\u0430\u0439\u0432\u0435\u0440\u0434\u0456\u04a3 \u0430\u0442\u044b.", "\u0412\u0435\u0431-\u0448\u043e\u043b\u0493\u044b\u0448 - \u0441\u0456\u0437 \u0436\u04b1\u043c\u044b\u0441 \u0456\u0441\u0442\u0435\u0439\u0442\u0456\u043d \u0448\u043e\u043b\u0493\u044b\u0448\u0442\u044b\u04a3 \u0430\u0442\u0430\u0443\u044b.", "\u0421\u0456\u0437 \u0442\u0456\u043b\u0434\u0456 \u04e9\u0437\u0433\u0435\u0440\u0442\u0456\u043f, \u043a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044f \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456\u043d \u0441\u0430\u049b\u0442\u0430\u0493\u0430\u043d \u043a\u0435\u0437\u0434\u0435, \u0431\u0430\u0440\u043b\u044b\u049b \u043c\u04d9\u0442\u0456\u043d, \u04e9\u0440\u043d\u0435\u043a\u0442\u0435\u0440, \u04e9\u0440\u043d\u0435\u043a\u0442\u0435\u0440, \u0422\u04af\u0439\u043c\u0435\u0448\u0456\u043a \u0430\u0442\u0430\u0443\u043b\u0430\u0440\u044b \u0436\u04d9\u043d\u0435 \u0431\u0430\u0441\u049b\u0430 \u043c\u04d9\u0442\u0456\u043d \u0436\u0430\u04a3\u0430 \u0442\u0456\u043b\u0434\u0435 \u043a\u04e9\u0440\u0441\u0435\u0442\u0456\u043b\u0435\u0434\u0456. \u0416\u0430\u04a3\u0430 \u0447\u0430\u0442\u0442\u0430\u0440 \u0442\u0430\u04a3\u0434\u0430\u043b\u0493\u0430\u043d \u0442\u0456\u043b\u0433\u0435 \u0430\u0443\u0434\u0430\u0440\u044b\u043b\u0430\u0434\u044b \u0436\u04d9\u043d\u0435 \u0441\u0456\u0437 \u043e\u0441\u044b \u0436\u0430\u04a3\u0430 \u0442\u0456\u043b\u0434\u0435 \u0441\u04e9\u0439\u043b\u0435\u0443\u0434\u0456 \u0442\u044b\u04a3\u0434\u0430\u0439 \u0430\u043b\u0430\u0441\u044b\u0437. \u0412\u0435\u0431-\u0448\u043e\u043b\u0493\u044b\u0448 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0456 \u0442\u0443\u0440\u0430\u043b\u044b \u043c\u0430\u04a3\u044b\u0437\u0434\u044b \u0435\u0441\u043a\u0435\u0440\u0442\u0443. \u04d8\u0434\u0435\u043f\u043a\u0456 \u0431\u043e\u0439\u044b\u043d\u0448\u0430, \u0432\u0435\u0431-\u0448\u043e\u043b\u0493\u044b\u0448\u0442\u044b\u04a3 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0456 Microsoft Edge-\u043a\u0435 \u043e\u0440\u043d\u0430\u0442\u044b\u043b\u0493\u0430\u043d, \u04e9\u0439\u0442\u043a\u0435\u043d\u0456 \u043e\u043b \u04d9\u0440\u049b\u0430\u0448\u0430\u043d Windows \u0436\u04af\u0439\u0435\u0441\u0456\u043d\u0435 \u043e\u0440\u043d\u0430\u0442\u044b\u043b\u0493\u0430\u043d. \u0411\u04b1\u043b \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440 \u04af\u0448\u0456\u043d \u0442\u0435\u043a \u0430\u043c\u0430\u043b\u0434\u044b\u049b \u0436\u04af\u0439\u0435\u0434\u0435 \u043e\u0440\u043d\u0430\u0442\u044b\u043b\u0493\u0430\u043d \u0436\u04d9\u043d\u0435 \u0436\u04b1\u043c\u044b\u0441 \u0456\u0441\u0442\u0435\u0439\u0442\u0456\u043d \u0448\u043e\u043b\u0493\u044b\u0448\u0442\u044b \u0442\u0430\u04a3\u0434\u0430\u04a3\u044b\u0437.", "\u0416\u0430\u04a3\u0430 \u0442\u04af\u0439\u043c\u0435\u043d\u0456 \u0431\u0430\u0441\u0443 AWW \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u0430\u0441\u044b\u043d \u0442\u043e\u043b\u0442\u044b\u0440\u0443 \u04af\u0448\u0456\u043d \u043f\u0456\u0448\u0456\u043d\u0434\u0456 \u043a\u04e9\u0440\u0441\u0435\u0442\u0435\u0434\u0456. 5-\u0441\u0443\u0440\u0435\u0442\u0442\u0456 \u049b\u0430\u0440\u0430\u04a3\u044b\u0437.", "5-\u0441\u0443\u0440\u0435\u0442. \u0416\u0430\u04a3\u0430 \u0441\u04b1\u0445\u0431\u0430\u0442 \u0431\u0435\u0440\u0443\u0448\u0456 \u043f\u0440\u043e\u0444\u0438\u043b\u044c", "\u00ab\u0416\u0430\u04a3\u0430 \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u00bb \u0431\u0430\u0493\u0434\u0430\u0440\u043b\u0430\u043c\u0430\u0441\u044b \u043d\u0435\u0433\u0456\u0437\u0433\u0456 \u0436\u04b1\u043c\u044b\u0441 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456\u043d \u049b\u0430\u043c\u0442\u0438\u0434\u044b:", "\u041b\u0430\u049b\u0430\u043f \u0430\u0442\u044b - \u0441\u0456\u0437 \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b \u04af\u0448\u0456\u043d \u0442\u0430\u04a3\u0434\u0430\u0493\u0430\u043d \u0430\u0442\u0430\u0443.", "\u0422\u0456\u043b - \u0421\u0456\u0437\u0434\u0456\u04a3 \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443 \u0442\u0456\u043b\u0456\u04a3\u0456\u0437.", "\u0421\u0438\u043f\u0430\u0442\u0442\u0430\u043c\u0430 - \u0441\u0456\u0437\u0434\u0456\u04a3 \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043d\u044b\u04a3 \u0441\u0438\u043f\u0430\u0442\u0442\u0430\u043c\u0430\u0441\u044b.", "\u041c\u0438\u043a\u0440\u043e\u0444\u043e\u043d\u0434\u044b \u043f\u0430\u0439\u0434\u0430\u043b\u0430\u043d\u0443 - \u041c\u0438\u043a\u0440\u043e\u0444\u043e\u043d\u043d\u044b\u04a3 \u0436\u0430\u043b\u0430\u0443\u0448\u0430\u0441\u044b\u043d \u043e\u0440\u043d\u0430\u0442\u044b\u04a3\u044b\u0437.", "\u0421\u0443\u0440\u0435\u0442 - \u0441\u04b1\u0445\u0431\u0430\u0442 \u0431\u0435\u0440\u0443\u0448\u0456\u043d\u0456\u04a3 \u0431\u0435\u043b\u0433\u0456\u0448\u0435\u0441\u0456\u043d \u043e\u0440\u043d\u0430\u0442\u044b\u04a3\u044b\u0437.", "\u0415\u0433\u0435\u0440 \u0441\u0456\u0437 \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443 \u04af\u0448\u0456\u043d \u043a\u0435\u0441\u043a\u0456\u043d\u0434\u0456 \u0442\u0430\u04a3\u0434\u0430\u043c\u0430\u0493\u0430\u043d \u0431\u043e\u043b\u0441\u0430\u04a3\u044b\u0437, \u04d9\u0434\u0435\u043f\u043a\u0456 \u0441\u0443\u0440\u0435\u0442 \u043e\u043b \u04af\u0448\u0456\u043d \u043f\u0430\u0439\u0434\u0430\u043b\u0430\u043d\u044b\u043b\u0430\u0434\u044b.", "\u00ab\u041c\u0438\u043a\u0440\u043e\u0444\u043e\u043d\u0434\u044b \u043f\u0430\u0439\u0434\u0430\u043b\u0430\u043d\u0443\u00bb \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0456\u043d \u0442\u044b\u04a3\u0434\u0430\u0493\u0430\u043d \u043a\u0435\u0437\u0434\u0435 \u043e\u0440\u043d\u0430\u0442\u044b\u043b\u043c\u0430\u0493\u0430\u043d (\u0436\u0430\u04a3\u0430\u043b\u044b\u049b\u0442\u0430\u0440, \u0430\u0443\u0434\u0438\u043e \u0441\u0430\u0431\u0430\u049b\u0442\u0430\u0440 \u0436\u04d9\u043d\u0435 \u0442.\u0431.).", "\u00ab\u041a\u04e9\u043c\u0435\u043a\u00bb \u049b\u0430\u0443\u0456\u043f\u0441\u0456\u0437\u0434\u0456\u0433\u0456 \u0441\u0456\u0437\u0434\u0456\u04a3 \u0442\u0456\u043b\u0456\u04a3\u0456\u0437\u0434\u0435 \u0431\u0430\u0493\u0434\u0430\u0440\u043b\u0430\u043c\u0430\u043c\u0435\u043d \u049b\u0430\u043b\u0430\u0439 \u0436\u04b1\u043c\u044b\u0441 \u0456\u0441\u0442\u0435\u0443 \u043a\u0435\u0440\u0435\u043a\u0442\u0456\u0433\u0456\u043d \u0441\u0438\u043f\u0430\u0442\u0442\u0430\u0439\u0434\u044b. 6-\u0441\u0443\u0440\u0435\u0442\u0442\u0456 \u049b\u0430\u0440\u0430\u04a3\u044b\u0437.", "6-\u0441\u0443\u0440\u0435\u0442. \u0410\u043d\u044b\u049b\u0442\u0430\u043c\u0430 \u0431\u04e9\u043b\u0456\u043c\u0456\u043d\u0434\u0435.", "\u00ab\u0428\u044b\u0493\u0443\u00bb \u0431\u0430\u0442\u044b\u0440\u043c\u0430\u0441\u044b\u043d \u0431\u0430\u0441\u0443 \u0431\u0430\u0493\u0434\u0430\u0440\u043b\u0430\u043c\u0430\u043d\u044b \u0430\u044f\u049b\u0442\u0430\u0439\u0434\u044b. 7-\u0441\u0443\u0440\u0435\u0442\u0442\u0456 \u049b\u0430\u0440\u0430\u04a3\u044b\u0437.", "7-\u0441\u0443\u0440\u0435\u0442. \u0428\u044b\u0493\u0443 \u0442\u04af\u0439\u043c\u0435\u0441\u0456.", "\u0411\u0440\u0430\u0443\u0437\u0435\u0440 \u0442\u0435\u0440\u0435\u0437\u0435\u0441\u0456\u043d \u0436\u0430\u0431\u0443 \u043d\u0435\u043c\u0435\u0441\u0435 \u0448\u043e\u043b\u0493\u044b\u0448\u0442\u044b \u0436\u0430\u0431\u0443 \u0431\u0430\u0493\u0434\u0430\u0440\u043b\u0430\u043c\u0430\u043d\u044b \u0430\u044f\u049b\u0442\u0430\u0439\u0434\u044b.", "\u0411\u0435\u0442\u0442\u0456 \u0436\u0430\u04a3\u0430\u0440\u0442\u0443 \u0431\u0430\u0493\u0434\u0430\u0440\u043b\u0430\u043c\u0430\u043d\u044b \u0434\u0430 \u0430\u044f\u049b\u0442\u0430\u0439\u0434\u044b.", "\u0411\u0440\u0430\u0443\u0437\u0435\u0440\u0434\u0456\u04a3 \u0441\u043e\u043b \u0436\u0430\u0493\u044b\u043d\u0434\u0430 \u0441\u0456\u0437\u0434\u0456\u04a3 \u0441\u04b1\u0445\u0431\u0430\u0442 \u0431\u0435\u0440\u0443\u0448\u0456\u043b\u0435\u0440\u0434\u0456\u04a3 \u0442\u0456\u0437\u0456\u043c\u0456. 8-\u0441\u0443\u0440\u0435\u0442\u0442\u0456 \u049b\u0430\u0440\u0430\u04a3\u044b\u0437.", "8-\u0441\u0443\u0440\u0435\u0442. \u04d8\u04a3\u0433\u0456\u043c\u0435\u043b\u0435\u0441\u0443\u0448\u0456\u043b\u0435\u0440\u0434\u0456\u04a3 \u0442\u0456\u0437\u0456\u043c\u0456.", "\u04d8\u0440 \u0441\u04b1\u0445\u0431\u0430\u0442\u043a\u0435\u0440 \u04af\u0448\u0456\u043d, \u043e\u043b\u0430\u0440\u0434\u044b\u04a3 \u0431\u0435\u043b\u0433\u0456\u0448\u0435\u0441\u0456 \u04af\u0448\u0456\u043d, \u0441\u043e\u04a3\u0493\u044b \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043d\u044b\u04a3 \u043a\u04af\u043d\u0456 \u0436\u04d9\u043d\u0435 \u0441\u0456\u0437\u0434\u0456\u04a3 \u0442\u0456\u043b\u0456\u04a3\u0456\u0437\u0434\u0435\u0433\u0456 \u0441\u043e\u04a3\u0493\u044b \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043d\u044b\u04a3 \u043c\u04d9\u0442\u0456\u043d\u0456 \u043a\u04e9\u0440\u0441\u0435\u0442\u0456\u043b\u0433\u0435\u043d. \u0422\u0430\u043f\u0441\u044b\u0440\u043c\u0430\u043d\u044b\u04a3 \u043a\u04af\u043d\u0456 \u043f\u0456\u0448\u0456\u043c\u0456 \u0441\u0456\u0437\u0434\u0456\u04a3 \u0442\u0456\u043b\u0456\u04a3\u0456\u0437\u0433\u0435 \u0441\u04d9\u0439\u043a\u0435\u0441 \u043a\u0435\u043b\u0435\u0434\u0456. \u0421\u04d9\u04a3\u0433\u0456\u043b\u0435\u0441\u0442\u0456 \u0431\u0430\u0441\u049b\u0430\u043d \u043a\u0435\u0437\u0434\u0435 \u043e\u043b\u0430\u0440\u0434\u044b\u04a3 \u0441\u04e9\u0439\u043b\u0435\u0441\u0443 \u0442\u0430\u0440\u0438\u0445\u044b \u043a\u04e9\u0440\u0441\u0435\u0442\u0456\u043b\u0435\u0434\u0456.", "\u04d8\u04a3\u0433\u0456\u043c\u0435\u043b\u0435\u0441\u0443\u0448\u0456\u043d\u0456\u04a3 \u0441\u04e9\u0439\u043b\u0435\u0441\u0443 \u0442\u0430\u0440\u0438\u0445\u044b \u0431\u0440\u0430\u0443\u0437\u0435\u0440\u0434\u0456\u04a3 \u043e\u04a3 \u0436\u0430\u0493\u044b\u043d\u0434\u0430 \u043e\u0440\u043d\u0430\u043b\u0430\u0441\u049b\u0430\u043d. 9-\u0441\u0443\u0440\u0435\u0442\u0442\u0456 \u049b\u0430\u0440\u0430\u04a3\u044b\u0437.", "\u0421\u0443\u0440\u0435\u0442 9. \u0421\u04e9\u0439\u043b\u0435\u0441\u0443\u0448\u0456\u043d\u0456\u04a3 \u0441\u04e9\u0439\u043b\u0435\u0441\u0443 \u0442\u0430\u0440\u0438\u0445\u044b.", "\u0421\u043e\u0442 \u043f\u0440\u043e\u0446\u0435\u0441\u0441\u043e\u0440\u044b\u043d\u044b\u04a3 \u0441\u04e9\u0439\u043b\u0435\u0441\u0443 \u0442\u0430\u0440\u0438\u0445\u044b \u0441\u043e\u043b \u0436\u0430\u049b \u0431\u04e9\u043b\u0456\u0433\u0456\u043d\u0434\u0435\u0433\u0456 \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043d\u044b \u043d\u04b1\u049b\u0443\u0493\u0430 \u0431\u043e\u043b\u0430\u0434\u044b.", "\u0416\u043e\u0493\u0430\u0440\u0493\u044b \u043c\u04d9\u0437\u0456\u0440\u0434\u0435:", "\u04d8\u04a3\u0433\u0456\u043c\u0435\u043b\u0435\u0441\u0443\u0448\u0456 \u0431\u0435\u043b\u0433\u0456\u0448\u0435\u0441\u0456", "\u0421\u0442\u0430\u0440\u0442\u043e\u043a\u043e\u0440\u043b\u0430\u0440\u0434\u044b\u04a3 \u043b\u0430\u049b\u0430\u043f \u0430\u0442\u044b", "\u00ab\u0421\u04e9\u0439\u043b\u0435\u0441\u0443\u0434\u0456 \u0431\u0430\u0441\u0442\u0430\u0443\u00bb \u0431\u0430\u0442\u044b\u0440\u043c\u0430\u0441\u044b", "\u00ab\u0422\u0430\u0437\u0430\u043b\u0430\u0443 \u0442\u0430\u0440\u0438\u0445\u044b\u00bb \u0431\u0430\u0442\u044b\u0440\u043c\u0430\u0441\u044b", "\u00ab\u0418\u043d\u0442\u0435\u0440\u043b\u0440\u043e\u043a\u0442\u0438\u0432\u0442\u0456 \u0442\u04af\u0440\u0434\u0435 \u0436\u043e\u044e\u00bb \u0442\u04af\u0439\u043c\u0435\u0441\u0456\u043d \u0431\u0430\u0441\u044b\u04a3\u044b\u0437", "\u00ab\u0418\u043d\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u00bb \u0431\u0430\u0442\u044b\u0440\u043c\u0430\u0441\u044b", "\u0422\u0430\u04a3\u0434\u0430\u043b\u0493\u0430\u043d \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043c\u0435\u043d \u0441\u04e9\u0439\u043b\u0435\u0441\u0443 \u0442\u0430\u0440\u0438\u0445\u044b \u043e\u04a3 \u0436\u0430\u049b\u0442\u0430 \u043f\u0430\u0439\u0434\u0430 \u0431\u043e\u043b\u0430\u0434\u044b.", "\u0427\u0430\u0442 \u0442\u0430\u049b\u044b\u0440\u044b\u0431\u044b \u0436\u04b1\u043f\u0442\u044b\u04a3 \u043d\u04e9\u043c\u0456\u0440\u043b\u0435\u043d\u0433\u0435\u043d\u0456: \u00ab\u0421\u0430\u043b\u0445\u0438\u0442\u0435\u043a\u0442\u043e\u0440\u0434\u044b\u04a3 \u0442\u0456\u043b\u0456\u00bb / \u00ab\u0421\u0456\u0437\u0434\u0456\u04a3 \u0442\u0456\u043b\u0456\u04a3\u0456\u0437\u00bb.", "\u0421\u04e9\u0439\u043b\u0435\u0441\u0443 \u0442\u0430\u049b\u044b\u0440\u044b\u0431\u044b\u043d\u0434\u0430 \u00ab\u043e\u0441\u044b \u0447\u0430\u0442\u0442\u044b \u0436\u043e\u044e\u00bb \u0442\u04af\u0439\u043c\u0435\u0441\u0456\u043d \u0431\u0430\u0440.", "\u00ab\u041e\u0441\u044b \u0447\u0430\u0442\u0442\u044b \u0436\u043e\u044e\u00bb \u0442\u04af\u0439\u043c\u0435\u0441\u0456\u043d \u0431\u0430\u0441\u049b\u0430\u043d \u043a\u0435\u0437\u0434\u0435, \u0431\u04b1\u043b \u0447\u0430\u0442 \u0441\u04b1\u0445\u0431\u0430\u0442 \u0431\u0435\u0440\u0443\u0448\u0456\u043d\u0456\u04a3 \u0441\u04e9\u0439\u043b\u0435\u0441\u0443 \u0442\u0430\u0440\u0438\u0445\u044b\u043d\u0430\u043d \u0436\u043e\u0439\u044b\u043b\u0430\u0434\u044b.", "\u0411\u0430\u0440\u043b\u044b\u049b \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440 2 \u0442\u043e\u043f\u049b\u0430 \u0431\u04e9\u043b\u0456\u043d\u0435\u0434\u0456:", "\u0421\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043d\u044b\u04a3 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440\u044b.", "\u0421\u0456\u0437\u0434\u0456\u04a3 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440\u044b\u04a3\u044b\u0437.", "\u0421\u04d9\u04a3\u0433\u0456\u043b\u0435\u0448\u0456\u043d\u0456\u04a3 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440\u044b \u0441\u043e\u043b\u0493\u0430 \u0430\u0443\u044b\u0441\u0442\u044b\u0440\u044b\u043b\u0430\u0434\u044b. \u0421\u0456\u0437\u0434\u0456\u04a3 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440\u044b\u04a3\u044b\u0437 \u043e\u04a3\u0493\u0430 \u049b\u0430\u0440\u0430\u0439 \u0436\u044b\u043b\u0436\u044b\u0442\u044b\u043b\u0430\u0434\u044b.", "\u04d8\u0440 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430 \u0442\u043e\u0431\u044b 2 \u0431\u04e9\u043b\u0456\u043c\u043d\u0435\u043d \u0442\u04b1\u0440\u0430\u0434\u044b:", "\u0425\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430 \u043c\u04d9\u0442\u0456\u043d\u0456 \u0421\u04d9\u0439\u043a\u0435\u0441\u0442\u0456\u043a \u0442\u0456\u043b\u0456\u043d\u0434\u0435\u0433\u0456, \u043e\u0441\u044b \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043d\u044b\u04a3 \u0442\u04af\u0441\u0456 \u049b\u0430\u0440\u0430 \u0442\u04af\u0441\u0442\u0456.", "\u0425\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430 \u043c\u04d9\u0442\u0456\u043d\u0456 \u0421\u0456\u0437\u0434\u0456\u04a3 \u0442\u0456\u043b\u0456\u04a3\u0456\u0437\u0434\u0435\u0433\u0456 \u043c\u04d9\u0442\u0456\u043d, \u0431\u04b1\u043b \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043d\u044b\u04a3 \u0442\u04af\u0441\u0456 \u0436\u0430\u0441\u044b\u043b.", "\u0425\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430 \u043a\u04af\u043d\u0456 \u0441\u0456\u0437\u0434\u0456\u04a3 \u0442\u0456\u043b\u0456\u04a3\u0456\u0437\u0433\u0435 \u0441\u04d9\u0439\u043a\u0435\u0441 \u043a\u0435\u043b\u0435\u0434\u0456.", "\u0416\u0430\u04a3\u0430 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440 (\u043a\u04af\u043d\u0456 \u0431\u043e\u0439\u044b\u043d\u0448\u0430) \u0435\u0441\u043a\u0456 One-\u0434\u0435\u043d \u0442\u04e9\u043c\u0435\u043d \u043e\u0440\u043d\u0430\u043b\u0430\u0441\u049b\u0430\u043d.", "\u04d8\u04a3\u0433\u0456\u043c\u0435\u043b\u0435\u0441\u0443\u0448\u0456\u043d\u0456\u04a3 \u04d9\u04a3\u0433\u0456\u043c\u0435\u043b\u0435\u0440\u0456\u043d\u0456\u04a3 \u0442\u04af\u0431\u0456\u043d\u0434\u0435 \u00ab\u0421\u0442\u0430\u0440\u0442\u0438\u043d\u0433\u00bb \u0431\u0430\u0442\u044b\u0440\u043c\u0430\u0441\u044b \u0431\u043e\u043b\u044b\u043f \u0442\u0430\u0431\u044b\u043b\u0430\u0434\u044b. \u0428\u0442\u0430\u0442\u049b\u0430\u043d \u043a\u0435\u0437\u0434\u0435, \u0431\u0430\u0493\u0434\u0430\u0440\u043b\u0430\u043c\u0430 \u0441\u0438\u0433\u043d\u0430\u043b / \u0448\u0443 \u0434\u0435\u04a3\u0433\u0435\u0439\u043b\u0435\u0440\u0456\u043d \u0430\u043d\u044b\u049b\u0442\u0430\u0443 \u04af\u0448\u0456\u043d \u043c\u0438\u043a\u0440\u043e\u0444\u043e\u043d \u043c\u0435\u043d \u0434\u044b\u0431\u044b\u0441 \u049b\u04b1\u0440\u044b\u043b\u0493\u044b\u0441\u044b\u043d \u043a\u0430\u043b\u0438\u0431\u0440\u043b\u0435\u0443\u0434\u0456 \u0431\u0430\u0441\u0442\u0430\u0439\u0434\u044b \u0436\u04d9\u043d\u0435 \u0441\u04d9\u0439\u043a\u0435\u0441 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043d\u044b \u043a\u04e9\u0440\u0441\u0435\u0442\u0435\u0434\u0456.", "\u0414\u044b\u0431\u044b\u0441\u0442\u044b\u049b \u049b\u04b1\u0440\u044b\u043b\u0493\u044b\u043b\u0430\u0440\u0434\u044b \u043a\u0430\u043b\u0438\u0431\u0440\u043b\u0435\u0443\u0434\u0435\u043d \u043a\u0435\u0439\u0456\u043d \u0442\u04af\u0439\u043c\u0435\u043b\u0435\u0440\u0434\u0456\u04a3 \u0430\u0442\u0430\u0443\u043b\u0430\u0440\u044b \u04e9\u0437\u0433\u0435\u0440\u0435\u0434\u0456: \u00ab\u0421\u04e9\u0439\u043b\u0435\u0441\u0443\u0434\u0456 \u0431\u0430\u0441\u0442\u0430\u0443\u00bb -> \u00ab\u0421\u04e9\u0439\u043b\u0435\u0441\u0443\u0434\u0456 \u0442\u043e\u049b\u0442\u0430\u0442\u0443\u00bb.", "\u041e\u0441\u044b \u043a\u0435\u0437\u0434\u0435\u043d \u0431\u0430\u0441\u0442\u0430\u043f \u0441\u04e9\u0439\u043b\u0435\u0441\u0443\u0434\u0456 \u0431\u0430\u0441\u0442\u0430\u0443\u0493\u0430 \u043d\u0435\u043c\u0435\u0441\u0435 \u0430\u0443\u0434\u0438\u043e / \u0431\u0435\u0439\u043d\u0435 \u0444\u0430\u0439\u043b\u044b\u043d \u0436\u0435\u043b\u0456\u0433\u0435 \u049b\u043e\u0441\u0443\u0493\u0430 \u0431\u043e\u043b\u0430\u0434\u044b.", "\u0411\u0430\u0440\u043b\u044b\u049b \u043a\u0456\u0440\u0456\u0441 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440 (\u0431\u0430\u0441\u049b\u0430 \u0430\u0434\u0430\u043c\u043d\u0430\u043d) \u0441\u043e\u043b \u0436\u0430\u049b\u0442\u0430 \u043f\u0430\u0439\u0434\u0430 \u0431\u043e\u043b\u0430\u0434\u044b.", "\u0411\u0430\u0440\u043b\u044b\u049b \u0435\u0441\u043a\u0456\u0440\u0433\u0435\u043d \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440 (\u0441\u0456\u0437\u0434\u0435\u043d) \u043e\u04a3 \u0436\u0430\u049b\u0442\u0430 \u043f\u0430\u0439\u0434\u0430 \u0431\u043e\u043b\u0430\u0434\u044b.", "\u0421\u0456\u0437 \u04e9\u0437\u0456\u04a3\u0456\u0437\u0434\u0456\u04a3 \u0442\u0456\u043b\u0456\u04a3\u0456\u0437\u0434\u0435 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440\u0434\u044b \u0442\u044b\u04a3\u0434\u0430\u0439\u0441\u044b\u0437, \u0430\u043b \u0441\u0456\u0437\u0434\u0456\u04a3 \u0431\u0430\u0441\u049b\u0430 \u0430\u0434\u0430\u043c\u044b\u04a3\u044b\u0437 \u0442\u0456\u043b\u0434\u0435\u0440\u0434\u0435 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440\u0434\u044b \u0442\u044b\u04a3\u0434\u0430\u0439\u0434\u044b.", "\u0421\u04e9\u0439\u043b\u0435\u0441\u0443\u0434\u0456\u04a3 \u0441\u043e\u04a3\u044b\u043d\u0434\u0430 / \u0411\u0435\u0439\u043d\u0435\u043d\u0456 \u0442\u044b\u04a3\u0434\u0430\u0443, \u00ab\u0421\u04e9\u0439\u043b\u0435\u0441\u0443\u0434\u0456 \u0442\u043e\u049b\u0442\u0430\u0442\u0443\u00bb \u0431\u0430\u0442\u044b\u0440\u043c\u0430\u043b\u0430\u0440\u044b\u043d\u044b\u04a3 \u0431\u0456\u0440\u0456\u043d \u0431\u0430\u0441\u0443 \u043a\u0435\u0440\u0435\u043a.", "\u04d8\u04a3\u0433\u0456\u043c\u0435\u043b\u0435\u0441\u0443 \u043a\u0435\u043b\u0435\u0441\u0456 \u043a\u0435\u0437\u0434\u0435 \u0434\u0435 \u0430\u044f\u049b\u0442\u0430\u043b\u0430\u0434\u044b:", "\u0421\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043b\u0430\u0440\u0434\u044b\u04a3 \u0442\u0456\u0437\u0456\u043c\u0456\u043d\u0434\u0435\u0433\u0456 \u0431\u0440\u0430\u0443\u0437\u0435\u0440\u0434\u0456\u04a3 \u0441\u043e\u043b \u0436\u0430\u049b \u0431\u04e9\u043b\u0456\u0433\u0456\u043d\u0434\u0435\u0433\u0456 \u0431\u0430\u0441\u049b\u0430 \u0430\u0434\u0430\u043c\u0434\u044b \u0431\u0430\u0441\u0443.", "\u0421\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043b\u0430\u0440 \u0442\u0456\u0437\u0456\u043c\u0456\u043d\u0456\u04a3 \u0436\u043e\u0493\u0430\u0440\u0493\u044b \u0436\u0430\u0493\u044b\u043d\u0434\u0430\u0493\u044b \u00ab\u0416\u0430\u04a3\u0430\u00bb \u0442\u04af\u0439\u043c\u0435\u0441\u0456\u043d \u0431\u0430\u0441\u044b\u04a3\u044b\u0437.", "\u0416\u043e\u0493\u0430\u0440\u0493\u044b \u043c\u04d9\u0437\u0456\u0440\u0434\u0435\u0433\u0456 \u00ab\u0410\u043d\u044b\u049b\u0442\u0430\u043c\u0430\u00bb \u0442\u04af\u0439\u043c\u0435\u0441\u0456\u043d \u0431\u0430\u0441\u044b\u04a3\u044b\u0437.", "\u0416\u043e\u0493\u0430\u0440\u0493\u044b \u043c\u04d9\u0437\u0456\u0440\u0434\u0435\u0433\u0456 \u00ab\u0416\u0443\u0440\u043d\u0430\u043b\u0434\u044b \u04e9\u0448\u0456\u0440\u0443\u00bb \u0442\u04af\u0439\u043c\u0435\u0441\u0456\u043d \u0431\u0430\u0441\u044b\u04a3\u044b\u0437.", "\u0416\u043e\u0493\u0430\u0440\u0493\u044b \u043c\u04d9\u0437\u0456\u0440\u0434\u0435\u0433\u0456 \u00ab\u0421\u04d9\u043b\u0435\u043c\u0434\u0435\u0441\u0443\u0448\u0456\u043d\u0456 \u0436\u043e\u044e\u00bb \u0442\u04af\u0439\u043c\u0435\u0441\u0456\u043d \u0431\u0430\u0441\u044b\u04a3\u044b\u0437.", "\u0416\u043e\u0493\u0430\u0440\u0493\u044b \u043c\u04d9\u0437\u0456\u0440\u0434\u0435\u0433\u0456 \u00ab\u0418\u043d\u0442\u0435\u0440\u0444\u0435\u043a\u0442\u043e\u0440\u0434\u044b\u04a3 \u043f\u0440\u043e\u0444\u0438\u043b\u0456\u043d\u00bb \u0431\u0430\u0442\u044b\u0440\u043c\u0430\u0441\u044b\u043d \u0431\u0430\u0441\u0443 \u0430\u0440\u049b\u044b\u043b\u044b.", "\u0416\u043e\u0493\u0430\u0440\u0493\u044b \u043c\u04d9\u0437\u0456\u0440\u0434\u0435\u0433\u0456 \u00ab\u0428\u044b\u0493\u0443\u00bb \u0442\u04af\u0439\u043c\u0435\u0441\u0456\u043d \u0431\u0430\u0441\u0443 \u0430\u0440\u049b\u044b\u043b\u044b.", "\u0421\u04e9\u0439\u043b\u0435\u0441\u0443 \u0442\u0430\u0440\u0438\u0445\u044b\u043d\u0434\u0430\u0493\u044b \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440 \u0434\u0438\u0441\u043f\u043b\u0435\u0439\u0456 \u043c\u04d9\u0437\u0456\u0440\u0434\u0456\u04a3 \u0436\u043e\u0493\u0430\u0440\u0493\u044b \u0441\u043e\u043b \u0436\u0430\u049b \u0431\u04e9\u043b\u0456\u0433\u0456\u043d\u0434\u0435\u0433\u0456 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440 \u0434\u0438\u0441\u043f\u043b\u0435\u0439 \u043e\u043f\u0446\u0438\u044f\u0441\u044b\u043d \u0442\u0430\u04a3\u0434\u0430\u0443 \u0430\u0440\u049b\u044b\u043b\u044b \u0441\u0430\u049b\u0442\u0430\u043b\u0430\u0434\u044b (\u0436\u0430\u0441\u044b\u043b \u043a\u04e9\u0440\u0441\u0435\u0442\u043a\u0456).", "\u00ab\u0411\u0430\u0440\u043b\u044b\u049b \u0442\u0456\u043b\u0434\u0435\u0440\u0434\u0456\u00bb \u0442\u0430\u04a3\u0434\u0430\u0493\u0430\u043d \u043a\u0435\u0437\u0434\u0435 - \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043d\u044b\u04a3 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440\u044b \u0436\u04d9\u043d\u0435 \u0441\u0456\u0437 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440 \u0431\u0430\u0440\u043b\u044b\u049b \u0442\u0456\u043b\u0434\u0435\u0440\u0434\u0435 \u043a\u04e9\u0440\u0441\u0435\u0442\u0456\u043b\u0435\u0434\u0456.", "\u00ab\u041c\u0435\u043d\u0456\u04a3 \u0442\u0456\u043b\u0456\u043c\u0434\u0456\u00bb \u0442\u0430\u04a3\u0434\u0430\u0443 \u043a\u0435\u0437\u0456\u043d\u0434\u0435 - \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043d\u044b\u04a3 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440\u044b \u0436\u04d9\u043d\u0435 \u0441\u0456\u0437 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440 \u0442\u0435\u043a \u0441\u0456\u0437\u0434\u0456\u04a3 \u0442\u0456\u043b\u0456\u04a3\u0456\u0437\u0434\u0435 \u043a\u04e9\u0440\u0441\u0435\u0442\u0456\u043b\u0435\u0434\u0456.", "\u00ab\u0421\u0430\u043b\u0430\u0442\u0430\u0430\u0440\u0430\u043b\u044b\u049b \u0442\u0456\u043b\u00bb \u0442\u0430\u04a3\u0434\u0430\u0443 \u043a\u0435\u0437\u0456\u043d\u0434\u0435 - \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043d\u044b\u04a3 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440\u044b \u0436\u04d9\u043d\u0435 \u0441\u0456\u0437 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u043c\u0430\u043b\u0430\u0440 \u0442\u0435\u043a \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u0441 \u0442\u0456\u043b\u0456\u043d\u0434\u0435 \u043a\u04e9\u0440\u0441\u0435\u0442\u0456\u043b\u0435\u0434\u0456.", "\u04d8\u0434\u0435\u043f\u043a\u0456 \u0445\u0430\u0431\u0430\u0440\u043b\u0430\u0440\u0434\u044b \u043a\u04e9\u0440\u0441\u0435\u0442\u0443 \u0440\u0435\u0436\u0438\u043c\u0456 - \u00ab\u0411\u0430\u0440\u043b\u044b\u049b \u0442\u0456\u043b\u0434\u0435\u0440\u00bb.", "\u00ab\u0416\u0443\u0440\u043d\u0430\u043b\u0434\u044b \u04e9\u0448\u0456\u0440\u0443\u00bb \u0442\u04af\u0439\u043c\u0435\u0441\u0456\u043d \u0431\u0430\u0441\u049b\u0430\u043d \u043a\u0435\u0437\u0434\u0435, \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043c\u0435\u043d \u0431\u0430\u0440\u043b\u044b\u049b \u0447\u0430\u0442\u0442\u0430\u0440 \u0436\u043e\u0439\u044b\u043b\u0430\u0434\u044b, \u0431\u0456\u0440\u0430\u049b \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b \u049b\u0430\u043b\u0430\u0434\u044b. 10-\u0441\u0443\u0440\u0435\u0442\u0442\u0456 \u049b\u0430\u0440\u0430\u04a3\u044b\u0437.", "\u0421\u0443\u0440\u0435\u0442 10. \u04d8\u04a3\u0433\u0456\u043c\u0435\u043b\u0435\u0441\u0443\u0448\u0456\u043d\u0456\u04a3 \u0442\u0430\u0440\u0438\u0445\u044b\u043d \u0442\u0430\u0437\u0430\u0440\u0442\u0443.", "\u0415\u0433\u0435\u0440 \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043c\u0435\u043d \u0441\u04b1\u0445\u0431\u0430\u0442 \u049b\u0430\u0437\u0456\u0440 \u049b\u0430\u0437\u0456\u0440\u0434\u0456\u04a3 \u04e9\u0437\u0456\u043d\u0434\u0435 \u043e\u0440\u044b\u043d\u0434\u0430\u043b\u0443\u0434\u0430 \u0431\u043e\u043b\u0441\u0430, \u043e\u043b \u0442\u043e\u049b\u0442\u0430\u0442\u044b\u043b\u0430\u0434\u044b.", "\u00ab\u0418\u043d\u0442\u0435\u0440\u043b\u0440\u043e\u043b\u043e\u043a\u0430\u0442\u043e\u0440\u0434\u044b \u0436\u043e\u044e\u00bb \u0431\u0430\u0442\u044b\u0440\u043c\u0430\u0441\u044b\u043d \u0431\u0430\u0441\u0443 \u0430\u0440\u049b\u044b\u043b\u044b \u0441\u04e9\u0439\u043b\u0435\u0441\u0443\u043b\u0435\u0440\u0434\u0456 \u0441\u04b1\u0445\u0431\u0430\u0442 \u0431\u0435\u0440\u0443\u0448\u0456\u043c\u0435\u043d \u0436\u04d9\u043d\u0435 \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043c\u0435\u043d \u0436\u043e\u044f\u0434\u044b. 11-\u0441\u0443\u0440\u0435\u0442\u0442\u0456 \u049b\u0430\u0440\u0430\u04a3\u044b\u0437.", "\u0421\u0443\u0440\u0435\u0442 11. \u04d8\u04a3\u0433\u0456\u043c\u0435\u043b\u0435\u0441\u0443\u0448\u0456\u043d\u0456 \u0436\u043e\u044e.", "\u0415\u0433\u0435\u0440 \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b\u043c\u0435\u043d \u0441\u04b1\u0445\u0431\u0430\u0442 \u049b\u0430\u0437\u0456\u0440 \u049b\u0430\u0437\u0456\u0440\u0434\u0456\u04a3 \u04e9\u0437\u0456\u043d\u0434\u0435 \u043e\u0440\u044b\u043d\u0434\u0430\u043b\u0443\u0434\u0430 \u0431\u043e\u043b\u0441\u0430, \u043e\u043b \u0442\u043e\u049b\u0442\u0430\u0442\u044b\u043b\u0430\u0434\u044b.", "\u00abCourterOcutor \u043f\u0440\u043e\u0444\u0438\u043b\u0456\u043d\u0456\u04a3 \u043f\u0440\u043e\u0444\u0438\u043b\u0456\u043d\u00bb \u0431\u0430\u0441\u0443 \u0430\u0440\u049b\u044b\u043b\u044b \u0441\u04b1\u0445\u0431\u0430\u0442\u0442\u0430\u0441\u0443\u0448\u044b \u0434\u0435\u0440\u0435\u043a\u0442\u0435\u0440\u043c\u0435\u043d \u0442\u043e\u043b\u0442\u044b\u0440\u044b\u043b\u0493\u0430\u043d \u043f\u0456\u0448\u0456\u043d\u0434\u0456 \u043a\u04e9\u0440\u0441\u0435\u0442\u0435\u0434\u0456. 12-\u0441\u0443\u0440\u0435\u0442\u0442\u0456 \u049b\u0430\u0440\u0430\u04a3\u044b\u0437.", "\u0421\u0443\u0440\u0435\u0442 12. \u0421\u0430\u043b\u0430\u0442\u0430 \u0431\u04e9\u043b\u0456\u043c\u0448\u0435\u0441\u0456\u043d\u0456\u04a3 \u043f\u0440\u043e\u0444\u0438\u043b\u0456\u043d \u049b\u0430\u0440\u0430\u0443.", "\u0411\u04b1\u043b \u0437\u0430\u0442 \u0437\u0430\u0442\u049b\u0430 \u04b1\u049b\u0441\u0430\u0441", "\u0422\u0456\u043a \u0441\u0435\u043f\u0430\u0440\u0430\u0442\u043e\u0440 \u0436\u04b1\u043c\u044b\u0441 \u043a\u0435\u04a3\u0456\u0441\u0442\u0456\u0433\u0456\u043d\u0456\u04a3 \u0441\u043e\u043b \u0436\u04d9\u043d\u0435 \u043e\u04a3 \u0436\u0430\u049b \u0430\u0439\u043c\u0430\u049b\u0442\u0430\u0440\u044b\u043d\u044b\u04a3 \u0435\u043d\u0456\u043d \u04e9\u0437\u0433\u0435\u0440\u0442\u0443\u0433\u0435 \u043c\u04af\u043c\u043a\u0456\u043d\u0434\u0456\u043a \u0431\u0435\u0440\u0435\u0434\u0456. 13-\u0441\u0443\u0440\u0435\u0442\u0442\u0456 \u049b\u0430\u0440\u0430\u04a3\u044b\u0437.", "\u0421\u0443\u0440\u0435\u0442 13. \u0421\u043e\u043b \u0436\u04d9\u043d\u0435 \u043e\u04a3 \u0436\u0430\u049b \u0431\u04e9\u043b\u0456\u043a\u0442\u0435\u0440\u0434\u0456\u04a3 \u0442\u0456\u043a \u0441\u0435\u043f\u0430\u0440\u0430\u0442\u043e\u0440\u044b.", "\u0422\u0456\u043a \u0441\u0435\u043f\u0430\u0440\u0430\u0442\u043e\u0440\u0434\u044b \u0436\u044b\u043b\u0436\u044b\u0442\u049b\u0430\u043d \u043a\u0435\u0437\u0434\u0435 \u043e\u043d\u044b\u04a3 \u043e\u0440\u043d\u044b \u0441\u0430\u049b\u0442\u0430\u043b\u0430\u0434\u044b. \u0411\u0430\u0493\u0434\u0430\u0440\u043b\u0430\u043c\u0430\u043d\u044b \u049b\u0430\u0439\u0442\u0430 \u0431\u0430\u0441\u0442\u0430\u0493\u0430\u043d\u0434\u0430, \u0441\u0456\u0437 \u043e\u0440\u043d\u0430\u0442\u049b\u0430\u043d \u0441\u043e\u04a3\u0493\u044b \u043e\u0440\u044b\u043d \u049b\u0430\u043b\u043f\u044b\u043d\u0430 \u043a\u0435\u043b\u0442\u0456\u0440\u0456\u043b\u0435\u0434\u0456.", "\u0422\u0456\u043d\u0442\u0443\u0456\u0440 \u043a\u0443\u0440\u0441\u043e\u0440\u044b\u043d Speaker \u0441\u0443\u0440\u0435\u0442\u0456\u043d \u044d\u043a\u0440\u0430\u043d\u043d\u044b\u04a3 \u0442\u04e9\u043c\u0435\u043d\u0433\u0456 \u043e\u04a3 \u0436\u0430\u049b \u0431\u04b1\u0440\u044b\u0448\u044b\u043d\u0434\u0430 \u0436\u044b\u043b\u0436\u044b\u0442\u044b\u043f, \u0442\u0456\u043d\u0442\u0443\u0456\u0440\u0434\u0456\u04a3 \u043e\u04a3 \u0436\u0430\u049b \u0431\u0430\u0442\u044b\u0440\u043c\u0430\u0441\u044b\u043c\u0435\u043d \u0436\u044b\u043b\u0436\u044b\u0442\u044b\u04a3\u044b\u0437, 14-\u0441\u0443\u0440\u0435\u0442\u0442\u0435 \u043a\u04e9\u0440\u0441\u0435\u0442\u0456\u043b\u0433\u0435\u043d\u0434\u0435\u0439 \u00ab\u0414\u044b\u0431\u044b\u0441 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456\u00bb \u043c\u04d9\u0437\u0456\u0440\u0456\u043d\u0456\u04a3 \u0442\u0430\u0440\u043c\u0430\u0493\u044b\u043d \u0442\u0430\u04a3\u0434\u0430\u04a3\u044b\u0437.", "14-\u0441\u0443\u0440\u0435\u0442. \u0414\u044b\u0431\u044b\u0441 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456.", "\u0410\u0493\u044b\u043c\u0434\u0430\u0493\u044b \u0434\u044b\u0431\u044b\u0441 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456 \u0431\u0430\u0440 \u044d\u043a\u0440\u0430\u043d \u043f\u0430\u0439\u0434\u0430 \u0431\u043e\u043b\u0430\u0434\u044b.", "15-\u0441\u0443\u0440\u0435\u0442. \u0410\u0493\u044b\u043c\u0434\u0430\u0493\u044b \u0434\u044b\u0431\u044b\u0441 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456.", "\u0422\u0430\u043f\u0441\u044b\u0440\u043c\u0430\u043d\u044b \u0431\u0430\u0441\u0442\u0430\u043c\u0430\u0441 \u0431\u04b1\u0440\u044b\u043d \u0436\u0430\u0441\u0430\u043b\u0493\u0430\u043d \u0431\u0430\u0441\u0442\u0430\u043f\u049b\u044b \u043c\u04d9\u043d\u0434\u0435\u0440\u0434\u0456 \u049b\u0430\u043b\u043f\u044b\u043d\u0430 \u043a\u0435\u043b\u0442\u0456\u0440\u0456\u04a3\u0456\u0437. \u0421\u0456\u0437\u0434\u0456\u04a3 \u0436\u0430\u0493\u0434\u0430\u0439\u044b\u04a3\u044b\u0437\u0434\u0430 \u0430\u0442\u0430\u0443\u043b\u0430\u0440 \u0431\u0430\u0441\u049b\u0430\u0448\u0430 \u0431\u043e\u043b\u0430\u0434\u044b.", "16-\u0441\u0443\u0440\u0435\u0442. \u0411\u0430\u0441\u0442\u0430\u043f\u049b\u044b \u0434\u044b\u0431\u044b\u0441 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456.", "\u0416\u04af\u0439\u0435 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u043b\u0435\u0440\u0456 \u049b\u0430\u043b\u043f\u044b\u043d\u0430 \u043a\u0435\u043b\u0442\u0456\u0440\u0456\u043b\u0434\u0456, \u0441\u0456\u0437 Windows-\u0442\u0430 \u0436\u04b1\u043c\u044b\u0441 \u0456\u0441\u0442\u0435\u0439 \u0430\u043b\u0430\u0441\u044b\u0437."]