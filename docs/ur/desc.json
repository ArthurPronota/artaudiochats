["\u067e\u0631\u0648\u06af\u0631\u0627\u0645 \"\u0622\u0688\u06cc\u0648 \u0686\u06cc\u0679\u0633\" \u06a9\u06cc \u062a\u0641\u0635\u06cc\u0644\u06d4", "\u0645\u0646\u062f\u0631\u062c\u0627\u062a", "1. \u0634\u0631\u0648\u0639 \u06a9\u0631\u0646\u06d2 \u0633\u06d2 \u067e\u06c1\u0644\u06d2\u06d4", "2. \u0645\u062e\u062a\u0635\u0631 \u062a\u0641\u0635\u06cc\u0644", "3. \u0645\u0648\u0627\u0635\u0644\u0627\u062a \u06a9\u06d2 \u0644\u0626\u06d2 \u062f\u0633\u062a\u06cc\u0627\u0628 \u0632\u0628\u0627\u0646\u0648\u06ba \u06a9\u06cc \u0641\u06c1\u0631\u0633\u062a\u06d4", "4. \u0622\u067e \u06a9\u0648 \u067e\u0631\u0648\u06af\u0631\u0627\u0645 \u06a9\u06d2 \u06a9\u0627\u0645 \u06a9\u0631\u0646\u06d2 \u06a9\u06cc \u06a9\u06cc\u0627 \u0636\u0631\u0648\u0631\u062a \u06c1\u06d2\u06d4", "5. \u067e\u0631\u0648\u06af\u0631\u0627\u0645 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u06a9\u0627\u0645 \u06a9\u0631\u0646\u0627\u06d4", "5.1 \u062a\u0631\u062a\u06cc\u0628\u06d4", "5.2 \u0627\u06cc\u06a9 \u0646\u0626\u06d2 \u0628\u0627\u06c1\u0645\u06cc \u062a\u0639\u0627\u0648\u0646 \u06a9\u0627 \u067e\u0631\u0648\u0641\u0627\u0626\u0644\u06d4", "5.3 \u06c1\u06cc\u0644\u067e \u0633\u06cc\u06a9\u0634\u0646\u06d4", "5.4 \u0627\u06cc\u06af\u0632\u0679 \u0628\u0679\u0646\u06d4", "5.5 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u0648\u06ba \u06a9\u06cc \u0641\u06c1\u0631\u0633\u062a\u06d4", "5.6 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06cc \u0686\u06cc\u0679 \u06a9\u06cc \u062a\u0627\u0631\u06cc\u062e\u06d4", "5.7 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06cc \u062a\u0627\u0631\u06cc\u062e \u06a9\u0648 \u0635\u0627\u0641 \u06a9\u0631\u0646\u0627\u06d4", "5.8 \u0627\u06cc\u06a9 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u0648 \u062d\u0630\u0641 \u06a9\u0631\u0646\u0627\u06d4", "5.9 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u0627 \u067e\u0631\u0648\u0641\u0627\u0626\u0644 \u062f\u06cc\u06a9\u06be\u0646\u0627\u06d4", "5.10 \u0628\u0627\u0626\u06cc\u06ba \u0627\u0648\u0631 \u062f\u0627\u0626\u06cc\u06ba \u062d\u0635\u0648\u06ba \u06a9\u06d2 \u062f\u0631\u0645\u06cc\u0627\u0646 \u0639\u0645\u0648\u062f\u06cc \u062c\u062f\u0627\u06a9\u0627\u0631\u06d4", "6. \u0622\u067e \u06a9\u0627\u0645 \u062e\u062a\u0645 \u06a9\u0631\u0646\u06d2 \u06a9\u06d2 \u0628\u0639\u062f\u06d4", "\u0633\u06a9\u0631\u06cc\u0646 \u06a9\u06d2 \u0646\u0686\u0644\u06d2 \u062f\u0627\u0626\u06cc\u06ba \u06a9\u0648\u0646\u06d2 \u0645\u06cc\u06ba \u0627\u0633\u067e\u06cc\u06a9\u0631 \u0627\u0645\u06cc\u062c \u067e\u0631 \u0645\u0627\u0624\u0633 \u06a9\u0631\u0633\u0631 \u06a9\u0648 \u06c1\u0648\u0648\u0631 \u06a9\u0631\u06cc\u06ba \u0627\u0648\u0631 \u062f\u0627\u0626\u06cc\u06ba \u06a9\u0644\u06a9 \u06a9\u0631\u06cc\u06ba \u060c \u06a9\u06be\u0644\u06cc \u0622\u0648\u0627\u0632 \u06a9\u06cc \u062a\u0631\u062a\u06cc\u0628\u0627\u062a \"\u0645\u06cc\u0646\u0648 \u0622\u0626\u0679\u0645 \u060c \u062c\u06cc\u0633\u0627 \u06a9\u06c1 \u0634\u06a9\u0644 1 \u0645\u06cc\u06ba \u0634\u0627\u0646 \u06c1\u06d2\u06d4", "\u0686\u062a\u0631\u0627 1\u06d4 \u0622\u0648\u0627\u0632 \u06a9\u06cc \u06a9\u06be\u0644\u06cc \u062a\u0631\u062a\u06cc\u0628\u0627\u062a\u06d4", "\u0645\u0648\u062c\u0648\u062f\u06c1 \u0622\u0648\u0627\u0632 \u06a9\u06cc \u062a\u0631\u062a\u06cc\u0628\u0627\u062a \u0648\u0627\u0644\u06cc \u0627\u0633\u06a9\u0631\u06cc\u0646 \u0638\u0627\u06c1\u0631 \u06c1\u0648\u06af\u06cc\u06d4 \u06cc\u0627\u062f \u0631\u06a9\u06be\u06cc\u06ba \u06a9\u06c1 \u0627\u0646 \u067e\u0679 \u0627\u0648\u0631 \u0622\u0624\u0679 \u067e\u0679 \u0622\u0688\u06cc\u0648 \u0688\u06cc\u0648\u0627\u0626\u0633\u0632 \u06a9\u06d2 \u0644\u0626\u06d2 \u06a9\u06cc\u0627 \u062a\u0631\u062a\u06cc\u0628 \u062f\u06cc\u0627 \u06af\u06cc\u0627 \u06c1\u06d2\u06d4 \u06a9\u0627\u0645 \u062e\u062a\u0645 \u06a9\u0631\u0646\u06d2 \u06a9\u06d2 \u0628\u0639\u062f \u0622\u067e \u06a9\u0648 \u0627\u0633 \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u06a9\u06cc \u0636\u0631\u0648\u0631\u062a \u06c1\u0648\u06af\u06cc\u06d4 \u0686\u062a\u0631\u0627 2 \u0645\u06cc\u06ba \u060c \u0633\u0631\u062e \u062a\u06cc\u0631 \u062f\u06a9\u06be\u0627\u062a\u06d2 \u06c1\u06cc\u06ba \u06a9\u06c1 \u0622\u067e \u06a9\u0648 \u06cc\u0627\u062f \u0631\u06a9\u06be\u0646\u06d2 \u06a9\u06cc \u06a9\u06cc\u0627 \u0636\u0631\u0648\u0631\u062a \u06c1\u06d2\u06d4 \u0622\u067e \u06a9\u06d2 \u0645\u0639\u0627\u0645\u0644\u06d2 \u0645\u06cc\u06ba \u060c \u0646\u0627\u0645 \u0645\u062e\u062a\u0644\u0641 \u06c1\u0648\u06ba \u06af\u06d2\u06d4", "\u0686\u062a\u0631\u0627 2\u06d4 \u0627\u0628\u062a\u062f\u0627\u0626\u06cc \u0622\u0648\u0627\u0632 \u06a9\u06cc \u062a\u0631\u062a\u06cc\u0628\u0627\u062a", "\u0635\u0648\u062a\u06cc \u0622\u0624\u0679 \u067e\u0679 \u0688\u06cc\u0648\u0627\u0626\u0633 \u067e\u0631 \u0633\u06cc\u0679 \u06a9\u0631\u06cc\u06ba", "\u0635\u0648\u062a\u06cc \u0627\u0646 \u067e\u0679 \u0688\u06cc\u0648\u0627\u0626\u0633 \u067e\u0631 \u0633\u06cc\u0679 \u06a9\u0631\u06cc\u06ba", "\u0686\u062a\u0631\u0627 3 \u0645\u06cc\u06ba \u060c \u0633\u0631\u062e \u062a\u06cc\u0631 \u062f\u06a9\u06be\u0627\u062a\u06d2 \u06c1\u06cc\u06ba \u06a9\u06c1 \u0622\u067e \u06a9\u0648 \u06a9\u06cc\u0627 \u062a\u0631\u062a\u06cc\u0628 \u062f\u06cc\u0646\u06d2 \u06a9\u06cc \u0636\u0631\u0648\u0631\u062a \u06c1\u06d2\u06d4", "\u0686\u062a\u0631\u0627 3\u06d4 \u06a9\u0627\u0645 \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06cc \u0622\u0648\u0627\u0632 \u06a9\u06cc \u062a\u0631\u062a\u06cc\u0628\u0627\u062a", "\u0633\u0633\u0679\u0645 \u06a9\u06cc \u062a\u0631\u062a\u06cc\u0628\u0627\u062a \u0645\u06a9\u0645\u0644 \u06c1\u06cc\u06ba \u060c \u0622\u067e \u067e\u0631\u0648\u06af\u0631\u0627\u0645 \u0686\u0644\u0627 \u0633\u06a9\u062a\u06d2 \u06c1\u06cc\u06ba", "\u0622\u067e \u062c\u0633 \u0632\u0628\u0627\u0646 \u06a9\u0648 \u062c\u0627\u0646\u062a\u06d2 \u06c1\u0648 \u0648\u06c1 \u0628\u0648\u0644\u062a\u06d2 \u06c1\u06cc\u06ba \u060c \u0622\u067e \u06a9\u0648 \u0627\u0633 \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u0633\u0646\u0627 \u062c\u0627\u062a\u0627 \u06c1\u06d2 \u062c\u0633 \u06a9\u06cc \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u0627 \u0622\u067e \u06a9\u0648 \u0633\u0645\u062c\u06be\u062a\u0627 \u06c1\u06d2\u06d4 \u0622\u067e \u06a9\u06d2 \u06a9\u0648\u0646\u06a9\u0648\u0631\u0633\u06cc\u0679\u0633 \u06a9\u0627 \u0627\u06cc\u06a9 \u0644\u0627\u06af \u0627\u0646 \u0631\u06a9\u06be\u0627 \u06af\u06cc\u0627 \u06c1\u06d2 \u060c \u062c\u0633\u06d2 \u0622\u067e \u0646\u06d2 \u06a9\u06be\u0691\u0627 \u06a9\u06cc\u0627 \u06c1\u06d2\u06d4 \u062a\u0645\u0627\u0645 \u06a9\u0627\u0631\u0648\u0627\u0626\u06cc\u0627\u06ba \u0645\u0642\u0627\u0645\u06cc \u0637\u0648\u0631 \u067e\u0631 \u0622\u067e \u06a9\u06d2 \u06a9\u0645\u067e\u06cc\u0648\u0679\u0631 \u067e\u0631 \u0648\u0646\u0688\u0648\u0632 10 \u06cc\u0627 \u0648\u0646\u0688\u0648\u0632 11 \u067e\u0631 \u0686\u0644\u062a\u06cc \u06c1\u06cc\u06ba\u06d4 \u0627\u06cc\u06a9 \u06af\u0631\u0627\u0641\u06a9\u0633 \u067e\u0631\u0648\u0633\u06cc\u0633\u0631 \u0645\u0637\u0644\u0648\u0628\u06c1 \u06c1\u06d2 \u060c \u0644\u06cc\u06a9\u0646 \u0627\u0633 \u06a9\u06cc \u0636\u0631\u0648\u0631\u062a \u0646\u06c1\u06cc\u06ba \u06c1\u06d2 \u060c \u062a\u0627\u06a9\u06c1 \u067e\u0631\u0648\u06af\u0631\u0627\u0645 \u06a9\u0627\u0645 \u06a9\u0631\u0646\u06d2 \u06a9\u06d2 \u0644 .\u06d4 \u06af\u0631\u0627\u0641\u06a9\u0633 \u067e\u0631\u0648\u0633\u06cc\u0633\u0631 \u06a9\u06d2 \u0630\u0631\u06cc\u0639\u06c1 \u062a\u0631\u062c\u0645\u06c1 \u06a9\u06d2 \u0645\u0639\u06cc\u0627\u0631 \u06a9\u0648 \u0628\u06c1\u062a\u0631 \u0628\u0646\u0627\u06cc\u0627 \u06af\u06cc\u0627 \u06c1\u06d2\u06d4", "\u0627\u06af\u0631 \u0622\u067e \u0627\u0633 \u0641\u06c1\u0631\u0633\u062a \u0645\u06cc\u06ba \u0633\u06d2 \u06a9\u0633\u06cc \u0627\u06cc\u06a9 \u0632\u0628\u0627\u0646 \u06a9\u0648 \u0633\u0645\u062c\u06be\u062a\u06d2 \u06c1\u06cc\u06ba \u062a\u0648 \u060c \u0622\u067e \u0627\u0633 \u0641\u06c1\u0631\u0633\u062a \u0645\u06cc\u06ba \u0633\u06d2 \u06a9\u0633\u06cc \u0628\u06be\u06cc \u0632\u0628\u0627\u0646 \u06a9\u06d2 \u0645\u0642\u0627\u0645\u06cc \u0627\u0633\u067e\u06cc\u06a9\u0631 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0633\u06a9\u06cc\u06ba \u06af\u06d2\u06d4 \u0645\u0648\u0627\u0635\u0644\u0627\u062a \u0679\u06cc\u0644\u06cc\u06af\u0631\u0627\u0645 \u060c \u0648\u0627\u0679\u0633 \u0627\u06cc\u067e \u060c \u06af\u0648\u06af\u0644 \u0645\u06cc\u0679 \u060c \u0648\u06cc \u06a9\u06d2 \u0645\u06cc\u0633\u0646\u062c\u0631 \u060c \u06cc\u0627\u0646\u062f\u06cc\u06a9\u0633 \u0645\u06cc\u0633\u0646\u062c\u0631 \u06cc\u0627 \u06a9\u0633\u06cc \u062f\u0648\u0633\u0631\u06d2 \u0645\u06cc\u0633\u0646\u062c\u0631 \u0645\u06cc\u06ba \u06c1\u0648\u0633\u06a9\u062a\u06d2 \u06c1\u06cc\u06ba\u06d4 \u0622\u067e \u06a9\u0633\u06cc \u0628\u06be\u06cc \u0645\u06cc\u0646\u0679\u06cc\u0648 \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u062e\u0628\u0631\u06cc\u06ba \u060c \u062a\u0631\u0628\u06cc\u062a\u06cc \u06a9\u0648\u0631\u0633 \u0627\u0648\u0631 \u06a9\u0633\u06cc \u0628\u06be\u06cc \u062f\u0648\u0633\u0631\u06d2 \u067e\u0648\u0688 \u06a9\u0627\u0633\u0679 \u06a9\u0648 \u0633\u0646 \u0633\u06a9\u062a\u06d2 \u06c1\u06cc\u06ba \u0627\u0648\u0631 \u0627\u0646 \u06a9\u0648 \u0633\u0645\u062c\u06be \u0633\u06a9\u062a\u06d2 \u06c1\u06cc\u06ba\u06d4 \u0627\u0628 \u063a\u06cc\u0631 \u0645\u0644\u06a9\u06cc \u06a9\u0645\u067e\u0646\u06cc\u0648\u06ba \u0645\u06cc\u06ba \u0627\u0646\u0679\u0631\u0648\u06cc\u0648 \u067e\u0627\u0633 \u06a9\u0631\u0646\u0627 \u0627\u0648\u0631 \u0628\u06c1\u062a \u06a9\u0686\u06be \u0645\u0645\u06a9\u0646 \u06c1\u06d2\u06d4 \u0622\u067e \u063a\u06cc\u0631 \u0645\u0644\u06a9\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u0622\u0688\u06cc\u0648 / \u0648\u06cc\u0688\u06cc\u0648 \u0641\u0627\u0626\u0644 \u0628\u06be\u06cc \u06a9\u06be\u06cc\u0644 \u0633\u06a9\u062a\u06d2 \u06c1\u06cc\u06ba \u0627\u0648\u0631 \u0627\u0633\u06d2 \u0627\u067e\u0646\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u0633\u0646 \u0633\u06a9\u062a\u06d2 \u06c1\u06cc\u06ba\u06d4 \u0636\u0645\u0646\u06cc \u0627\u06cc\u067e\u0644\u06cc \u06a9\u06cc\u0634\u0646\u0632 \u0645\u06cc\u06ba \u0633\u06d2 \u0627\u06cc\u06a9 \u0627\u06cc\u06a9 \u06c1\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u06af\u0641\u062a\u06af\u0648 \u06c1\u06d2 \u060c \u0644\u06cc\u06a9\u0646 \u0622\u067e \u06a9\u0627 \u0628\u0627\u06c1\u0645\u06cc \u062a\u0628\u0627\u062f\u0644\u06c1 \u062e\u06cc\u0627\u0644 \u067e\u06cc\u062f\u0627 \u06c1\u0648\u0646\u06d2 \u0648\u0627\u0644\u0627 \u06c1\u06d2\u06d4 \u0622\u067e \u06a9\u06cc \u0627\u067e\u0646\u06cc \u0622\u0648\u0627\u0632 \u0646\u06c1\u06cc\u06ba\u06d4 tois \u06cc\u06c1 \u0636\u0631\u0648\u0631\u06cc \u06c1\u06d2. \u0628\u06c1\u062a \u0633\u0627\u0631\u06cc \u0645\u0645\u06a9\u0646\u06c1 \u062f\u0631\u062e\u0648\u0627\u0633\u062a\u06cc\u06ba \u06c1\u06cc\u06ba\u06d4", "\u0622\u067e\u0631\u06cc\u0679\u0646\u06af \u0633\u0633\u0679\u0645 \u0648\u0646\u0688\u0648\u0632 10 \u06cc\u0627 \u0648\u0646\u0688\u0648\u0632 11\u06d4", "\u062f\u0633\u062a\u06cc\u0627\u0628 \u06c1\u0627\u0631\u0688 \u0688\u0631\u0627\u0626\u06cc\u0648 \u0627\u0633\u067e\u06cc\u0633 8 \u062c\u06cc \u0628\u06cc\u06d4", "10 \u062c\u06cc \u0628\u06cc \u0633\u06d2 \u0631\u0627\u0645\u06d4", "\u062c\u06cc \u067e\u06cc \u06cc\u0648 (\u06af\u0631\u0627\u0641\u06a9\u0633 \u067e\u0631\u0648\u0633\u06cc\u0633\u0646\u06af \u06cc\u0648\u0646\u0679) 6 \u062c\u06cc \u0628\u06cc \u06cc\u0627 \u0627\u0633 \u0633\u06d2 \u0632\u06cc\u0627\u062f\u06c1 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u060c \u0645\u0637\u0644\u0648\u0628\u06c1 \u0644\u06cc\u06a9\u0646 \u0636\u0631\u0648\u0631\u06cc \u0646\u06c1\u06cc\u06ba\u06d4", "\u0645\u0627\u0626\u06a9\u0631\u0648\u0641\u0648\u0646 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u06c1\u06cc\u0688 \u0641\u0648\u0646\u06d4", "\u067e\u0631\u0648\u06af\u0631\u0627\u0645 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u06a9\u0627\u0645 \u06a9\u0631\u0646\u06d2 \u06a9\u0627 \u067e\u0648\u0631\u0627 \u0627\u0646\u0679\u0631\u0641\u06cc\u0633 \u0628\u0631\u0627\u0624\u0632\u0631 \u0633\u06d2 \u06a9\u06cc\u0627 \u062c\u0627\u062a\u0627 \u06c1\u06d2\u06d4", "\u062c\u0628 \u0622\u067e \"\u06a9\u0646\u0641\u06cc\u06af\u0631\u06cc\u0634\u0646\" \u06a9\u06d2 \u0628\u0679\u0646 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u062a\u06d2 \u06c1\u06cc\u06ba \u060c \u0627\u0648\u0631 \u0627\u06c1\u0645 \u0622\u067e\u0631\u06cc\u0679\u0646\u06af \u067e\u06cc\u0631\u0627\u0645\u06cc\u0679\u0631\u0632 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u0641\u0627\u0631\u0645 \u0679\u0627\u067e \u0645\u06cc\u0646\u0648 \u0645\u06cc\u06ba \u0638\u0627\u06c1\u0631 \u06c1\u0648\u062a\u0627 \u06c1\u06d2\u06d4 \u0634\u06a9\u0644 4 \u062f\u06cc\u06a9\u06be\u06cc\u06ba\u06d4", "\u0686\u062a\u0631\u0627 4. \u062a\u0631\u062a\u06cc\u0628", "\u06a9\u0646\u0641\u06cc\u06af\u0631\u06cc\u0634\u0646 \u0633\u06cc\u06a9\u0634\u0646 \u0645\u06cc\u06ba \u0627\u06c1\u0645 \u0622\u067e\u0631\u06cc\u0679\u0646\u06af \u067e\u06cc\u0631\u0627\u0645\u06cc\u0679\u0631\u0632 \u0634\u0627\u0645\u0644 \u06c1\u06cc\u06ba:", "\u0632\u0628\u0627\u0646 - \u062c\u0633 \u0632\u0628\u0627\u0646 \u06a9\u0648 \u0622\u067e \u0628\u0648\u0644\u062a\u06d2 \u06c1\u06cc\u06ba \u0627\u0633\u06d2 \u062a\u0631\u062a\u06cc\u0628 \u062f\u06cc\u0646\u0627\u06d4", "\u0622\u0648\u0627\u0632 - \u0622\u067e \u06a9\u06cc \u0622\u0648\u0627\u0632 \u06a9\u0648 \u062e\u062a\u0645 \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u0622\u0644\u06d2 \u06a9\u06d2 \u0644\u0626\u06d2 \u0688\u0631\u0627\u0626\u06cc\u0648\u0631 \u06a9\u0627 \u0646\u0627\u0645\u06d4", "\u0645\u0627\u0626\u06a9\u0631\u0648\u0641\u0648\u0646 - \u0622\u067e \u06a9\u06d2 \u0645\u0627\u0626\u06a9\u0631\u0648\u0641\u0648\u0646 \u06a9\u06d2 \u0644\u0626\u06d2 \u0688\u0631\u0627\u0626\u06cc\u0648\u0631 \u06a9\u0627 \u0646\u0627\u0645\u06d4", "\u0648\u06cc\u0628 \u0628\u0631\u0627\u0624\u0632\u0631 - \u0628\u0631\u0627\u0624\u0632\u0631 \u06a9\u0627 \u0646\u0627\u0645 \u062c\u0633 \u0645\u06cc\u06ba \u0622\u067e \u06a9\u0627\u0645 \u06a9\u0631\u06cc\u06ba \u06af\u06d2\u06d4", "\u062c\u0628 \u0622\u067e \u0632\u0628\u0627\u0646 \u06a9\u0648 \u062a\u0628\u062f\u06cc\u0644 \u06a9\u0631\u062a\u06d2 \u06c1\u06cc\u06ba \u0627\u0648\u0631 \u062a\u0631\u062a\u06cc\u0628 \u06a9\u06cc \u062a\u0631\u062a\u06cc\u0628\u0627\u062a \u06a9\u0648 \u0645\u062d\u0641\u0648\u0638 \u06a9\u0631\u062a\u06d2 \u06c1\u06cc\u06ba \u062a\u0648 \u060c \u062a\u0645\u0627\u0645 \u0645\u062a\u0646 \u060c \u0627\u0638\u06c1\u0627\u0631 \u060c \u0628\u0679\u0646 \u06a9\u06d2 \u0646\u0627\u0645 \u0627\u0648\u0631 \u062f\u06cc\u06af\u0631 \u0645\u062a\u0646 \u06a9\u0648 \u0646\u0626\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u062f\u06a9\u06be\u0627\u06cc\u0627 \u062c\u0627\u0626\u06d2 \u06af\u0627\u06d4 \u0646\u0626\u06cc \u0686\u06cc\u0679\u0633 \u06a9\u0648 \u0645\u0646\u062a\u062e\u0628 \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u062a\u0631\u062c\u0645\u06c1 \u06a9\u06cc\u0627 \u062c\u0627\u0626\u06d2 \u06af\u0627 \u060c \u0627\u0648\u0631 \u0622\u067e \u0627\u0633 \u0646\u0626\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u062a\u0642\u0631\u06cc\u0631 \u0633\u0646\u06cc\u06ba \u06af\u06d2\u06d4 \u0648\u06cc\u0628 \u0628\u0631\u0627\u0624\u0632\u0631 \u067e\u06cc\u0631\u0627\u0645\u06cc\u0679\u0631 \u06a9\u06d2 \u0628\u0627\u0631\u06d2 \u0645\u06cc\u06ba \u0627\u06c1\u0645 \u0646\u0648\u0679\u06d4 \u067e\u06c1\u0644\u06d2 \u0633\u06d2 \u0637\u06d2 \u0634\u062f\u06c1 \u0637\u0648\u0631 \u067e\u0631 \u060c \u0648\u06cc\u0628 \u0628\u0631\u0627\u0624\u0632\u0631 \u067e\u06cc\u0631\u0627\u0645\u06cc\u0679\u0631 \u0645\u0627\u0626\u06cc\u06a9\u0631\u0648\u0633\u0627\u0641\u0679 \u0627\u06cc\u062c \u067e\u0631 \u0633\u06cc\u0679 \u06c1\u06d2 \u060c \u06a9\u06cc\u0648\u0646\u06a9\u06c1 \u06cc\u06c1 \u06c1\u0645\u06cc\u0634\u06c1 \u0648\u0646\u0688\u0648\u0632 \u0645\u06cc\u06ba \u0646\u0635\u0628 \u06c1\u0648\u062a\u0627 \u06c1\u06d2\u06d4 \u0627\u0633 \u067e\u06cc\u0631\u0627\u0645\u06cc\u0679\u0631 \u06a9\u06d2 \u0644\u0626\u06d2 \u060c \u0635\u0631\u0641 \u0628\u0631\u0627\u0624\u0632\u0631 \u06a9\u0627 \u0627\u0646\u062a\u062e\u0627\u0628 \u06a9\u0631\u06cc\u06ba \u062c\u0648 \u0622\u067e \u06a9\u06d2 \u0622\u067e\u0631\u06cc\u0679\u0646\u06af \u0633\u0633\u0679\u0645 \u067e\u0631 \u0627\u0646\u0633\u0679\u0627\u0644 \u0627\u0648\u0631 \u0686\u0644 \u0631\u06c1\u0627 \u06c1\u06d2\u06d4", "\u0646\u0626\u06d2 \u0628\u0679\u0646 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u0646\u0627 AWW \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u0648 \u0628\u06be\u0631\u0646\u06d2 \u06a9\u06d2 \u0644\u0626\u06d2 \u0627\u06cc\u06a9 \u0641\u0627\u0631\u0645 \u062f\u06a9\u06be\u0627\u062a\u0627 \u06c1\u06d2\u06d4 \u0634\u06a9\u0644 5 \u062f\u06cc\u06a9\u06be\u06cc\u06ba\u06d4", "\u0686\u062a\u0631\u0627 5\u06d4 \u0646\u06cc\u0627 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u0627 \u067e\u0631\u0648\u0641\u0627\u0626\u0644", "\"\u0646\u06cc\u0627 \u0627\u0646\u0679\u0631\u0644\u0648\u06a9\u06cc\u0679\u0631 \u067e\u0631\u0648\u0641\u0627\u0626\u0644\" \u0633\u06cc\u06a9\u0634\u0646 \u0645\u06cc\u06ba \u0627\u06c1\u0645 \u0622\u067e\u0631\u06cc\u0679\u0646\u06af \u067e\u06cc\u0631\u0627\u0645\u06cc\u0679\u0631\u0632 \u0634\u0627\u0645\u0644 \u06c1\u06cc\u06ba:", "\u0639\u0631\u0641\u06cc \u0646\u0627\u0645 - \u0648\u06c1 \u0646\u0627\u0645 \u062c\u0648 \u0622\u067e \u0627\u067e\u0646\u06d2 \u0628\u0627\u06c1\u0645\u06cc \u06af\u0641\u062a\u06af\u0648 \u06a9\u06d2 \u0644\u0626\u06d2 \u0645\u0646\u062a\u062e\u0628 \u06a9\u0631\u062a\u06d2 \u06c1\u06cc\u06ba\u06d4", "\u0632\u0628\u0627\u0646 - \u0622\u067e \u06a9\u0627 \u0628\u0627\u06c1\u0645\u06cc \u0628\u0648\u0644\u0646\u06d2 \u0648\u0627\u0644\u0627 \u0632\u0628\u0627\u0646 \u0628\u0648\u0644\u062a\u0627 \u06c1\u06d2\u06d4", "\u062a\u0641\u0635\u06cc\u0644 - \u0622\u067e \u06a9\u06d2 \u06af\u0641\u062a\u06af\u0648 \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06cc \u062a\u0641\u0635\u06cc\u0644\u06d4", "\u0645\u0627\u0626\u06a9\u0631\u0648\u0641\u0648\u0646 \u06a9\u0627 \u0627\u0633\u062a\u0639\u0645\u0627\u0644 \u06a9\u0631\u06cc\u06ba - \u0645\u0627\u0626\u06a9\u0631\u0648\u0641\u0648\u0646 \u06a9\u06d2 \u0627\u0633\u062a\u0639\u0645\u0627\u0644 \u06a9\u0627 \u062c\u06be\u0646\u0688\u0627 \u0633\u06cc\u0679 \u06a9\u0631\u06cc\u06ba\u06d4", "\u062a\u0635\u0648\u06cc\u0631\u06cc - \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u0644\u0626\u06d2 \u0622\u0626\u06cc\u06a9\u0646 \u0633\u06cc\u0679 \u06a9\u0631\u06cc\u06ba\u06d4", "\u0627\u06af\u0631 \u0622\u067e \u0646\u06d2 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u0644\u0626\u06d2 \u06a9\u0648\u0626\u06cc \u062a\u0635\u0648\u06cc\u0631 \u0645\u0646\u062a\u062e\u0628 \u0646\u06c1\u06cc\u06ba \u06a9\u06cc \u06c1\u06d2 \u062a\u0648 \u060c \u0627\u0633 \u06a9\u06d2 \u0644\u0626\u06d2 \u067e\u06c1\u0644\u06d2 \u0633\u06d2 \u0637\u06d2 \u0634\u062f\u06c1 \u062a\u0635\u0648\u06cc\u0631 \u0627\u0633\u062a\u0639\u0645\u0627\u0644 \u06c1\u0648\u06af\u06cc\u06d4", "\u062c\u0628 \u0622\u067e \u0633\u0646 \u0631\u06c1\u06d2 \u06c1\u0648 (\u062e\u0628\u0631\u06cc\u06ba \u060c \u0622\u0688\u06cc\u0648 \u0627\u0633\u0628\u0627\u0642 \u060c \u0648\u063a\u06cc\u0631\u06c1) \u0645\u0639\u0627\u0645\u0644\u0627\u062a \u06a9\u06d2 \u0644\u0626\u06d2 \"\u0645\u0627\u0626\u06a9\u0631\u0648\u0641\u0648\u0646 \u06a9\u0627 \u0627\u0633\u062a\u0639\u0645\u0627\u0644 \u06a9\u0631\u06cc\u06ba\" \u067e\u06cc\u0631\u0627\u0645\u06cc\u0679\u0631 \u06a9\u06cc\u0646\u06cc\u0679 \u063a\u06cc\u0631 \u0633\u06cc\u0679 \u06a9\u0631\u06cc\u06ba\u06d4", "\"\u0645\u062f\u062f\" \u0633\u06cc\u06a9\u06cc\u0648\u0631\u0679\u06cc \u0645\u06cc\u06ba \u0628\u06cc\u0627\u0646 \u06a9\u06cc\u0627 \u06af\u06cc\u0627 \u06c1\u06d2 \u06a9\u06c1 \u0622\u067e \u06a9\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u067e\u0631\u0648\u06af\u0631\u0627\u0645 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u06a9\u06cc\u0633\u06d2 \u06a9\u0627\u0645 \u06a9\u0631\u06cc\u06ba\u06d4 \u0634\u06a9\u0644 6 \u062f\u06cc\u06a9\u06be\u06cc\u06ba\u06d4", "\u0686\u062a\u0631\u0627 6\u06d4 \u0645\u062f\u062f \u0633\u06cc\u06a9\u0634\u0646\u06d4", "\"\u0628\u0627\u06c1\u0631 \u0646\u06a9\u0644\u06cc\u06ba\" \u06a9\u06d2 \u0628\u0679\u0646 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u0646\u06d2 \u0633\u06d2 \u067e\u0631\u0648\u06af\u0631\u0627\u0645 \u062e\u062a\u0645 \u06c1\u0648\u062c\u0627\u062a\u0627 \u06c1\u06d2\u06d4 \u0634\u06a9\u0644 7 \u062f\u06cc\u06a9\u06be\u06cc\u06ba\u06d4", "\u0686\u062a\u0631\u0627 7\u06d4 \u062e\u0627\u0631\u062c\u06cc \u0628\u0679\u0646\u06d4", "\u0628\u0631\u0627\u0624\u0632\u0631 \u0648\u0646\u0688\u0648 \u06a9\u0648 \u0628\u0646\u062f \u06a9\u0631\u0646\u0627 \u06cc\u0627 \u0628\u0631\u0627\u0624\u0632\u0631 \u06a9\u0648 \u0628\u0646\u062f \u06a9\u0631\u0646\u0627 \u0628\u06be\u06cc \u067e\u0631\u0648\u06af\u0631\u0627\u0645 \u06a9\u0648 \u062e\u062a\u0645 \u06a9\u0631\u062a\u0627 \u06c1\u06d2\u06d4", "\u0635\u0641\u062d\u06c1 \u06a9\u0648 \u062a\u0627\u0632\u06c1 \u062f\u0645 \u06a9\u0631\u0646\u06d2 \u0633\u06d2 \u0628\u06be\u06cc \u067e\u0631\u0648\u06af\u0631\u0627\u0645 \u062e\u062a\u0645 \u06c1\u0648\u062c\u0627\u062a\u0627 \u06c1\u06d2\u06d4", "\u0628\u0631\u0627\u0624\u0632\u0631 \u06a9\u06d2 \u0628\u0627\u0626\u06cc\u06ba \u062c\u0627\u0646\u0628 \u0622\u067e \u06a9\u06d2 \u0628\u0627\u06c1\u0645\u06cc \u06af\u0641\u062a\u06af\u0648 \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u0648\u06ba \u06a9\u06cc \u0641\u06c1\u0631\u0633\u062a \u06c1\u06d2\u06d4 \u0634\u06a9\u0644 8 \u062f\u06cc\u06a9\u06be\u06cc\u06ba\u06d4", "\u0686\u062a\u0631\u0627 8\u06d4 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u0648\u06ba \u06a9\u06cc \u0641\u06c1\u0631\u0633\u062a\u06d4", "\u06c1\u0631 \u0627\u06cc\u06a9 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u0644\u0626\u06d2 \u060c \u0627\u0646 \u06a9\u0627 \u0622\u0626\u06a9\u0646 \u060c \u0622\u062e\u0631\u06cc \u067e\u06cc\u063a\u0627\u0645 \u06a9\u06cc \u062a\u0627\u0631\u06cc\u062e \u060c \u0627\u0648\u0631 \u0622\u067e \u06a9\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u0622\u062e\u0631\u06cc \u067e\u06cc\u063a\u0627\u0645 \u06a9\u0627 \u0645\u062a\u0646 \u062f\u06a9\u06be\u0627\u06cc\u0627 \u06af\u06cc\u0627 \u06c1\u06d2\u06d4 \u062a\u0627\u0631\u06cc\u062e \u06a9\u06cc \u0634\u06a9\u0644 \u0622\u067e \u06a9\u06cc \u0632\u0628\u0627\u0646 \u0633\u06d2 \u0645\u0637\u0627\u0628\u0642\u062a \u0631\u06a9\u06be\u062a\u06cc \u06c1\u06d2\u06d4 \u062c\u0628 \u0622\u067e \u06a9\u0633\u06cc \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u062a\u06d2 \u06c1\u06cc\u06ba \u062a\u0648 \u060c \u0627\u0646 \u06a9\u06cc \u0686\u06cc\u0679 \u06a9\u06cc \u062a\u0627\u0631\u06cc\u062e \u0638\u0627\u06c1\u0631 \u06c1\u0648\u062a\u06cc \u06c1\u06d2\u06d4", "\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06cc \u0686\u06cc\u0679 \u06a9\u06cc \u062a\u0627\u0631\u06cc\u062e \u0628\u0631\u0627\u0624\u0632\u0631 \u06a9\u06d2 \u062f\u0627\u0626\u06cc\u06ba \u062c\u0627\u0646\u0628 \u0648\u0627\u0642\u0639 \u06c1\u06d2\u06d4 \u0634\u06a9\u0644 9 \u062f\u06cc\u06a9\u06be\u06cc\u06ba\u06d4", "\u0686\u062a\u0631\u0627 9\u06d4 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06cc \u0686\u06cc\u0679 \u06a9\u06cc \u062a\u0627\u0631\u06cc\u062e\u06d4", "\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06cc \u0686\u06cc\u0679 \u06c1\u0633\u0679\u0631\u06cc \u0646\u06d2 \u0622\u067e \u06a9\u0648 \u0628\u0627\u0626\u06cc\u06ba \u062d\u0635\u06d2 \u0645\u06cc\u06ba \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u06cc\u0627 \u06c1\u06d2\u06d4", "\u0627\u0648\u067e\u0631 \u0648\u0627\u0644\u06d2 \u0645\u06cc\u0646\u0648 \u067e\u0631 \u0645\u0634\u062a\u0645\u0644 \u06c1\u06d2:", "\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u0627 \u0622\u0626\u06cc\u06a9\u0646", "\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u0627 \u0639\u0631\u0641\u06cc \u0646\u0627\u0645", "\"\u06af\u0641\u062a\u06af\u0648 \u0634\u0631\u0648\u0639 \u06a9\u0631\u06cc\u06ba\" \u06a9\u0627 \u0628\u0679\u0646", "\"\u0648\u0627\u0636\u062d \u062a\u0627\u0631\u06cc\u062e\" \u06a9\u0627 \u0628\u0679\u0646", "\"\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u0627\" \u0628\u0679\u0646 \u06a9\u0648 \u062d\u0630\u0641 \u06a9\u0631\u06cc\u06ba", "\"\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u0627 \u067e\u0631\u0648\u0641\u0627\u0626\u0644\" \u0628\u0679\u0646", "\u0645\u0646\u062a\u062e\u0628 \u06a9\u0631\u062f\u06c1 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u0686\u06cc\u0679 \u06a9\u06cc \u062a\u0627\u0631\u06cc\u062e \u0635\u062d\u06cc\u062d \u062d\u0635\u06d2 \u0645\u06cc\u06ba \u0638\u0627\u06c1\u0631 \u06c1\u0648\u062a\u06cc \u06c1\u06d2\u06d4", "\u0686\u06cc\u0679 \u06a9\u06d2 \u0639\u0646\u0648\u0627\u0646 \u0645\u06cc\u06ba \u06cc\u0627\u06a9\u0633 \u06a9\u06d2 \u0627\u06cc\u06a9 \u062c\u0648\u0691\u06d2 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u0646\u0645\u0628\u0631 \u06c1\u06d2: \"\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06cc \u0632\u0628\u0627\u0646\"/\"\u0622\u067e \u06a9\u06cc \u0632\u0628\u0627\u0646\"\u06d4", "\u0686\u06cc\u0679 \u06a9\u06d2 \u0639\u0646\u0648\u0627\u0646 \u0645\u06cc\u06ba \"\u0627\u0633 \u0686\u06cc\u0679 \u06a9\u0648 \u062d\u0630\u0641 \u06a9\u0631\u06cc\u06ba\" \u06a9\u06d2 \u0628\u0679\u0646 \u067e\u0631 \u0645\u0634\u062a\u0645\u0644 \u06c1\u06d2\u06d4", "\u062c\u0628 \u0622\u067e \"\u0627\u0633 \u0686\u06cc\u0679 \u06a9\u0648 \u062d\u0630\u0641 \u06a9\u0631\u06cc\u06ba\" \u06a9\u06d2 \u0628\u0679\u0646 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u062a\u06d2 \u06c1\u06cc\u06ba \u062a\u0648 \u060c \u06cc\u06c1 \u0686\u06cc\u0679 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06cc \u0686\u06cc\u0679 \u06a9\u06cc \u062a\u0627\u0631\u06cc\u062e \u0633\u06d2 \u062d\u0630\u0641 \u06a9\u0631\u062f\u06cc \u062c\u0627\u062a\u06cc \u06c1\u06d2\u06d4", "\u062a\u0645\u0627\u0645 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a \u06a9\u0648 2 \u06af\u0631\u0648\u067e\u0648\u06ba \u0645\u06cc\u06ba \u062a\u0642\u0633\u06cc\u0645 \u06a9\u06cc\u0627 \u06af\u06cc\u0627 \u06c1\u06d2:", "\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a\u06d4", "\u0622\u067e \u06a9\u06d2 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a", "\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a \u0628\u0627\u0626\u06cc\u06ba \u0637\u0631\u0641 \u0645\u0646\u062a\u0642\u0644 \u06a9\u0631\u062f\u06cc\u0626\u06d2 \u062c\u0627\u062a\u06d2 \u06c1\u06cc\u06ba\u06d4 \u0622\u067e \u06a9\u06d2 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a \u062f\u0627\u0626\u06cc\u06ba \u0637\u0631\u0641 \u0645\u0646\u062a\u0642\u0644 \u06a9\u0631\u062f\u06cc\u0626\u06d2 \u06af\u0626\u06d2 \u06c1\u06cc\u06ba\u06d4", "\u06c1\u0631 \u067e\u06cc\u063a\u0627\u0645 \u06af\u0631\u0648\u067e 2 \u062d\u0635\u0648\u06ba \u067e\u0631 \u0645\u0634\u062a\u0645\u0644 \u06c1\u0648\u062a\u0627 \u06c1\u06d2:", "\u0645\u06cc\u0633\u062c \u0679\u06cc\u06a9\u0633\u0679 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u060c \u0627\u0633 \u067e\u06cc\u063a\u0627\u0645 \u06a9\u0627 \u0631\u0646\u06af \u0633\u06cc\u0627\u06c1 \u06c1\u06d2\u06d4", "\u067e\u06cc\u063a\u0627\u0645 \u06a9\u0627 \u0645\u062a\u0646 \u0622\u067e \u06a9\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u060c \u0627\u0633 \u067e\u06cc\u063a\u0627\u0645 \u06a9\u0627 \u0631\u0646\u06af \u0633\u0628\u0632 \u06c1\u06d2\u06d4", "\u067e\u06cc\u063a\u0627\u0645 \u06a9\u06cc \u062a\u0627\u0631\u06cc\u062e \u0622\u067e \u06a9\u06cc \u0632\u0628\u0627\u0646 \u0633\u06d2 \u0645\u0633\u0627\u0648\u06cc \u06c1\u06d2\u06d4", "\u0646\u0626\u06d2 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a (\u062a\u0627\u0631\u06cc\u062e \u06a9\u06d2 \u0645\u0637\u0627\u0628\u0642) \u067e\u0631\u0627\u0646\u06d2 \u0627\u0648\u0648\u0646\u0633 \u0633\u06d2 \u06a9\u0645 \u0648\u0627\u0642\u0639 \u06c1\u06cc\u06ba\u06d4", "\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u0686\u06cc\u0679\u0633 \u06a9\u06d2 \u0628\u0627\u0644\u06a9\u0644 \u0646\u06cc\u0686\u06d2 \"\u0627\u0633\u0679\u0627\u0631\u0679 \u06af\u0641\u062a\u06af\u0648\" \u06a9\u0627 \u0628\u0679\u0646 \u06c1\u06d2\u06d4 \u062c\u0628 \u0622\u067e \u0627\u0633 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u062a\u06d2 \u06c1\u06cc\u06ba \u062a\u0648 \u060c \u067e\u0631\u0648\u06af\u0631\u0627\u0645 \u0633\u06af\u0646\u0644/\u0634\u0648\u0631 \u06a9\u06cc \u0633\u0637\u062d \u06a9\u0627 \u062a\u0639\u06cc\u0646 \u06a9\u0631\u0646\u06d2 \u06a9\u06d2 \u0644\u0626\u06d2 \u0645\u0627\u0626\u06a9\u0631\u0648\u0641\u0648\u0646 \u0627\u0648\u0631 \u0633\u0627\u0624\u0646\u0688 \u0688\u06cc\u0648\u0627\u0626\u0633 \u06a9\u0648 \u06a9\u06cc\u0644\u06cc\u0628\u0631\u06cc\u0679 \u06a9\u0631\u0646\u0627 \u0634\u0631\u0648\u0639 \u06a9\u0631\u062a\u0627 \u06c1\u06d2 \u0627\u0648\u0631 \u0627\u0633 \u0633\u06d2 \u0645\u062a\u0639\u0644\u0642\u06c1 \u067e\u06cc\u063a\u0627\u0645 \u06a9\u0648 \u0638\u0627\u06c1\u0631 \u06a9\u0631\u062a\u0627 \u06c1\u06d2\u06d4", "\u0635\u0648\u062a\u06cc \u0622\u0644\u0627\u062a \u06a9\u0648 \u06a9\u06cc\u0644\u06cc\u0628\u0631\u06cc\u0679 \u06a9\u0631\u0646\u06d2 \u06a9\u06d2 \u0628\u0639\u062f \u060c \u0628\u0679\u0646\u0648\u06ba \u06a9\u06d2 \u0646\u0627\u0645 \u062a\u0628\u062f\u06cc\u0644 \u06c1\u0648\u062c\u0627\u062a\u06d2 \u06c1\u06cc\u06ba: \"\u06af\u0641\u062a\u06af\u0648 \u0634\u0631\u0648\u0639 \u06a9\u0631\u06cc\u06ba\" -> \"\u06af\u0641\u062a\u06af\u0648 \u06a9\u0648 \u0631\u0648\u06a9\u06cc\u06ba\"\u06d4", "\u0627\u0633 \u0646\u0642\u0637\u06c1 \u0646\u0638\u0631 \u0633\u06d2 \u060c \u0622\u067e \u06af\u0641\u062a\u06af\u0648 \u0634\u0631\u0648\u0639 \u06a9\u0631\u0633\u06a9\u062a\u06d2 \u06c1\u06cc\u06ba \u06cc\u0627 \u0622\u0688\u06cc\u0648/\u0648\u06cc\u0688\u06cc\u0648 \u0641\u0627\u0626\u0644 \u0644\u0627\u0646\u0686 \u06a9\u0631\u0633\u06a9\u062a\u06d2 \u06c1\u06cc\u06ba\u06d4", "\u062a\u0645\u0627\u0645 \u0622\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a (\u062f\u0648\u0633\u0631\u06d2 \u0634\u062e\u0635 \u0633\u06d2) \u0628\u0627\u0626\u06cc\u06ba \u0637\u0631\u0641 \u0638\u0627\u06c1\u0631 \u06c1\u0648\u06ba \u06af\u06d2\u06d4", "\u062a\u0645\u0627\u0645 \u0622\u0624\u0679\u0646\u06af \u067e\u06cc\u063a\u0627\u0645\u0627\u062a (\u0622\u067e \u0633\u06d2) \u062f\u0627\u0626\u06cc\u06ba \u0637\u0631\u0641 \u0638\u0627\u06c1\u0631 \u06c1\u0648\u06ba \u06af\u06d2\u06d4", "\u0622\u067e \u0627\u067e\u0646\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u067e\u06cc\u063a\u0627\u0645\u0627\u062a \u0633\u0646\u06cc\u06ba \u06af\u06d2 \u0627\u0648\u0631 \u0622\u067e \u06a9\u0627 \u062f\u0648\u0633\u0631\u0627 \u0634\u062e\u0635 \u0627\u0646 \u06a9\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u067e\u06cc\u063a\u0627\u0645\u0627\u062a \u0633\u0646\u06cc\u06ba \u06af\u06d2\u06d4", "\u06af\u0641\u062a\u06af\u0648 \u06a9\u06d2 \u0627\u062e\u062a\u062a\u0627\u0645 \u067e\u0631/\u0648\u06cc\u0688\u06cc\u0648 \u0633\u0646\u0646\u06d2 \u067e\u0631 \u060c \u0622\u067e \u06a9\u0648 \"\u0627\u0633\u0679\u0627\u067e \u06af\u0641\u062a\u06af\u0648\" \u06a9\u06d2 \u0628\u0679\u0646\u0648\u06ba \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u0646\u06d2 \u06a9\u06cc \u0636\u0631\u0648\u0631\u062a \u06c1\u06d2\u06d4", "\u06af\u0641\u062a\u06af\u0648 \u0628\u06be\u06cc \u062e\u062a\u0645 \u06c1\u0648\u062a\u06cc \u06c1\u06d2 \u062c\u0628:", "\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u0648\u06ba \u06a9\u06cc \u0641\u06c1\u0631\u0633\u062a \u0645\u06cc\u06ba \u0628\u0631\u0627\u0624\u0632\u0631 \u06a9\u06d2 \u0628\u0627\u0626\u06cc\u06ba \u062d\u0635\u06d2 \u0645\u06cc\u06ba \u062f\u0648\u0633\u0631\u06d2 \u0634\u062e\u0635 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u0646\u0627\u06d4", "\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u0648\u06ba \u06a9\u06cc \u0641\u06c1\u0631\u0633\u062a \u06a9\u06d2 \u0627\u0648\u067e\u0631\u06cc \u062d\u0635\u06d2 \u0645\u06cc\u06ba \"\u0646\u0626\u06d2\" \u0628\u0679\u0646 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u0646\u0627\u06d4", "\u0627\u0648\u067e\u0631 \u0648\u0627\u0644\u06d2 \u0645\u06cc\u0646\u0648 \u0645\u06cc\u06ba \"\u0645\u062f\u062f\" \u06a9\u06d2 \u0628\u0679\u0646 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u0646\u0627\u06d4", "\u0627\u0648\u067e\u0631 \u0648\u0627\u0644\u06d2 \u0645\u06cc\u0646\u0648 \u0645\u06cc\u06ba \"\u0648\u0627\u0636\u062d \u062a\u0627\u0631\u06cc\u062e\" \u06a9\u06d2 \u0628\u0679\u0646 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u0646\u0627\u06d4", "\u0627\u0648\u067e\u0631 \u0648\u0627\u0644\u06d2 \u0645\u06cc\u0646\u0648 \u0645\u06cc\u06ba \"\u0688\u06cc\u0644\u0644\u0648\u06a9\u06cc\u0679\u0631 \u06a9\u0648 \u062d\u0630\u0641 \u06a9\u0631\u06cc\u06ba\" \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u0646\u0627\u06d4", "\u0627\u0648\u067e\u0631 \u0648\u0627\u0644\u06d2 \u0645\u06cc\u0646\u0648 \u0645\u06cc\u06ba \"\u0627\u0646\u0679\u0631\u0644\u0648\u06a9\u06cc\u0679\u0631 \u06a9\u06d2 \u067e\u0631\u0648\u0641\u0627\u0626\u0644\" \u06a9\u06d2 \u0628\u0679\u0646 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u06a9\u06d2\u06d4", "\u0627\u0648\u067e\u0631 \u0648\u0627\u0644\u06d2 \u0645\u06cc\u0646\u0648 \u0645\u06cc\u06ba \"\u0628\u0627\u06c1\u0631 \u0646\u06a9\u0644\u06cc\u06ba\" \u06a9\u06d2 \u0628\u0679\u0646 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u06a9\u06d2\u06d4", "\u0686\u06cc\u0679 \u06a9\u06cc \u062a\u0627\u0631\u06cc\u062e \u0645\u06cc\u06ba \u067e\u06cc\u063a\u0627\u0645\u0627\u062a \u06a9\u06cc \u0646\u0645\u0627\u0626\u0634 \u0645\u06cc\u0646\u0648 \u06a9\u06d2 \u0627\u0648\u067e\u0631\u06cc \u0628\u0627\u0626\u06cc\u06ba \u062d\u0635\u06d2 (\u06af\u0631\u06cc\u0646 \u0627\u06cc\u0631\u0648) \u0645\u06cc\u06ba \u0645\u06cc\u0633\u062c \u0688\u0633\u067e\u0644\u06d2 \u06a9\u06d2 \u0622\u067e\u0634\u0646 \u06a9\u0648 \u0645\u0646\u062a\u062e\u0628 \u06a9\u0631\u06a9\u06d2 \u06a9\u06cc \u06af\u0626\u06cc \u06c1\u06d2\u06d4", "\u062c\u0628 \"\u062a\u0645\u0627\u0645 \u0632\u0628\u0627\u0646\u06cc\u06ba\" \u0645\u0646\u062a\u062e\u0628 \u06a9\u0631\u062a\u06d2 \u06c1\u0648 - \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a \u0627\u0648\u0631 \u0622\u067e \u06a9\u06d2 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a \u062a\u0645\u0627\u0645 \u0632\u0628\u0627\u0646\u0648\u06ba \u0645\u06cc\u06ba \u0638\u0627\u06c1\u0631 \u06c1\u0648\u062a\u06d2 \u06c1\u06cc\u06ba\u06d4", "\u062c\u0628 \"\u0645\u06cc\u0631\u06cc \u0632\u0628\u0627\u0646\" \u06a9\u0627 \u0627\u0646\u062a\u062e\u0627\u0628 \u06a9\u0631\u062a\u06d2 \u06c1\u0648 - \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a \u0627\u0648\u0631 \u0622\u067e \u06a9\u06d2 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a \u0635\u0631\u0641 \u0622\u067e \u06a9\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u0638\u0627\u06c1\u0631 \u06c1\u0648\u062a\u06d2 \u06c1\u06cc\u06ba\u06d4", "\u062c\u0628 \"\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06cc \u0632\u0628\u0627\u0646\" \u06a9\u0627 \u0627\u0646\u062a\u062e\u0627\u0628 \u06a9\u0631\u062a\u06d2 \u06c1\u0648 - \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a \u0627\u0648\u0631 \u0622\u067e \u06a9\u06d2 \u067e\u06cc\u063a\u0627\u0645\u0627\u062a \u0635\u0631\u0641 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06cc \u0632\u0628\u0627\u0646 \u0645\u06cc\u06ba \u0638\u0627\u06c1\u0631 \u06c1\u0648\u062a\u06d2 \u06c1\u06cc\u06ba\u06d4", "\u067e\u06c1\u0644\u06d2 \u0633\u06d2 \u0637\u06d2 \u0634\u062f\u06c1 \u0645\u06cc\u0633\u062c \u0688\u0633\u067e\u0644\u06d2 \u0645\u0648\u0688 \"\u062a\u0645\u0627\u0645 \u0632\u0628\u0627\u0646\u06cc\u06ba\" \u06c1\u06d2\u06d4", "\u062c\u0628 \"\u0648\u0627\u0636\u062d \u062a\u0627\u0631\u06cc\u062e\" \u06a9\u06d2 \u0628\u0679\u0646 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u062a\u06d2 \u06c1\u0648 \u062a\u0648 \u060c \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u062a\u0645\u0627\u0645 \u0686\u06cc\u0679\u0633 \u062d\u0630\u0641 \u06c1\u0648\u062c\u0627\u062a\u06d2 \u06c1\u06cc\u06ba \u060c \u0644\u06cc\u06a9\u0646 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u0627 \u0628\u0627\u0642\u06cc \u0631\u06c1\u062a\u0627 \u06c1\u06d2\u06d4 \u0634\u06a9\u0644 10 \u062f\u06cc\u06a9\u06be\u06cc\u06ba\u06d4", "\u0686\u062a\u0631\u0627 10\u06d4 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06cc \u062a\u0627\u0631\u06cc\u062e \u06a9\u0648 \u0635\u0627\u0641 \u06a9\u0631\u0646\u0627\u06d4", "\u0627\u06af\u0631 \u0641\u06cc \u0627\u0644\u062d\u0627\u0644 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u0628\u0627\u062a \u0686\u06cc\u062a \u062c\u0627\u0631\u06cc \u06c1\u06d2 \u062a\u0648 \u060c \u0627\u0633\u06d2 \u0631\u0648\u06a9 \u062f\u06cc\u0627 \u06af\u06cc\u0627 \u06c1\u06d2\u06d4", "\"\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u0648 \u062d\u0630\u0641 \u06a9\u0631\u06cc\u06ba\" \u06a9\u06d2 \u0628\u0679\u0646 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u0646\u06d2 \u0633\u06d2 \u062a\u0645\u0627\u0645 \u0686\u06cc\u0679\u0633 \u06a9\u0648 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u0627\u0648\u0631 \u062e\u0648\u062f \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u062d\u0630\u0641 \u06a9\u0631\u062f\u06cc\u062a\u0627 \u06c1\u06d2\u06d4 \u0634\u06a9\u0644 11 \u062f\u06cc\u06a9\u06be\u06cc\u06ba\u06d4", "\u0686\u062a\u0631\u0627 11\u06d4 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u0648 \u062d\u0630\u0641 \u06a9\u0631\u0646\u0627\u06d4", "\u0627\u06af\u0631 \u0641\u06cc \u0627\u0644\u062d\u0627\u0644 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u0633\u0627\u062a\u06be \u0628\u0627\u062a \u0686\u06cc\u062a \u062c\u0627\u0631\u06cc \u06c1\u06d2 \u062a\u0648 \u060c \u0627\u0633\u06d2 \u0631\u0648\u06a9 \u062f\u06cc\u0627 \u06af\u06cc\u0627 \u06c1\u06d2\u06d4", "\"\u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u067e\u0631\u0648\u0641\u0627\u0626\u0644\" \u06a9\u06d2 \u0628\u0679\u0646 \u067e\u0631 \u06a9\u0644\u06a9 \u06a9\u0631\u0646\u06d2 \u0633\u06d2 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u06d2 \u0688\u06cc\u0679\u0627 \u0633\u06d2 \u0628\u06be\u0631\u0627 \u06c1\u0648\u0627 \u0627\u06cc\u06a9 \u0641\u0627\u0631\u0645 \u062f\u06a9\u06be\u0627\u062a\u0627 \u06c1\u06d2\u06d4 \u0634\u06a9\u0644 12 \u062f\u06cc\u06a9\u06be\u06cc\u06ba\u06d4", "\u0686\u062a\u0631\u0627 12\u06d4 \u0628\u0627\u062a \u0686\u06cc\u062a \u06a9\u0631\u0646\u06d2 \u0648\u0627\u0644\u06d2 \u06a9\u0627 \u067e\u0631\u0648\u0641\u0627\u0626\u0644 \u062f\u06cc\u06a9\u06be\u0646\u0627\u06d4", "\u06cc\u06c1 \u0622\u0626\u0679\u0645 \u0622\u0626\u0679\u0645 \u0633\u06d2 \u0645\u0644\u062a\u0627 \u062c\u0644\u062a\u0627 \u06c1\u06d2", "\u0639\u0645\u0648\u062f\u06cc \u062c\u062f\u0627\u06a9\u0627\u0631 \u0622\u067e \u06a9\u0648 \u0648\u0631\u06a9 \u0627\u0633\u067e\u06cc\u0633 \u06a9\u06d2 \u0628\u0627\u0626\u06cc\u06ba \u0627\u0648\u0631 \u062f\u0627\u0626\u06cc\u06ba \u0639\u0644\u0627\u0642\u0648\u06ba \u06a9\u06cc \u0686\u0648\u0691\u0627\u0626\u06cc \u06a9\u0648 \u062a\u0628\u062f\u06cc\u0644 \u06a9\u0631\u0646\u06d2 \u06a9\u06cc \u0627\u062c\u0627\u0632\u062a \u062f\u06cc\u062a\u0627 \u06c1\u06d2\u06d4 \u0634\u06a9\u0644 13 \u062f\u06cc\u06a9\u06be\u06cc\u06ba\u06d4", "\u0686\u062a\u0631\u0627 13\u06d4 \u0628\u0627\u0626\u06cc\u06ba \u0627\u0648\u0631 \u062f\u0627\u0626\u06cc\u06ba \u062d\u0635\u0648\u06ba \u06a9\u0627 \u0639\u0645\u0648\u062f\u06cc \u062c\u062f\u0627\u06a9\u0627\u0631\u06d4", "\u062c\u0628 \u0622\u067e \u0639\u0645\u0648\u062f\u06cc \u062c\u062f\u0627\u06a9\u0627\u0631 \u06a9\u0648 \u0645\u0646\u062a\u0642\u0644 \u06a9\u0631\u062a\u06d2 \u06c1\u06cc\u06ba \u062a\u0648 \u060c \u0627\u0633 \u06a9\u06cc \u067e\u0648\u0632\u06cc\u0634\u0646 \u0645\u062d\u0641\u0648\u0638 \u06c1\u0648\u062c\u0627\u062a\u06cc \u06c1\u06d2\u06d4 \u062c\u0628 \u0622\u067e \u067e\u0631\u0648\u06af\u0631\u0627\u0645 \u06a9\u0648 \u062f\u0648\u0628\u0627\u0631\u06c1 \u0634\u0631\u0648\u0639 \u06a9\u0631\u062a\u06d2 \u06c1\u06cc\u06ba \u062a\u0648 \u060c \u0622\u062e\u0631\u06cc \u067e\u0648\u0632\u06cc\u0634\u0646 \u062c\u0648 \u0622\u067e \u0646\u06d2 \u0645\u0631\u062a\u0628 \u06a9\u06cc \u06c1\u06d2 \u0627\u0633\u06d2 \u0628\u062d\u0627\u0644 \u06a9\u06cc\u0627 \u062c\u0627\u0626\u06d2 \u06af\u0627\u06d4", "\u0645\u0627\u0624\u0633 \u06a9\u0631\u0633\u0631 \u06a9\u0648 \u0627\u0633\u06a9\u0631\u06cc\u0646 \u06a9\u06d2 \u0646\u0686\u0644\u06d2 \u062f\u0627\u0626\u06cc\u06ba \u06a9\u0648\u0646\u06d2 \u0645\u06cc\u06ba \u0627\u0633\u067e\u06cc\u06a9\u0631 \u0627\u0645\u06cc\u062c \u06a9\u06d2 \u0627\u0648\u067e\u0631 \u0645\u0646\u062a\u0642\u0644 \u06a9\u0631\u06cc\u06ba \u0627\u0648\u0631 \u062f\u0627\u0626\u06cc\u06ba \u06a9\u0644\u06a9 \u06a9\u0631\u06cc\u06ba \u060c \"\u0627\u0648\u067e\u0646 \u0633\u0627\u0624\u0646\u0688 \u0633\u06cc\u0679\u0646\u06af\u0632\" \u0645\u06cc\u0646\u0648 \u0622\u0626\u0679\u0645 \u06a9\u0648 \u0645\u0646\u062a\u062e\u0628 \u06a9\u0631\u06cc\u06ba \u060c \u062c\u06cc\u0633\u0627 \u06a9\u06c1 \u0634\u06a9\u0644 14 \u0645\u06cc\u06ba \u062f\u06a9\u06be\u0627\u06cc\u0627 \u06af\u06cc\u0627 \u06c1\u06d2\u06d4", "\u0686\u062a\u0631\u0627 14\u06d4 \u06a9\u06be\u0644\u06cc \u0622\u0648\u0627\u0632 \u06a9\u06cc \u062a\u0631\u062a\u06cc\u0628\u0627\u062a\u06d4", "\u0645\u0648\u062c\u0648\u062f\u06c1 \u0622\u0648\u0627\u0632 \u06a9\u06cc \u062a\u0631\u062a\u06cc\u0628\u0627\u062a \u0648\u0627\u0644\u06cc \u0627\u0633\u06a9\u0631\u06cc\u0646 \u0638\u0627\u06c1\u0631 \u06c1\u0648\u06af\u06cc\u06d4", "\u0686\u062a\u0631\u0627 15\u06d4 \u0645\u0648\u062c\u0648\u062f\u06c1 \u0622\u0648\u0627\u0632 \u06a9\u06cc \u062a\u0631\u062a\u06cc\u0628\u0627\u062a\u06d4", "\u0627\u0628\u062a\u062f\u0627\u0626\u06cc \u0627\u0642\u062f\u0627\u0631 \u06a9\u0648 \u0628\u062d\u0627\u0644 \u06a9\u0631\u06cc\u06ba \u062c\u0648 \u06a9\u0627\u0645 \u0634\u0631\u0648\u0639 \u06a9\u0631\u0646\u06d2 \u0633\u06d2 \u067e\u06c1\u0644\u06d2 \u062a\u06be\u06d2\u06d4 \u0622\u067e \u06a9\u06d2 \u0645\u0639\u0627\u0645\u0644\u06d2 \u0645\u06cc\u06ba \u060c \u0646\u0627\u0645 \u0645\u062e\u062a\u0644\u0641 \u06c1\u0648\u06ba \u06af\u06d2\u06d4", "\u0686\u062a\u0631\u0627 16\u06d4 \u0627\u0628\u062a\u062f\u0627\u0626\u06cc \u0622\u0648\u0627\u0632 \u06a9\u06cc \u062a\u0631\u062a\u06cc\u0628\u0627\u062a\u06d4", "\u0633\u0633\u0679\u0645 \u06a9\u06cc \u062a\u0631\u062a\u06cc\u0628\u0627\u062a \u06a9\u0648 \u0628\u062d\u0627\u0644 \u06a9\u0631\u062f\u06cc\u0627 \u06af\u06cc\u0627 \u06c1\u06d2 \u060c \u0622\u067e \u0648\u0646\u0688\u0648\u0632 \u0645\u06cc\u06ba \u06a9\u0627\u0645 \u06a9\u0631\u0633\u06a9\u062a\u06d2 \u06c1\u06cc\u06ba\u06d4"]