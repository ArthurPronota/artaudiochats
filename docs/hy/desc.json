["\u00ab\u0531\u0578\u0582\u0564\u056b\u0578 \u0566\u0580\u0578\u0582\u0575\u0581\u0576\u0565\u0580\u00bb \u056e\u0580\u0561\u0563\u0580\u056b \u0576\u056f\u0561\u0580\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568:", "\u0532\u0578\u057e\u0561\u0576\u0564\u0561\u056f\u0578\u0582\u0569\u0575\u0578\u0582\u0576", "1-\u0568: \u0546\u0561\u056d\u0584\u0561\u0576 \u057d\u056f\u057d\u0565\u056c\u0568:", "2-\u0568. \u0540\u0561\u056f\u056b\u0580\u0573 \u0576\u056f\u0561\u0580\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576:", "3. \u0540\u0561\u0572\u0578\u0580\u0564\u0561\u056f\u0581\u0574\u0561\u0576 \u0570\u0561\u0574\u0561\u0580 \u0574\u0561\u057f\u0579\u0565\u056c\u056b \u056c\u0565\u0566\u0578\u0582\u0576\u0565\u0580\u056b \u0581\u0578\u0582\u0581\u0561\u056f:", "4. \u053b\u0576\u0579 \u0571\u0565\u0566 \u0570\u0561\u0580\u056f\u0561\u057e\u0578\u0580 \u0567 \u0561\u0577\u056d\u0561\u057f\u0561\u0576\u0584\u056b \u0561\u0577\u056d\u0561\u057f\u0561\u0576\u0584\u056b \u0570\u0561\u0574\u0561\u0580:", "5. \u0531\u0577\u056d\u0561\u057f\u0565\u056c\u0578\u057e \u056e\u0580\u0561\u0563\u0580\u056b \u0570\u0565\u057f:", "5.1 \u053f\u0561\u0566\u0574\u0561\u0571\u0565\u0582\u0578\u0582\u0574:", "5.2 \u0546\u0578\u0580 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u0578\u0582\u0569\u0575\u0561\u0576 \u057a\u0580\u0578\u0586\u056b\u056c:", "5.3 \u0555\u0563\u0576\u0578\u0582\u0569\u0575\u0561\u0576 \u0562\u0561\u056a\u056b\u0576:", "5.4 \u0535\u056c\u0584 \u056f\u0578\u0573\u0561\u056f\u0568:", "5.5 \u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0576\u0565\u0580\u056b \u0581\u0578\u0582\u0581\u0561\u056f:", "5.6 \u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u0566\u0580\u0578\u0582\u0575\u0581\u056b \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568:", "5.7 \u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568 \u0574\u0561\u0584\u0580\u0565\u056c\u0568:", "5.8 \u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u057b\u0576\u057b\u0578\u0582\u0574:", "5.9 \u0534\u056b\u057f\u0565\u056c\u0578\u057e \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u057a\u0580\u0578\u0586\u056b\u056c\u0568:", "5.10 \u0541\u0561\u056d \u0565\u0582 \u0561\u057b \u0574\u0561\u057d\u0565\u0580\u056b \u0574\u056b\u057b\u0565\u0582 \u0578\u0582\u0572\u0572\u0561\u0570\u0561\u0575\u0561\u0581 \u057f\u0561\u0580\u0561\u0576\u057b\u0561\u057f\u056b\u0579:", "6. \u0531\u0577\u056d\u0561\u057f\u0565\u056c\u0568 \u0561\u057e\u0561\u0580\u057f\u0565\u056c\u0578\u0582\u0581 \u0570\u0565\u057f\u0578:", "\u054d\u0561\u057e\u0561\u057c\u0576\u0565\u056c \u0574\u056f\u0576\u056b\u056f\u056b \u056f\u0578\u0582\u0580\u057d\u0578\u0580\u0568 \u0562\u0561\u0580\u0571\u0580\u0561\u056d\u0578\u057d\u056b \u057a\u0561\u057f\u056f\u0565\u0580\u0578\u057e \u0567\u056f\u0580\u0561\u0576\u056b \u057d\u057f\u0578\u0580\u056b\u0576 \u0561\u057b \u0561\u0576\u056f\u0575\u0578\u0582\u0576\u0578\u0582\u0574 \u0565\u0582 \u0561\u057b \u057d\u0565\u0572\u0574\u0578\u0582\u0574\u0578\u057e, \u0562\u0561\u0581 \u0571\u0561\u0575\u0576\u0561\u0575\u056b\u0576 \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580 \u00bb\u0568\u0576\u057f\u0580\u0561\u0581\u0561\u0576\u056f\u056b \u057f\u0561\u0580\u0580\u0568, \u056b\u0576\u0579\u057a\u0565\u057d Shawn- \u0568` 1-\u056b\u0576:", "\u0546\u056f\u0561\u0580 1: \u0532\u0561\u0581 \u0571\u0561\u0575\u0576\u0561\u0575\u056b\u0576 \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580:", "\u0540\u0576\u0561\u0580\u0561\u057e\u0578\u0580 \u0567 \u0567\u056f\u0580\u0561\u0576\u0578\u057e \u0567\u056f\u0580\u0561\u0576 \u0578\u0582\u0576\u0565\u0581\u0578\u0572 \u0567\u056f\u0580\u0561\u0576 \u0578\u0582\u0576\u0565\u0581\u0578\u0572 \u0567\u056f\u0580\u0561\u0576: \u0540\u056b\u0577\u0565\u0584, \u0569\u0565 \u056b\u0576\u0579 \u0567 \u0576\u0561\u056d\u0561\u057f\u0565\u057d\u057e\u0561\u056e \u0574\u0578\u0582\u057f\u0584\u056b \u0565\u0582 \u0565\u056c\u0584\u0561\u0575\u056b\u0576 \u0561\u0578\u0582\u0564\u056b\u0578 \u057d\u0561\u0580\u0584\u0565\u0580\u056b \u0570\u0561\u0574\u0561\u0580: \u0531\u0577\u056d\u0561\u057f\u0565\u056c\u0568 \u0561\u057e\u0561\u0580\u057f\u0565\u056c\u0578\u0582\u0581 \u0570\u0565\u057f\u0578 \u0571\u0565\u0566 \u0570\u0561\u0580\u056f\u0561\u057e\u0578\u0580 \u056f\u056c\u056b\u0576\u056b \u0561\u0575\u057d \u057f\u0565\u0572\u0565\u056f\u0561\u057f\u057e\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568: \u0546\u056f\u0561\u0580 2-\u0578\u0582\u0574 \u056f\u0561\u0580\u0574\u056b\u0580 \u0576\u0565\u057f\u0565\u0580\u0568 \u0581\u0578\u0582\u0575\u0581 \u0565\u0576 \u057f\u0561\u056c\u056b\u057d, \u0569\u0565 \u056b\u0576\u0579 \u057a\u0565\u057f\u0584 \u0567 \u0570\u056b\u0577\u0565\u0584: \u0541\u0565\u0580 \u0564\u0565\u057a\u0584\u0578\u0582\u0574 \u0561\u0576\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u057f\u0561\u0580\u0562\u0565\u0580 \u056f\u056c\u056b\u0576\u0565\u0576:", "\u0533\u056e\u0561\u057a\u0561\u057f\u056f\u0565\u0580 2. \u0546\u0561\u056d\u0576\u0561\u056f\u0561\u0576 \u0571\u0561\u0575\u0576\u0561\u0575\u056b\u0576 \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580", "\u054d\u0561\u0570\u0574\u0561\u0576\u0565\u0584 \u0571\u0561\u0575\u0576\u0561\u0575\u056b\u0576 \u0565\u056c\u0584\u0561\u0575\u056b\u0576 \u057d\u0561\u0580\u0584\u0568", "\u054d\u0561\u0570\u0574\u0561\u0576\u0565\u0584 \u0571\u0561\u0575\u0576\u0561\u0575\u056b\u0576 \u0574\u0578\u0582\u057f\u0584\u0561\u0575\u056b\u0576 \u057d\u0561\u0580\u0584\u0568", "\u0533\u056e\u0561\u057a\u0561\u057f\u056f\u0565\u0580 3-\u0578\u0582\u0574 \u056f\u0561\u0580\u0574\u056b\u0580 \u0576\u0565\u057f\u0565\u0580\u0568 \u0581\u0578\u0582\u0575\u0581 \u0565\u0576 \u057f\u0561\u056c\u056b\u057d, \u0569\u0565 \u056b\u0576\u0579 \u0565\u0582 \u0571\u0565\u0566 \u0570\u0561\u0580\u056f\u0561\u057e\u0578\u0580 \u0567 \u056f\u0561\u0580\u0563\u0561\u057e\u0578\u0580\u0565\u056c:", "\u0533\u056e\u0561\u057a\u0561\u057f\u056f\u0565\u0580 3. \u0531\u0577\u056d\u0561\u057f\u0561\u0576\u0584\u0561\u0575\u056b\u0576 \u0571\u0561\u0575\u0576\u0561\u0575\u056b\u0576 \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580", "\u0540\u0561\u0574\u0561\u056f\u0561\u0580\u0563\u056b \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580\u0568 \u0561\u0574\u0562\u0578\u0572\u057b\u0561\u056f\u0561\u0576 \u0565\u0576, \u056f\u0561\u0580\u0578\u0572 \u0565\u0584 \u0563\u0578\u0580\u056e\u0561\u0580\u056f\u0565\u056c \u056e\u0580\u0561\u0563\u056b\u0580\u0568", "\u0534\u0578\u0582\u0584 \u056d\u0578\u057d\u0578\u0582\u0574 \u0565\u0584 \u0571\u0565\u0580 \u0563\u056b\u057f\u0561\u056e \u056c\u0565\u0566\u0578\u0582\u0576, \u056c\u057d\u0578\u0582\u0574 \u0565\u0584 \u0571\u0565\u0580 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0568 \u0570\u0561\u057d\u056f\u0561\u0576\u0561\u056c\u056b \u056c\u0565\u0566\u057e\u0578\u057e: \u0541\u0565\u0580 \u056f\u0578\u0576\u056f\u0580\u0565\u057f\u0576\u0565\u0580\u056b \u0574\u0561\u057f\u0575\u0561\u0576\u0576 \u0567 \u057a\u0561\u0570\u057e\u0578\u0582\u0574, \u0578\u0580\u0568 \u056f\u0561\u0580\u0578\u0572 \u0565\u0584 \u0585\u0563\u057f\u0561\u0563\u0578\u0580\u056e\u0565\u056c: \u0532\u0578\u056c\u0578\u0580 \u0563\u0578\u0580\u056e\u0578\u0572\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u056b\u0580\u0561\u056f\u0561\u0576\u0561\u0581\u057e\u0578\u0582\u0574 \u0565\u0576 \u057f\u0565\u0572\u0561\u056f\u0561\u0576 \u0570\u0561\u0574\u0561\u056f\u0561\u0580\u0563\u0579\u0578\u0582\u0574 \u0561\u0577\u056d\u0561\u057f\u0578\u0572 Windows 10 \u056f\u0561\u0574 Windows 11-\u056b \u057e\u0580\u0561: \u0533\u0580\u0561\u0586\u056b\u056f\u0561\u0575\u056b \u057a\u0580\u0578\u0581\u0565\u057d\u0578\u0580\u0568 \u0581\u0561\u0576\u056f\u0561\u056c\u056b \u0567, \u0562\u0561\u0575\u0581 \u0579\u056b \u057a\u0561\u0570\u0561\u0576\u057b\u057e\u0578\u0582\u0574, \u0578\u0580\u057a\u0565\u057d\u0566\u056b \u056e\u0580\u0561\u0563\u056b\u0580\u0568 \u0561\u0577\u056d\u0561\u057f\u056b: \u0539\u0561\u0580\u0563\u0574\u0561\u0576\u0578\u0582\u0569\u0575\u0561\u0576 \u0578\u0580\u0561\u056f\u0568 \u0562\u0561\u0580\u0565\u056c\u0561\u057e\u057e\u0578\u0582\u0574 \u0567 \u0563\u0580\u0561\u0586\u056b\u056f\u0561\u056f\u0561\u0576 \u057a\u0580\u0578\u0581\u0565\u057d\u0578\u0580\u056b \u0570\u0565\u057f:", "\u0535\u0569\u0565 \u200b\u200b\u0561\u0575\u057d \u0581\u0578\u0582\u0581\u0561\u056f\u056b\u0581 \u0570\u0561\u057d\u056f\u0561\u0576\u0578\u0582\u0574 \u0565\u0584 \u056c\u0565\u0566\u0578\u0582\u0576\u0565\u0580\u056b\u0581 \u0574\u0565\u056f\u0568, \u0561\u057a\u0561 \u056f\u056f\u0561\u0580\u0578\u0572\u0561\u0576\u0561\u0584 \u0577\u0583\u057e\u0565\u056c \u0561\u0575\u057d \u0581\u0578\u0582\u0581\u0561\u056f\u056b\u0581 \u0581\u0561\u0576\u056f\u0561\u0581\u0561\u056e \u056c\u0565\u0566\u057e\u0578\u057e \u0562\u0576\u056b\u056f \u0563\u0580\u0565\u0580\u056b \u0570\u0565\u057f: \u0540\u0561\u0572\u0578\u0580\u0564\u0561\u056f\u0581\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568 \u056f\u0561\u0580\u0578\u0572 \u0567 \u056c\u056b\u0576\u0565\u056c Telegram- \u0578\u0582\u0574, WhatsApp- \u0568, Google \u0570\u0561\u0576\u0564\u056b\u057a\u0578\u0582\u0574\u0568, Vkmessenger- \u0568, YandexMessenger- \u0568 \u056f\u0561\u0574 \u0581\u0561\u0576\u056f\u0561\u0581\u0561\u056e \u0561\u0575\u056c \u057d\u0578\u0582\u0580\u0570\u0561\u0576\u0564\u0561\u056f: \u0534\u0578\u0582\u0584 \u056f\u0561\u0580\u0578\u0572 \u0565\u0584 \u056c\u057d\u0565\u056c \u0576\u0578\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580, \u057e\u0565\u0580\u0561\u057a\u0561\u057f\u0580\u0561\u057d\u057f\u0574\u0561\u0576 \u0564\u0561\u057d\u0568\u0576\u0569\u0561\u0581 \u0565\u0582 \u0581\u0561\u0576\u056f\u0561\u0581\u0561\u056e \u0561\u0575\u056c podcasts \u0581\u0561\u0576\u056f\u0561\u0581\u0561\u056e \u056c\u0565\u0566\u057e\u0578\u057e \u056c\u0565\u0566\u0578\u0582\u0576\u0565\u0580\u056b\u0581 \u0565\u0582 \u0570\u0561\u057d\u056f\u0561\u0576\u0561\u056c \u0564\u0580\u0561\u0576\u0584: \u0531\u0575\u056a\u0574 \u0570\u0576\u0561\u0580\u0561\u057e\u0578\u0580 \u0567 \u0570\u0561\u0580\u0581\u0561\u0566\u0580\u0578\u0582\u0575\u0581\u0576\u0565\u0580 \u0570\u0561\u0576\u0571\u0576\u0565\u056c \u0585\u057f\u0561\u0580\u0565\u0580\u056f\u0580\u0575\u0561 \u0568\u0576\u056f\u0565\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0578\u0582\u0574 \u0565\u0582 \u0577\u0561\u057f \u0561\u057e\u0565\u056c\u056b\u0576: \u053f\u0561\u0580\u0578\u0572 \u0565\u0584 \u0576\u0561\u0565\u0582 \u056d\u0561\u0572\u0561\u056c \u0561\u0578\u0582\u0564\u056b\u0578 / \u057e\u056b\u0564\u0565\u0578 \u0586\u0561\u0575\u056c \u0585\u057f\u0561\u0580 \u056c\u0565\u0566\u057e\u0578\u057e \u0565\u0582 \u056c\u057d\u0565\u056c \u0561\u0575\u0576 \u0571\u0565\u0580 \u056c\u0565\u0566\u057e\u0578\u057e: \u053f\u0578\u0572\u0584\u0561\u0575\u056b\u0576 \u0564\u056b\u0574\u0578\u0582\u0574\u0576\u0565\u0580\u056b\u0581 \u0574\u0565\u056f\u0568 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u0570\u0565\u057f \u0566\u0580\u0578\u0582\u0575\u0581\u0576 \u0567 \u0576\u0578\u0582\u0575\u0576 \u056c\u0565\u0566\u057e\u0578\u057e, \u0562\u0561\u0575\u0581 \u0571\u0565\u0580 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0568 \u056f\u056c\u057d\u056b \u057d\u057f\u0565\u0572\u056e\u057e\u0561\u056e \u057f\u0565\u057d\u0561\u056e\u0568: \u0548\u0579 \u0569\u0565 \u0571\u0565\u0580 \u057d\u0565\u0583\u0561\u056f\u0561\u0576 \u0571\u0561\u0575\u0576\u0568: Tois \u057d\u0561 \u0561\u0576\u0570\u0580\u0561\u056a\u0565\u0577\u057f \u0567: \u053f\u0561\u0576 \u0562\u0561\u0566\u0574\u0561\u0569\u056b\u057e \u0570\u0576\u0561\u0580\u0561\u057e\u0578\u0580 \u056e\u0580\u0561\u0563\u0580\u0565\u0580:", "\u0555\u057a\u0565\u0580\u0561\u0581\u056b\u0578\u0576 \u0570\u0561\u0574\u0561\u056f\u0561\u0580\u0563 Windows 10 \u056f\u0561\u0574 Windows 11:", "\u0540\u0561\u057d\u0561\u0576\u0565\u056c\u056b \u056f\u0578\u0577\u057f \u057d\u056f\u0561\u057e\u0561\u057c\u0561\u056f 8 \u0533\u0532:", "RAM 10 \u0533\u0532-\u056b\u0581:", "GPU (\u0563\u0580\u0561\u0586\u056b\u056f\u0561\u0575\u056b \u057e\u0565\u0580\u0561\u0574\u0577\u0561\u056f\u0574\u0561\u0576 \u0574\u056b\u0561\u057e\u0578\u0580) 6 \u0533\u0532 \u056f\u0561\u0574 \u0561\u057e\u0565\u056c\u056b, \u0581\u0561\u0576\u056f\u0561\u056c\u056b, \u0562\u0561\u0575\u0581 \u0578\u0579 \u0561\u0576\u0570\u0580\u0561\u056a\u0565\u0577\u057f:", "\u0531\u056f\u0561\u0576\u057b\u0561\u056f\u0561\u056c\u0576\u0565\u0580 \u0574\u056b\u056f\u0580\u0578\u0586\u0578\u0576\u0578\u057e:", "\u053e\u0580\u0561\u0563\u0580\u056b \u0570\u0565\u057f \u0561\u0577\u056d\u0561\u057f\u0565\u056c\u0578\u0582 \u0561\u0574\u0562\u0578\u0572\u057b \u056b\u0576\u057f\u0565\u0580\u0586\u0565\u0575\u057d\u0568 \u056b\u0580\u0561\u056f\u0561\u0576\u0561\u0581\u057e\u0578\u0582\u0574 \u0567 \u0566\u0576\u0576\u0561\u0580\u056f\u056b\u0579\u056b\u0581:", "\u0535\u0580\u0562 \u056f\u057f\u057f\u0561\u0581\u0576\u0578\u0582\u0574 \u0565\u0584 \u00ab\u056f\u0561\u0566\u0574\u0561\u0571\u0565\u0582\u0578\u0582\u0574\u0568\u00bb \u056f\u0578\u0573\u0561\u056f\u0568, \u0565\u0582 \u0570\u056b\u0574\u0576\u0561\u056f\u0561\u0576 \u0563\u0578\u0580\u056e\u0561\u057c\u0576\u0561\u056f\u0561\u0576 \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580\u0578\u057e \u0571\u0565\u0582\u0568 \u0581\u0578\u0582\u0581\u0561\u0564\u0580\u057e\u0578\u0582\u0574 \u0567 \u056c\u0561\u057e\u0561\u0563\u0578\u0582\u0575\u0576 \u0568\u0576\u057f\u0580\u0561\u0581\u0561\u0576\u056f\u0578\u0582\u0574: \u054f\u0565\u057d \u0546\u056f\u0561\u0580 4:", "\u0546\u056f\u0561\u0580 4: \u053f\u0561\u0566\u0574\u0561\u0571\u0565\u0582\u0578\u0582\u0574:", "\u053f\u0561\u0566\u0574\u0561\u0571\u0565\u0582\u0574\u0561\u0576 \u0562\u0561\u056a\u056b\u0576\u0568 \u057a\u0561\u0580\u0578\u0582\u0576\u0561\u056f\u0578\u0582\u0574 \u0567 \u0570\u056b\u0574\u0576\u0561\u056f\u0561\u0576 \u0563\u0578\u0580\u056e\u0561\u057c\u0576\u0561\u056f\u0561\u0576 \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580\u0568.", "\u053c\u0565\u0566\u0578\u0582\u0576 - \u0571\u0565\u0580 \u056d\u0578\u057d\u0561\u056e \u056c\u0565\u0566\u0578\u0582\u0576 \u0564\u0576\u0565\u056c\u0568:", "\u0541\u0561\u0575\u0576 - \u057e\u0561\u0580\u0578\u0580\u0564\u056b \u0561\u0576\u0578\u0582\u0576\u0568 \u0571\u0565\u0580 \u0571\u0561\u0575\u0576\u0561\u0575\u056b\u0576-\u057d\u0561\u0580\u0584\u056b \u0570\u0561\u0574\u0561\u0580:", "\u0544\u056b\u056f\u0580\u0578\u0586\u0578\u0576 - \u057e\u0561\u0580\u0578\u0580\u0564\u056b \u0561\u0576\u0578\u0582\u0576\u0568 \u0571\u0565\u0580 \u056d\u0578\u057d\u0561\u0583\u0578\u0572\u056b \u0570\u0561\u0574\u0561\u0580:", "\u054e\u0565\u0562 \u0566\u0576\u0576\u0561\u0580\u056f\u056b\u0579 - \u0566\u0576\u0576\u0561\u0580\u056f\u0579\u056b \u0561\u0576\u057e\u0561\u0576\u0578\u0582\u0574\u0568, \u0578\u0580\u0578\u0582\u0574 \u0564\u0578\u0582\u0584 \u056f\u0561\u0577\u056d\u0561\u057f\u0565\u0584:", "\u0535\u0580\u0562 \u0583\u0578\u056d\u0578\u0582\u0574 \u0565\u0584 \u056c\u0565\u0566\u0578\u0582\u0576 \u0565\u0582 \u057a\u0561\u0570\u0565\u0584 \u056f\u0561\u0566\u0574\u0561\u0571\u0565\u0582\u0574\u0561\u0576 \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580\u0568, \u0562\u0578\u056c\u0578\u0580 \u057f\u0565\u0584\u057d\u057f\u0565\u0580\u0568, \u0561\u0580\u057f\u0561\u0570\u0561\u0575\u057f\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568, \u056f\u0578\u0573\u0561\u056f\u056b \u0561\u0576\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u0565\u0582 \u0561\u0575\u056c \u057f\u0565\u0584\u057d\u057f\u0568 \u056f\u0581\u0578\u0582\u0581\u0561\u0564\u0580\u057e\u0565\u0576 \u0576\u0578\u0580 \u056c\u0565\u0566\u057e\u0578\u057e: \u0546\u0578\u0580 \u0566\u0580\u0578\u0582\u0575\u0581\u0576\u0565\u0580\u0568 \u056f\u057e\u0565\u0580\u0561\u056e\u057e\u0565\u0576 \u0568\u0576\u057f\u0580\u057e\u0561\u056e \u056c\u0565\u0566\u057e\u0578\u057e, \u0565\u0582 \u0561\u0575\u057d \u0576\u0578\u0580 \u056c\u0565\u0566\u057e\u0578\u057e \u056f\u056c\u057d\u0565\u0584 \u056d\u0578\u057d\u0584\u0568: \u053f\u0561\u0580\u0565\u0582\u0578\u0580 \u0576\u0577\u0578\u0582\u0574 \u057e\u0565\u0562 \u0566\u0576\u0576\u0561\u0580\u056f\u0579\u056b \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580\u056b \u0574\u0561\u057d\u056b\u0576: \u053c\u057c\u0565\u056c\u0575\u0561\u0575\u0576, \u057e\u0565\u0562 \u0566\u0576\u0576\u0561\u0580\u056f\u0579\u056b \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0568 \u0564\u0580\u057e\u0561\u056e \u0567 Microsoft Edge- \u056b\u0576, \u0584\u0561\u0576\u056b \u0578\u0580 \u0561\u0575\u0576 \u0574\u056b\u0577\u057f \u057f\u0565\u0572\u0561\u0564\u0580\u057e\u0578\u0582\u0574 \u0567 Windows- \u0578\u0582\u0574: \u0531\u0575\u057d \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u056b \u0570\u0561\u0574\u0561\u0580 \u0568\u0576\u057f\u0580\u0565\u0584 \u0574\u056b\u0561\u0575\u0576 \u0566\u0576\u0576\u0561\u0580\u056f\u056b\u0579\u0568, \u0578\u0580\u0568 \u057f\u0565\u0572\u0561\u0564\u0580\u057e\u0561\u056e \u0567 \u0565\u0582 \u0563\u0578\u0580\u056e\u0578\u0582\u0574 \u0567 \u0571\u0565\u0580 \u0563\u0578\u0580\u056e\u0561\u057e\u0561\u0580 \u0570\u0561\u0574\u0561\u056f\u0561\u0580\u0563\u0578\u0582\u0574:", "\u0546\u0578\u0580 \u056f\u0578\u0573\u0561\u056f\u0568 \u056f\u057f\u057f\u0561\u0581\u0576\u0565\u056c\u0568 \u0571\u0565\u0582 \u0567 \u0581\u0578\u0582\u0581\u0561\u0564\u0580\u0578\u0582\u0574 AWW- \u056b \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0568 \u056c\u0580\u0561\u0581\u0576\u0565\u056c\u0578\u0582 \u0570\u0561\u0574\u0561\u0580: \u054f\u0565\u057d \u0546\u056f\u0561\u0580 5:", "\u0533\u056e\u0561\u057a\u0561\u057f\u056f\u0565\u0580 5: \u0546\u0578\u0580 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581 \u057a\u0580\u0578\u0586\u056b\u056c", "\u00ab\u0546\u0578\u0580 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u057a\u0580\u0578\u0586\u056b\u056c\u0568\u00bb \u0562\u0561\u056a\u056b\u0576\u0568 \u057a\u0561\u0580\u0578\u0582\u0576\u0561\u056f\u0578\u0582\u0574 \u0567 \u0570\u056b\u0574\u0576\u0561\u056f\u0561\u0576 \u0563\u0578\u0580\u056e\u0561\u057c\u0576\u0561\u056f\u0561\u0576 \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580\u0568.", "\u0531\u0576\u0578\u0582\u0576 - \u0531\u0576\u0578\u0582\u0576\u0568, \u0578\u0580\u0568 \u0564\u0578\u0582\u0584 \u0568\u0576\u057f\u0580\u0578\u0582\u0574 \u0565\u0584 \u0571\u0565\u0580 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u0570\u0561\u0574\u0561\u0580:", "\u053c\u0565\u0566\u0578\u0582\u0576 - \u0571\u0565\u0580 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0568 \u056d\u0578\u057d\u0578\u0582\u0574 \u0567 \u056c\u0565\u0566\u0578\u0582\u0576:", "\u0546\u056f\u0561\u0580\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576 - \u0571\u0565\u0580 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u0576\u056f\u0561\u0580\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568:", "\u0555\u0563\u057f\u0561\u0563\u0578\u0580\u056e\u0565\u0584 \u0574\u056b\u056f\u0580\u0578\u0586\u0578\u0576 `\u057d\u0561\u0570\u0574\u0561\u0576\u0565\u0584 \u056d\u0578\u057d\u0561\u0583\u0578\u0572\u056b \u0585\u0563\u057f\u0561\u0563\u0578\u0580\u056e\u0574\u0561\u0576 \u0564\u0580\u0578\u0577\u0568:", "\u054a\u0561\u057f\u056f\u0565\u0580 - \u054d\u0561\u0570\u0574\u0561\u0576\u0565\u0584 \u057a\u0561\u057f\u056f\u0565\u0580\u0561\u056f\u0568 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u0570\u0561\u0574\u0561\u0580:", "\u0535\u0569\u0565 \u200b\u200b\u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u0570\u0561\u0574\u0561\u0580 \u057a\u0561\u057f\u056f\u0565\u0580 \u0579\u0565\u0584 \u0568\u0576\u057f\u0580\u0565\u056c, \u0576\u0580\u0561 \u0570\u0561\u0574\u0561\u0580 \u056f\u0585\u0563\u057f\u0561\u0563\u0578\u0580\u056e\u057e\u056b \u056c\u057c\u0565\u056c\u0575\u0561\u0575\u0576 \u057a\u0561\u057f\u056f\u0565\u0580\u0568:", "\u00ab\u0555\u0563\u057f\u0561\u0563\u0578\u0580\u056e\u0565\u0584 \u056d\u0578\u057d\u0561\u0583\u0578\u0572\u0568\u00bb \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0561\u0575\u056b\u0576 \u057b\u0580\u0561\u0576\u0581\u0584\u0568 `\u056c\u057d\u0578\u0582\u0574 \u0565\u0584 \u0564\u0565\u057a\u0584\u0565\u0580\u056b \u0570\u0561\u0574\u0561\u0580 (\u0546\u0578\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580, \u0561\u0578\u0582\u0564\u056b\u0578 \u0564\u0561\u057d\u0565\u0580 \u0565\u0582 \u0561\u0575\u056c\u0576):", "\u00ab\u0555\u0563\u0576\u0578\u0582\u0569\u0575\u0561\u0576\u00bb \u0561\u0576\u057e\u057f\u0561\u0576\u0563\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568 \u0576\u056f\u0561\u0580\u0561\u0563\u0580\u0578\u0582\u0574 \u0567, \u0569\u0565 \u056b\u0576\u0579\u057a\u0565\u057d \u0561\u0577\u056d\u0561\u057f\u0565\u056c \u056e\u0580\u0561\u0563\u0580\u056b \u0570\u0565\u057f \u0571\u0565\u0580 \u056c\u0565\u0566\u057e\u0578\u057e: \u054f\u0565\u057d \u0546\u056f\u0561\u0580 6:", "\u0546\u056f\u0561\u0580 6: \u0555\u0563\u0576\u0578\u0582\u0569\u0575\u0561\u0576 \u0562\u0561\u056a\u056b\u0576:", "\u053f\u057f\u057f\u0561\u0581\u0576\u0565\u056c\u0578\u057e \u00ab\u0535\u056c\u0584\u00bb \u056f\u0578\u0573\u0561\u056f\u0568, \u0561\u057e\u0561\u0580\u057f\u0578\u0582\u0574 \u0567 \u056e\u0580\u0561\u0563\u056b\u0580\u0568: \u054f\u0565\u057d \u0546\u056f\u0561\u0580 7:", "\u0546\u056f\u0561\u0580 7. \u0535\u056c\u0584\u056b \u056f\u0578\u0573\u0561\u056f\u0568:", "\u053e\u0580\u0561\u0563\u056b\u0580\u0568 \u0561\u057e\u0561\u0580\u057f\u057e\u0578\u0582\u0574 \u0567 \u0576\u0561\u0565\u0582 \u0566\u0576\u0576\u0561\u0580\u056f\u0579\u056b \u057a\u0561\u057f\u0578\u0582\u0570\u0561\u0576\u0568 \u056f\u0561\u0574 \u0583\u0561\u056f\u0565\u056c\u0578\u057e \u0566\u0576\u0576\u0561\u0580\u056f\u056b\u0579\u0568 \u0583\u0561\u056f\u0565\u056c\u0568:", "\u0537\u057b\u0568 \u0569\u0561\u0580\u0574\u0561\u0581\u0576\u0565\u056c\u0568 \u0576\u0578\u0582\u0575\u0576\u057a\u0565\u057d \u0561\u057e\u0561\u0580\u057f\u0578\u0582\u0574 \u0567 \u056e\u0580\u0561\u0563\u056b\u0580\u0568:", "\u0536\u0576\u0576\u0561\u0580\u056f\u0579\u056b \u0571\u0561\u056d \u056f\u0578\u0572\u0574\u0578\u0582\u0574 \u0571\u0565\u0580 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0576\u0565\u0580\u056b \u0581\u0578\u0582\u0581\u0561\u056f\u0576 \u0567: \u054f\u0565\u057d \u0546\u056f\u0561\u0580 8:", "\u0546\u056f\u0561\u0580 8: \u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0576\u0565\u0580\u056b \u0581\u0578\u0582\u0581\u0561\u056f:", "\u0545\u0578\u0582\u0580\u0561\u0584\u0561\u0576\u0579\u0575\u0578\u0582\u0580 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u0570\u0561\u0574\u0561\u0580 \u0576\u0580\u0561\u0576\u0581 \u057a\u0561\u057f\u056f\u0565\u0580\u0561\u056f\u0568, \u057e\u0565\u0580\u057b\u056b\u0576 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0561\u0576 \u0561\u0574\u057d\u0561\u0569\u056b\u057e\u0568 \u0565\u0582 \u0571\u0565\u0580 \u056c\u0565\u0566\u057e\u0578\u057e \u057e\u0565\u0580\u057b\u056b\u0576 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0561\u0576 \u057f\u0565\u0584\u057d\u057f\u0568 \u0581\u0578\u0582\u0581\u0561\u0564\u0580\u057e\u0578\u0582\u0574 \u0565\u0576: \u0531\u057c\u0561\u057b\u0561\u0564\u0580\u0561\u0576\u0584\u056b \u0571\u0565\u0582\u0561\u0579\u0561\u0583\u056b \u0561\u0574\u057d\u0561\u0569\u057e\u056b \u0571\u0565\u0582\u0561\u0579\u0561\u0583\u0568 \u0570\u0561\u0574\u0561\u057a\u0561\u057f\u0561\u057d\u056d\u0561\u0576\u0578\u0582\u0574 \u0567 \u0571\u0565\u0580 \u056c\u0565\u0566\u057e\u056b\u0576: \u0535\u0580\u0562 \u056f\u057f\u057f\u0561\u0581\u0576\u0578\u0582\u0574 \u0565\u0584 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b\u0576, \u0581\u0578\u0582\u0581\u0561\u0564\u0580\u057e\u0578\u0582\u0574 \u0567 \u056b\u0580\u0565\u0576\u0581 \u0566\u0580\u0578\u0582\u0575\u0581\u056b \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568:", "\u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u0566\u0580\u0578\u0582\u0575\u0581\u056b \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568 \u0563\u057f\u0576\u057e\u0578\u0582\u0574 \u0567 \u0566\u0576\u0576\u0561\u0580\u056f\u0579\u056b \u0561\u057b \u056f\u0578\u0572\u0574\u0578\u0582\u0574: \u054f\u0565\u057d \u0546\u056f\u0561\u0580 9:", "\u0533\u056e\u0561\u057a\u0561\u057f\u056f\u0565\u0580 9: \u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u0566\u0580\u0578\u0582\u0575\u0581\u056b \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568:", "\u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u0566\u0580\u0578\u0582\u0575\u0581\u056b \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568 isplayed wen \u0534\u0578\u0582\u0584 \u056f\u057f\u057f\u0561\u0581\u0576\u0578\u0582\u0574 \u0565\u0584 \u056d\u0561\u057c\u0576\u0561\u0577\u0583\u0578\u0569\u0568 \u0571\u0561\u056d \u0574\u0561\u057d\u0578\u0582\u0574:", "\u054e\u0565\u0580\u0565\u0582\u056b \u0568\u0576\u057f\u0580\u0561\u0581\u0561\u0576\u056f\u0568 \u057a\u0561\u0580\u0578\u0582\u0576\u0561\u056f\u0578\u0582\u0574 \u0567.", "\u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u057a\u0561\u057f\u056f\u0565\u0580\u0561\u056f\u0568", "\u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u0574\u0561\u056f\u0561\u0576\u0578\u0582\u0576\u0568", "\u00ab\u054d\u056f\u057d\u0565\u056c \u056d\u0578\u057d\u0561\u056f\u0581\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568\u00bb \u056f\u0578\u0573\u0561\u056f\u0568", "\u00ab\u0544\u0561\u0584\u0578\u0582\u0580 \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u00bb \u056f\u0578\u0573\u0561\u056f\u0568", "\u00abDelete \u0576\u057b\u0565\u056c \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u00bb \u056f\u0578\u0573\u0561\u056f\u0568", "\u00ab\u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u057a\u0580\u0578\u0586\u056b\u056c\u0568\u00bb \u056f\u0578\u0573\u0561\u056f\u0568", "\u0538\u0576\u057f\u0580\u057e\u0561\u056e \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u0570\u0565\u057f \u0566\u0580\u0578\u0582\u0575\u0581\u056b \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568 \u0570\u0561\u0575\u057f\u0576\u057e\u0578\u0582\u0574 \u0567 \u0573\u056b\u0577\u057f \u0574\u0561\u057d\u0578\u0582\u0574:", "\u0536\u0580\u0578\u0582\u0581\u0561\u0580\u0561\u0576\u056b \u057e\u0565\u0580\u0576\u0561\u0563\u056b\u0580\u0568 \u0570\u0561\u0574\u0561\u0580\u0561\u056f\u0561\u056c\u057e\u0578\u0582\u0574 \u0567 \u0574\u056b \u0566\u0578\u0582\u0575\u0563 Yaks. \u00ab\u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u056c\u0565\u0566\u0578\u0582\u00bb / \u00ab\u0541\u0565\u0580 \u056c\u0565\u0566\u0578\u0582\u0576\u00bb:", "Chat- \u056b \u057e\u0565\u0580\u0576\u0561\u0563\u056b\u0580\u0568 \u057a\u0561\u0580\u0578\u0582\u0576\u0561\u056f\u0578\u0582\u0574 \u0567 \u00abDelete \u0576\u057b\u0565\u056c \u0561\u0575\u057d \u0566\u0580\u0578\u0582\u0575\u0581\u0568\u00bb \u056f\u0578\u0573\u0561\u056f\u0568:", "\u0535\u0580\u0562 \u056f\u057f\u057f\u0561\u0581\u0580\u0565\u0584 \u00abDelete \u0576\u057b\u0565\u056c \u0561\u0575\u057d \u0566\u0580\u0578\u0582\u0575\u0581\u0568\u00bb \u056f\u0578\u0573\u0561\u056f\u0568, \u0561\u0575\u057d \u0566\u0580\u0578\u0582\u0575\u0581\u0568 \u057b\u0576\u057b\u057e\u0578\u0582\u0574 \u0567 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u0566\u0580\u0578\u0582\u0575\u0581\u056b \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u056b\u0581:", "\u0532\u0578\u056c\u0578\u0580 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u0562\u0561\u056a\u0561\u0576\u057e\u0578\u0582\u0574 \u0565\u0576 2 \u056d\u0574\u0562\u056b.", "\u0540\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b\u0581:", "\u0541\u0565\u0580 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568:", "\u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u057f\u0565\u0572\u0561\u0583\u0578\u056d\u057e\u0578\u0582\u0574 \u0565\u0576 \u0571\u0561\u056d: \u0541\u0565\u0580 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u057f\u0565\u0572\u0561\u0583\u0578\u056d\u057e\u0578\u0582\u0574 \u0565\u0576 \u0561\u057b:", "\u0540\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0561\u0576 \u0575\u0578\u0582\u0580\u0561\u0584\u0561\u0576\u0579\u0575\u0578\u0582\u0580 \u056d\u0578\u0582\u0574\u0562 \u0562\u0561\u0572\u056f\u0561\u0581\u0561\u056e \u0567 2 \u0574\u0561\u057d\u056b\u0581.", "\u0540\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0561\u0576 \u057f\u0565\u0584\u057d\u057f\u0568 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u056c\u0565\u0566\u057e\u0578\u057e, \u0561\u0575\u057d \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0561\u0576 \u0563\u0578\u0582\u0575\u0576\u0568 \u057d\u0565\u0582 \u0567:", "\u0540\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0561\u0576 \u057f\u0565\u0584\u057d\u057f\u0568 \u0571\u0565\u0580 \u056c\u0565\u0566\u057e\u0578\u057e, \u0561\u0575\u057d \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0561\u0576 \u0563\u0578\u0582\u0575\u0576\u0568 \u056f\u0561\u0576\u0561\u0579 \u0567:", "\u0540\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0561\u0576 \u0561\u0574\u057d\u0561\u0569\u056b\u057e\u0568 \u0570\u0561\u0574\u0561\u057a\u0561\u057f\u0561\u057d\u056d\u0561\u0576\u0578\u0582\u0574 \u0567 \u0571\u0565\u0580 \u056c\u0565\u0566\u057e\u056b\u0576:", "\u0546\u0578\u0580 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568 (\u0568\u057d\u057f \u0561\u0574\u057d\u0561\u0569\u057e\u056b) \u057f\u0565\u0572\u0561\u056f\u0561\u0575\u057e\u0561\u056e \u0565\u0576 \u0561\u057e\u0565\u056c\u056b \u0581\u0561\u056e\u0580, \u0584\u0561\u0576 \u0570\u056b\u0576 \u0585\u0578\u0576\u056b\u0561\u0576\u0565\u0580\u0568:", "\u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u0566\u0580\u0578\u0582\u0575\u0581\u056b \u0570\u0565\u0576\u0581 \u0576\u0565\u0580\u0584\u0565\u0582\u0578\u0582\u0574 \u00ab\u0574\u0565\u056f\u0576\u0561\u0580\u056f\u056b \u056d\u0578\u057d\u0561\u056f\u0581\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u00bb \u056f\u0578\u0573\u0561\u056f\u0576 \u0567: \u0535\u0580\u0562 \u056f\u057f\u057f\u0561\u0581\u0580\u0565\u0584 \u0561\u0575\u0576, \u056e\u0580\u0561\u0563\u056b\u0580\u0568 \u057d\u056f\u057d\u0578\u0582\u0574 \u0567 \u057f\u0580\u0561\u0574\u0561\u0579\u0561\u0583\u0565\u056c \u056d\u0578\u057d\u0561\u0583\u0578\u0572\u0568 \u0565\u0582 \u0571\u0561\u0575\u0576\u0561\u0575\u056b\u0576 \u057d\u0561\u0580\u0584\u0568 `\u0561\u0566\u0564\u0561\u0576\u0577\u0561\u0576\u056b / \u0561\u0572\u0574\u0578\u0582\u056f\u056b \u0574\u0561\u056f\u0561\u0580\u0564\u0561\u056f\u0568 \u0578\u0580\u0578\u0577\u0565\u056c\u0578\u0582 \u0565\u0582 \u0570\u0561\u0574\u0561\u057a\u0561\u057f\u0561\u057d\u056d\u0561\u0576 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568 \u0581\u0578\u0582\u0581\u0561\u0564\u0580\u0578\u0582\u0574 \u0567:", "\u0541\u0561\u0575\u0576\u0561\u0575\u056b\u0576 \u057d\u0561\u0580\u0584\u0565\u0580\u0568 \u057f\u0580\u0561\u0574\u0561\u0579\u0561\u0583\u0565\u056c\u0578\u0582\u0581 \u0570\u0565\u057f\u0578 \u056f\u0578\u0573\u0561\u056f\u0576\u0565\u0580\u056b \u0561\u0576\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u0583\u0578\u056d\u057e\u0578\u0582\u0574 \u0565\u0576. \u00ab\u054d\u056f\u057d\u0565\u056c \u056d\u0578\u057d\u0561\u056f\u0581\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568\u00bb -> \u00ab\u0534\u0561\u0564\u0561\u0580\u0565\u0581\u0580\u0565\u0584 \u056d\u0578\u057d\u0561\u056f\u0581\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u00bb:", "\u0531\u0575\u057d \u057a\u0561\u0570\u056b\u0581 \u056f\u0561\u0580\u0578\u0572 \u0565\u0584 \u057d\u056f\u057d\u0565\u056c \u056d\u0578\u057d\u0561\u056f\u0581\u0578\u0582\u0569\u0575\u0578\u0582\u0576 \u056f\u0561\u0574 \u0563\u0578\u0580\u056e\u0561\u0580\u056f\u0565\u056c \u0561\u0578\u0582\u0564\u056b\u0578 / \u057e\u056b\u0564\u0565\u0578 \u0586\u0561\u0575\u056c:", "\u0532\u0578\u056c\u0578\u0580 \u0574\u0578\u0582\u057f\u0584\u0561\u0575\u056b\u0576 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568 (\u0574\u0575\u0578\u0582\u057d \u0561\u0576\u0571\u056b\u0581) \u056f\u0570\u0561\u0575\u057f\u0576\u057e\u0565\u0576 \u0571\u0561\u056d \u056f\u0578\u0572\u0574\u0578\u0582\u0574:", "\u0532\u0578\u056c\u0578\u0580 \u0565\u056c\u0584\u0561\u0575\u056b\u0576 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568 (\u0571\u0565\u0566\u0576\u056b\u0581) \u056f\u0570\u0561\u0575\u057f\u0576\u057e\u0565\u0576 \u0561\u057b \u056f\u0578\u0572\u0574\u0578\u0582\u0574:", "\u0534\u0578\u0582\u0584 \u056f\u056c\u057d\u0565\u0584 \u0571\u0565\u0580 \u056c\u0565\u0566\u057e\u0578\u057e \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580, \u0565\u0582 \u0571\u0565\u0580 \u0574\u0575\u0578\u0582\u057d \u0561\u0576\u0571\u0568 \u056f\u056c\u057d\u056b \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580 \u056b\u0580\u0565\u0576\u0581 \u056c\u0565\u0566\u057e\u0578\u057e:", "\u0536\u0580\u0578\u0582\u0575\u0581\u056b \u0561\u057e\u0561\u0580\u057f\u056b\u0576 / \u054f\u0565\u057d\u0561\u0576\u0575\u0578\u0582\u0569\u0568 \u056c\u057d\u0565\u056c\u056b\u057d \u057a\u0565\u057f\u0584 \u0567 \u057d\u0565\u0572\u0574\u0565\u056c \u00ab\u0534\u0561\u0564\u0561\u0580\u0565\u0581\u0574\u0561\u0576 \u056d\u0578\u057d\u0561\u056f\u0581\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u056b\u0581\u00bb \u056f\u0578\u0573\u0561\u056f\u0576\u0565\u0580\u056b\u0581 \u0574\u0565\u056f\u0568:", "\u053d\u0578\u057d\u0561\u056f\u0581\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576 \u0561\u057e\u0561\u0580\u057f\u057e\u0578\u0582\u0574 \u0567 \u0576\u0561\u0565\u0582 \u0561\u0575\u0576 \u056a\u0561\u0574\u0561\u0576\u0561\u056f, \u0565\u0580\u0562.", "\u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0576\u0565\u0580\u056b \u0581\u0561\u0576\u056f\u0578\u0582\u0574 \u0566\u0576\u0576\u0561\u0580\u056f\u0579\u056b \u0571\u0561\u056d \u0574\u0561\u057d\u0578\u0582\u0574 \u056f\u057f\u057f\u0561\u0581\u0576\u0565\u056c\u0578\u057e \u0574\u0575\u0578\u0582\u057d \u0561\u0576\u0571\u056b\u0576:", "\u053f\u057f\u057f\u0561\u0581\u0576\u0565\u056c\u0578\u057e \u00ab\u0546\u0578\u0580\u00bb \u056f\u0578\u0573\u0561\u056f\u0568 `\u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0576\u0565\u0580\u056b \u0581\u0578\u0582\u0581\u0561\u056f\u056b \u057e\u0565\u0580\u0565\u0582\u0578\u0582\u0574:", "\u053f\u057f\u057f\u0561\u0581\u0576\u0565\u056c\u0578\u057e \u00ab\u0555\u0563\u0576\u0578\u0582\u0569\u0575\u0561\u0576\u00bb \u056f\u0578\u0573\u0561\u056f\u0568 \u057e\u0565\u0580\u0565\u0582\u056b \u0568\u0576\u057f\u0580\u0561\u0581\u0561\u0576\u056f\u0578\u0582\u0574:", "\u053f\u057f\u057f\u0561\u0581\u0576\u0565\u056c\u0578\u057e \u00ab\u0544\u0561\u0584\u0578\u0582\u0580 \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u00bb \u056f\u0578\u0573\u0561\u056f\u0568 \u057e\u0565\u0580\u0565\u0582\u056b \u0568\u0576\u057f\u0580\u0561\u0581\u0561\u0576\u056f\u0578\u0582\u0574:", "\u053f\u057f\u057f\u0561\u0581\u0576\u0565\u056c\u0578\u057e \u00abDelete \u0576\u057b\u0565\u056c \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0568\u00bb \u056c\u0561\u057e\u0561\u0563\u0578\u0582\u0575\u0576 \u0568\u0576\u057f\u0580\u0561\u0581\u0561\u0576\u056f\u0578\u0582\u0574:", "\u053f\u057f\u057f\u0561\u0581\u0576\u0565\u056c\u0578\u057e \u00abInterlocutor- \u056b \u057a\u0580\u0578\u0586\u056b\u056c\u0568\u00bb \u056f\u0578\u0573\u0561\u056f\u0568 \u056c\u0561\u057e\u0561\u0563\u0578\u0582\u0575\u0576 \u0581\u0561\u0576\u056f\u0578\u0582\u0574:", "\u053f\u057f\u057f\u0561\u0581\u0576\u0565\u056c\u0578\u057e \u00ab\u0535\u056c\u0584\u00bb \u056f\u0578\u0573\u0561\u056f\u0568 \u057e\u0565\u0580\u0565\u0582\u056b \u0568\u0576\u057f\u0580\u0561\u0581\u0561\u0576\u056f\u0578\u0582\u0574:", "\u0536\u0580\u0578\u0582\u0581\u057e\u0561\u056e \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0561\u0576 \u0574\u0565\u057b \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u056b \u0581\u0578\u0582\u0581\u0561\u0564\u0580\u0578\u0582\u0574 `\u0568\u0576\u057f\u0580\u0565\u056c\u0578\u057e \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0561\u0576 \u0581\u0578\u0582\u0581\u0561\u0564\u0580\u0574\u0561\u0576 \u057f\u0561\u0580\u0562\u0565\u0580\u0561\u056f\u0568 \u0568\u0576\u057f\u0580\u0561\u0581\u0561\u0576\u056f\u056b \u057e\u0565\u0580\u056b\u0576 \u0571\u0561\u056d \u0574\u0561\u057d\u0578\u0582\u0574 (\u056f\u0561\u0576\u0561\u0579 \u057d\u056c\u0561\u0584):", "\u00ab\u0532\u0578\u056c\u0578\u0580 \u056c\u0565\u0566\u0578\u0582\u0576\u0565\u0580\u0568\u00bb \u0568\u0576\u057f\u0580\u0565\u056c\u056b\u057d `\u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u0565\u0582 \u0564\u0578\u0582\u0584 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580 \u0565\u0584 \u0581\u0578\u0582\u0581\u0561\u0564\u0580\u057e\u0578\u0582\u0574 \u0562\u0578\u056c\u0578\u0580 \u056c\u0565\u0566\u0578\u0582\u0576\u0565\u0580\u0578\u057e:", "\u00ab\u053b\u0574 \u056c\u0565\u0566\u0578\u0582\u0576\u00bb \u0568\u0576\u057f\u0580\u0565\u056c\u056b\u057d `\u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u0565\u0582 \u0564\u0578\u0582\u0584 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580 \u0565\u0584 \u0581\u0578\u0582\u0581\u0561\u0564\u0580\u057e\u0578\u0582\u0574 \u0574\u056b\u0561\u0575\u0576 \u0571\u0565\u0580 \u056c\u0565\u0566\u057e\u0578\u057e:", "\u00ab\u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u056c\u0565\u0566\u0578\u0582\u00bb \u0568\u0576\u057f\u0580\u0565\u056c\u056b\u057d. \u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u0565\u0582 \u0564\u0578\u0582\u0584 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580 \u0565\u0584 \u0581\u0578\u0582\u0581\u0561\u0564\u0580\u057e\u0578\u0582\u0574 \u0574\u056b\u0561\u0575\u0576 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u056c\u0565\u0566\u057e\u0578\u057e:", "\u053c\u057c\u0565\u056c\u0575\u0561\u0575\u0576 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0561\u0576 \u0581\u0578\u0582\u0581\u0561\u0564\u0580\u0574\u0561\u0576 \u057c\u0565\u056a\u056b\u0574\u0568 \u00ab\u0562\u0578\u056c\u0578\u0580 \u056c\u0565\u0566\u0578\u0582\u0576\u0565\u0580\u0576\u00bb \u0565\u0576:", "\u00ab\u0544\u0561\u0584\u0578\u0582\u0580 \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u00bb \u056f\u0578\u0573\u0561\u056f\u0568 \u057d\u0565\u0572\u0574\u0565\u056c\u056b\u057d \u0562\u0578\u056c\u0578\u0580 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0576\u0565\u0580\u0568 \u057b\u0576\u057b\u057e\u0578\u0582\u0574 \u0565\u0576, \u0562\u0561\u0575\u0581 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0568 \u0574\u0576\u0578\u0582\u0574 \u0567: \u054f\u0565\u057d \u0546\u056f\u0561\u0580 10:", "\u0546\u056f\u0561\u0580 10: \u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u057a\u0561\u057f\u0574\u0578\u0582\u0569\u0575\u0561\u0576 \u0574\u0561\u0584\u0580\u0578\u0582\u0574:", "\u0535\u0569\u0565 \u200b\u200b\u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u0570\u0565\u057f \u0566\u0580\u0578\u0582\u0575\u0581\u0568 \u0576\u0565\u0580\u056f\u0561\u0575\u0578\u0582\u0574\u057d \u0568\u0576\u0569\u0561\u0576\u0578\u0582\u0574 \u0567, \u0561\u0575\u0576 \u0564\u0561\u0564\u0561\u0580\u0565\u0581\u057e\u0561\u056e \u0567:", "\u053f\u057f\u057f\u0561\u0581\u0576\u0565\u056c\u0578\u057e \u00abDelete \u0576\u057b\u0565\u056c \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u00bb \u056f\u0578\u0573\u0561\u056f\u0568, \u057b\u0576\u057b\u0578\u0582\u0574 \u0567 \u0562\u0578\u056c\u0578\u0580 \u0566\u0580\u0578\u0582\u0575\u0581\u0576\u0565\u0580\u0568 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u0565\u0582 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u0570\u0565\u057f: \u054f\u0565\u057d \u0546\u056f\u0561\u0580 11:", "\u0546\u056f\u0561\u0580 11: \u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u0568 \u057b\u0576\u057b\u0565\u056c\u0568:", "\u0535\u0569\u0565 \u200b\u200b\u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u0570\u0565\u057f \u0566\u0580\u0578\u0582\u0575\u0581\u0568 \u0576\u0565\u0580\u056f\u0561\u0575\u0578\u0582\u0574\u057d \u0568\u0576\u0569\u0561\u0576\u0578\u0582\u0574 \u0567, \u0561\u0575\u0576 \u0564\u0561\u0564\u0561\u0580\u0565\u0581\u057e\u0561\u056e \u0567:", "\u053f\u057f\u057f\u0561\u0581\u0576\u0565\u056c\u0578\u057e \u00ab\u0536\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u057a\u0580\u0578\u0586\u056b\u056c\u0568\u00bb \u056f\u0578\u0573\u0561\u056f\u0568 \u0581\u0578\u0582\u0581\u0561\u0564\u0580\u0578\u0582\u0574 \u0567 \u0574\u056b \u0571\u0565\u0582, \u0578\u0580\u0568 \u056c\u0581\u057e\u0561\u056e \u0567 \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u056b\u0581\u056b \u057f\u057e\u0575\u0561\u056c\u0576\u0565\u0580\u0578\u057e: \u054f\u0565\u057d \u0546\u056f\u0561\u0580 12:", "\u0533\u056e\u0561\u057a\u0561\u057f\u056f\u0565\u0580 12: \u0534\u056b\u057f\u0565\u056c\u0578\u057e \u0566\u0580\u0578\u0582\u0581\u0561\u056f\u0581\u056b \u057a\u0580\u0578\u0586\u056b\u056c\u0568:", "\u0531\u0575\u057d \u0561\u057a\u0580\u0561\u0576\u0584\u0568 \u0576\u0574\u0561\u0576 \u0567 \u056b\u0580\u056b", "\u0548\u0582\u0572\u0572\u0561\u0570\u0561\u0575\u0561\u0581 \u0561\u0576\u057b\u0561\u057f\u056b\u0579\u0568 \u0569\u0578\u0582\u0575\u056c \u0567 \u057f\u0561\u056c\u056b\u057d \u0583\u0578\u056d\u0565\u056c \u0561\u0577\u056d\u0561\u057f\u0561\u0576\u0584\u0561\u0575\u056b\u0576 \u057f\u0561\u0580\u0561\u056e\u0584\u056b \u0571\u0561\u056d \u0565\u0582 \u0561\u057b \u057f\u0561\u0580\u0561\u056e\u0584\u0576\u0565\u0580\u056b \u056c\u0561\u0575\u0576\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568: \u054f\u0565\u057d \u0546\u056f\u0561\u0580 13:", "\u0546\u056f\u0561\u0580 13. \u0541\u0561\u056d \u0565\u0582 \u0561\u057b \u0574\u0561\u057d\u0565\u0580\u056b \u0578\u0582\u0572\u0572\u0561\u0570\u0561\u0575\u0561\u0581 \u057f\u0561\u0580\u0561\u0576\u057b\u0561\u057f\u056b\u0579\u0568:", "\u0548\u0582\u0572\u0572\u0561\u0570\u0561\u0575\u0561\u0581 \u057f\u0561\u0580\u0561\u0576\u057b\u0561\u057f\u056b\u0579\u0568 \u057f\u0565\u0572\u0561\u0583\u0578\u056d\u0565\u056c\u056b\u057d \u0564\u0580\u0561 \u0564\u056b\u0580\u0584\u0568 \u057a\u0561\u0570\u057e\u0578\u0582\u0574 \u0567: \u053e\u0580\u0561\u0563\u056b\u0580\u0568 \u057e\u0565\u0580\u0561\u0563\u0578\u0580\u056e\u0561\u0580\u056f\u0565\u056c\u056b\u057d \u056f\u057e\u0565\u0580\u0561\u056f\u0561\u0576\u0563\u0576\u057e\u056b \u0571\u0565\u0580 \u057d\u0561\u0570\u0574\u0561\u0576\u0561\u056e \u057e\u0565\u0580\u057b\u056b\u0576 \u0564\u056b\u0580\u0584\u0568:", "\u054f\u0565\u0572\u0561\u0583\u0578\u056d\u0565\u0584 \u0574\u056f\u0576\u056b\u056f\u056b \u056f\u0578\u0582\u0580\u057d\u0578\u0580\u0568 \u0562\u0561\u0580\u0571\u0580\u0561\u056d\u0578\u057d\u056b \u057a\u0561\u057f\u056f\u0565\u0580\u0578\u057e \u0567\u056f\u0580\u0561\u0576\u056b \u057d\u057f\u0578\u0580\u056b\u0576 \u0561\u057b \u0561\u0576\u056f\u0575\u0578\u0582\u0576\u0578\u0582\u0574 \u0565\u0582 \u0561\u057b \u057d\u0565\u0572\u0574\u0578\u0582\u0574\u0578\u057e, \u0568\u0576\u057f\u0580\u0565\u0584 \u00ab\u0532\u0561\u0581 \u0571\u0561\u0575\u0576\u0561\u0575\u056b\u0576 \u056f\u0561\u0580\u0563\u0561\u057e\u0578\u0580\u0578\u0582\u0574\u0576\u0565\u0580\u00bb \u0568\u0576\u057f\u0580\u0561\u0581\u0561\u0576\u056f\u056b \u057f\u0561\u0580\u0580\u0568, \u056b\u0576\u0579\u057a\u0565\u057d \u0581\u0578\u0582\u0575\u0581 \u0567 \u057f\u0580\u057e\u0561\u056e \u0546\u056f\u0561\u0580 14-\u0578\u0582\u0574:", "\u0546\u056f\u0561\u0580 14: \u0532\u0561\u0581 \u0571\u0561\u0575\u0576\u0561\u0575\u056b\u0576 \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580:", "\u0540\u0576\u0561\u0580\u0561\u057e\u0578\u0580 \u0567 \u0567\u056f\u0580\u0561\u0576\u0578\u057e \u0567\u056f\u0580\u0561\u0576 \u0578\u0582\u0576\u0565\u0581\u0578\u0572 \u0567\u056f\u0580\u0561\u0576 \u0578\u0582\u0576\u0565\u0581\u0578\u0572 \u0567\u056f\u0580\u0561\u0576:", "\u0546\u056f\u0561\u0580 15: \u0538\u0576\u0569\u0561\u0581\u056b\u056f \u0571\u0561\u0575\u0576\u0561\u0575\u056b\u0576 \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580:", "\u054e\u0565\u0580\u0561\u056f\u0561\u0576\u0563\u0576\u0565\u056c \u0576\u0561\u056d\u0576\u0561\u056f\u0561\u0576 \u0561\u0580\u056a\u0565\u0584\u0576\u0565\u0580\u0568, \u0578\u0580\u0578\u0576\u0584 \u0561\u057c\u0561\u057b \u0561\u057c\u0561\u057b\u0561\u0564\u0580\u0561\u0576\u0584\u0568 \u057d\u056f\u057d\u057e\u0565\u056c \u0567\u056b\u0576: \u0541\u0565\u0580 \u0564\u0565\u057a\u0584\u0578\u0582\u0574 \u0561\u0576\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u057f\u0561\u0580\u0562\u0565\u0580 \u056f\u056c\u056b\u0576\u0565\u0576:", "\u0546\u056f\u0561\u0580 16: \u054d\u056f\u0566\u0562\u0576\u0561\u0563\u0578\u0582\u0575\u0576 \u0571\u0561\u0575\u0576\u0561\u0575\u056b\u0576 \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580:", "\u0540\u0561\u0574\u0561\u056f\u0561\u0580\u0563\u056b \u057a\u0561\u0580\u0561\u0574\u0565\u057f\u0580\u0565\u0580\u0568 \u057e\u0565\u0580\u0561\u056f\u0561\u0576\u0563\u0576\u057e\u0565\u056c \u0565\u0576, \u056f\u0561\u0580\u0578\u0572 \u0565\u0584 \u0561\u0577\u056d\u0561\u057f\u0565\u056c Windows- \u0578\u0582\u0574:"]