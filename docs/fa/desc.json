["\u062a\u0648\u0636\u06cc\u062d\u0627\u062a \u0628\u0631\u0646\u0627\u0645\u0647 \"\u0686\u062a \u0647\u0627\u06cc \u0635\u0648\u062a\u06cc\"", "\u0645\u0637\u0627\u0644\u0628", "1 \u0642\u0628\u0644 \u0627\u0632 \u0634\u0631\u0648\u0639", "2. \u062a\u0648\u0636\u06cc\u062d\u0627\u062a \u0645\u062e\u062a\u0635\u0631", "3. \u0644\u06cc\u0633\u062a \u0632\u0628\u0627\u0646\u0647\u0627\u06cc \u0645\u0648\u062c\u0648\u062f \u0628\u0631\u0627\u06cc \u0627\u0631\u062a\u0628\u0627\u0637\u0627\u062a", "4. \u0622\u0646\u0686\u0647 \u0628\u0631\u0627\u06cc \u06a9\u0627\u0631 \u0628\u0631\u0627\u06cc \u0628\u0631\u0646\u0627\u0645\u0647 \u0646\u06cc\u0627\u0632 \u062f\u0627\u0631\u06cc\u062f", "5. \u06a9\u0627\u0631 \u0628\u0627 \u0628\u0631\u0646\u0627\u0645\u0647", "5.1 \u067e\u06cc\u06a9\u0631\u0628\u0646\u062f\u06cc", "5.2 \u0645\u0634\u062e\u0635\u0627\u062a \u06cc\u06a9 \u0631\u0627\u0628\u0637 \u062c\u062f\u06cc\u062f", "5.3 \u0628\u062e\u0634 \u0631\u0627\u0647\u0646\u0645\u0627", "\u062f\u06a9\u0645\u0647 \u062e\u0631\u0648\u062c 5.4", "5.5 \u0644\u06cc\u0633\u062a \u0627\u0632 \u0647\u0645\u0628\u0633\u062a\u06af\u06cc \u0647\u0627", "5.6 \u062a\u0627\u0631\u06cc\u062e\u0686\u0647 \u0686\u062a Interocutor", "5.7 \u067e\u0627\u06a9\u0633\u0627\u0632\u06cc \u062a\u0627\u0631\u06cc\u062e\u0686\u0647 \u0647\u0645\u06a9\u0627\u0631", "5.8 \u062d\u0630\u0641 \u06cc\u06a9 \u0647\u0645\u06a9\u0627\u0631", "5.9 \u0645\u0634\u0627\u0647\u062f\u0647 \u0646\u0645\u0627\u06cc\u0647 Interocutor", "5.10 \u062c\u062f\u0627\u06a9\u0646\u0646\u062f\u0647 \u0639\u0645\u0648\u062f\u06cc \u0628\u06cc\u0646 \u0642\u0633\u0645\u062a \u0647\u0627\u06cc \u0686\u067e \u0648 \u0631\u0627\u0633\u062a", "6 \u0628\u0639\u062f \u0627\u0632 \u0627\u062a\u0645\u0627\u0645 \u06a9\u0627\u0631", "\u0645\u06a9\u0627\u0646 \u0646\u0645\u0627 \u0645\u0627\u0648\u0633 \u0631\u0627 \u0631\u0648\u06cc \u062a\u0635\u0648\u06cc\u0631 \u0628\u0644\u0646\u062f\u06af\u0648 \u062f\u0631 \u06af\u0648\u0634\u0647 \u067e\u0627\u06cc\u06cc\u0646 \u0633\u0645\u062a \u0631\u0627\u0633\u062a \u0635\u0641\u062d\u0647 \u0648 \u06a9\u0644\u06cc\u06a9 \u0631\u0627\u0633\u062a \u060c \u0645\u0648\u0631\u062f \u0645\u0646\u0648\u06cc \u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0635\u062f\u0627 \u0628\u0627\u0632 \"\u060c \u0628\u0647 \u0639\u0646\u0648\u0627\u0646 \u0634\u0627\u0648\u0646 \u062f\u0631 \u0634\u06a9\u0644 1 \u060c \u0634\u0646\u0627\u0648\u0631 \u06a9\u0646\u06cc\u062f", "\u0634\u06a9\u0644 1 \u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0635\u062f\u0627\u06cc \u0628\u0627\u0632", "\u0635\u0641\u062d\u0647 \u0627\u06cc \u0628\u0627 \u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0635\u062f\u0627\u06cc \u0641\u0639\u0644\u06cc \u0638\u0627\u0647\u0631 \u0645\u06cc \u0634\u0648\u062f. \u0628\u0647 \u06cc\u0627\u062f \u062f\u0627\u0634\u062a\u0647 \u0628\u0627\u0634\u06cc\u062f \u06a9\u0647 \u0628\u0631\u0627\u06cc \u062f\u0633\u062a\u06af\u0627\u0647 \u0647\u0627\u06cc \u0635\u0648\u062a\u06cc \u0648\u0631\u0648\u062f\u06cc \u0648 \u062e\u0631\u0648\u062c\u06cc \u062a\u0646\u0638\u06cc\u0645 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0628\u0639\u062f \u0627\u0632 \u0627\u062a\u0645\u0627\u0645 \u06a9\u0627\u0631 \u0628\u0647 \u0627\u06cc\u0646 \u0627\u0637\u0644\u0627\u0639\u0627\u062a \u0627\u062d\u062a\u06cc\u0627\u062c \u062e\u0648\u0627\u0647\u06cc\u062f \u062f\u0627\u0634\u062a. \u062f\u0631 \u0634\u06a9\u0644 2 \u060c \u0641\u0644\u0634 \u0647\u0627\u06cc \u0642\u0631\u0645\u0632 \u0622\u0646\u0686\u0647 \u0631\u0627 \u06a9\u0647 \u0628\u0627\u06cc\u062f \u0628\u0647 \u062e\u0627\u0637\u0631 \u0628\u0633\u067e\u0627\u0631\u06cc\u062f \u0646\u0634\u0627\u0646 \u0645\u06cc \u062f\u0647\u062f. \u062f\u0631 \u0645\u0648\u0631\u062f \u0634\u0645\u0627 \u060c \u0646\u0627\u0645 \u0647\u0627 \u0645\u062a\u0641\u0627\u0648\u062a \u062e\u0648\u0627\u0647\u0646\u062f \u0628\u0648\u062f", "\u0634\u06a9\u0644 2 \u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0627\u0648\u0644\u06cc\u0647 \u0635\u062f\u0627", "\u062f\u0633\u062a\u06af\u0627\u0647 \u062e\u0631\u0648\u062c\u06cc \u0635\u062f\u0627 \u0631\u0627 \u0631\u0648\u06cc \u062a\u0646\u0638\u06cc\u0645 \u06a9\u0646\u06cc\u062f", "\u062f\u0633\u062a\u06af\u0627\u0647 \u0648\u0631\u0648\u062f\u06cc \u0635\u062f\u0627 \u0631\u0627 \u0631\u0648\u06cc \u062a\u0646\u0638\u06cc\u0645 \u06a9\u0646\u06cc\u062f", "\u062f\u0631 \u0634\u06a9\u0644 3 \u060c \u0641\u0644\u0634 \u0647\u0627\u06cc \u0642\u0631\u0645\u0632 \u0646\u0634\u0627\u0646 \u0645\u06cc \u062f\u0647\u062f \u06a9\u0647 \u0686\u0647 \u0686\u06cc\u0632\u06cc \u0648 \u0646\u06cc\u0627\u0632 \u0628\u0647 \u062a\u0646\u0638\u06cc\u0645 \u062f\u0627\u0634\u062a\u06cc\u062f", "\u0634\u06a9\u0644 3 \u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0635\u062f\u0627 \u06a9\u0627\u0631", "\u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0633\u06cc\u0633\u062a\u0645 \u06a9\u0627\u0645\u0644 \u0627\u0633\u062a \u060c \u0645\u06cc \u062a\u0648\u0627\u0646\u06cc\u062f \u0628\u0631\u0646\u0627\u0645\u0647 \u0631\u0627 \u0627\u062c\u0631\u0627 \u06a9\u0646\u06cc\u062f", "\u0634\u0645\u0627 \u0628\u0647 \u0632\u0628\u0627\u0646\u06cc \u06a9\u0647 \u0645\u06cc \u062f\u0627\u0646\u06cc\u062f \u0635\u062d\u0628\u062a \u0645\u06cc \u06a9\u0646\u06cc\u062f \u060c \u0628\u0647 \u0632\u0628\u0627\u0646\u06cc \u06a9\u0647 \u0647\u0645\u06a9\u0627\u0631 \u0634\u0645\u0627 \u0645\u06cc \u0641\u0647\u0645\u062f \u0634\u0646\u06cc\u062f\u0647 \u0645\u06cc \u0634\u0648\u062f. \u06cc\u06a9 \u0648\u0631\u0648\u062f \u0628\u0647 \u0633\u06cc\u0633\u062a\u0645 \u0634\u0645\u0627 \u0646\u06af\u0647 \u062f\u0627\u0634\u062a\u0647 \u0645\u06cc \u0634\u0648\u062f \u060c \u06a9\u0647 \u0634\u0645\u0627 Canage \u0647\u0633\u062a\u06cc\u062f. \u0647\u0645\u0647 \u0639\u0645\u0644\u06cc\u0627\u062a \u0628\u0647 \u0635\u0648\u0631\u062a \u0645\u062d\u0644\u06cc \u062f\u0631 \u0631\u0627\u06cc\u0627\u0646\u0647 \u0634\u0645\u0627 \u0627\u0646\u062c\u0627\u0645 \u0645\u06cc \u0634\u0648\u062f \u06a9\u0647 \u0648\u06cc\u0646\u062f\u0648\u0632 10 \u06cc\u0627 \u0648\u06cc\u0646\u062f\u0648\u0632 11 \u0631\u0627 \u0627\u062c\u0631\u0627 \u0645\u06cc \u06a9\u0646\u062f. \u06cc\u06a9 \u067e\u0631\u062f\u0627\u0632\u0646\u062f\u0647 \u06af\u0631\u0627\u0641\u06cc\u06a9\u06cc \u0645\u0637\u0644\u0648\u0628 \u0627\u0633\u062a \u0627\u0645\u0627 \u0646\u06cc\u0627\u0632\u06cc \u0628\u0647 \u0622\u0646 \u0646\u062f\u0627\u0631\u062f \u062a\u0627 \u0627\u06cc\u0646 \u0628\u0631\u0646\u0627\u0645\u0647 \u06a9\u0627\u0631 \u06a9\u0646\u062f. \u06a9\u06cc\u0641\u06cc\u062a \u062a\u0631\u062c\u0645\u0647 \u0628\u0627 \u06cc\u06a9 \u067e\u0631\u062f\u0627\u0632\u0646\u062f\u0647 \u06af\u0631\u0627\u0641\u06cc\u06a9\u06cc \u0628\u0647\u0628\u0648\u062f \u0645\u06cc \u06cc\u0627\u0628\u062f", "\u0627\u06af\u0631 \u06cc\u06a9\u06cc \u0627\u0632 \u0632\u0628\u0627\u0646\u0647\u0627\u06cc \u0627\u06cc\u0646 \u0644\u06cc\u0633\u062a \u0631\u0627 \u0628\u0641\u0647\u0645\u06cc\u062f \u060c \u0645\u06cc \u062a\u0648\u0627\u0646\u06cc\u062f \u0628\u0627 \u06cc\u06a9 \u0635\u062d\u0628\u062a \u0628\u0648\u0645\u06cc \u0627\u0632 \u0647\u0631 \u0632\u0628\u0627\u0646 Ofer \u0627\u0632 \u0627\u06cc\u0646 \u0644\u06cc\u0633\u062a \u0627\u0631\u062a\u0628\u0627\u0637 \u0628\u0631\u0642\u0631\u0627\u0631 \u06a9\u0646\u06cc\u062f. \u0627\u0631\u062a\u0628\u0627\u0637\u0627\u062a \u0645\u06cc \u062a\u0648\u0627\u0646\u062f \u062f\u0631 Telegram \u060c WhatsApp \u060c Google Meet \u060c VKMessenger \u060c Yandexmessenger \u06cc\u0627 \u0647\u0631 \u067e\u06cc\u0627\u0645 \u0631\u0633\u0627\u0646 \u062f\u06cc\u06af\u0631 \u0628\u0627\u0634\u062f. \u0634\u0645\u0627 \u0645\u06cc \u062a\u0648\u0627\u0646\u06cc\u062f \u0628\u0647 \u0647\u0631 \u06cc\u06a9 \u0627\u0632 \u0632\u0628\u0627\u0646\u0647\u0627\u06cc \u0630\u0647\u0646\u06cc \u0628\u0647 \u0627\u062e\u0628\u0627\u0631 \u060c \u062f\u0648\u0631\u0647 \u0622\u0645\u0648\u0632\u0634\u06cc \u0648 \u0647\u0631 \u067e\u0627\u062f\u06a9\u0633\u062a \u0647\u0627\u06cc \u062f\u06cc\u06af\u0631 \u06af\u0648\u0634 \u062f\u0647\u06cc\u062f \u0648 \u0622\u0646\u0647\u0627 \u0631\u0627 \u062f\u0631\u06a9 \u06a9\u0646\u06cc\u062f. \u0627\u06a9\u0646\u0648\u0646 \u0645\u06cc \u062a\u0648\u0627\u0646 \u0645\u0635\u0627\u062d\u0628\u0647 \u0647\u0627 \u0631\u0627 \u062f\u0631 \u0634\u0631\u06a9\u062a \u0647\u0627\u06cc \u062e\u0627\u0631\u062c\u06cc \u0648 \u0645\u0648\u0627\u0631\u062f \u062f\u06cc\u06af\u0631 \u06af\u0630\u0631\u0627\u0646\u062f. \u0647\u0645\u0686\u0646\u06cc\u0646 \u0645\u06cc \u062a\u0648\u0627\u0646\u06cc\u062f \u0641\u0627\u06cc\u0644 \u0635\u0648\u062a\u06cc / \u062a\u0635\u0648\u06cc\u0631\u06cc \u0631\u0627 \u0628\u0647 \u0632\u0628\u0627\u0646 \u062e\u0627\u0631\u062c\u06cc \u067e\u062e\u0634 \u06a9\u0631\u062f\u0647 \u0648 \u0622\u0646 \u0631\u0627 \u0628\u0647 \u0632\u0628\u0627\u0646 \u062e\u0648\u062f \u0628\u0634\u0646\u0648\u06cc\u062f. \u06cc\u06a9\u06cc \u0627\u0632 \u0628\u0631\u0646\u0627\u0645\u0647 \u0647\u0627\u06cc \u062c\u0627\u0646\u0628\u06cc \u0645\u06a9\u0627\u0644\u0645\u0627\u062a \u0628\u0627 \u0647\u0645\u06a9\u0627\u0631 \u0628\u0647 \u0647\u0645\u0627\u0646 \u0632\u0628\u0627\u0646 \u0627\u0633\u062a \u060c \u0627\u0645\u0627 \u0647\u0645\u06a9\u0627\u0631 \u0634\u0645\u0627 \u0634\u0645\u0627 \u0631\u0627 \u0645\u06cc \u0634\u0646\u0648\u062f. \u0635\u062f\u0627\u06cc \u062e\u0648\u062f\u062a \u0646\u06cc\u0633\u062a tois \u0627\u06cc\u0646 \u0636\u0631\u0648\u0631\u06cc \u0627\u0633\u062a. \u0628\u0633\u06cc\u0627\u0631\u06cc \u0627\u0632 \u0628\u0631\u0646\u0627\u0645\u0647 \u0647\u0627\u06cc \u0645\u0645\u06a9\u0646 \u0648\u062c\u0648\u062f \u062f\u0627\u0631\u062f", "\u0633\u06cc\u0633\u062a\u0645 \u0639\u0627\u0645\u0644 \u0648\u06cc\u0646\u062f\u0648\u0632 10 \u06cc\u0627 \u0648\u06cc\u0646\u062f\u0648\u0632 11", "\u0641\u0636\u0627\u06cc \u0647\u0627\u0631\u062f \u062f\u06cc\u0633\u06a9 \u0645\u0648\u062c\u0648\u062f 8 \u06af\u06cc\u06af\u0627\u0628\u0627\u06cc\u062a", "\u0631\u0645 \u0627\u0632 10 \u06af\u06cc\u06af\u0627\u0628\u0627\u06cc\u062a", "GPU (\u0648\u0627\u062d\u062f \u067e\u0631\u062f\u0627\u0632\u0634 \u06af\u0631\u0627\u0641\u06cc\u06a9) \u0628\u0627 6 \u06af\u06cc\u06af\u0627\u0628\u0627\u06cc\u062a \u06cc\u0627 \u0628\u06cc\u0634\u062a\u0631 \u060c \u0645\u0637\u0644\u0648\u0628 \u0627\u0645\u0627 \u0644\u0627\u0632\u0645 \u0646\u06cc\u0633\u062a", "\u0647\u062f\u0641\u0648\u0646 \u0628\u0627 \u0645\u06cc\u06a9\u0631\u0648\u0641\u0648\u0646", "\u06a9\u0644 \u0631\u0627\u0628\u0637 \u06a9\u0627\u0631 \u0628\u0627 \u0628\u0631\u0646\u0627\u0645\u0647 \u0627\u0632 \u0645\u0631\u0648\u0631\u06af\u0631 \u0627\u0646\u062c\u0627\u0645 \u0645\u06cc \u0634\u0648\u062f", "\u0647\u0646\u06af\u0627\u0645\u06cc \u06a9\u0647 \u0631\u0648\u06cc \u062f\u06a9\u0645\u0647 \"\u067e\u06cc\u06a9\u0631\u0628\u0646\u062f\u06cc\" \u06a9\u0644\u06cc\u06a9 \u0645\u06cc \u06a9\u0646\u06cc\u062f \u060c \u0648 \u0628\u0627 \u067e\u0627\u0631\u0627\u0645\u062a\u0631\u0647\u0627\u06cc \u0627\u0635\u0644\u06cc \u0639\u0645\u0644\u06cc\u0627\u062a\u06cc \u062f\u0631 \u0645\u0646\u0648\u06cc \u0628\u0627\u0644\u0627 \u0646\u0645\u0627\u06cc\u0634 \u062f\u0627\u062f\u0647 \u0645\u06cc \u0634\u0648\u062f. \u0634\u06a9\u0644 4 \u0631\u0627 \u0628\u0628\u06cc\u0646\u06cc\u062f", "\u0634\u06a9\u0644 4 \u067e\u06cc\u06a9\u0631\u0628\u0646\u062f\u06cc", "\u0628\u062e\u0634 \u067e\u06cc\u06a9\u0631\u0628\u0646\u062f\u06cc \u0634\u0627\u0645\u0644 \u067e\u0627\u0631\u0627\u0645\u062a\u0631\u0647\u0627\u06cc \u0627\u0635\u0644\u06cc \u0639\u0645\u0644\u06cc\u0627\u062a\u06cc \u0627\u0633\u062a:", "\u0632\u0628\u0627\u0646 - \u062a\u0646\u0638\u06cc\u0645 \u0632\u0628\u0627\u0646\u06cc \u06a9\u0647 \u0635\u062d\u0628\u062a \u0645\u06cc \u06a9\u0646\u06cc\u062f", "\u0635\u062f\u0627 - \u0646\u0627\u0645 \u062f\u0631\u0627\u06cc\u0648\u0631 \u0628\u0631\u0627\u06cc \u062f\u0633\u062a\u06af\u0627\u0647 \u0635\u062f\u0627\u06cc \u0635\u062f\u0627 \u0634\u0645\u0627", "\u0645\u06cc\u06a9\u0631\u0648\u0641\u0648\u0646 - \u0646\u0627\u0645 \u062f\u0631\u0627\u06cc\u0648\u0631 \u0628\u0631\u0627\u06cc \u0645\u06cc\u06a9\u0631\u0648\u0641\u0648\u0646 \u0634\u0645\u0627", "\u0645\u0631\u0648\u0631\u06af\u0631 \u0648\u0628 - \u0646\u0627\u0645 \u0645\u0631\u0648\u0631\u06af\u0631 \u06a9\u0647 \u062f\u0631 \u0622\u0646 \u06a9\u0627\u0631 \u062e\u0648\u0627\u0647\u06cc\u062f \u06a9\u0631\u062f", "\u0647\u0646\u06af\u0627\u0645\u06cc \u06a9\u0647 \u0632\u0628\u0627\u0646 \u0631\u0627 \u062a\u063a\u06cc\u06cc\u0631 \u062f\u0627\u062f\u0647 \u0648 \u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u067e\u06cc\u06a9\u0631\u0628\u0646\u062f\u06cc \u0631\u0627 \u0630\u062e\u06cc\u0631\u0647 \u0645\u06cc \u06a9\u0646\u06cc\u062f \u060c \u062a\u0645\u0627\u0645 \u0645\u062a\u0646 \u060c \u0639\u0628\u0627\u0631\u0627\u062a \u060c \u0646\u0627\u0645 \u062f\u06a9\u0645\u0647 \u0647\u0627 \u0648 \u0645\u062a\u0646 \u062f\u06cc\u06af\u0631 \u0628\u0647 \u0632\u0628\u0627\u0646 \u062c\u062f\u06cc\u062f \u0646\u0645\u0627\u06cc\u0634 \u062f\u0627\u062f\u0647 \u0645\u06cc \u0634\u0648\u062f. \u0686\u062a \u0647\u0627\u06cc \u062c\u062f\u06cc\u062f \u0628\u0647 \u0632\u0628\u0627\u0646 \u0645\u0646\u062a\u062e\u0628 \u062a\u0631\u062c\u0645\u0647 \u0645\u06cc \u0634\u0648\u0646\u062f \u0648 \u0633\u062e\u0646\u0631\u0627\u0646\u06cc \u0631\u0627 \u0628\u0647 \u0627\u06cc\u0646 \u0632\u0628\u0627\u0646 \u062c\u062f\u06cc\u062f \u062e\u0648\u0627\u0647\u06cc\u062f \u0634\u0646\u06cc\u062f. \u0646\u06a9\u062a\u0647 \u0645\u0647\u0645 \u062f\u0631 \u0645\u0648\u0631\u062f \u067e\u0627\u0631\u0627\u0645\u062a\u0631 \u0645\u0631\u0648\u0631\u06af\u0631 \u0648\u0628. \u0628\u0647 \u0637\u0648\u0631 \u067e\u06cc\u0634 \u0641\u0631\u0636 \u060c \u067e\u0627\u0631\u0627\u0645\u062a\u0631 \u0645\u0631\u0648\u0631\u06af\u0631 \u0648\u0628 \u0631\u0648\u06cc Microsoft Edge \u062a\u0646\u0638\u06cc\u0645 \u0634\u062f\u0647 \u0627\u0633\u062a \u060c \u0632\u06cc\u0631\u0627 \u0647\u0645\u06cc\u0634\u0647 \u062f\u0631 \u0648\u06cc\u0646\u062f\u0648\u0632 \u0646\u0635\u0628 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0628\u0631\u0627\u06cc \u0627\u06cc\u0646 \u067e\u0627\u0631\u0627\u0645\u062a\u0631 \u060c \u0641\u0642\u0637 \u0645\u0631\u0648\u0631\u06af\u0631 \u0646\u0635\u0628 \u0634\u062f\u0647 \u0648 \u062f\u0631 \u0633\u06cc\u0633\u062a\u0645 \u0639\u0627\u0645\u0644 \u062e\u0648\u062f \u0631\u0627 \u0627\u0646\u062a\u062e\u0627\u0628 \u06a9\u0646\u06cc\u062f", "\u0628\u0627 \u06a9\u0644\u06cc\u06a9 \u0628\u0631 \u0631\u0648\u06cc \u062f\u06a9\u0645\u0647 \u062c\u062f\u06cc\u062f \u060c \u06cc\u06a9 \u0641\u0631\u0645 \u0628\u0631\u0627\u06cc \u067e\u0631 \u06a9\u0631\u062f\u0646 AWW Interlocutor \u0631\u0627 \u0646\u0634\u0627\u0646 \u0645\u06cc \u062f\u0647\u062f. \u0634\u06a9\u0644 5 \u0631\u0627 \u0628\u0628\u06cc\u0646\u06cc\u062f", "\u0634\u06a9\u0644 5 \u0645\u0634\u062e\u0635\u0627\u062a \u062c\u062f\u06cc\u062f \u0645\u062a\u0642\u0627\u0628\u0644", "\u0628\u062e\u0634 \"\u0645\u0634\u062e\u0635\u0627\u062a \u062c\u062f\u06cc\u062f Interlocutor\" \u0634\u0627\u0645\u0644 \u067e\u0627\u0631\u0627\u0645\u062a\u0631\u0647\u0627\u06cc \u0627\u0635\u0644\u06cc \u0639\u0645\u0644\u06cc\u0627\u062a\u06cc \u0627\u0633\u062a:", "\u0646\u0627\u0645 \u0645\u0633\u062a\u0639\u0627\u0631 - \u0646\u0627\u0645\u06cc \u06a9\u0647 \u0628\u0631\u0627\u06cc \u0647\u0645\u06a9\u0627\u0631 \u062e\u0648\u062f \u0627\u0646\u062a\u062e\u0627\u0628 \u0645\u06cc \u06a9\u0646\u06cc\u062f", "\u0632\u0628\u0627\u0646 - \u0632\u0628\u0627\u0646\u06cc \u06a9\u0647 \u0647\u0645\u06a9\u0627\u0631 \u0634\u0645\u0627 \u0635\u062d\u0628\u062a \u0645\u06cc \u06a9\u0646\u062f", "\u062a\u0648\u0636\u06cc\u062d\u0627\u062a - \u062a\u0648\u0636\u06cc\u062d\u06cc \u0627\u0632 \u0647\u0645\u06a9\u0627\u0631 \u0634\u0645\u0627", "\u0627\u0632 \u0645\u06cc\u06a9\u0631\u0648\u0641\u0648\u0646 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u06a9\u0646\u06cc\u062f - \u067e\u0631\u0686\u0645 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0627\u0632 \u0645\u06cc\u06a9\u0631\u0648\u0641\u0648\u0646 \u0631\u0627 \u062a\u0646\u0638\u06cc\u0645 \u06a9\u0646\u06cc\u062f", "Image - \u0646\u0645\u0627\u062f \u0631\u0627 \u0628\u0631\u0627\u06cc Interocutor \u062a\u0646\u0638\u06cc\u0645 \u06a9\u0646\u06cc\u062f", "\u0627\u06af\u0631 \u062a\u0635\u0648\u06cc\u0631\u06cc \u0631\u0627 \u0628\u0631\u0627\u06cc \u0647\u0645\u06a9\u0627\u0631 \u0627\u0646\u062a\u062e\u0627\u0628 \u0646\u06a9\u0631\u062f\u0647 \u0627\u06cc\u062f \u060c \u0627\u0632 \u062a\u0635\u0648\u06cc\u0631 \u067e\u06cc\u0634 \u0641\u0631\u0636 \u0628\u0631\u0627\u06cc \u0627\u0648 \u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0645\u06cc \u0634\u0648\u062f", "\u067e\u0627\u0631\u0627\u0645\u062a\u0631 \"\u0627\u0633\u062a\u0641\u0627\u062f\u0647 \u0627\u0632 \u0645\u06cc\u06a9\u0631\u0648\u0641\u0648\u0646\" Canet \u0628\u0631\u0627\u06cc \u0645\u0648\u0627\u0631\u062f\u06cc \u06a9\u0647 \u06af\u0648\u0634 \u0645\u06cc \u062f\u0647\u06cc\u062f (\u0627\u062e\u0628\u0627\u0631 \u060c \u062f\u0631\u0648\u0633 \u0635\u0648\u062a\u06cc \u0648 \u063a\u06cc\u0631\u0647) UNET \u0627\u0633\u062a", "\u0627\u0645\u0646\u06cc\u062a \"\u06a9\u0645\u06a9\" \u0646\u062d\u0648\u0647 \u06a9\u0627\u0631 \u0628\u0627 \u0628\u0631\u0646\u0627\u0645\u0647 \u0631\u0627 \u0628\u0647 \u0632\u0628\u0627\u0646 \u0634\u0645\u0627 \u062a\u0648\u0635\u06cc\u0641 \u0645\u06cc \u06a9\u0646\u062f. \u0634\u06a9\u0644 6 \u0631\u0627 \u0628\u0628\u06cc\u0646\u06cc\u062f", "\u0634\u06a9\u0644 6. \u0628\u062e\u0634 \u0631\u0627\u0647\u0646\u0645\u0627", "\u0628\u0627 \u06a9\u0644\u06cc\u06a9 \u0628\u0631 \u0631\u0648\u06cc \u062f\u06a9\u0645\u0647 \"\u062e\u0631\u0648\u062c\" \u0628\u0631\u0646\u0627\u0645\u0647 \u0631\u0627 \u062e\u0627\u062a\u0645\u0647 \u0645\u06cc \u062f\u0647\u062f. \u0634\u06a9\u0644 7 \u0631\u0627 \u0628\u0628\u06cc\u0646\u06cc\u062f", "\u0634\u06a9\u0644 7 \u062f\u06a9\u0645\u0647 \u062e\u0631\u0648\u062c", "\u0628\u0633\u062a\u0646 \u067e\u0646\u062c\u0631\u0647 \u0645\u0631\u0648\u0631\u06af\u0631 \u06cc\u0627 \u0628\u0633\u062a\u0646 \u0645\u0631\u0648\u0631\u06af\u0631 \u0646\u06cc\u0632 \u0628\u0631\u0646\u0627\u0645\u0647 \u0631\u0627 \u067e\u0627\u06cc\u0627\u0646 \u0645\u06cc \u062f\u0647\u062f", "\u0637\u0631\u0627\u0648\u062a \u0635\u0641\u062d\u0647 \u0647\u0645\u0686\u0646\u06cc\u0646 \u0628\u0631\u0646\u0627\u0645\u0647 \u0631\u0627 \u067e\u0627\u06cc\u0627\u0646 \u0645\u06cc \u062f\u0647\u062f", "\u062f\u0631 \u0633\u0645\u062a \u0686\u067e \u0645\u0631\u0648\u0631\u06af\u0631 \u0644\u06cc\u0633\u062a\u06cc \u0627\u0632 \u0645\u062f\u0627\u062e\u0644\u0627\u062a \u0634\u0645\u0627 \u0642\u0631\u0627\u0631 \u062f\u0627\u0631\u062f. \u0634\u06a9\u0644 8 \u0631\u0627 \u0628\u0628\u06cc\u0646\u06cc\u062f", "\u0634\u06a9\u0644 8 \u0644\u06cc\u0633\u062a \u0647\u0645\u0628\u0633\u062a\u06af\u06cc \u0647\u0627", "\u0628\u0631\u0627\u06cc \u0647\u0631 \u06cc\u06a9 \u0627\u0632 \u0647\u0645\u0628\u0633\u062a\u06af\u06cc \u0647\u0627 \u060c \u0646\u0645\u0627\u062f \u0622\u0646\u0647\u0627 \u060c \u062a\u0627\u0631\u06cc\u062e \u0622\u062e\u0631\u06cc\u0646 \u067e\u06cc\u0627\u0645 \u0648 \u0645\u062a\u0646 \u0622\u062e\u0631\u06cc\u0646 \u067e\u06cc\u0627\u0645 \u062f\u0631 \u0632\u0628\u0627\u0646 \u0634\u0645\u0627 \u0646\u0634\u0627\u0646 \u062f\u0627\u062f\u0647 \u0634\u062f\u0647 \u0627\u0633\u062a. \u0642\u0627\u0644\u0628 \u062a\u0627\u0631\u06cc\u062e \u0627\u0632 \u0637\u0631\u06cc\u0642 \u06a9\u0627\u0631 \u0628\u0627 \u0632\u0628\u0627\u0646 \u0634\u0645\u0627 \u0645\u0637\u0627\u0628\u0642\u062a \u062f\u0627\u0631\u062f. \u0648\u0642\u062a\u06cc \u0631\u0648\u06cc \u06cc\u06a9 \u0647\u0645\u06a9\u0627\u0631 \u06a9\u0644\u06cc\u06a9 \u0645\u06cc \u06a9\u0646\u06cc\u062f \u060c \u062a\u0627\u0631\u06cc\u062e\u0686\u0647 \u06af\u067e \u0622\u0646\u0647\u0627 \u0646\u0645\u0627\u06cc\u0634 \u062f\u0627\u062f\u0647 \u0645\u06cc \u0634\u0648\u062f", "\u062a\u0627\u0631\u06cc\u062e\u0686\u0647 \u06af\u067e \u0627\u0632 \u0647\u0645\u0628\u0633\u062a\u06af\u06cc \u062f\u0631 \u0633\u0645\u062a \u0631\u0627\u0633\u062a \u0645\u0631\u0648\u0631\u06af\u0631 \u0642\u0631\u0627\u0631 \u062f\u0627\u0631\u062f. \u0634\u06a9\u0644 9 \u0631\u0627 \u0628\u0628\u06cc\u0646\u06cc\u062f", "\u0634\u06a9\u0644 9. \u062a\u0627\u0631\u06cc\u062e\u0686\u0647 \u06af\u067e \u0647\u0645\u06a9\u0627\u0631", "\u062a\u0627\u0631\u06cc\u062e \u0686\u062a Interocutor iSplayed wen \u0634\u0645\u0627 \u0631\u0648\u06cc \u0642\u0633\u0645\u062a \u0686\u067e \u062f\u0631 \u0642\u0633\u0645\u062a \u0633\u0645\u062a \u0686\u067e \u06a9\u0644\u06cc\u06a9 \u0645\u06cc \u06a9\u0646\u06cc\u062f", "\u0645\u0646\u0648\u06cc \u0628\u0627\u0644\u0627 \u0634\u0627\u0645\u0644:", "\u0646\u0645\u0627\u062f \u0647\u0645\u06a9\u0627\u0631", "\u0646\u0627\u0645 \u0645\u0633\u062a\u0639\u0627\u0631 \u0647\u0645\u06a9\u0627\u0631", "\u062f\u06a9\u0645\u0647 \"\u0634\u0631\u0648\u0639 \u0645\u06a9\u0627\u0644\u0645\u0647\"", "\u062f\u06a9\u0645\u0647 \"\u062a\u0627\u0631\u06cc\u062e \u0631\u0648\u0634\u0646\"", "\u062f\u06a9\u0645\u0647 \"Delete Interocutor\"", "\u062f\u06a9\u0645\u0647 \"\u0646\u0645\u0627\u06cc\u0647 Interocutor\"", "\u062a\u0627\u0631\u06cc\u062e\u0686\u0647 \u06af\u067e \u0628\u0627 \u0647\u0645\u06a9\u0627\u0631 \u0627\u0646\u062a\u062e\u0627\u0628 \u0634\u062f\u0647 \u062f\u0631 \u0642\u0633\u0645\u062a \u0633\u0645\u062a \u0631\u0627\u0633\u062a \u0638\u0627\u0647\u0631 \u0645\u06cc \u0634\u0648\u062f", "\u0639\u0646\u0648\u0627\u0646 \u06af\u067e \u0628\u0627 \u06cc\u06a9 \u062c\u0641\u062a \u06cc\u0627\u06a9\u0633 \u0634\u0645\u0627\u0631\u0647 \u06af\u0630\u0627\u0631\u06cc \u0634\u062f\u0647 \u0627\u0633\u062a: \"\u0632\u0628\u0627\u0646 Interocutor\"/\"\u0632\u0628\u0627\u0646 \u0634\u0645\u0627\"", "\u0639\u0646\u0648\u0627\u0646 \u06af\u067e \u0634\u0627\u0645\u0644 \u062f\u06a9\u0645\u0647 \"\u062d\u0630\u0641 \u0627\u06cc\u0646 \u06af\u067e\" \u0627\u0633\u062a", "\u0648\u0642\u062a\u06cc \u0631\u0648\u06cc \u062f\u06a9\u0645\u0647 \"\u062d\u0630\u0641 \u0627\u06cc\u0646 \u06af\u067e\" \u06a9\u0644\u06cc\u06a9 \u0645\u06cc \u06a9\u0646\u06cc\u062f \u060c \u0627\u06cc\u0646 \u06af\u067e \u0627\u0632 \u062a\u0627\u0631\u06cc\u062e \u0686\u062a Interocutor \u062d\u0630\u0641 \u0645\u06cc \u0634\u0648\u062f", "\u0647\u0645\u0647 \u067e\u06cc\u0627\u0645 \u0647\u0627 \u0628\u0647 2 \u06af\u0631\u0648\u0647 \u062a\u0642\u0633\u06cc\u0645 \u0645\u06cc \u0634\u0648\u0646\u062f:", "\u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc \u0645\u0631\u0628\u0648\u0637 \u0628\u0647 \u0631\u0627\u0628\u0637", "\u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc \u0634\u0645\u0627", "\u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc \u0645\u0631\u0628\u0648\u0637 \u0628\u0647 \u0645\u062a\u0642\u0627\u0628\u0644 \u0628\u0647 \u0633\u0645\u062a \u0686\u067e \u0645\u0646\u062a\u0642\u0644 \u0645\u06cc \u0634\u0648\u0646\u062f. \u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc \u0634\u0645\u0627 \u0628\u0647 \u0633\u0645\u062a \u0631\u0627\u0633\u062a \u0645\u0646\u062a\u0642\u0644 \u0645\u06cc \u0634\u0648\u0646\u062f", "\u0647\u0631 \u06af\u0631\u0648\u0647 \u067e\u06cc\u0627\u0645 \u0627\u0632 2 \u0628\u062e\u0634 \u062a\u0634\u06a9\u06cc\u0644 \u0634\u062f\u0647 \u0627\u0633\u062a:", "\u0645\u062a\u0646 \u067e\u06cc\u0627\u0645 \u0628\u0647 \u0632\u0628\u0627\u0646 \u0647\u0645\u06a9\u0627\u0631 \u060c \u0631\u0646\u06af \u0627\u06cc\u0646 \u067e\u06cc\u0627\u0645 \u0633\u06cc\u0627\u0647 \u0627\u0633\u062a", "\u067e\u06cc\u0627\u0645 \u067e\u06cc\u0627\u0645 \u0628\u0647 \u0632\u0628\u0627\u0646 \u0634\u0645\u0627 \u060c \u0631\u0646\u06af \u0627\u06cc\u0646 \u067e\u06cc\u0627\u0645 \u0633\u0628\u0632 \u0627\u0633\u062a", "\u062a\u0627\u0631\u06cc\u062e \u067e\u06cc\u0627\u0645 \u0628\u0627 \u0632\u0628\u0627\u0646 \u0634\u0645\u0627 \u0645\u0637\u0627\u0628\u0642\u062a \u062f\u0627\u0631\u062f", "\u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc \u062c\u062f\u06cc\u062f\u062a\u0631 (\u0628\u0631\u0627\u0633\u0627\u0633 \u062a\u0627\u0631\u06cc\u062e) \u067e\u0627\u06cc\u06cc\u0646 \u062a\u0631 \u0627\u0632 Oones \u0642\u062f\u06cc\u0645\u06cc \u062a\u0631 \u0642\u0631\u0627\u0631 \u062f\u0627\u0631\u0646\u062f", "\u062f\u0631 \u0627\u0646\u062a\u0647\u0627\u06cc \u0686\u062a \u0647\u0627\u06cc Interocutor \u060c \u062f\u06a9\u0645\u0647 \"\u0634\u0631\u0648\u0639 \u0645\u06a9\u0627\u0644\u0645\u0647\" \u0642\u0631\u0627\u0631 \u062f\u0627\u0631\u062f. \u0647\u0646\u06af\u0627\u0645\u06cc \u06a9\u0647 \u0631\u0648\u06cc \u0622\u0646 \u06a9\u0644\u06cc\u06a9 \u0645\u06cc \u06a9\u0646\u06cc\u062f \u060c \u0628\u0631\u0646\u0627\u0645\u0647 \u0628\u0631\u0627\u06cc \u062a\u0639\u06cc\u06cc\u0646 \u0633\u0637\u062d \u0633\u06cc\u06af\u0646\u0627\u0644/\u0646\u0648\u06cc\u0632 \u060c \u06a9\u0627\u0644\u06cc\u0628\u0631\u0627\u0633\u06cc\u0648\u0646 \u0645\u06cc\u06a9\u0631\u0648\u0641\u0648\u0646 \u0648 \u062f\u0633\u062a\u06af\u0627\u0647 \u0635\u062f\u0627 \u0631\u0627 \u0634\u0631\u0648\u0639 \u0645\u06cc \u06a9\u0646\u062f \u0648 \u067e\u06cc\u0627\u0645 \u0645\u0631\u0628\u0648\u0637\u0647 \u0631\u0627 \u0646\u0634\u0627\u0646 \u0645\u06cc \u062f\u0647\u062f", "\u067e\u0633 \u0627\u0632 \u06a9\u0627\u0644\u06cc\u0628\u0631\u0627\u0633\u06cc\u0648\u0646 \u062f\u0633\u062a\u06af\u0627\u0647 \u0647\u0627\u06cc \u0635\u0648\u062a\u06cc \u060c \u0646\u0627\u0645 \u062f\u06a9\u0645\u0647 \u0647\u0627 \u062a\u063a\u06cc\u06cc\u0631 \u0645\u06cc \u06a9\u0646\u0646\u062f: \"\u0645\u06a9\u0627\u0644\u0645\u0647 \u0631\u0627 \u0634\u0631\u0648\u0639 \u06a9\u0646\u06cc\u062f\" -> \"\u0645\u06a9\u0627\u0644\u0645\u0647 \u0631\u0627 \u0645\u062a\u0648\u0642\u0641 \u06a9\u0646\u06cc\u062f\"", "\u0627\u0632 \u0627\u06cc\u0646 \u0646\u0642\u0637\u0647 \u0628\u0647 \u0628\u0639\u062f \u060c \u0645\u06cc \u062a\u0648\u0627\u0646\u06cc\u062f \u06cc\u06a9 \u0645\u06a9\u0627\u0644\u0645\u0647 \u0631\u0627 \u0634\u0631\u0648\u0639 \u06a9\u0646\u06cc\u062f \u06cc\u0627 \u067e\u0631\u0648\u0646\u062f\u0647 \u0635\u0648\u062a\u06cc/\u062a\u0635\u0648\u06cc\u0631\u06cc \u0631\u0627 \u0628\u0647 \u0635\u0648\u0631\u062a \u062e\u0637 \u0628\u0647 \u0631\u0627\u0647 \u0627\u0646\u062f\u0627\u0632\u06cc \u06a9\u0646\u06cc\u062f", "\u062a\u0645\u0627\u0645 \u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc \u0648\u0631\u0648\u062f\u06cc (\u0627\u0632 \u0634\u062e\u0635 \u062f\u06cc\u06af\u0631) \u062f\u0631 \u0633\u0645\u062a \u0686\u067e \u0638\u0627\u0647\u0631 \u0645\u06cc \u0634\u0648\u0646\u062f", "\u062a\u0645\u0627\u0645 \u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc \u062e\u0631\u0648\u062c\u06cc (\u0627\u0632 \u0634\u0645\u0627) \u062f\u0631 \u0633\u0645\u062a \u0631\u0627\u0633\u062a \u0638\u0627\u0647\u0631 \u0645\u06cc \u0634\u0648\u0646\u062f", "\u067e\u06cc\u0627\u0645 \u0647\u0627 \u0631\u0627 \u0628\u0647 \u0632\u0628\u0627\u0646 \u062e\u0648\u062f \u062e\u0648\u0627\u0647\u06cc\u062f \u0634\u0646\u06cc\u062f \u0648 \u0634\u062e\u0635 \u062f\u06cc\u06af\u0631 \u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc \u062e\u0648\u062f \u0631\u0627 \u0628\u0647 \u0632\u0628\u0627\u0646 \u062e\u0648\u062f \u0645\u06cc \u0634\u0646\u0648\u062f", "\u062f\u0631 \u067e\u0627\u06cc\u0627\u0646 \u0645\u06a9\u0627\u0644\u0645\u0647/\u06af\u0648\u0634 \u062f\u0627\u062f\u0646 \u0628\u0647 \u0648\u06cc\u062f\u06cc\u0648 \u060c \u0628\u0627\u06cc\u062f \u0631\u0648\u06cc \u06cc\u06a9\u06cc \u0627\u0632 \u062f\u06a9\u0645\u0647 \u0647\u0627\u06cc \"\u0645\u06a9\u0627\u0644\u0645\u0647 \u062a\u0648\u0642\u0641\" \u06a9\u0644\u06cc\u06a9 \u06a9\u0646\u06cc\u062f", "\u0645\u06a9\u0627\u0644\u0645\u0647 \u0646\u06cc\u0632 \u0628\u0647 \u067e\u0627\u06cc\u0627\u0646 \u0645\u06cc \u0631\u0633\u062f \u06a9\u0647:", "\u0628\u0627 \u06a9\u0644\u06cc\u06a9 \u0628\u0631 \u0631\u0648\u06cc \u0634\u062e\u0635 \u062f\u06cc\u06af\u0631 \u062f\u0631 \u0642\u0633\u0645\u062a \u0633\u0645\u062a \u0686\u067e \u0645\u0631\u0648\u0631\u06af\u0631 \u062f\u0631 \u0644\u06cc\u0633\u062a \u0647\u0645\u0628\u0633\u062a\u06af\u06cc \u0647\u0627", "\u0628\u0627 \u06a9\u0644\u06cc\u06a9 \u0628\u0631 \u0631\u0648\u06cc \u062f\u06a9\u0645\u0647 \"\u062c\u062f\u06cc\u062f\" \u062f\u0631 \u0628\u0627\u0644\u0627\u06cc \u0644\u06cc\u0633\u062a Intlocutors", "\u0628\u0627 \u06a9\u0644\u06cc\u06a9 \u0628\u0631 \u0631\u0648\u06cc \u062f\u06a9\u0645\u0647 \"\u0631\u0627\u0647\u0646\u0645\u0627\" \u062f\u0631 \u0645\u0646\u0648\u06cc \u0628\u0627\u0644\u0627", "\u0628\u0627 \u06a9\u0644\u06cc\u06a9 \u0628\u0631 \u0631\u0648\u06cc \u062f\u06a9\u0645\u0647 \"Clear History\" \u062f\u0631 \u0645\u0646\u0648\u06cc \u0628\u0627\u0644\u0627", "\u0628\u0627 \u06a9\u0644\u06cc\u06a9 \u0628\u0631 \u0631\u0648\u06cc \"Delete Interlocutor\" \u062f\u0631 \u0645\u0646\u0648\u06cc \u0628\u0627\u0644\u0627", "\u0628\u0627 \u06a9\u0644\u06cc\u06a9 \u0628\u0631 \u0631\u0648\u06cc \u062f\u06a9\u0645\u0647 \"\u0646\u0645\u0627\u06cc\u0647 Interocutor\" \u062f\u0631 \u0645\u0646\u0648\u06cc \u0628\u0627\u0644\u0627", "\u0628\u0627 \u06a9\u0644\u06cc\u06a9 \u0631\u0648\u06cc \u062f\u06a9\u0645\u0647 \"\u062e\u0631\u0648\u062c\" \u062f\u0631 \u0645\u0646\u0648\u06cc \u0628\u0627\u0644\u0627", "\u0646\u0645\u0627\u06cc\u0634 \u067e\u06cc\u0627\u0645 \u062f\u0631 \u062a\u0627\u0631\u06cc\u062e \u0686\u062a \u0628\u0627 \u0627\u0646\u062a\u062e\u0627\u0628 \u06af\u0632\u06cc\u0646\u0647 \u0646\u0645\u0627\u06cc\u0634 \u067e\u06cc\u0627\u0645 \u062f\u0631 \u0642\u0633\u0645\u062a \u0633\u0645\u062a \u0686\u067e \u0628\u0627\u0644\u0627 \u0645\u0646\u0648 (\u0641\u0644\u0634 \u0633\u0628\u0632) \u0645\u06cc \u062a\u0648\u0627\u0646\u062f", "\u0647\u0646\u06af\u0627\u0645 \u0627\u0646\u062a\u062e\u0627\u0628 \"\u0647\u0645\u0647 \u0632\u0628\u0627\u0646\u0647\u0627\" - \u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc Interocutor \u0648 \u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc \u0634\u0645\u0627 \u0628\u0647 \u0647\u0645\u0647 \u0632\u0628\u0627\u0646\u0647\u0627 \u0646\u0645\u0627\u06cc\u0634 \u062f\u0627\u062f\u0647 \u0645\u06cc \u0634\u0648\u0646\u062f", "\u0647\u0646\u06af\u0627\u0645 \u0627\u0646\u062a\u062e\u0627\u0628 \"\u0632\u0628\u0627\u0646 \u0645\u0646\" - \u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc Interocutor \u0648 \u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc \u0634\u0645\u0627 \u0641\u0642\u0637 \u062f\u0631 \u0632\u0628\u0627\u0646 \u0634\u0645\u0627 \u0646\u0645\u0627\u06cc\u0634 \u062f\u0627\u062f\u0647 \u0645\u06cc \u0634\u0648\u0646\u062f", "\u0647\u0646\u06af\u0627\u0645 \u0627\u0646\u062a\u062e\u0627\u0628 \"\u0632\u0628\u0627\u0646 Interocutor\" - \u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc Interocutor \u0648 \u067e\u06cc\u0627\u0645 \u0647\u0627\u06cc \u0634\u0645\u0627 \u0641\u0642\u0637 \u062f\u0631 \u0632\u0628\u0627\u0646 Interocutor \u0646\u0645\u0627\u06cc\u0634 \u062f\u0627\u062f\u0647 \u0645\u06cc \u0634\u0648\u0646\u062f", "\u062d\u0627\u0644\u062a \u0646\u0645\u0627\u06cc\u0634 \u067e\u06cc\u0634 \u0641\u0631\u0636 \u067e\u06cc\u0627\u0645 \"\u0647\u0645\u0647 \u0632\u0628\u0627\u0646\u0647\u0627\" \u0627\u0633\u062a", "\u0647\u0646\u06af\u0627\u0645 \u06a9\u0644\u06cc\u06a9 \u0628\u0631 \u0631\u0648\u06cc \u062f\u06a9\u0645\u0647 \"\u062a\u0627\u0631\u06cc\u062e \u0631\u0648\u0634\u0646\" \u060c \u0647\u0645\u0647 \u0686\u062a \u0647\u0627 \u0628\u0627 \u0647\u0645\u0628\u0633\u062a\u06af\u06cc \u062d\u0630\u0641 \u0645\u06cc \u0634\u0648\u0646\u062f \u060c \u0627\u0645\u0627 \u0647\u0645\u0628\u0633\u062a\u06af\u06cc \u0628\u0627\u0642\u06cc \u0645\u06cc \u0645\u0627\u0646\u062f. \u0634\u06a9\u0644 10 \u0631\u0627 \u0628\u0628\u06cc\u0646\u06cc\u062f", "\u0634\u06a9\u0644 10. \u067e\u0627\u06a9 \u06a9\u0631\u062f\u0646 \u062a\u0627\u0631\u06cc\u062e\u0686\u0647 \u0647\u0645\u0628\u0633\u062a\u06af\u06cc", "\u0627\u06af\u0631 \u062f\u0631 \u062d\u0627\u0644 \u062d\u0627\u0636\u0631 \u0686\u062a \u0628\u0627 \u0647\u0645\u06a9\u0627\u0631 \u062f\u0631 \u062d\u0627\u0644 \u0627\u0646\u062c\u0627\u0645 \u0627\u0633\u062a \u060c \u0645\u062a\u0648\u0642\u0641 \u0645\u06cc \u0634\u0648\u062f", "\u0628\u0627 \u06a9\u0644\u06cc\u06a9 \u0628\u0631 \u0631\u0648\u06cc \u062f\u06a9\u0645\u0647 \"Delete Interlocutor\" \u060c \u0647\u0645\u0647 \u0686\u062a \u0647\u0627 \u0631\u0627 \u0628\u0627 \u062e\u0648\u062f \u0645\u062a\u0642\u0627\u0628\u0644 \u0648 \u062e\u0648\u062f \u0645\u062a\u0642\u0627\u0628\u0644 \u062d\u0630\u0641 \u0645\u06cc \u06a9\u0646\u062f. \u0634\u06a9\u0644 11 \u0631\u0627 \u0628\u0628\u06cc\u0646\u06cc\u062f", "\u0634\u06a9\u0644 11. \u062d\u0630\u0641 \u0647\u0645\u0628\u0633\u062a\u06af\u06cc", "\u0627\u06af\u0631 \u062f\u0631 \u062d\u0627\u0644 \u062d\u0627\u0636\u0631 \u0686\u062a \u0628\u0627 \u0647\u0645\u06a9\u0627\u0631 \u062f\u0631 \u062d\u0627\u0644 \u0627\u0646\u062c\u0627\u0645 \u0627\u0633\u062a \u060c \u0645\u062a\u0648\u0642\u0641 \u0645\u06cc \u0634\u0648\u062f", "\u0628\u0627 \u06a9\u0644\u06cc\u06a9 \u0628\u0631 \u0631\u0648\u06cc \u062f\u06a9\u0645\u0647 \"\u0646\u0645\u0627\u06cc\u0647 Interocutor\" \u0641\u0631\u0645 \u067e\u0631 \u0627\u0632 \u062f\u0627\u062f\u0647 \u0647\u0627\u06cc Interocutor \u0631\u0627 \u0646\u0634\u0627\u0646 \u0645\u06cc \u062f\u0647\u062f. \u0634\u06a9\u0644 12 \u0631\u0627 \u0628\u0628\u06cc\u0646\u06cc\u062f", "\u0634\u06a9\u0644 12 \u0645\u0634\u0627\u0647\u062f\u0647 \u0645\u0634\u062e\u0635\u0627\u062a \u0645\u062a\u0642\u0627\u0628\u0644", "\u0627\u06cc\u0646 \u0645\u0648\u0631\u062f \u0645\u0634\u0627\u0628\u0647 \u0645\u0648\u0631\u062f \u0627\u0633\u062a", "\u062c\u062f\u0627\u06a9\u0646\u0646\u062f\u0647 \u0639\u0645\u0648\u062f\u06cc \u0628\u0647 \u0634\u0645\u0627 \u0627\u0645\u06a9\u0627\u0646 \u0645\u06cc \u062f\u0647\u062f \u0639\u0631\u0636 \u0645\u0646\u0627\u0637\u0642 \u0686\u067e \u0648 \u0631\u0627\u0633\u062a \u0641\u0636\u0627\u06cc \u06a9\u0627\u0631\u06cc \u0631\u0627 \u062a\u063a\u06cc\u06cc\u0631 \u062f\u0647\u06cc\u062f. \u0634\u06a9\u0644 13 \u0631\u0627 \u0628\u0628\u06cc\u0646\u06cc\u062f", "\u0634\u06a9\u0644 13. \u062c\u062f\u0627\u06a9\u0646\u0646\u062f\u0647 \u0639\u0645\u0648\u062f\u06cc \u0642\u0633\u0645\u062a\u0647\u0627\u06cc \u0686\u067e \u0648 \u0631\u0627\u0633\u062a", "\u0647\u0646\u06af\u0627\u0645\u06cc \u06a9\u0647 \u062c\u062f\u0627\u06a9\u0646\u0646\u062f\u0647 \u0639\u0645\u0648\u062f\u06cc \u0631\u0627 \u062d\u0631\u06a9\u062a \u0645\u06cc \u062f\u0647\u06cc\u062f \u060c \u0645\u0648\u0642\u0639\u06cc\u062a \u0622\u0646 \u0630\u062e\u06cc\u0631\u0647 \u0645\u06cc \u0634\u0648\u062f. \u0647\u0646\u06af\u0627\u0645\u06cc \u06a9\u0647 \u0628\u0631\u0646\u0627\u0645\u0647 \u0631\u0627 \u0645\u062c\u062f\u062f\u0627\u064b \u0631\u0627\u0647 \u0627\u0646\u062f\u0627\u0632\u06cc \u0645\u06cc \u06a9\u0646\u06cc\u062f \u060c \u0622\u062e\u0631\u06cc\u0646 \u0645\u0648\u0642\u0639\u06cc\u062a\u06cc \u06a9\u0647 \u062a\u0646\u0638\u06cc\u0645 \u06a9\u0631\u062f\u0647 \u0627\u06cc\u062f \u0628\u0627\u0632\u06af\u0631\u062f\u0627\u0646\u062f\u0647 \u0645\u06cc \u0634\u0648\u062f", "\u0645\u06a9\u0627\u0646 \u0646\u0645\u0627 \u0645\u0627\u0648\u0633 \u0631\u0627 \u0631\u0648\u06cc \u062a\u0635\u0648\u06cc\u0631 \u0628\u0644\u0646\u062f\u06af\u0648 \u062f\u0631 \u06af\u0648\u0634\u0647 \u0633\u0645\u062a \u0631\u0627\u0633\u062a \u067e\u0627\u06cc\u06cc\u0646 \u0635\u0641\u062d\u0647 \u062d\u0631\u06a9\u062a \u062f\u0647\u06cc\u062f \u0648 \u0631\u0627\u0633\u062a \u06a9\u0644\u06cc\u06a9 \u06a9\u0646\u06cc\u062f \u060c \u0647\u0645\u0627\u0646\u0637\u0648\u0631 \u06a9\u0647 \u062f\u0631 \u0634\u06a9\u0644 14 \u0646\u0634\u0627\u0646 \u062f\u0627\u062f\u0647 \u0634\u062f\u0647 \u0627\u0633\u062a \u060c \u0645\u0648\u0631\u062f \u0645\u0646\u0648\u06cc \"\u0628\u0627\u0632 \u062a\u0646\u0638\u06cc\u0645 \u0635\u062f\u0627\" \u0631\u0627 \u0627\u0646\u062a\u062e\u0627\u0628 \u06a9\u0646\u06cc\u062f", "\u0634\u06a9\u0644 14 \u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0635\u062f\u0627\u06cc \u0628\u0627\u0632", "\u0635\u0641\u062d\u0647 \u0627\u06cc \u0628\u0627 \u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0635\u062f\u0627\u06cc \u0641\u0639\u0644\u06cc \u0638\u0627\u0647\u0631 \u0645\u06cc \u0634\u0648\u062f", "\u0634\u06a9\u0644 15 \u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0635\u062f\u0627\u06cc \u0641\u0639\u0644\u06cc", "\u0645\u0642\u0627\u062f\u06cc\u0631 \u0627\u0648\u0644\u06cc\u0647 \u0631\u0627 \u06a9\u0647 \u0642\u0628\u0644 \u0627\u0632 \u0634\u0631\u0648\u0639 \u06a9\u0627\u0631 \u0628\u0648\u062f\u0646\u062f \u060c \u0628\u0627\u0632\u06cc\u0627\u0628\u06cc \u06a9\u0646\u06cc\u062f. \u062f\u0631 \u0645\u0648\u0631\u062f \u0634\u0645\u0627 \u060c \u0646\u0627\u0645 \u0647\u0627 \u0645\u062a\u0641\u0627\u0648\u062a \u062e\u0648\u0627\u0647\u0646\u062f \u0628\u0648\u062f", "\u0634\u06a9\u0644 16 \u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0627\u0648\u0644\u06cc\u0647 \u0635\u062f\u0627", "\u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0633\u06cc\u0633\u062a\u0645 \u0628\u0627\u0632\u0633\u0627\u0632\u06cc \u0634\u062f\u0647 \u0627\u0633\u062a \u060c \u0634\u0645\u0627 \u0645\u06cc \u062a\u0648\u0627\u0646\u06cc\u062f \u062f\u0631 \u0648\u06cc\u0646\u062f\u0648\u0632 \u06a9\u0627\u0631 \u06a9\u0646\u06cc\u062f"]